ASPNETCORE_ENVIRONMENT=Production

POSTGRES_DB=homeservice
POSTGRES_USER=homeservice
POSTGRES_PASSWORD=replace-with-a-strong-password

API_PORT=8080
COMPANY_PORT=8081
ADMIN_PORT=8082
POSTGRES_PORT=5432

API_BASE_URL=http://api:8080

# API database options:
# Preferred explicit Npgsql format:
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=homeservice;Username=homeservice;Password=replace-with-a-strong-password
# Coolify PostgreSQL URL format is also accepted:
# DATABASE_URL=postgres://homeservice:replace-with-a-strong-password@postgres:5432/homeservice

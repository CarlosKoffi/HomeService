@page "/settings"

<PageTitle>Kaza Prestataire - Parametres</PageTitle>

<main class="provider-mobile-shell">
    <section class="screen-heading">
        <span>Parametres</span>
        <h1>Configuration</h1>
        <p>Controlez les informations utilisees pour vous affecter des missions.</p>
    </section>

    <section class="provider-card">
        <div class="provider-profile-row">
            <span class="profile-photo">AK</span>
            <div>
                <strong>Awa Kone</strong>
                <small>Prestataire employee - CI Home Service</small>
            </div>
            <em>92%</em>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Disponibilite</span>
                <h2>Mode de travail</h2>
            </div>
        </div>
        <div class="settings-list">
            <article>
                <div>
                    <strong>Disponible pour le live</strong>
                    <small>Visible par votre entreprise pour les demandes immediates.</small>
                </div>
                <button type="button" class="mini-toggle active">ON</button>
            </article>
            <article>
                <div>
                    <strong>Rayon maximum</strong>
                    <small>Recevoir des missions jusqu'a 5 km autour de vous.</small>
                </div>
                <em>5 km</em>
            </article>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Localisation</span>
                <h2>Verification terrain</h2>
            </div>
        </div>
        <div class="settings-list">
            <article>
                <div>
                    <strong>Position au depart</strong>
                    <small>Demandee quand vous acceptez une mission live.</small>
                </div>
                <em>Requise</em>
            </article>
            <article>
                <div>
                    <strong>Position a l'arrivee</strong>
                    <small>Verifiee avec tolerance autour du client.</small>
                </div>
                <em>Requise</em>
            </article>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Notifications</span>
                <h2>Alertes</h2>
            </div>
        </div>
        <div class="settings-list">
            <article>
                <div>
                    <strong>SMS</strong>
                    <small>Mission affectee, rappel et changement important.</small>
                </div>
                <button type="button" class="mini-toggle active">ON</button>
            </article>
            <article>
                <div>
                    <strong>WhatsApp</strong>
                    <small>Canal recommande si le reseau data est disponible.</small>
                </div>
                <button type="button" class="mini-toggle">OFF</button>
            </article>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Securite</span>
                <h2>Compte</h2>
            </div>
        </div>
        <div class="settings-list">
            <article>
                <div>
                    <strong>Mot de passe</strong>
                    <small>Derniere modification il y a 12 jours.</small>
                </div>
                <em>Modifier</em>
            </article>
        </div>
    </section>
</main>

<ProviderBottomNav Active="settings" />

@page "/missions"

<PageTitle>Kaza Prestataire - Missions</PageTitle>

<main class="provider-mobile-shell">
    <section class="screen-heading">
        <span>Missions</span>
        <h1>Vos affectations</h1>
        <p>Suivez les demandes live, les rendez-vous a venir et l'historique recent.</p>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Live</span>
                <h2>A traiter maintenant</h2>
            </div>
            <em>02:41</em>
        </div>
        <div class="mission-detail-card live">
            <strong>Menage a domicile</strong>
            <small>CI Home Service - Cocody Angre - 1,8 km</small>
            <div class="mission-actions compact">
                <button type="button" class="ghost-action">Refuser</button>
                <button type="button" class="primary-action">Accepter</button>
            </div>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Planning</span>
                <h2>A venir</h2>
            </div>
        </div>
        <div class="mission-list">
            <article>
                <time>16:30</time>
                <div>
                    <strong>Nounou</strong>
                    <small>Plateau - CI Home Service - rendez-vous confirme</small>
                </div>
                <em>Assignee</em>
            </article>
            <article>
                <time>Demain</time>
                <div>
                    <strong>Jardinage</strong>
                    <small>Riviera 3 - depart a confirmer 30 min avant</small>
                </div>
                <em>Rdv</em>
            </article>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Historique</span>
                <h2>Terminees</h2>
            </div>
        </div>
        <div class="mission-list">
            <article>
                <time>Hier</time>
                <div>
                    <strong>Menage a domicile</strong>
                    <small>Marcory - prestation terminee avec photo finale</small>
                </div>
                <em>OK</em>
            </article>
        </div>
    </section>
</main>

<ProviderBottomNav Active="missions" />

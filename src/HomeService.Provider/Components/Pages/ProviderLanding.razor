@page "/"
@using HomeService.Contracts.Contact
@inject ProviderApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>wélé Prestataire</PageTitle>

<div class="provider-landing premium-b2b">
    @if (ShowCandidateSubmitted)
    {
        <section class="provider-submission-banner" role="status">
            <div>
                <span>Demande envoyee</span>
                <strong>L'entreprise analyse votre dossier.</strong>
                <p>Vous serez contacte apres verification. Vous n'avez rien d'autre a faire pour le moment.</p>
            </div>
            <a href="/#home">Retour accueil</a>
        </section>
    }

    <section id="home" class="premium-hero provider-premium-hero">
        <img class="premium-hero-image provider-hero-image" src="@ResolveContentUrl(HomeContent.Hero.ImageUrl)" alt="@HomeContent.Hero.ImageAlt" />
        <div class="premium-hero-overlay"></div>
        <div class="premium-hero-content">
            <p class="premium-label">@HomeContent.Hero.Label</p>
            <h1>
                @HeroHeadline.Main
                @if (!string.IsNullOrWhiteSpace(HeroHeadline.Highlight))
                {
                    <span>@HeroHeadline.Highlight</span>
                }
            </h1>
            <p>@HomeContent.Hero.Subtitle</p>
            <div class="premium-actions">
                <a class="premium-primary" href="@NormalizeCtaUrl(HomeContent.Hero.PrimaryCta.Url)">@HomeContent.Hero.PrimaryCta.Label</a>
                <a class="premium-secondary" href="@HomeContent.Hero.SecondaryCta.Url">@HomeContent.Hero.SecondaryCta.Label</a>
            </div>
            <div class="premium-proof" aria-label="Parcours prestataire wélé">
                @foreach (var proof in HomeContent.Hero.ProofItems)
                {
                    <span>@proof</span>
                }
            </div>
        </div>
    </section>

    <section id="benefits" class="premium-section provider-benefits-section" aria-label="Avantages prestataire">
        <div class="premium-section-head">
            <p class="premium-label">Avantages</p>
            <h2>@HomeContent.Trusted.Headline</h2>
            <p>@HomeContent.Trusted.Subtitle</p>
        </div>
        <div class="provider-benefit-cards">
            @foreach (var item in HomeContent.Trusted.Items)
            {
                var benefit = SplitBenefitItem(item);
                <article>
                    <strong>@benefit.Title</strong>
                    <p>@benefit.Text</p>
                </article>
            }
        </div>
    </section>

    <section id="how" class="premium-section">
        <div class="premium-section-head">
            <p class="premium-label">@HomeContent.Steps.Label</p>
            <h2>@HomeContent.Steps.Headline</h2>
            <p>@HomeContent.Steps.Subtitle</p>
        </div>

        <div class="premium-how-grid provider-how-grid">
            @foreach (var step in HomeContent.Steps.Items)
            {
                <article>
                    <figure><img src="@ResolveContentUrl(step.Image)" alt="@step.Title" loading="lazy" /></figure>
                    <div class="premium-step-meta"><span>@step.Number</span><strong>@step.Label</strong></div>
                    <h3>@step.Title</h3>
                    <p>@step.Text</p>
                </article>
            }
        </div>
    </section>

    <section id="app" class="premium-section premium-dashboard-section">
        <div class="premium-section-head">
            <p class="premium-label">@HomeContent.Dashboard.Label</p>
            <h2>@HomeContent.Dashboard.Headline</h2>
            <p>@HomeContent.Dashboard.Subtitle</p>
        </div>

        <div class="provider-mobile-showcase">
            <div class="provider-mobile-copy">
                <span>wélé mobile</span>
                <strong>Un espace pense pour le terrain.</strong>
                <p>Le prestataire voit l'essentiel: son profil, la prochaine mission, les messages et les services suivis.</p>
            </div>

            <div class="provider-phone-frame" aria-label="Apercu de l'application mobile wélé Prestataire">
                <div class="provider-phone-speaker"></div>
                <div class="provider-phone-screen">
                    <div class="provider-phone-status">
                        <span>9:41</span>
                        <strong>wélé</strong>
                    </div>

                    <section class="provider-phone-hero-card">
                        <small>Prochaine mission</small>
                        <h3>@(HomeContent.Dashboard.Requests.FirstOrDefault() ?? "Mission menage a Cocody")</h3>
                        <p>Reponse attendue rapidement</p>
                    </section>

                    <div class="provider-phone-stats">
                        @foreach (var stat in HomeContent.Dashboard.Stats.Take(3))
                        {
                            <article>
                                <span>@stat.Label</span>
                                <strong>@stat.Value</strong>
                                <small>@stat.Help</small>
                            </article>
                        }
                    </div>

                    <section class="provider-phone-list">
                        <h4>Fil du jour</h4>
                        @foreach (var request in HomeContent.Dashboard.Requests.Skip(1).Take(2))
                        {
                            <p>@request</p>
                        }
                    </section>

                    <section class="provider-phone-list compact">
                        <h4>Profil terrain</h4>
                        @foreach (var provider in HomeContent.Dashboard.Providers.Take(2))
                        {
                            <p>@provider</p>
                        }
                    </section>

                    <nav class="provider-phone-nav" aria-label="Navigation mobile">
                        <span class="active">Accueil</span>
                        <span>Services</span>
                        <span>Chat</span>
                        <span>Profil</span>
                    </nav>
                </div>
            </div>
        </div>
    </section>

    <section id="faq" class="premium-section premium-faq-section">
        <div class="premium-section-head centered">
            <p class="premium-label">@HomeContent.Faq.Label</p>
            <h2>@HomeContent.Faq.Headline</h2>
        </div>

        <div class="premium-faq">
            @foreach (var item in HomeContent.Faq.Questions.Select((question, index) => new { question, index }))
            {
                <details open="@(item.index == 0)">
                    <summary>@item.question.Question</summary>
                    <p>@item.question.Answer</p>
                </details>
            }
        </div>
    </section>

    <section id="contact" class="premium-section premium-contact-section">
        <div class="premium-contact-copy">
            <p class="premium-label">@HomeContent.Contact.Label</p>
            <h2>@HomeContent.Contact.Headline</h2>
            <p>@HomeContent.Contact.Subtitle</p>
            <div class="premium-contact-tags">
                @foreach (var tag in HomeContent.Contact.Tags)
                {
                    <span>@tag</span>
                }
            </div>
        </div>

        <form class="premium-contact-form" @onsubmit="SubmitContactAsync" @onsubmit:preventDefault>
            <div class="premium-form-grid">
                <label>Nom complet<input placeholder="Ex: Awa Konate" @bind="ContactName" /></label>
                <label>Service principal<input placeholder="Ex: Menage a domicile" @bind="ContactService" /></label>
                <label>Telephone<input type="tel" placeholder="+225 07 00 00 00 00" @bind="ContactPhone" /></label>
                <label>Commune<input placeholder="Ex: Cocody" @bind="ContactArea" /></label>
            </div>
            <label>
                Message
                <textarea rows="5" placeholder="Expliquez rapidement votre besoin..." @bind="ContactBody"></textarea>
            </label>

            @if (!string.IsNullOrWhiteSpace(ContactMessage))
            {
                <p class="field-message">@ContactMessage</p>
            }

            <button type="submit" class="premium-primary">Envoyer le message</button>
        </form>
    </section>

    <footer class="premium-footer">
        <div class="premium-footer-brand">
            <a class="premium-footer-logo" href="#home" aria-label="Retour accueil wélé">
                <img src="images/wele-logo.png" alt="wélé" />
            </a>
            <p>@HomeContent.Footer.BrandText</p>
        </div>
        @foreach (var column in HomeContent.Footer.Columns)
        {
            <nav aria-label="@column.Title">
                <h2>@column.Title</h2>
                @foreach (var link in column.Links)
                {
                    <a href="#contact">@link</a>
                }
            </nav>
        }
        <div class="premium-footer-bottom">
            <span>@HomeContent.Footer.Copyright</span>
            <span>@HomeContent.Footer.Baseline</span>
        </div>
    </footer>
</div>

@code {
    private CompanyHomeCmsResponse HomeContent { get; set; } = CreateDefaultHomeContent();
    private HeroHeadlineParts HeroHeadline => SplitHeroHeadline(HomeContent.Hero.Headline);
    private string ContactName { get; set; } = string.Empty;
    private string ContactService { get; set; } = string.Empty;
    private string ContactPhone { get; set; } = string.Empty;
    private string ContactArea { get; set; } = string.Empty;
    private string ContactBody { get; set; } = string.Empty;
    private string? ContactMessage { get; set; }
    private bool ShowCandidateSubmitted { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        ShowCandidateSubmitted = query.TryGetValue("candidate", out var candidate)
            && string.Equals(candidate.ToString(), "submitted", StringComparison.OrdinalIgnoreCase);
        HomeContent = await ApiClient.GetProviderHomeContentAsync() ?? CreateDefaultHomeContent();
    }

    private async Task SubmitContactAsync()
    {
        if (string.IsNullOrWhiteSpace(ContactName)
            || string.IsNullOrWhiteSpace(ContactPhone)
            || string.IsNullOrWhiteSpace(ContactBody))
        {
            ContactMessage = "Renseignez au moins le nom, le telephone et le message.";
            return;
        }

        var subject = string.IsNullOrWhiteSpace(ContactService)
            ? "Contact prestataire"
            : $"Contact prestataire - {ContactService.Trim()}";
        var message = string.IsNullOrWhiteSpace(ContactArea)
            ? ContactBody
            : $"{ContactBody.Trim()}\n\nCommune: {ContactArea.Trim()}";

        var result = await ApiClient.SubmitContactRequestAsync(new SubmitContactRequest(
            "ProviderLanding",
            ContactName,
            null,
            ContactPhone,
            null,
            subject,
            message));

        if (!result.IsSuccess)
        {
            ContactMessage = result.ErrorMessage ?? "Impossible d'envoyer le message pour le moment.";
            return;
        }

        ContactName = string.Empty;
        ContactService = string.Empty;
        ContactPhone = string.Empty;
        ContactArea = string.Empty;
        ContactBody = string.Empty;
        ContactMessage = "Message envoye. Notre equipe vous recontacte rapidement.";
    }

    private static string NormalizeCtaUrl(string url)
    {
        return string.Equals(url.Trim('/'), "onboarding", StringComparison.OrdinalIgnoreCase)
            ? "/onboarding?mode=register"
            : url;
    }

    private string ResolveContentUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(url, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return url.StartsWith("/api/", StringComparison.OrdinalIgnoreCase)
            ? ApiClient.ToApiUrl(url)
            : NormalizeLegacyMediaUrl(url.TrimStart('/'));
    }

    private static string NormalizeLegacyMediaUrl(string url)
    {
        return url.Replace("images/kaza-", "images/wele-", StringComparison.OrdinalIgnoreCase);
    }

    private static HeroHeadlineParts SplitHeroHeadline(string headline)
    {
        const string marker = ". ";
        var index = headline.IndexOf(marker, StringComparison.Ordinal);
        return index < 0
            ? new HeroHeadlineParts(headline, string.Empty)
            : new HeroHeadlineParts(headline[..(index + 1)], headline[(index + marker.Length)..]);
    }

    private static BenefitItem SplitBenefitItem(string item)
    {
        var index = item.IndexOf(':', StringComparison.Ordinal);
        return index < 0
            ? new BenefitItem(item, string.Empty)
            : new BenefitItem(item[..index].Trim(), item[(index + 1)..].Trim());
    }

    private static CompanyHomeCmsResponse CreateDefaultHomeContent()
    {
        return new CompanyHomeCmsResponse(
            new CompanyHomeHeroCmsResponse(
                "wélé prestataire",
                "Rejoignez notre réseau de professionnels à Abidjan",
                "Recevez des demandes de clients et développez votre activité.",
                new CmsLinkResponse("Créer un compte", "/onboarding?mode=register"),
                new CmsLinkResponse("Voir le fonctionnement", "#benefits"),
                "images/wele-provider-hero.png",
                "Prestataires de services à domicile wélé",
                ["Clients à Abidjan", "Paiement sécurisé", "Planning libre"]),
            new CompanyHomeStepsCmsResponse(
                "Fonctionnement",
                "Trois étapes pour démarrer.",
                "Un parcours simple pour proposer votre profil en intérim à une entreprise partenaire.",
                [
                    new CmsStepResponse("01", "Formulaire", "Créez votre compte en ligne", "Renseignez vos informations, votre service principal et votre zone.", "images/wele-provider-step-1.svg"),
                    new CmsStepResponse("02", "Entreprise", "Choisissez une entreprise", "wélé vous propose des entreprises qui acceptent les profils intérimaires dans votre domaine.", "images/wele-provider-step-2.svg"),
                    new CmsStepResponse("03", "Validation", "L'entreprise étudie votre demande", "Si elle vous valide, vous pourrez recevoir des missions dans l'application mobile.", "images/wele-provider-step-3.svg")
                ]),
            new CompanyHomeTrustedCmsResponse(
                "Pourquoi rejoindre wélé ?",
                "Nous vous aidons à trouver des clients et développer votre activité.",
                [
                    "Clients réguliers : recevez des demandes de clients dans votre zone. Plus besoin de chercher.",
                    "Paiement sécurisé : les clients paient avant l'intervention, vous êtes payé rapidement.",
                    "Liberté totale : vous choisissez vos horaires et les missions que vous acceptez. Pas d'engagement, vous gérez votre planning."
                ]),
            new CompanyHomeDashboardCmsResponse(
                "Application",
                "Tout tient dans votre téléphone.",
                "Vos missions, vos services, vos messages et votre profil restent clairs, même avec peu de connexion.",
                [
                    new CmsDashboardStatResponse("Mission", "1", "A traiter à la fois"),
                    new CmsDashboardStatResponse("Distance", "2 km", "Zone proche"),
                    new CmsDashboardStatResponse("Profil", "92%", "Presque complet")
                ],
                ["Mission ménage à Cocody", "Demande jardinage à Marcory", "Rendez-vous électricité demain"],
                ["Disponible maintenant", "Code entreprise actif", "Book photo à compléter"]),
            new CompanyHomeFaqCmsResponse(
                "FAQ",
                "Foire aux questions",
                [
                    new CmsFaqItemResponse("Je peux m'inscrire sans entreprise ?", "Oui. Vous créez un profil intérim. Une entreprise devra ensuite vous valider avant les missions."),
                    new CmsFaqItemResponse("A quoi sert le code entreprise ?", "Il permet d'activer le profil que votre entreprise a déjà créé pour vous."),
                    new CmsFaqItemResponse("Quand vois-je le numéro du client ?", "Après acceptation et confirmation de la mission, les contacts utiles deviennent visibles."),
                    new CmsFaqItemResponse("Pourquoi ajouter des photos ?", "Pour certains services, un book aide l'entreprise à valider votre profil et vos prestations.")
                ]),
            new CompanyHomeContactCmsResponse(
                "Contact",
                "Besoin d'aide pour démarrer ?",
                "Laissez vos coordonnées. Nous vous orientons vers le bon parcours.",
                ["Abidjan", "Intérim", "Services à domicile"]),
            new CompanyHomeFooterCmsResponse(
                "La plateforme qui rapproche les prestataires sérieux des entreprises de services.",
                "(c) 2026 wélé Technologies. Tous droits réservés.",
                "Conçu pour l'Afrique de l'Ouest",
                [
                    new CmsFooterColumnResponse("Produit", ["Fonctionnement", "Sécurité", "Support"]),
                    new CmsFooterColumnResponse("Prestataire", ["Créer un profil", "Missions", "Profil intérim"]),
                    new CmsFooterColumnResponse("Ressources", ["Centre d'aide", "FAQ", "Contact", "WhatsApp"]),
                    new CmsFooterColumnResponse("Légal", ["CGU", "Confidentialité", "Mentions légales"])
                ]));
    }

    private sealed record HeroHeadlineParts(string Main, string Highlight);
    private sealed record BenefitItem(string Title, string Text);
}

@page "/"
@page "/onboarding"
@inject ProviderApiClient Api
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Kaza Prestataire - Acces</PageTitle>

<main class="provider-mobile-shell onboarding-shell">
    <section class="screen-heading compact-heading onboarding-hero-copy">
        <span>Kaza prestataire</span>
        <h1>Se connecter</h1>
        <p>Accedez a vos missions ou creez votre compte prestataire.</p>
    </section>

    <nav class="onboarding-tabs onboarding-primary-tabs" aria-label="Choix du parcours prestataire">
        <button type="button" class="@TabClass("login")" @onclick='() => SetMode("login")'>
            <span>Se connecter</span>
            <small>Code ou telephone</small>
        </button>
        <button type="button" class="@TabClass("register")" @onclick='() => SetMode("register")'>
            <span>Creer un compte</span>
            <small>Profil interim</small>
        </button>
    </nav>

    @if (ActiveMode == "login")
    {
        <section class="onboarding-choice-card highlighted">
            <div class="onboarding-card-head">
                <div class="onboarding-icon">
                    <svg viewBox="0 0 24 24"><path d="M8 11V8a4 4 0 0 1 8 0v3" /><path d="M6 11h12v9H6z" /><path d="M12 15v2" /></svg>
                </div>
                <div>
                    <span>Connexion</span>
                    <h2>Se connecter</h2>
                    <p>Avec un code d'activation ou votre numero de telephone.</p>
                </div>
            </div>

            <div class="login-method-tabs" role="tablist" aria-label="Mode de connexion">
                <button type="button" class="@LoginMethodClass("code")" @onclick='() => SetLoginMethod("code")'>
                    <strong>Code activation</strong>
                </button>
                <button type="button" class="@LoginMethodClass("password")" @onclick='() => SetLoginMethod("password")'>
                    <strong>Acces</strong>
                </button>
            </div>

            @if (LoginMethod == "code")
            {
                <div class="onboarding-form-block">
                    <label>
                        Code recu
                        <input placeholder="Ex: KAZA-482135" @bind="InvitationCode" @bind:event="oninput" />
                    </label>

                    @if (Invitation is not null)
                    {
                        <div class="invitation-preview">
                            <strong>@Invitation.ProviderName</strong>
                            <span>@Invitation.CompanyName</span>
                            <small>Valable jusqu'au @Invitation.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    }

                    <div class="two-field-grid">
                        <label>Mot de passe<input type="password" autocomplete="new-password" placeholder="Minimum 8 caracteres" @bind="ActivationPassword" /></label>
                        <label>Confirmation<input type="password" autocomplete="new-password" placeholder="Retapez le mot de passe" @bind="ActivationConfirmPassword" /></label>
                    </div>

                    <label class="remember-row">
                        <input type="checkbox" @bind="RememberMe" />
                        <span>Rester connecte sur ce telephone</span>
                    </label>

                    @if (!string.IsNullOrWhiteSpace(ActivationMessage))
                    {
                        <p class="field-message">@ActivationMessage</p>
                    }

                    <div class="action-row">
                        <button type="button" class="ghost-action" @onclick="LoadInvitationAsync" disabled="@IsBusy">Verifier</button>
                        <button type="button" class="primary-action" @onclick="ActivateAsync" disabled="@IsBusy">Activer</button>
                    </div>
                </div>
            }
            else
            {
                <div class="onboarding-form-block">
                    <label>Telephone<input type="tel" autocomplete="tel" placeholder="+225 07 00 00 00 00" @bind="PhoneNumber" /></label>
                    <label>Mot de passe<input type="password" autocomplete="current-password" placeholder="Votre mot de passe" @bind="LoginPassword" /></label>

                    <label class="remember-row">
                        <input type="checkbox" @bind="RememberMe" />
                        <span>Rester connecte sur ce telephone</span>
                    </label>

                    @if (!string.IsNullOrWhiteSpace(LoginMessage))
                    {
                        <p class="field-message">@LoginMessage</p>
                    }

                    <button type="button" class="primary-action orange-action" @onclick="LoginAsync" disabled="@IsBusy">Se connecter</button>
                </div>
            }
        </section>
    }
    else
    {
        <section class="onboarding-choice-card">
            <div class="onboarding-card-head">
                <div class="onboarding-icon orange">
                    <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /><path d="M4 21a8 8 0 0 1 16 0" /><path d="M19 8v6" /><path d="M16 11h6" /></svg>
                </div>
                <div>
                    <span>Candidature prestataire</span>
                    <h2>Creer mon compte</h2>
                    <p>Renseignez vos informations et vos services. Une entreprise devra valider votre profil avant les missions.</p>
                </div>
            </div>

            <div class="register-fieldset">
                <span>Competence</span>
                <label>
                    Service propose
                    <input list="provider-services"
                           placeholder="Ex: Menage a domicile"
                           @bind="ServiceEntry"
                           @bind:event="oninput" />
                    <datalist id="provider-services">
                        @foreach (var service in ExistingServices)
                        {
                            <option value="@service.Name"></option>
                        }
                    </datalist>
                    <small>Si le service n'existe pas encore, il sera cree comme nouveau service a verifier.</small>
                </label>
                <label>Annee d'experience<input type="number" min="0" placeholder="Ex: 3" @bind="RegisterYearsOfExperience" /></label>
                @if (!string.IsNullOrWhiteSpace(ServiceEntry))
                {
                    <div class="service-autocomplete-preview">
                        @if (FindExistingService(ServiceEntry) is not null)
                        {
                            <span>Service existant</span>
                            <strong>@FindExistingService(ServiceEntry)!.Name</strong>
                        }
                        else
                        {
                            <span>Nouveau service</span>
                            <strong>@ServiceEntry.Trim()</strong>
                        }
                    </div>
                }
            </div>

            <div class="register-fieldset">
                <span>Identite</span>
                <div class="two-field-grid">
                    <label>Prenom<input placeholder="Awa" @bind="RegisterFirstName" /></label>
                    <label>Nom<input placeholder="Kone" @bind="RegisterLastName" /></label>
                </div>
                <div class="two-field-grid">
                    <label>Sexe
                        <select @bind="RegisterGender">
                            <option value="">Selectionnez</option>
                            <option value="Female">Femme</option>
                            <option value="Male">Homme</option>
                        </select>
                    </label>
                    <label>Date de naissance<InputDate @bind-Value="RegisterBirthDate" /></label>
                </div>
            </div>

            <div class="register-fieldset">
                <span>Contact</span>
                <label>Tel<input type="tel" placeholder="+225 07 00 00 00 00" @bind="RegisterPhoneNumber" /></label>
                <label>Adresse
                    <input list="abidjan-neighborhoods" placeholder="Ex: Cocody Angre" @bind="RegisterAddress" />
                    <datalist id="abidjan-neighborhoods">
                        @foreach (var area in AbidjanAreas)
                        {
                            <option value="@area"></option>
                        }
                    </datalist>
                </label>
            </div>

            <div class="register-fieldset">
                <span>Securite</span>
                <div class="two-field-grid">
                    <label>Mot de passe<input type="password" placeholder="Minimum 8 caracteres" @bind="RegisterPassword" /></label>
                    <label>Confirmation<input type="password" placeholder="Retapez le mot de passe" @bind="RegisterConfirmPassword" /></label>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(RegisterMessage))
            {
                <p class="field-message">@RegisterMessage</p>
            }

            <button type="button" class="primary-action" @onclick="RegisterAsync" disabled="@IsBusy">Creer mon compte</button>
        </section>
    }

    <section class="profile-completion-banner onboarding-note">
        <div>
            <span>Opportunites</span>
            <strong>Interim</strong>
        </div>
        <p>Trouvez une entreprise dans votre secteur et realisez des missions grace a votre collaboration.</p>
    </section>
</main>

@code {
    private string ActiveMode { get; set; } = "login";
    private string LoginMethod { get; set; } = "code";
    private string InvitationCode { get; set; } = string.Empty;
    private string ActivationPassword { get; set; } = string.Empty;
    private string ActivationConfirmPassword { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string LoginPassword { get; set; } = string.Empty;
    private string RegisterFirstName { get; set; } = string.Empty;
    private string RegisterLastName { get; set; } = string.Empty;
    private string RegisterPhoneNumber { get; set; } = string.Empty;
    private DateTime? RegisterBirthDate { get; set; }
    private string RegisterAddress { get; set; } = string.Empty;
    private string RegisterGender { get; set; } = string.Empty;
    private int RegisterYearsOfExperience { get; set; }
    private string RegisterPassword { get; set; } = string.Empty;
    private string RegisterConfirmPassword { get; set; } = string.Empty;
    private IReadOnlyList<ServiceSummaryResponse> ExistingServices { get; set; } = [];
    private static readonly string[] AbidjanAreas =
    [
        "Abobo - Abobo Baoule",
        "Abobo - Avocatier",
        "Abobo - PK18",
        "Adjame - 220 logements",
        "Adjame - Williamsville",
        "Anyama - Centre",
        "Attecoube - Locodjro",
        "Bingerville - Centre",
        "Cocody - Angre",
        "Cocody - Deux Plateaux",
        "Cocody - Riviera 2",
        "Cocody - Riviera 3",
        "Cocody - Riviera Palmeraie",
        "Cocody - Mermoz",
        "Koumassi - Centre",
        "Koumassi - Remblais",
        "Marcory - Zone 4",
        "Marcory - Residentiel",
        "Plateau - Centre",
        "Port-Bouet - Vridi",
        "Port-Bouet - Gonzagueville",
        "Treichville - Avenue 16",
        "Yopougon - Ananeraie",
        "Yopougon - Maroc",
        "Yopougon - Niangon",
        "Yopougon - Selmer"
    ];
    private string ServiceEntry { get; set; } = string.Empty;
    private bool RememberMe { get; set; } = true;
    private bool IsBusy { get; set; }
    private string? ActivationMessage { get; set; }
    private string? LoginMessage { get; set; }
    private string? RegisterMessage { get; set; }
    private ProviderInvitationPreviewResponse? Invitation { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ExistingServices = (await Api.GetServicesAsync()).Where(service => service.IsActive).ToList();
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        if (query.TryGetValue("code", out var code))
        {
            ActiveMode = "login";
            LoginMethod = "code";
            InvitationCode = code.ToString();
            await LoadInvitationAsync();
        }
    }

    private void SetMode(string mode)
    {
        ActiveMode = mode;
        ActivationMessage = null;
        LoginMessage = null;
        RegisterMessage = null;
    }

    private string TabClass(string mode) => ActiveMode == mode ? "active" : string.Empty;

    private void SetLoginMethod(string method)
    {
        LoginMethod = method;
        ActivationMessage = null;
        LoginMessage = null;
    }

    private string LoginMethodClass(string method) => LoginMethod == method ? "active" : string.Empty;

    private async Task LoadInvitationAsync()
    {
        ActivationMessage = null;
        Invitation = null;
        if (string.IsNullOrWhiteSpace(InvitationCode))
        {
            ActivationMessage = "Saisissez le code recu.";
            return;
        }

        IsBusy = true;
        var result = await Api.GetInvitationAsync(InvitationCode);
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            ActivationMessage = result.ErrorMessage ?? "Code introuvable.";
            return;
        }

        Invitation = result.Value;
        PhoneNumber = Invitation.PhoneNumber;
    }

    private async Task ActivateAsync()
    {
        ActivationMessage = null;
        IsBusy = true;
        var result = await Api.ActivateAsync(new ProviderInvitationActivationRequest(
            InvitationCode,
            ActivationPassword,
            ActivationConfirmPassword,
            RememberMe));
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            ActivationMessage = result.ErrorMessage ?? "Activation impossible.";
            return;
        }

        await StoreSessionAsync(result.Value);
        Navigation.NavigateTo("/home");
    }

    private async Task LoginAsync()
    {
        LoginMessage = null;
        IsBusy = true;
        var result = await Api.LoginAsync(new ProviderPortalLoginRequest(PhoneNumber, LoginPassword, RememberMe));
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            LoginMessage = result.ErrorMessage ?? "Connexion impossible.";
            return;
        }

        await StoreSessionAsync(result.Value);
        Navigation.NavigateTo("/home");
    }

    private async Task RegisterAsync()
    {
        RegisterMessage = null;
        if (RegisterBirthDate is null)
        {
            RegisterMessage = "Renseignez une date de naissance valide.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ServiceEntry.Trim()) || ServiceEntry.Trim().Length < 3)
        {
            RegisterMessage = "Selectionnez ou saisissez un service.";
            return;
        }

        if (string.IsNullOrWhiteSpace(RegisterGender))
        {
            RegisterMessage = "Selectionnez le sexe du prestataire.";
            return;
        }

        IsBusy = true;
        var request = new ProviderSelfRegistrationRequest(
            RegisterFirstName,
            RegisterLastName,
            RegisterPhoneNumber,
            DateOnly.FromDateTime(RegisterBirthDate.Value),
            RegisterAddress,
            RegisterGender,
            RegisterYearsOfExperience,
            null,
            null,
            5,
            RegisterPassword,
            RegisterConfirmPassword,
            BuildSelectedServiceRequests(),
            BuildProposedServiceNames());
        var result = await Api.RegisterSelfAsync(request);
        if (!result.IsSuccess)
        {
            IsBusy = false;
            RegisterMessage = result.ErrorMessage ?? "Creation impossible.";
            return;
        }

        var login = await Api.LoginAsync(new ProviderPortalLoginRequest(RegisterPhoneNumber, RegisterPassword, true));
        IsBusy = false;
        if (!login.IsSuccess || login.Value is null)
        {
            RegisterMessage = "Profil cree. Connectez-vous avec votre telephone et mot de passe.";
            ActiveMode = "login";
            LoginMethod = "password";
            PhoneNumber = RegisterPhoneNumber;
            return;
        }

        await StoreSessionAsync(login.Value);
        Navigation.NavigateTo("/home");
    }

    private async Task StoreSessionAsync(ProviderPortalLoginResponse session)
    {
        await Js.InvokeVoidAsync("localStorage.setItem", "kaza.provider.session", System.Text.Json.JsonSerializer.Serialize(session));
    }

    private ServiceSummaryResponse? FindExistingService(string serviceName)
    {
        return ExistingServices.FirstOrDefault(service => IsSameCompletionValue(service.Name, serviceName));
    }

    private IReadOnlyList<ProviderCandidateServiceRequest> BuildSelectedServiceRequests()
    {
        var existing = FindExistingService(ServiceEntry);
        return existing is null
            ? []
            : [new ProviderCandidateServiceRequest(existing.Id, "Confirmed", RegisterYearsOfExperience)];
    }

    private IReadOnlyList<string> BuildProposedServiceNames()
    {
        return FindExistingService(ServiceEntry) is null
            ? [ServiceEntry.Trim()]
            : [];
    }

    private static bool IsSameService(string left, string right)
    {
        return IsSameCompletionValue(left, right);
    }

    private static bool IsSameCompletionValue(string left, string right)
    {
        return NormalizeCompletionValue(left) == NormalizeCompletionValue(right);
    }

    private static string NormalizeCompletionValue(string value)
    {
        var normalized = value.Trim().Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalized.Length);
        foreach (var character in normalized)
        {
            var category = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(character);
            if (category != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                builder.Append(char.ToLowerInvariant(character));
            }
        }

        return builder.ToString().Normalize(System.Text.NormalizationForm.FormC);
    }
}

@page "/onboarding"
@inject ProviderApiClient Api
@inject NavigationManager Navigation

<PageTitle>Kaza Prestataire - Interim</PageTitle>

<main class="provider-onboarding-page">
    <section class="registration-header onboarding-hero-copy">
        <p class="eyebrow">Kaza prestataire</p>
        <h1>@PageHeadline</h1>
        <p>@PageSubtitle</p>
    </section>

    <section class="registration-form onboarding-form-shell">
        <div class="onboarding-choice-card">
            <div class="onboarding-card-head">
                <div class="onboarding-icon orange">
                    <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /><path d="M4 21a8 8 0 0 1 16 0" /><path d="M19 8v6" /><path d="M16 11h6" /></svg>
                </div>
                <div>
                    <span>Candidature prestataire</span>
                    <h2>Creer mon compte</h2>
                    <p>Renseignez vos informations et vos services. Une entreprise devra valider votre profil avant les missions.</p>
                </div>
            </div>

            <div class="register-fieldset">
                <span>Competence</span>
                <label>
                    Service propose
                    <input list="provider-services"
                           placeholder="Ex: Menage, tondre gazon, repassage"
                           value="@ServiceEntry"
                           @oninput="OnServiceEntryChanged" />
                    <datalist id="provider-services">
                        @foreach (var option in OnboardingOptions)
                        {
                            <option value="@option.Label"></option>
                        }
                    </datalist>
                    <small>Choisissez un service ou une prestation. Si cela n'existe pas encore, le service sera propose a Kaza.</small>
                </label>
                <label>Annee d'experience<input type="number" min="0" placeholder="Ex: 3" @bind="RegisterYearsOfExperience" /></label>
                @if (!string.IsNullOrWhiteSpace(ServiceEntry))
                {
                    <div class="service-autocomplete-preview">
                        @if (FindSelectedOption(ServiceEntry) is not null)
                        {
                            <span>@FindSelectedOption(ServiceEntry)!.Type existant</span>
                            <strong>@FindSelectedOption(ServiceEntry)!.Label</strong>
                        }
                        else
                        {
                            <span>Nouveau service</span>
                            <strong>@ServiceEntry.Trim()</strong>
                        }
                    </div>
                }
            </div>

            <div class="register-fieldset">
                <span>Identite</span>
                <div class="two-field-grid">
                    <label>Prenom<input placeholder="Awa" @bind="RegisterFirstName" /></label>
                    <label>Nom<input placeholder="Kone" @bind="RegisterLastName" /></label>
                </div>
                <div class="two-field-grid">
                    <label>Sexe
                        <select @bind="RegisterGender">
                            <option value="">Selectionnez</option>
                            <option value="Female">Femme</option>
                            <option value="Male">Homme</option>
                        </select>
                    </label>
                    <label>Date de naissance<InputDate @bind-Value="RegisterBirthDate" /></label>
                </div>
            </div>

            <div class="register-fieldset">
                <span>Contact</span>
                <label>Tel<input type="tel" placeholder="+225 07 00 00 00 00" @bind="RegisterPhoneNumber" /></label>
                <label>Adresse
                    <input list="abidjan-neighborhoods" placeholder="Ex: Cocody Angre" value="@RegisterAddress" @oninput="OnAddressChanged" />
                    <datalist id="abidjan-neighborhoods">
                        @foreach (var area in AbidjanAreas)
                        {
                            <option value="@area"></option>
                        }
                    </datalist>
                </label>
            </div>

            <div class="register-fieldset opportunity-fieldset">
                <span>Opportunites proches</span>
                <p class="opportunity-help">Kaza vous propose jusqu'a 5 entreprises qui acceptent les candidatures interimaires dans votre domaine. Une seule entreprise recevra votre demande : la premiere est selectionnee par defaut, vous pouvez en choisir une autre.</p>
                @if (IsLoadingOpportunities)
                {
                    <div class="opportunity-empty">Recherche des entreprises compatibles...</div>
                }
                else if (SelectedOption is null)
                {
                    <div class="opportunity-empty">Choisissez d'abord un service ou une prestation.</div>
                }
                else if (CompanyOpportunities.Count == 0)
                {
                    <div class="opportunity-empty">Aucune entreprise compatible trouvee pour le moment. Essayez une zone plus large ou un service proche.</div>
                }
                else
                {
                    <div class="opportunity-list">
                        @foreach (var opportunity in CompanyOpportunities)
                        {
                            <label class="opportunity-card @(SelectedOpportunityCompanyIds.Contains(opportunity.CompanyId) ? "selected" : string.Empty)">
                                    <input type="radio"
                                           name="selected-company-opportunity"
                                           checked="@SelectedOpportunityCompanyIds.Contains(opportunity.CompanyId)"
                                           @onchange="@(() => SelectOpportunity(opportunity.CompanyId))" />
                                <span>
                                    <strong>@opportunity.CompanyName</strong>
                                    <small>@opportunity.ProximityLabel</small>
                                </span>
                                <em>@string.Join(", ", opportunity.MatchingPrestations.Count > 0 ? opportunity.MatchingPrestations : opportunity.MatchingServices)</em>
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="register-fieldset">
                <span>Securite</span>
                <div class="two-field-grid">
                    <label>Mot de passe<input type="password" placeholder="Minimum 8 caracteres" @bind="RegisterPassword" /></label>
                    <label>Confirmation<input type="password" placeholder="Retapez le mot de passe" @bind="RegisterConfirmPassword" /></label>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(RegisterMessage))
            {
                <p class="field-message">@RegisterMessage</p>
            }

            <button type="button" class="primary-action" @onclick="RegisterAsync" disabled="@IsBusy">Creer mon compte</button>
        </div>
    </section>

    <section class="onboarding-note">
        <div>
            <span>Opportunites</span>
            <strong>Interim</strong>
        </div>
        <p>Trouvez une entreprise dans votre secteur et realisez des missions grace a votre collaboration.</p>
    </section>
</main>

@code {
    private string PageHeadline => "Creer votre compte interimaire";
    private string PageSubtitle => "Renseignez vos informations, choisissez une entreprise compatible et envoyez votre candidature.";
    private string RegisterFirstName { get; set; } = string.Empty;
    private string RegisterLastName { get; set; } = string.Empty;
    private string RegisterPhoneNumber { get; set; } = string.Empty;
    private DateTime? RegisterBirthDate { get; set; }
    private string RegisterAddress { get; set; } = string.Empty;
    private string RegisterGender { get; set; } = string.Empty;
    private int RegisterYearsOfExperience { get; set; }
    private string RegisterPassword { get; set; } = string.Empty;
    private string RegisterConfirmPassword { get; set; } = string.Empty;
    private IReadOnlyList<ProviderOnboardingOptionResponse> OnboardingOptions { get; set; } = [];
    private IReadOnlyList<ProviderCompanyOpportunityResponse> CompanyOpportunities { get; set; } = [];
    private ProviderOnboardingOptionResponse? SelectedOption { get; set; }
    private HashSet<Guid> SelectedOpportunityCompanyIds { get; } = [];
    private bool IsLoadingOpportunities { get; set; }
    private static readonly string[] AbidjanAreas =
    [
        "Abobo - Abobo Baoule",
        "Abobo - Avocatier",
        "Abobo - PK18",
        "Adjame - 220 logements",
        "Adjame - Williamsville",
        "Anyama - Centre",
        "Attecoube - Locodjro",
        "Bingerville - Centre",
        "Cocody - Angre",
        "Cocody - Deux Plateaux",
        "Cocody - Riviera 2",
        "Cocody - Riviera 3",
        "Cocody - Riviera Palmeraie",
        "Cocody - Mermoz",
        "Koumassi - Centre",
        "Koumassi - Remblais",
        "Marcory - Zone 4",
        "Marcory - Residentiel",
        "Plateau - Centre",
        "Port-Bouet - Vridi",
        "Port-Bouet - Gonzagueville",
        "Treichville - Avenue 16",
        "Yopougon - Ananeraie",
        "Yopougon - Maroc",
        "Yopougon - Niangon",
        "Yopougon - Selmer"
    ];
    private string ServiceEntry { get; set; } = string.Empty;
    private bool IsBusy { get; set; }
    private string? RegisterMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        OnboardingOptions = await Api.GetOnboardingOptionsAsync(null);
    }

    private async Task RegisterAsync()
    {
        RegisterMessage = null;
        if (RegisterBirthDate is null)
        {
            RegisterMessage = "Renseignez une date de naissance valide.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ServiceEntry.Trim()) || ServiceEntry.Trim().Length < 3)
        {
            RegisterMessage = "Selectionnez ou saisissez un service.";
            return;
        }

        if (string.IsNullOrWhiteSpace(RegisterGender))
        {
            RegisterMessage = "Selectionnez le sexe du prestataire.";
            return;
        }

        if (SelectedOpportunityCompanyIds.Count == 0)
        {
            RegisterMessage = "Selectionnez une entreprise proche pour envoyer votre demande.";
            return;
        }

        IsBusy = true;
        var request = new ProviderSelfRegistrationRequest(
            RegisterFirstName,
            RegisterLastName,
            RegisterPhoneNumber,
            DateOnly.FromDateTime(RegisterBirthDate.Value),
            RegisterAddress,
            RegisterGender,
            RegisterYearsOfExperience,
            null,
            null,
            5,
            RegisterPassword,
            RegisterConfirmPassword,
            BuildSelectedServiceRequests(),
            BuildProposedServiceNames(),
            BuildSelectedCandidateSelections(),
            SelectedOpportunityCompanyIds.ToList());
        var result = await Api.RegisterSelfAsync(request);
        IsBusy = false;
        if (!result.IsSuccess)
        {
            RegisterMessage = result.ErrorMessage ?? "Creation impossible.";
            return;
        }

        Navigation.NavigateTo("/?candidate=submitted");
    }

    private async Task OnServiceEntryChanged(ChangeEventArgs args)
    {
        ServiceEntry = args.Value?.ToString() ?? string.Empty;
        OnboardingOptions = await Api.GetOnboardingOptionsAsync(ServiceEntry);
        SelectedOption = FindSelectedOption(ServiceEntry);
        SelectedOpportunityCompanyIds.Clear();
        await LoadOpportunitiesAsync();
    }

    private async Task OnAddressChanged(ChangeEventArgs args)
    {
        RegisterAddress = args.Value?.ToString() ?? string.Empty;
        SelectedOpportunityCompanyIds.Clear();
        await LoadOpportunitiesAsync();
    }

    private async Task LoadOpportunitiesAsync()
    {
        CompanyOpportunities = [];
        if (SelectedOption is null)
        {
            return;
        }

        IsLoadingOpportunities = true;
        CompanyOpportunities = await Api.GetOnboardingOpportunitiesAsync(
            SelectedOption.Type,
            SelectedOption.Id,
            RegisterAddress);
        IsLoadingOpportunities = false;
        if (CompanyOpportunities.Count > 0)
        {
            SelectedOpportunityCompanyIds.Add(CompanyOpportunities[0].CompanyId);
        }
    }

    private void SelectOpportunity(Guid companyId)
    {
        SelectedOpportunityCompanyIds.Clear();
        SelectedOpportunityCompanyIds.Add(companyId);
    }

    private ProviderOnboardingOptionResponse? FindSelectedOption(string entry)
    {
        if (string.IsNullOrWhiteSpace(entry))
        {
            return null;
        }

        var normalizedEntry = NormalizeCompletionValue(entry);
        return OnboardingOptions.FirstOrDefault(option =>
                NormalizeCompletionValue(option.Label) == normalizedEntry
                || NormalizeCompletionValue(option.ServiceName) == normalizedEntry
                || (!string.IsNullOrWhiteSpace(option.PrestationName) && NormalizeCompletionValue(option.PrestationName) == normalizedEntry))
            ?? OnboardingOptions.FirstOrDefault(option =>
                NormalizeCompletionValue(option.Label).Contains(normalizedEntry, StringComparison.Ordinal)
                || normalizedEntry.Contains(NormalizeCompletionValue(option.Label), StringComparison.Ordinal)
                || NormalizeCompletionValue(option.ServiceName).Contains(normalizedEntry, StringComparison.Ordinal)
                || (!string.IsNullOrWhiteSpace(option.PrestationName)
                    && NormalizeCompletionValue(option.PrestationName).Contains(normalizedEntry, StringComparison.Ordinal)));
    }

    private IReadOnlyList<ProviderCandidateServiceRequest> BuildSelectedServiceRequests()
    {
        var selected = SelectedOption ?? FindSelectedOption(ServiceEntry);
        return selected is null
            ? []
            : [new ProviderCandidateServiceRequest(selected.ServiceId, "Confirmed", RegisterYearsOfExperience)];
    }

    private IReadOnlyList<ProviderCandidateSelectionRequest> BuildSelectedCandidateSelections()
    {
        var selected = SelectedOption ?? FindSelectedOption(ServiceEntry);
        return selected is null
            ? []
            : [new ProviderCandidateSelectionRequest(selected.Type, selected.Id, "Confirmed", RegisterYearsOfExperience)];
    }

    private IReadOnlyList<string> BuildProposedServiceNames()
    {
        return (SelectedOption ?? FindSelectedOption(ServiceEntry)) is null
            ? [ServiceEntry.Trim()]
            : [];
    }

    private static bool IsSameService(string left, string right)
    {
        return IsSameCompletionValue(left, right);
    }

    private static bool IsSameCompletionValue(string left, string right)
    {
        return NormalizeCompletionValue(left) == NormalizeCompletionValue(right);
    }

    private static string NormalizeCompletionValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Trim().Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalized.Length);
        foreach (var character in normalized)
        {
            var category = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(character);
            if (category != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                builder.Append(char.IsLetterOrDigit(character) ? char.ToLowerInvariant(character) : ' ');
            }
        }

        return string.Join(' ', builder
            .ToString()
            .Normalize(System.Text.NormalizationForm.FormC)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
    }
}

@page "/onboarding"
@inject ProviderApiClient Api
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Kaza Prestataire - Inscription</PageTitle>

<main class="provider-mobile-shell">
    <section class="screen-heading">
        <span>Acces prestataire</span>
        <h1>Entrez dans votre espace Kaza</h1>
        <p>Utilisez le code fourni par votre entreprise ou connectez-vous avec votre telephone si votre compte est deja active.</p>
    </section>

    <section class="onboarding-choice-card highlighted">
        <div class="onboarding-icon">
            <svg viewBox="0 0 24 24"><path d="M4 7h16" /><path d="M4 12h16" /><path d="M4 17h10" /></svg>
        </div>
        <div>
            <span>Activation entreprise</span>
            <h2>Code de preinscription</h2>
            <p>Ce code est cree par l'entreprise qui vous rattache comme prestataire.</p>
        </div>

        <label>
            Code recu
            <input placeholder="Ex: KAZA-482135" @bind="InvitationCode" @bind:event="oninput" />
        </label>

        @if (Invitation is not null)
        {
            <div class="invitation-preview">
                <strong>@Invitation.ProviderName</strong>
                <span>@Invitation.CompanyName</span>
                <small>Code valable jusqu'au @Invitation.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
            </div>
        }

        <div class="two-field-grid">
            <label>
                Mot de passe
                <input type="password" autocomplete="new-password" placeholder="Minimum 8 caracteres" @bind="ActivationPassword" />
            </label>
            <label>
                Confirmation
                <input type="password" autocomplete="new-password" placeholder="Retapez le mot de passe" @bind="ActivationConfirmPassword" />
            </label>
        </div>

        <label class="remember-row">
            <input type="checkbox" @bind="RememberMe" />
            <span>Rester connecte sur ce telephone</span>
        </label>

        @if (!string.IsNullOrWhiteSpace(ActivationMessage))
        {
            <p class="field-message">@ActivationMessage</p>
        }

        <div class="action-row">
            <button type="button" class="ghost-action" @onclick="LoadInvitationAsync" disabled="@IsBusy">Verifier</button>
            <button type="button" class="primary-action" @onclick="ActivateAsync" disabled="@IsBusy">Activer mon compte</button>
        </div>
    </section>

    <section class="onboarding-choice-card">
        <div class="onboarding-icon orange">
            <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
        </div>
        <div>
            <span>Compte active</span>
            <h2>Connexion</h2>
            <p>Connectez-vous avec le numero de telephone connu par votre entreprise.</p>
        </div>

        <label>
            Telephone
            <input type="tel" autocomplete="tel" placeholder="+225 07 00 00 00 00" @bind="PhoneNumber" />
        </label>
        <label>
            Mot de passe
            <input type="password" autocomplete="current-password" placeholder="Votre mot de passe" @bind="LoginPassword" />
        </label>

        @if (!string.IsNullOrWhiteSpace(LoginMessage))
        {
            <p class="field-message">@LoginMessage</p>
        }

        <button type="button" class="primary-action orange-action" @onclick="LoginAsync" disabled="@IsBusy">Se connecter</button>
    </section>

    <section class="onboarding-choice-card">
        <div class="onboarding-icon">
            <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /><path d="M4 21a8 8 0 0 1 16 0" /><path d="M19 8v6" /><path d="M16 11h6" /></svg>
        </div>
        <div>
            <span>Nouveau prestataire</span>
            <h2>Creer mon compte</h2>
            <p>Vous creez un profil demandeur d'interim. Ensuite vous pourrez completer vos services et candidater aux entreprises proches.</p>
        </div>

        <div class="two-field-grid">
            <label>Prenom<input placeholder="Awa" @bind="RegisterFirstName" /></label>
            <label>Nom<input placeholder="Kone" @bind="RegisterLastName" /></label>
        </div>
        <label>Telephone<input type="tel" placeholder="+225 07 00 00 00 00" @bind="RegisterPhoneNumber" /></label>
        <label>Date de naissance<InputDate @bind-Value="RegisterBirthDate" /></label>
        <label>Adresse<input placeholder="Cocody, Abidjan" @bind="RegisterAddress" /></label>
        <div class="two-field-grid">
            <label>Sexe
                <select @bind="RegisterGender">
                    <option value="Unspecified">Non renseigne</option>
                    <option value="Female">Femme</option>
                    <option value="Male">Homme</option>
                </select>
            </label>
            <label>Experience<input type="number" min="0" @bind="RegisterYearsOfExperience" /></label>
        </div>
        <div class="two-field-grid">
            <label>Mot de passe<input type="password" placeholder="Minimum 8 caracteres" @bind="RegisterPassword" /></label>
            <label>Confirmation<input type="password" placeholder="Retapez le mot de passe" @bind="RegisterConfirmPassword" /></label>
        </div>

        @if (!string.IsNullOrWhiteSpace(RegisterMessage))
        {
            <p class="field-message">@RegisterMessage</p>
        }

        <button type="button" class="primary-action" @onclick="RegisterAsync" disabled="@IsBusy">Creer mon compte</button>
    </section>

    <section class="profile-completion-banner">
        <div>
            <span>Regle importante</span>
            <strong>Validation entreprise</strong>
        </div>
        <p>Sans entreprise validee, vous pouvez preparer votre profil, mais vous ne recevez pas encore de missions.</p>
    </section>
</main>

@code {
    private string InvitationCode { get; set; } = string.Empty;
    private string ActivationPassword { get; set; } = string.Empty;
    private string ActivationConfirmPassword { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string LoginPassword { get; set; } = string.Empty;
    private string RegisterFirstName { get; set; } = string.Empty;
    private string RegisterLastName { get; set; } = string.Empty;
    private string RegisterPhoneNumber { get; set; } = string.Empty;
    private DateTime? RegisterBirthDate { get; set; }
    private string RegisterAddress { get; set; } = string.Empty;
    private string RegisterGender { get; set; } = "Unspecified";
    private int RegisterYearsOfExperience { get; set; }
    private string RegisterPassword { get; set; } = string.Empty;
    private string RegisterConfirmPassword { get; set; } = string.Empty;
    private bool RememberMe { get; set; } = true;
    private bool IsBusy { get; set; }
    private string? ActivationMessage { get; set; }
    private string? LoginMessage { get; set; }
    private string? RegisterMessage { get; set; }
    private ProviderInvitationPreviewResponse? Invitation { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        if (query.TryGetValue("code", out var code))
        {
            InvitationCode = code.ToString();
            await LoadInvitationAsync();
        }
    }

    private async Task LoadInvitationAsync()
    {
        ActivationMessage = null;
        Invitation = null;
        if (string.IsNullOrWhiteSpace(InvitationCode))
        {
            ActivationMessage = "Saisissez le code recu.";
            return;
        }

        IsBusy = true;
        var result = await Api.GetInvitationAsync(InvitationCode);
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            ActivationMessage = result.ErrorMessage ?? "Code introuvable.";
            return;
        }

        Invitation = result.Value;
        PhoneNumber = Invitation.PhoneNumber;
    }

    private async Task ActivateAsync()
    {
        ActivationMessage = null;
        IsBusy = true;
        var result = await Api.ActivateAsync(new ProviderInvitationActivationRequest(
            InvitationCode,
            ActivationPassword,
            ActivationConfirmPassword,
            RememberMe));
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            ActivationMessage = result.ErrorMessage ?? "Activation impossible.";
            return;
        }

        await StoreSessionAsync(result.Value);
        Navigation.NavigateTo("/");
    }

    private async Task LoginAsync()
    {
        LoginMessage = null;
        IsBusy = true;
        var result = await Api.LoginAsync(new ProviderPortalLoginRequest(PhoneNumber, LoginPassword, RememberMe));
        IsBusy = false;

        if (!result.IsSuccess || result.Value is null)
        {
            LoginMessage = result.ErrorMessage ?? "Connexion impossible.";
            return;
        }

        await StoreSessionAsync(result.Value);
        Navigation.NavigateTo("/");
    }

    private async Task RegisterAsync()
    {
        RegisterMessage = null;
        if (RegisterBirthDate is null)
        {
            RegisterMessage = "Renseignez une date de naissance valide.";
            return;
        }

        IsBusy = true;
        var request = new ProviderSelfRegistrationRequest(
            RegisterFirstName,
            RegisterLastName,
            RegisterPhoneNumber,
            DateOnly.FromDateTime(RegisterBirthDate.Value),
            RegisterAddress,
            RegisterGender,
            RegisterYearsOfExperience,
            null,
            null,
            5,
            RegisterPassword,
            RegisterConfirmPassword,
            []);
        var result = await Api.RegisterSelfAsync(request);
        if (!result.IsSuccess)
        {
            IsBusy = false;
            RegisterMessage = result.ErrorMessage ?? "Creation impossible.";
            return;
        }

        var login = await Api.LoginAsync(new ProviderPortalLoginRequest(RegisterPhoneNumber, RegisterPassword, true));
        IsBusy = false;
        if (!login.IsSuccess || login.Value is null)
        {
            RegisterMessage = "Profil cree. Connectez-vous avec votre telephone et mot de passe.";
            return;
        }

        await StoreSessionAsync(login.Value);
        Navigation.NavigateTo("/");
    }

    private async Task StoreSessionAsync(ProviderPortalLoginResponse session)
    {
        await Js.InvokeVoidAsync("localStorage.setItem", "kaza.provider.session", System.Text.Json.JsonSerializer.Serialize(session));
    }
}

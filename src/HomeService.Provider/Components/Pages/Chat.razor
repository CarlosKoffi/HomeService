@page "/chat"

<PageTitle>wélé Prestataire - Chat</PageTitle>

<main class="provider-mobile-shell">
    <section class="screen-heading">
        <span>Chat</span>
        <h1>Messages clients</h1>
        <p>Toutes les conversations liees aux missions en cours et passees.</p>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>En cours</span>
                <h2>Mission live</h2>
            </div>
            <em>Nouveau</em>
        </div>
        <div class="conversation-list">
            <article class="unread">
                <span class="chat-avatar">MA</span>
                <div>
                    <strong>Mme Akissi</strong>
                    <small>Je vous envoie une photo du portail cote pharmacie.</small>
                </div>
                <time>1 min</time>
            </article>
            <article>
                <span class="chat-avatar">CH</span>
                <div>
                    <strong>CI Home Service</strong>
                    <small>Confirmez votre depart quand vous acceptez la mission.</small>
                </div>
                <time>5 min</time>
            </article>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Archives</span>
                <h2>Anciennes missions</h2>
            </div>
        </div>
        <div class="conversation-list">
            <article>
                <span class="chat-avatar">KD</span>
                <div>
                    <strong>M. Kadio</strong>
                    <small>Merci pour la prestation de menage.</small>
                </div>
                <time>Hier</time>
            </article>
        </div>
    </section>
</main>

<ProviderBottomNav Active="chat" />

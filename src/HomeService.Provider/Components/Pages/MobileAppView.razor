@page "/mobileappview"

<PageTitle>Kaza Prestataire - Application mobile</PageTitle>

<main class="provider-site provider-mobile-preview-page">
    <section class="provider-site-hero mobile-preview-hero">
        <div class="provider-site-copy">
            <span class="provider-eyebrow">Application prestataire</span>
            <h1>Une interface mobile pour suivre chaque mission.</h1>
            <p>
                Cette vue presente l'experience que le prestataire utilisera sur son telephone:
                disponibilite, mission a accepter, chat client, services et parametres.
            </p>
            <div class="provider-site-actions">
                <a class="provider-primary-link" href="#download">Telecharger bientot</a>
                <a class="provider-secondary-link" href="/">Retour au site</a>
            </div>
        </div>

        <aside class="phone-preview" aria-label="Apercu application mobile Kaza">
            <div class="phone-shell">
                <div class="phone-status"></div>
                <section class="phone-card phone-status-card">
                    <span>Statut</span>
                    <strong>Disponible</strong>
                    <small>CI Home Service vous voit dans un rayon de 5 km.</small>
                </section>
                <section class="phone-card phone-mission-card">
                    <span>Mission proposee</span>
                    <h2>Menage a domicile</h2>
                    <p>Cocody Angre - Depart demande maintenant.</p>
                    <div>
                        <button>Refuser</button>
                        <button>Accepter</button>
                    </div>
                </section>
                <section class="phone-card phone-feed-card">
                    <span>Fil du jour</span>
                    <p>09:30 - Profil verifie</p>
                    <p>10:15 - Mission envoyee</p>
                    <p>10:17 - En attente de reponse</p>
                </section>
                <nav class="phone-bottom">
                    <span>Accueil</span>
                    <span>Services</span>
                    <span>Chat</span>
                    <span>Profil</span>
                </nav>
            </div>
        </aside>
    </section>

    <section id="download" class="provider-download-note">
        <span>Application mobile</span>
        <h2>Le telechargement sera active au lancement.</h2>
        <p>Les prestataires utiliseront l'application mobile Kaza pour creer leur profil, recevoir les missions et echanger avec les clients.</p>
    </section>
</main>

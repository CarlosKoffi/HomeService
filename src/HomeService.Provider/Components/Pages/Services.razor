@page "/services"

<PageTitle>wélé Prestataire - Services</PageTitle>

<main class="provider-mobile-shell">
    <section class="screen-heading">
        <span>Services</span>
        <h1>Ce que vous pouvez faire</h1>
        <p>Chaque service doit etre complet pour pouvoir recevoir des affectations.</p>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>Actifs</span>
                <h2>Assignables</h2>
            </div>
        </div>
        <div class="service-readiness-list">
            <div class="service-readiness-row">
                <span class="service-icon service-icon-sparkles" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M12 2l1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8L12 2z" /></svg>
                </span>
                <div>
                    <strong>Menage a domicile</strong>
                    <small>Pieces validees - profil complet</small>
                </div>
                <em class="ready">Pret</em>
            </div>
            <div class="service-readiness-row">
                <span class="service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M7 20s-1-3 2-5 8-1 8-8c0-2-2-4-5-4-4 0-7 3-7 7 0 3 2 4 2 4" /><path d="M12 13v8" /></svg>
                </span>
                <div>
                    <strong>Jardinage</strong>
                    <small>Disponible pour rendez-vous</small>
                </div>
                <em class="ready">Pret</em>
            </div>
        </div>
    </section>

    <section class="provider-card">
        <div class="section-title">
            <div>
                <span>A completer</span>
                <h2>Portfolio requis</h2>
            </div>
        </div>
        <div class="service-readiness-row">
            <span class="service-icon service-icon-scissors" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M4 7a3 3 0 1 0 3-3 3 3 0 0 0-3 3z" /><path d="M4 17a3 3 0 1 0 3-3 3 3 0 0 0-3 3z" /><path d="M20 4L8.8 14.8" /><path d="M8.8 9.2L20 20" /></svg>
            </span>
            <div>
                <strong>Coiffure a domicile</strong>
                <small>2/3 photos validees. Ajoutez une realisation.</small>
            </div>
            <em class="blocked">Bloque</em>
        </div>
        <div class="portfolio-strip">
            <span></span>
            <span></span>
            <button type="button">Ajouter</button>
        </div>
    </section>
</main>

<ProviderBottomNav Active="services" />

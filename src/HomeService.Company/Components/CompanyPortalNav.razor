@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<nav class="portal-subnav" aria-label="Navigation espace entreprise">
    <a class="@GetClass("dashboard")" href="@PortalLink("dashboard")">Tableau de bord</a>
    <a class="@GetClass("company-profile")" href="@PortalLink("company-profile")">Informations</a>
    <a class="@GetClass("employees")" href="@PortalLink("employees")">Employes</a>
    <a class="@GetClass("operations")" href="@PortalLink("operations")">Missions</a>
    <a class="@GetClass("accounts")" href="@PortalLink("accounts")">Encaissements</a>
</nav>

@code {
    [Parameter]
    public string Active { get; set; } = "dashboard";

    private string GetClass(string key) => string.Equals(Active, key, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;

    private string PortalLink(string path)
    {
        return Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase)
            ? $"{path}?preview=1"
            : path;
    }
}

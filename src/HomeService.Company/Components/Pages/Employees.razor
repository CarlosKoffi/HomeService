    private static string GetServiceEmoji(string serviceName)
    {
        var normalized = NormalizeSearch(serviceName);
        if (normalized.Contains("MENAGE", StringComparison.OrdinalIgnoreCase) || normalized.Contains("NETTOYAGE", StringComparison.OrdinalIgnoreCase))
        {
            return "🧹";
        }

        if (normalized.Contains("JARDIN", StringComparison.OrdinalIgnoreCase))
        {
            return "🌿";
        }

        if (normalized.Contains("NOUNOU", StringComparison.OrdinalIgnoreCase) || normalized.Contains("ENFANT", StringComparison.OrdinalIgnoreCase))
        {
            return "👶";
        }

        if (normalized.Contains("PLOMB", StringComparison.OrdinalIgnoreCase))
        {
            return "🔧";
        }

        if (normalized.Contains("ELECT", StringComparison.OrdinalIgnoreCase))
        {
            return "⚡";
        }

        if (normalized.Contains("BLANCH", StringComparison.OrdinalIgnoreCase) || normalized.Contains("LINGE", StringComparison.OrdinalIgnoreCase))
        {
            return "👔";
        }

        if (normalized.Contains("AUTO", StringComparison.OrdinalIgnoreCase))
        {
            return "🚗";
        }

        return "✓";
    }


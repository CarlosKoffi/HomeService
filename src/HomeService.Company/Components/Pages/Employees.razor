                            <div class="service-picker employee-skill-picker clean-skill-picker">
                                <div class="skill-picker-heading">
                                    <strong>Services et prestations</strong>
                                    <p>Ajoutez un service puis, si besoin, les prestations que ce prestataire peut assurer.</p>
                                </div>
                                <div class="service-editor-toolbar figma-service-toolbar clean-service-toolbar">
                                    <label>

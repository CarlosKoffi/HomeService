@page "/employees"
@layout HomeService.Company.Components.Layout.EmptyLayout
@using System.Globalization
@using System.Text
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Employes</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de votre espace entreprise.</p>
    </section>
}
else if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous avec le compte entreprise active pour gerer vos employes.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="employees"
                        Title="Employes"
                        Subtitle="Equipe et prestataires"
                        CompanyId="@Session.CompanyId"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(Session.IsCompanyApproved ? 75 : 35)">

    <section class="employee-workspace">
        <div class="employee-hero-panel">
            <div class="employee-hero-copy">
                <span>Effectif</span>
                <strong>@EmployeeRows.Count employe(s) suivi(s)</strong>
                <p>Controlez disponibilite, services, zones et pieces de vos prestataires.</p>
            </div>
            <div class="employee-hero-stats">
                <button type="button" class="@GetFilterButtonClass("Disponible")" @onclick="@(() => SetEmployeeFilter("Disponible"))">
                    <strong>@AvailableEmployees.Count</strong>
                    <span>Disponibles</span>
                </button>
                <button type="button" class="@GetFilterButtonClass("En mission")" @onclick="@(() => SetEmployeeFilter("En mission"))">
                    <strong class="blue">@LiveEmployees.Count</strong>
                    <span>En mission</span>
                </button>
                <button type="button" class="@GetFilterButtonClass("Non actif")" @onclick="@(() => SetEmployeeFilter("Non actif"))">
                    <strong>@InactiveEmployees.Count</strong>
                    <span>A activer</span>
                </button>
            </div>
        </div>

        <div class="employee-toolbar">
            <label class="employee-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input @bind="EmployeeSearch" @bind:event="oninput" placeholder="Rechercher un employe, service ou zone..." />
            </label>
            <div class="employee-filter-tabs" role="tablist" aria-label="Filtres employes">
                @foreach (var filter in EmployeeFilters)
                {
                    <button type="button" class="@GetFilterTabClass(filter)" @onclick="@(() => SetEmployeeFilter(filter))">@filter</button>
                }
            </div>
            <button type="button" class="employee-add-button" @onclick="ToggleForm">
                <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                @(ShowForm ? "Fermer" : "Ajouter un employe")
            </button>
        </div>
    </section>

    @if (ShowForm)
    {
        <div class="modal-backdrop employee-upsert-backdrop" @onclick="ToggleForm">
            <section class="employee-upsert-modal" @onclick:stopPropagation>
                <EditForm Model="Form" OnSubmit="CreateEmployeeAsync" class="employee-upsert-form employee-form-modern">
                    <header class="employee-upsert-header">
                        <div class="employee-upsert-title">
                            <span class="employee-upsert-icon">
                                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </span>
                            <span>
                                <strong>@T("company.employees.form.title", "Ajouter un employe")</strong>
                                <small>@T("company.employees.form.description", "Renseignez les informations du prestataire.")</small>
                            </span>
                        </div>
                        <button type="button" class="employee-upsert-close" @onclick="ToggleForm" aria-label="Fermer">
                            <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </header>

                    <div class="employee-upsert-body">
                        <article class="employee-profile-card identity-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon violet">
                                        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </span>
                                    <strong>Identite civile</strong>
                                </div>
                                <div class="employee-type-toggle">
                                    <button type="button" class="@(Form.EmploymentType == "CompanyEmployee" ? "active" : string.Empty)" @onclick="@(() => SetFormEmploymentType("CompanyEmployee"))">Employe</button>
                                    <button type="button" class="@(Form.EmploymentType == "TemporaryWorker" ? "active interim" : string.Empty)" @onclick="@(() => SetFormEmploymentType("TemporaryWorker"))">Interimaire</button>
                                </div>
                            </div>

                            <div class="employee-identity-layout">
                                <div class="form-grid upsert-grid">
                <label>
                    Prenom
                    <InputText @bind-Value="Form.FirstName" placeholder="Awa" />
                </label>
                <label>
                    Nom
                    <InputText @bind-Value="Form.LastName" placeholder="Kone" />
                </label>
                <label>
                    Date de naissance
                    <InputDate @bind-Value="BirthDate" />
                </label>
                                    <div class="@GetAgeBadgeClass(BirthDate)">
                                        <span>Age</span>
                                        <strong>@GetAgeText(BirthDate)</strong>
                                    </div>
                                </div>
                                <label class="@($"employee-photo-drop {(Form.Photo is not null ? "ready" : string.Empty)}")">
                                    <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                                    <span>@DisplayFileName(PhotoFileName, "Photo du prestataire")</span>
                                    <InputFile OnChange="OnPhotoSelected" accept=".jpg,.jpeg,.png,.webp" />
                                </label>
                            </div>
                        </article>

                        <article class="employee-profile-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon blue">
                                        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    </span>
                                    <strong>Contact</strong>
                                </div>
                            </div>

                            <div class="form-grid contact-grid">
                                <label class="wide-field">
                                    Zone d'intervention
                                    <InputText @bind-Value="Form.Address" placeholder="Cocody, Abidjan" />
                                </label>
                <label class="wide-field">
                                    Telephone
                                    <InputText @bind-Value="Form.PhoneNumber" placeholder="+225 07 00 00 00 00" />
                                </label>
                                <label class="wide-field">
                                    Email
                                    <InputText @bind-Value="Form.Email" placeholder="awa@exemple.com" />
                                </label>
                            </div>
                        </article>

                        <article class="employee-profile-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon green">
                                        <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    </span>
                                    <strong>Profil metier</strong>
                                </div>
                            </div>

                            <div class="form-grid compact-upsert-grid">
                                <label>
                                    Sexe
                                    <InputSelect @bind-Value="Form.Gender">
                                        <option value="Unspecified">Non renseigne</option>
                                        <option value="Female">Femme</option>
                                        <option value="Male">Homme</option>
                                    </InputSelect>
                                </label>
                                <label>
                                    Experience
                                    <InputNumber @bind-Value="Form.YearsOfExperience" />
                                </label>
                                <label>
                                    Perimetre km
                                    <InputNumber @bind-Value="Form.MissionRadiusKm" />
                                </label>
                <label>
                    Niveau
                    <InputSelect @bind-Value="Form.ExperienceLevel">
                        <option value="Junior">Junior</option>
                        <option value="Confirmed">Confirme</option>
                        <option value="Senior">Senior</option>
                        <option value="Expert">Expert</option>
                    </InputSelect>
                </label>
                <label>
                    Latitude mission
                    <InputNumber @bind-Value="Form.MissionLatitude" />
                </label>
                <label>
                    Longitude mission
                    <InputNumber @bind-Value="Form.MissionLongitude" />
                </label>
            </div>

            <div class="service-picker employee-skill-picker">
                <strong>@T("company.employees.services.title", "Services maitrises")</strong>
                <p>@T("company.employees.services.description", "Selectionnez les services puis les prestations que ce prestataire peut realiser. Les prix affiches sont les fourchettes plateforme.")</p>
                <div class="service-tile-grid">
                    @foreach (var service in Services)
                    {
                        var selection = Form.Services.FirstOrDefault(item => item.ServiceId == service.Id);
                        var activePrestations = GetActivePrestations(service.Id);
                        <article class="@($"service-check {(selection is not null ? "selected expanded" : string.Empty)}")">
                            <label class="service-check-toggle">
                                <input type="checkbox" checked="@(selection is not null)" @onchange="eventArgs => ToggleService(service.Id, eventArgs)" />
                                <span class="service-check-emoji">@GetServiceEmoji(service.Name)</span>
                                <span class="service-check-main">
                                    <strong>@service.Name</strong>
                                    <small>@FormatPriceRange(service.PriceMinAmount ?? service.NormalPriceAmount, service.PriceMaxAmount ?? service.PremiumPriceAmount, service.Currency)</small>
                                </span>
                                <span class="service-check-box">
                                    @if (selection is not null)
                                    {
                                        <svg viewBox="0 0 12 12"><path d="M2 6l3 3 5-5"/></svg>
                                    }
                                </span>
                            </label>

                            @if (selection is not null)
                            {
                                <div class="service-check-details figma-service-details">
                                    <label>
                                        Niveau
                                        <select @bind="selection.ExperienceLevel">
                                            <option value="Junior">Junior</option>
                                            <option value="Confirmed">Confirme</option>
                                            <option value="Senior">Senior</option>
                                            <option value="Expert">Expert</option>
                                        </select>
                                    </label>
                                    <label>
                                        Experience
                                        <InputNumber @bind-Value="selection.YearsOfExperience" />
                                    </label>
                                    <label class="service-premium-toggle">
                                        <input type="checkbox"
                                               checked="@(selection.PriceTier == "Premium")"
                                               @onchange="eventArgs => ToggleFormPremium(selection, eventArgs)" />
                                        <span>Profil premium</span>
                                    </label>
                                </div>

                                @if (activePrestations.Count > 0)
                                {
                                    <div class="service-prestation-picker figma-prestation-picker">
                                        <label>
                                            Prestations
                                            <input list="@GetPrestationDatalistId("form", selection.ServiceId)"
                                                   @bind="selection.PrestationSearchTerm"
                                                   @bind:event="oninput"
                                                   placeholder="Rechercher une prestation" />
                                        </label>
                                        <datalist id="@GetPrestationDatalistId("form", selection.ServiceId)">
                                            @foreach (var prestation in activePrestations)
                                            {
                                                <option value="@prestation.Name">@FormatPriceRange(prestation.PriceMinAmount ?? prestation.NormalPriceAmount, prestation.PriceMaxAmount ?? prestation.PremiumPriceAmount, prestation.Currency)</option>
                                            }
                                        </datalist>
                                        <button type="button" @onclick="() => AddFormPrestation(selection)">Ajouter</button>
                                        @if (selection.ServicePrestationIds.Count > 0)
                                        {
                                            <div class="selected-prestation-list">
                                                @foreach (var prestation in GetSelectedPrestations(selection.ServiceId, selection.ServicePrestationIds))
                                                {
                                                    <span>
                                                        @prestation.Name
                                                        <button type="button" @onclick="() => RemoveFormPrestation(selection, prestation.Id)" aria-label="Retirer la prestation">x</button>
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </article>
                    }
                </div>
            </div>
                        </article>

                        <article class="employee-profile-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon amber">
                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                                    </span>
                                    <strong>Documents</strong>
                                </div>
                            </div>
            <div class="employee-upload-grid">
                <label class="upload-mini required">
                    <strong>@T("company.employees.upload.identity", "Piece d'identite")</strong>
                    <small>@DisplayFileName(IdentityFileName, "PDF, JPG ou PNG")</small>
                    <em>@T("company.employees.upload.choose", "Selectionner")</em>
                    <InputFile OnChange="OnIdentitySelected" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                </label>
                <label class="upload-mini optional">
                    <strong>@T("company.employees.upload.diploma", "Diplome ou certificat")</strong>
                    <small>@DisplayFileName(DiplomaFileName, "Optionnel")</small>
                    <em>@T("company.employees.upload.choose", "Selectionner")</em>
                    <InputFile OnChange="OnDiplomaSelected" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                </label>
            </div>
                        </article>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <p class="field-message">@Message</p>
            }
                    </div>

                    <footer class="employee-upsert-footer">
                        <button type="button" class="secondary-action" @onclick="ToggleForm">Annuler</button>
                        <button type="submit" class="primary-action" disabled="@IsSaving">
                            @(IsSaving ? "Enregistrement..." : "Enregistrer l'employe")
                        </button>
                    </footer>
                </EditForm>
            </section>
        </div>
    }

    @if (LiveEmployees.Count > 0)
    {
        <section class="employee-live-card">
            <header>
                <span class="employee-live-dot"></span>
                <strong>En mission maintenant</strong>
                <em>@LiveEmployees.Count</em>
            </header>
            <div class="employee-live-grid">
                @foreach (var employee in LiveEmployees.Take(3))
                {
                    <button type="button" class="employee-live-item" @onclick="() => SelectEmployee(employee)">
                        <span class="@GetEmployeeAvatarClass(employee)">@GetInitials(employee)</span>
                        <span>
                            <strong>@employee.FirstName @employee.LastName</strong>
                            <small>@GetCurrentMissionTitle(employee)</small>
                            <em>@GetCurrentMissionLocation(employee)</em>
                        </span>
                    </button>
                }
            </div>
        </section>
    }

    <section class="employee-modern-table">
        <div class="employee-table-head">
            <button type="button" @onclick="@(() => ToggleEmployeeSort("name"))">Employe @GetSortMarker("name")</button>
            <span>Services</span>
            <button type="button" @onclick="@(() => ToggleEmployeeSort("experience"))">Experience @GetSortMarker("experience")</button>
            <span>Zone</span>
            <button type="button" @onclick="@(() => ToggleEmployeeSort("status"))">Statut @GetSortMarker("status")</button>
            <span></span>
        </div>
        @if (VisibleEmployees.Count == 0)
        {
            <div class="employee-empty-line">
                <strong>Aucun employe trouve</strong>
                <span>Changez le filtre ou ajoutez votre premier prestataire.</span>
            </div>
        }
        else
        {
            @foreach (var employee in VisibleEmployees)
            {
                <article class="@GetEmployeeRowClass(employee)" @onclick="() => SelectEmployee(employee)">
                    <div class="employee-person-cell">
                        <span class="@GetEmployeeAvatarClass(employee)">@GetInitials(employee)</span>
                        <div>
                            <strong>@employee.FirstName @employee.LastName</strong>
                            <a href="tel:@employee.PhoneNumber" @onclick:stopPropagation>@employee.PhoneNumber</a>
                            @if (!string.IsNullOrWhiteSpace(employee.Email))
                            {
                                <a href="mailto:@employee.Email" @onclick:stopPropagation>@employee.Email</a>
                            }
                            <small>@GetGenderLabel(employee.Gender) - @GetEmploymentTypeLabel(employee.EmploymentType)</small>
                        </div>
                    </div>
                    <div class="employee-service-tags">
                        @foreach (var service in employee.Services.Take(3))
                        {
                            <span>@service.ServiceName</span>
                        }
                        @if (employee.Services.Count > 3)
                        {
                            <span>+@(employee.Services.Count - 3)</span>
                        }
                    </div>
                    <div class="employee-experience-cell">
                        <strong>@employee.YearsOfExperience an(s)</strong>
                        <span class="@GetLevelClass(employee)">@GetExperienceLevelText(employee)</span>
                        <small>@GetServicePriceText(employee)</small>
                    </div>
                    <div class="employee-zone-cell">
                        <svg viewBox="0 0 24 24"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                        <span>@Display(employee.Address)</span>
                    </div>
                    <div class="employee-status-cell">
                        <span class="@GetEmployeeStatusBadgeClass(employee)">@GetEmployeeOperationalStatus(employee)</span>
                        <small class="@GetEmployeeLifecycleClass(employee)">@GetEmployeeLifecycleStatus(employee)</small>
                        <small>@GetDocumentsText(employee)</small>
                    </div>
                    <div class="employee-row-menu" @onclick:stopPropagation>
                        <button type="button"
                                class="employee-menu-trigger"
                                title="Actions"
                                aria-label="Actions employe"
                                @onclick="() => ToggleEmployeeActionMenu(employee.Id)">
                            <span></span>
                            <span></span>
                            <span></span>
                        </button>
                        @if (OpenEmployeeActionMenuId == employee.Id)
                        {
                            <div class="employee-action-menu">
                                <button type="button" @onclick="() => OpenEmployeeProfile(employee)">
                                    <svg viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                                    Voir le profil
                                </button>
                                @if (CanChangeAvailability(employee))
                                {
                                    <button type="button" @onclick="() => ToggleEmployeeAvailabilityAsync(employee)">
                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/></svg>
                                        @(employee.IsAvailable ? "Marquer indisponible" : "Marquer disponible")
                                    </button>
                                }
                                @if (CanSuspendEmployee(employee))
                                {
                                    <button type="button" @onclick="() => SuspendEmployeeAsync(employee.Id)">
                                        <svg viewBox="0 0 24 24"><path d="M12 3v6"/><path d="M8 7 4 11v5l4 4h8l4-4v-5l-4-4Z"/></svg>
                                        Suspendre
                                    </button>
                                }
                                <button type="button" class="danger" @onclick="() => DeleteEmployeeAsync(employee.Id)">
                                    <svg viewBox="0 0 24 24"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M6 7l1 14h10l1-14"/><path d="M9 7V4h6v3"/></svg>
                                    Supprimer
                                </button>
                            </div>
                        }
                    </div>
                </article>
            }
        }
        <footer>
            <span>@VisibleEmployees.Count resultat(s) affiche(s) sur @EmployeeRows.Count</span>
            <button type="button" @onclick="@(() => SetEmployeeFilter("Tous"))">Reinitialiser</button>
        </footer>
    </section>

    @if (SelectedEmployee is not null)
    {
        <div class="modal-backdrop employee-upsert-backdrop" @onclick="ClearSelectedEmployee">
            <section class="employee-upsert-modal employee-profile-modal" @onclick:stopPropagation>
                <EditForm Model="EditModel" OnSubmit="SaveEmployeeEditAsync" class="employee-upsert-form employee-form-modern">
                    <header class="employee-upsert-header">
                        <div class="employee-upsert-title">
                            <span class="employee-upsert-icon">
                                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </span>
                            <span>
                                <strong>@SelectedEmployee.FirstName @SelectedEmployee.LastName</strong>
                                <small>Profil prestataire modifiable</small>
                            </span>
                        </div>
                        <button type="button" class="employee-upsert-close" @onclick="ClearSelectedEmployee" aria-label="Fermer">
                            <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </header>

                    <div class="employee-upsert-body">
                        <article class="employee-profile-card identity-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon violet">
                                        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </span>
                                    <strong>Identite civile</strong>
                                </div>
                                <div class="employee-type-toggle">
                                    <button type="button" class="@(EditModel.EmploymentType == "CompanyEmployee" ? "active" : string.Empty)" @onclick="@(() => SetEditEmploymentType("CompanyEmployee"))">Employe</button>
                                    <button type="button" class="@(EditModel.EmploymentType == "TemporaryWorker" ? "active interim" : string.Empty)" @onclick="@(() => SetEditEmploymentType("TemporaryWorker"))">Interimaire</button>
                                </div>
                            </div>

                            <div class="employee-identity-layout">
                                <div class="form-grid upsert-grid">
                                    <label>
                                        Prenom
                                        <InputText @bind-Value="EditModel.FirstName" placeholder="Awa" />
                                    </label>
                                    <label>
                                        Nom
                                        <InputText @bind-Value="EditModel.LastName" placeholder="Kone" />
                                    </label>
                                    <label>
                                        Date de naissance
                                        <InputDate @bind-Value="EditBirthDate" />
                                    </label>
                                    <div class="@GetAgeBadgeClass(EditBirthDate)">
                                        <span>Age</span>
                                        <strong>@GetAgeText(EditBirthDate)</strong>
                                    </div>
                                </div>
                                <label class="@($"employee-photo-drop {(HasEmployeePhoto(SelectedEmployee) ? "ready" : string.Empty)}")">
                                    <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                                    <span>@(HasEmployeePhoto(SelectedEmployee) ? "Remplacer la photo" : "Photo du prestataire")</span>
                                    <InputFile OnChange='eventArgs => UploadEmployeeDocumentAsync("Photo", eventArgs)' accept=".jpg,.jpeg,.png,.webp" />
                                </label>
                            </div>
                        </article>

                        <article class="employee-profile-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon blue">
                                        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    </span>
                                    <strong>Contact</strong>
                                </div>
                            </div>

                            <div class="form-grid contact-grid">

                                    </InputSelect>
                                </label>
                                <label>
                                    Latitude mission
                                    <InputNumber @bind-Value="EditModel.MissionLatitude" />
                                </label>
                                <label>
                                    Longitude mission
                                    <InputNumber @bind-Value="EditModel.MissionLongitude" />

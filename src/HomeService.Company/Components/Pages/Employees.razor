                                @if (EditableServices.Count == 0)
                                {
                                    <p class="skill-empty-state">Aucun service rattache. Ajoutez au moins un service avant de rendre le profil exploitable.</p>
                                }
                                else
                                {
                                    <div class="service-edit-list clean-service-list">
                                        @foreach (var service in EditableServices)
                                        {
                                            var activePrestations = GetActivePrestations(service.ServiceId);
                                            var hasPrestations = activePrestations.Count > 0;
                                            <div class="employee-service-card-simple">
                                                <div class="employee-service-card-title">
                                                    <span class="service-check-emoji">@GetServiceEmoji(service.ServiceName)</span>
                                                    <div>
                                                        <strong>@service.ServiceName</strong>
                                                        <small>@(hasPrestations ? "Choisissez les prestations maitrisees." : "Tarif applique au service.")</small>
                                                    </div>
                                                </div>

                                                <div class="employee-service-line">
                                                    <label class="employee-service-field wide">
                                                        <span>Prestation</span>
                                                        @if (hasPrestations)
                                                        {
                                                            <select @bind="service.PrestationSearchTerm">
                                                                <option value="">Choisir une prestation</option>
                                                                @foreach (var prestation in activePrestations)
                                                                {
                                                                    <option value="@prestation.Name">@prestation.Name</option>
                                                                }
                                                            </select>

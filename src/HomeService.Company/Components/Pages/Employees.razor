                                                        else
                                                        {
                                                            <select disabled>
                                                                <option>Aucune prestation</option>
                                                            </select>
                                                        }
                                                    </label>

                                                    <label class="employee-service-field">
                                                        <span>Niveau</span>
                                                        <select @bind="service.ExperienceLevel">
                                                            <option value="Junior">Junior</option>
                                                            <option value="Confirmed">Confirme</option>
                                                            <option value="Senior">Senior</option>
                                                            <option value="Expert">Expert</option>
                                                        </select>
                                                    </label>

                                                    <label class="employee-service-field compact">
                                                        <span>Experience</span>
                                                        <InputNumber @bind-Value="service.YearsOfExperience" />
                                                    </label>

                                                    <label class="employee-premium-inline">
                                                        <input type="checkbox"
                                                               checked="@(service.PriceTier == "Premium")"
                                                               @onchange="eventArgs => TogglePremium(service, eventArgs)" />
                                                        <span>Premium</span>
                                                    </label>

                                                    <div class="employee-price-inline">
                                                        <span>Min</span>
                                                        <strong>@GetEffectiveMinPrice(service).ToString("N0") @GetEffectiveCurrency(service)</strong>
                                                    </div>

                                                    <div class="employee-price-inline">
                                                        <span>Max</span>
                                                        <strong>@GetEffectiveMaxPrice(service).ToString("N0") @GetEffectiveCurrency(service)</strong>
                                                    </div>
                                                </div>

                                                <div class="employee-service-actions-row">
                                                    @if (hasPrestations)
                                                    {
                                                        <button type="button"
                                                                class="add-prestation-action"
                                                                disabled="@string.IsNullOrWhiteSpace(service.PrestationSearchTerm)"
                                                                @onclick="() => AddEditablePrestationAsync(service)">
                                                            Ajouter prestation
                                                        </button>
                                                    }

                                                    @if (service.ServicePrestationIds.Count > 0)
                                                    {
                                                        <div class="selected-prestation-list">
                                                            @foreach (var prestation in GetSelectedPrestations(service.ServiceId, service.ServicePrestationIds))
                                                            {
                                                                <span>
                                                                    @prestation.Name
                                                                    <button type="button" @onclick="() => RemoveEditablePrestation(service, prestation.Id)" aria-label="Retirer la prestation">x</button>
                                                                </span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </article>

                        <article class="employee-profile-card">
                            <div class="employee-card-title-row">
                                <div>
                                    <span class="employee-section-icon amber">
                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                                    </span>
                                    <strong>Documents</strong>
                                </div>
                            </div>

                            <div class="document-manager">
                                @foreach (var slot in GetDocumentSlots(SelectedEmployee))
                                {
                                    <article class="@($"document-slot {slot.StatusClass}")">
                                        @if (!string.IsNullOrWhiteSpace(slot.PreviewUrl))
                                        {
                                            <div class="document-preview">
                                                @if (slot.IsImagePreview)
                                                {
                                                    <img src="@ToPreviewUrl(slot.PreviewUrl)" alt="@slot.Label" />
                                                }
                                                else
                                                {
                                                    <div class="document-preview-file">
                                                        <span>@GetDocumentPreviewCode(slot)</span>
                                                        <strong>Apercu disponible</strong>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="document-slot-info">
                                            <span>@slot.ShortCode</span>
                                            <strong>@slot.Label</strong>
                                            <small>@slot.FileName</small>
                                        </div>
                                        <div class="document-actions">
                                            @if (!string.IsNullOrWhiteSpace(slot.PreviewUrl))
                                            {
                                                <a href="@ApiClient.ToApiUrl(slot.PreviewUrl)" target="_blank">Ouvrir</a>
                                                <button type="button" class="danger-action" @onclick="() => DeleteEmployeeDocumentAsync(slot.DocumentId!.Value)">Supprimer</button>
                                            }
                                            <label class="replace-document">
                                                @(slot.DocumentId is null ? "Ajouter" : "Remplacer")
                                                <InputFile OnChange="eventArgs => UploadEmployeeDocumentAsync(slot.DocumentType, eventArgs)" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                                            </label>
                                        </div>
                                    </article>
                                }
                            </div>
                        </article>

                        <article class="employee-profile-card employee-access-card">
                            <div>
                                <span>Validation prestataire</span>
                                <strong>@GetEmployeeValidationTitle(SelectedEmployee)</strong>
                                <p>@GetEmployeeValidationText(SelectedEmployee)</p>
                            </div>
                        </article>

                        <article class="employee-profile-card employee-access-card">
                            <div>
                                <span>Acces application</span>
                                @if (!string.IsNullOrWhiteSpace(SelectedEmployee.InvitationCode))
                                {
                                    <strong>@SelectedEmployee.InvitationCode</strong>
                                    <p>Code a envoyer par SMS ou WhatsApp. Valable jusqu'au @SelectedEmployee.InvitationExpiresAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm").</p>
                                    @if (!string.IsNullOrWhiteSpace(SelectedEmployee.InvitationLink))
                                    {
                                        <a href="@SelectedEmployee.InvitationLink" target="_blank">Ouvrir le lien d'activation</a>
                                    }
                                }
                                else
                                {
                                    <strong>Compte active ou code expire</strong>
                                    <p>Generez un nouveau code si le prestataire doit recuperer son acces.</p>
                                }
                            </div>
                            <button type="button" class="secondary-action compact-action" @onclick="GenerateInvitationCodeAsync">Generer un nouveau code</button>
                        </article>

                        @if (!string.IsNullOrWhiteSpace(Message))
                        {
                            <p class="field-message">@Message</p>
                        }
                    </div>

                    <footer class="employee-upsert-footer">
                        <button type="button" class="secondary-action" @onclick="ClearSelectedEmployee">Annuler</button>
                        @if (CanApproveEmployee(SelectedEmployee))
                        {
                            <button type="button" class="secondary-action employee-footer-validation" disabled="@IsSaving" @onclick="() => ApproveEmployeeAsync(SelectedEmployee.Id)">
                                Valider pour mission
                            </button>
                        }
                        else if (CanSuspendEmployee(SelectedEmployee))
                        {
                            <button type="button" class="secondary-action danger-outline employee-footer-validation" disabled="@IsSaving" @onclick="() => SuspendEmployeeAsync(SelectedEmployee.Id)">
                                Suspendre
                            </button>
                        }
                        <button type="submit" class="primary-action" disabled="@IsSaving">
                            @(IsSaving ? "Enregistrement..." : "Enregistrer les modifications")
                        </button>
                    </footer>
                </EditForm>
            </section>
        </div>
    }
    </CompanyPortalShell>
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyEmployeeResponse> EmployeeRows { get; set; } = [];
    private IReadOnlyList<ServiceSummaryResponse> Services { get; set; } = [];
    private CompanyEmployeeFormModel Form { get; set; } = new();
    private DateTime? BirthDate { get; set; }
    private bool ShowForm { get; set; }
    private bool IsSaving { get; set; }
    private string? Message { get; set; }
    private string? PhotoFileName { get; set; }
    private string? IdentityFileName { get; set; }
    private string? DiplomaFileName { get; set; }
    private CompanyEmployeeResponse? SelectedEmployee { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private CompanyEmployeeEditModel EditModel { get; set; } = new();
    private DateTime? EditBirthDate { get; set; }
    private List<CompanyEmployeeServiceEditModel> EditableServices { get; set; } = [];
    private string? ServiceToAddId { get; set; }
    private IReadOnlyDictionary<string, string> Texts { get; set; } = new Dictionary<string, string>();
    private string EmployeeSearch { get; set; } = string.Empty;
    private string ActiveEmployeeFilter { get; set; } = "Tous";
    private string? EmployeeSortKey { get; set; } = "name";
    private bool EmployeeSortAscending { get; set; } = true;
    private Guid? OpenEmployeeActionMenuId { get; set; }
    private static readonly IReadOnlyList<string> EmployeeFilters = ["Tous", "Disponible", "En mission", "Hors ligne", "Non actif"];

    private IReadOnlyList<CompanyEmployeeResponse> AvailableEmployees => EmployeeRows
        .Where(employee => GetEmployeeOperationalStatus(employee) == "Disponible")
        .ToList();

    private IReadOnlyList<CompanyEmployeeResponse> LiveEmployees => EmployeeRows
        .Where(employee => GetEmployeeOperationalStatus(employee) == "En mission")
        .ToList();

    private IReadOnlyList<CompanyEmployeeResponse> InactiveEmployees => EmployeeRows
        .Where(employee => GetEmployeeOperationalStatus(employee) == "Non actif")
        .ToList();

    private IReadOnlyList<CompanyEmployeeResponse> VisibleEmployees
    {
        get
        {
            IEnumerable<CompanyEmployeeResponse> query = EmployeeRows;
            if (ActiveEmployeeFilter != "Tous")
            {
                query = query.Where(employee => GetEmployeeOperationalStatus(employee) == ActiveEmployeeFilter);
            }

            if (!string.IsNullOrWhiteSpace(EmployeeSearch))
            {
                var search = EmployeeSearch.Trim();
                query = query.Where(employee =>
                    $"{employee.FirstName} {employee.LastName}".Contains(search, StringComparison.OrdinalIgnoreCase)
                    || employee.PhoneNumber.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || (!string.IsNullOrWhiteSpace(employee.Email) && employee.Email.Contains(search, StringComparison.OrdinalIgnoreCase))
                    || (employee.Address?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)
                    || employee.Services.Any(service => service.ServiceName.Contains(search, StringComparison.OrdinalIgnoreCase)));
            }

            query = EmployeeSortKey switch
            {
                "experience" => EmployeeSortAscending
                    ? query.OrderBy(employee => employee.YearsOfExperience)
                    : query.OrderByDescending(employee => employee.YearsOfExperience),
                "status" => EmployeeSortAscending
                    ? query.OrderBy(GetEmployeeOperationalStatus)
                    : query.OrderByDescending(GetEmployeeOperationalStatus),
                _ => EmployeeSortAscending
                    ? query.OrderBy(employee => employee.LastName).ThenBy(employee => employee.FirstName)
                    : query.OrderByDescending(employee => employee.LastName).ThenByDescending(employee => employee.FirstName)
            };

            return query.ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            LoadPreviewData();
            ShowForm = Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("form=1", StringComparison.OrdinalIgnoreCase);
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadAsync();
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        if (IsPreviewMode())
        {
            LoadPreviewData();
            return;
        }

        await LoadTextsAsync();
        Services = await ApiClient.GetServicesAsync();
        if (Session is not null)
        {
            EmployeeRows = await ApiClient.GetCompanyEmployeesAsync(Session.CompanyId);
        }
    }

    private void ToggleForm()
    {
        ShowForm = !ShowForm;
        Message = null;
    }

    private void SetFormEmploymentType(string employmentType)
    {
        Form.EmploymentType = employmentType;
    }

    private void SetEditEmploymentType(string employmentType)
    {
        EditModel.EmploymentType = employmentType;
    }

    private void SetEmployeeFilter(string filter)
    {
        ActiveEmployeeFilter = filter;
    }

    private void ToggleEmployeeSort(string sortKey)
    {
        if (EmployeeSortKey == sortKey)
        {
            EmployeeSortAscending = !EmployeeSortAscending;
            return;
        }

        EmployeeSortKey = sortKey;
        EmployeeSortAscending = true;
    }

    private string GetSortMarker(string sortKey)
    {
        return EmployeeSortKey == sortKey
            ? (EmployeeSortAscending ? "↑" : "↓")
            : string.Empty;
    }

    private string GetFilterTabClass(string filter)
    {
        return ActiveEmployeeFilter == filter ? "active" : string.Empty;
    }

    private string GetFilterButtonClass(string filter)
    {
        return ActiveEmployeeFilter == filter ? "active" : string.Empty;
    }

    private void SelectEmployee(CompanyEmployeeResponse employee)
    {
        OpenEmployeeActionMenuId = null;
        SelectedEmployee = employee;
        EditModel = new CompanyEmployeeEditModel
        {
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            PhoneNumber = employee.PhoneNumber,
            Email = employee.Email,
            Address = employee.Address ?? string.Empty,
            Gender = employee.Gender,
            EmploymentType = employee.EmploymentType,
            YearsOfExperience = employee.YearsOfExperience,
            MissionLatitude = employee.CurrentLatitude,
            MissionLongitude = employee.CurrentLongitude,
            ExperienceLevel = employee.Services.FirstOrDefault()?.ExperienceLevel ?? "Confirmed",
            MissionRadiusKm = (int)(employee.ServiceRadiusKm ?? 5)
        };
        EditableServices = employee.Services
            .Where(service => service.IsActive)
            .Select(service => new CompanyEmployeeServiceEditModel
            {
                ServiceId = service.ServiceId,
                ServiceName = service.ServiceName,
                ExperienceLevel = service.ExperienceLevel,
                YearsOfExperience = service.YearsOfExperience,
                PriceTier = service.PriceTier,
                NormalPriceAmount = service.NormalPriceAmount,
                PremiumPriceAmount = service.PremiumPriceAmount,
                PriceMinAmount = service.PriceMinAmount ?? service.NormalPriceAmount,
                PriceMaxAmount = service.PriceMaxAmount ?? service.PremiumPriceAmount,
                Currency = service.Currency,
                ServicePrestationIds = service.Prestations
                    .Where(prestation => prestation.IsActive)
                    .Select(prestation => prestation.ServicePrestationId)
                    .ToList()
            })
            .ToList();
        ServiceToAddId = null;
        EditBirthDate = employee.BirthDate?.ToDateTime(TimeOnly.MinValue);
    }

    private void ClearSelectedEmployee()
    {
        SelectedEmployee = null;
        EditableServices = [];
        ServiceToAddId = null;
    }

    private void ToggleEmployeeActionMenu(Guid employeeId)
    {
        OpenEmployeeActionMenuId = OpenEmployeeActionMenuId == employeeId ? null : employeeId;
    }

    private void OpenEmployeeProfile(CompanyEmployeeResponse employee)
    {
        OpenEmployeeActionMenuId = null;
        SelectEmployee(employee);
    }

    private async Task SaveEmployeeEditAsync()
    {
        if (SelectedEmployee is null || Session is null || EditBirthDate is null)
        {
            return;
        }

        var updated = SelectedEmployee with
        {
            FirstName = EditModel.FirstName,
            LastName = EditModel.LastName,
            PhoneNumber = EditModel.PhoneNumber,
            Email = EditModel.Email,
            Address = EditModel.Address,
            Gender = EditModel.Gender,
            EmploymentType = EditModel.EmploymentType,
            ReceivesDirectRequests = EditModel.EmploymentType == "TemporaryWorker",
            YearsOfExperience = EditModel.YearsOfExperience,
            CurrentLatitude = EditModel.MissionLatitude,
            CurrentLongitude = EditModel.MissionLongitude,
            ServiceRadiusKm = EditModel.MissionRadiusKm,
            BirthDate = DateOnly.FromDateTime(EditBirthDate.Value),
            Services = EditableServices
                .Select(service => new CompanyEmployeeServiceResponse(
                    service.ServiceId,
                    service.ServiceName,
                    service.ExperienceLevel,
                    service.YearsOfExperience,
                    service.PriceTier,
                    service.NormalPriceAmount,
                    service.PremiumPriceAmount,
                    service.Currency,
                    true,
                    GetSelectedPrestations(service.ServiceId, service.ServicePrestationIds)
                        .Select(prestation => new CompanyEmployeeServicePrestationResponse(
                            prestation.Id,
                            prestation.Name,
                            prestation.NormalPriceAmount,
                            prestation.PremiumPriceAmount,
                            prestation.Currency,
                            true,
                            prestation.PriceMinAmount ?? prestation.NormalPriceAmount,
                            prestation.PriceMaxAmount ?? prestation.PremiumPriceAmount))
                        .ToList(),
                    service.PriceMinAmount,
                    service.PriceMaxAmount))
                .ToList()
        };

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(employee => employee.Id == updated.Id ? updated : employee).ToList();
            SelectedEmployee = updated;
            return;
        }

        var profileResult = await ApiClient.UpdateCompanyEmployeeAsync(
            Session.CompanyId,
            SelectedEmployee.Id,
            new UpdateCompanyEmployeeRequest(
                EditModel.FirstName,
                EditModel.LastName,
                EditModel.PhoneNumber,
                EditModel.Email,
                DateOnly.FromDateTime(EditBirthDate.Value),
                EditModel.Address,
                EditModel.Gender,
                EditModel.EmploymentType,
                EditModel.YearsOfExperience,
                EditModel.MissionLatitude,
                EditModel.MissionLongitude,
                EditModel.MissionRadiusKm));

        if (!profileResult.IsSuccess)
        {
            Message = profileResult.ErrorMessage;
            return;
        }

        var servicesResult = await ApiClient.UpdateCompanyEmployeeServicesAsync(
            Session.CompanyId,
            SelectedEmployee.Id,
            new UpdateCompanyEmployeeServicesRequest(EditableServices
                .Select(service => new UpsertCompanyEmployeeServiceRequest(
                    service.ServiceId,
                    service.ExperienceLevel,
                    service.YearsOfExperience,
                    service.PriceTier,
                    service.ServicePrestationIds))
                .ToList()));

        if (!servicesResult.IsSuccess)
        {
            Message = servicesResult.ErrorMessage;
            return;
        }

        await LoadAsync();
        SelectedEmployee = EmployeeRows.FirstOrDefault(employee => employee.Id == updated.Id);
    }

    private async Task GenerateInvitationCodeAsync()
    {
        if (SelectedEmployee is null || Session is null)
        {
            return;
        }

        Message = null;
        if (IsPreviewMode())
        {
            var previewInvitation = SelectedEmployee with
            {
                InvitationCode = "KAZA-482135",
                InvitationLink = "/onboarding?code=KAZA-482135",
                InvitationExpiresAt = DateTimeOffset.UtcNow.AddDays(14)
            };
            ApplySelectedEmployeeUpdate(previewInvitation);
            Message = "Mode demo: nouveau code genere.";
            return;
        }

        var result = await ApiClient.GenerateCompanyEmployeeInvitationCodeAsync(Session.CompanyId, SelectedEmployee.Id);
        if (!result.IsSuccess || result.Invitation is null)
        {
            Message = result.ErrorMessage ?? "Generation du code impossible.";
            return;
        }

        var updated = SelectedEmployee with
        {
            InvitationCode = result.Invitation.InvitationCode,
            InvitationLink = result.Invitation.InvitationLink,
            InvitationExpiresAt = result.Invitation.InvitationExpiresAt
        };
        ApplySelectedEmployeeUpdate(updated);
        Message = "Nouveau code d'acces prestataire genere.";
    }

    private async Task AddEditableServiceAsync()
    {
        if (!Guid.TryParse(ServiceToAddId, out var serviceId) || EditableServices.Any(service => service.ServiceId == serviceId))
        {
            Message = "Choisissez un service qui n'est pas deja rattache.";
            return;
        }

        var service = Services.FirstOrDefault(service => service.Id == serviceId);
        if (service is null)
        {
            Message = "Service introuvable.";
            return;
        }

        EditableServices.Add(new CompanyEmployeeServiceEditModel
        {
            ServiceId = service.Id,
            ServiceName = service.Name,
            ExperienceLevel = "Confirmed",
            YearsOfExperience = EditModel.YearsOfExperience,
            PriceTier = "Normal",
            NormalPriceAmount = service.NormalPriceAmount,
            PremiumPriceAmount = service.PremiumPriceAmount,
            PriceMinAmount = service.PriceMinAmount ?? service.NormalPriceAmount,
            PriceMaxAmount = service.PriceMaxAmount ?? service.PremiumPriceAmount,
            Currency = service.Currency,
            ServicePrestationIds = []
        });
        ServiceToAddId = null;
        var saved = await PersistEditableServicesAsync("Service ajoute au profil.");
        if (!saved)
        {
            Message = $"Service ajoute a l'ecran, mais pas encore enregistre: {Message}";
        }
        StateHasChanged();
    }

    private void RemoveEditableService(Guid serviceId)
    {
        EditableServices.RemoveAll(service => service.ServiceId == serviceId);
    }

    private async Task UploadEmployeeDocumentAsync(string documentType, InputFileChangeEventArgs eventArgs)
    {
        if (SelectedEmployee is null || Session is null || eventArgs.File is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            var document = new CompanyEmployeeDocumentResponse(
                Guid.NewGuid(),
                documentType,
                eventArgs.File.Name,
                string.IsNullOrWhiteSpace(eventArgs.File.ContentType) ? "application/octet-stream" : eventArgs.File.ContentType,
                "#",
                DateTimeOffset.UtcNow);
            var documents = SelectedEmployee.Documents
                .Where(item => item.DocumentType != documentType)
                .Append(document)
                .ToList();
            ApplySelectedEmployeeUpdate(SelectedEmployee with
            {
                Documents = documents,
                PhotoUrl = documentType == "Photo" ? "#" : SelectedEmployee.PhotoUrl,
                IdentityDocumentUrl = documentType == "IdentityDocument" ? "#" : SelectedEmployee.IdentityDocumentUrl,
                DiplomaDocumentUrl = documentType == "Diploma" ? "#" : SelectedEmployee.DiplomaDocumentUrl,
                HasDiploma = documentType == "Diploma" || SelectedEmployee.HasDiploma
            });
            return;
        }

        var result = await ApiClient.UploadCompanyEmployeeDocumentAsync(Session.CompanyId, SelectedEmployee.Id, documentType, eventArgs.File);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await RefreshSelectedEmployeeAsync();
    }

    private async Task DeleteEmployeeDocumentAsync(Guid documentId)
    {
        if (SelectedEmployee is null || Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            var removed = SelectedEmployee.Documents.FirstOrDefault(document => document.Id == documentId);
            var documents = SelectedEmployee.Documents.Where(document => document.Id != documentId).ToList();
            ApplySelectedEmployeeUpdate(SelectedEmployee with
            {
                Documents = documents,
                PhotoUrl = removed?.DocumentType == "Photo" ? null : SelectedEmployee.PhotoUrl,
                IdentityDocumentUrl = removed?.DocumentType == "IdentityDocument" ? null : SelectedEmployee.IdentityDocumentUrl,
                DiplomaDocumentUrl = removed?.DocumentType == "Diploma" ? null : SelectedEmployee.DiplomaDocumentUrl,
                HasDiploma = removed?.DocumentType == "Diploma" ? false : SelectedEmployee.HasDiploma
            });
            return;
        }

        var result = await ApiClient.DeleteCompanyEmployeeDocumentAsync(Session.CompanyId, SelectedEmployee.Id, documentId);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await RefreshSelectedEmployeeAsync();
    }


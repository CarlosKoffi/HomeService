    private async Task AddEditablePrestationAsync(CompanyEmployeeServiceEditModel service)
    {
        var prestation = FindPrestation(service.ServiceId, service.PrestationSearchTerm);
        if (prestation is null)
        {
            Message = "Choisissez une prestation dans la liste.";
            return;
        }

        if (service.ServicePrestationIds.Contains(prestation.Id))
        {
            Message = "Cette prestation est deja ajoutee.";
            return;
        }

        service.ServicePrestationIds.Add(prestation.Id);
        service.PrestationSearchTerm = null;
        var saved = await PersistEditableServicesAsync("Prestation ajoutee au profil.");
        if (!saved)
        {
            Message = $"Prestation ajoutee a l'ecran, mais pas encore enregistree: {Message}";
        }
        StateHasChanged();
    }

    private async Task<bool> PersistEditableServicesAsync(string successMessage)
    {
        Message = null;
        if (SelectedEmployee is null || Session is null || IsPreviewMode())
        {
            Message = IsPreviewMode() ? successMessage : Message;
            return true;
        }

        var servicesResult = await ApiClient.UpdateCompanyEmployeeServicesAsync(
            Session.CompanyId,
            SelectedEmployee.Id,
            new UpdateCompanyEmployeeServicesRequest(EditableServices
                .Select(service => new UpsertCompanyEmployeeServiceRequest(
                    service.ServiceId,
                    service.ExperienceLevel,
                    service.YearsOfExperience,
                    service.PriceTier,
                    service.ServicePrestationIds))
                .ToList()));

        if (!servicesResult.IsSuccess)
        {
            Message = servicesResult.ErrorMessage;
            return false;
        }

        Message = successMessage;
        return true;
    }


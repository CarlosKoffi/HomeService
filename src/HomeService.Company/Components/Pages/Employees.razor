    private EmployeeDocumentSlot ToDocumentSlot(CompanyEmployeeResponse employee, string documentType, string shortCode, string label, bool isRequired)
    {
        var document = employee.Documents
            .Where(document => document.DocumentType == documentType)
            .OrderByDescending(document => document.CreatedAt)
            .FirstOrDefault();

        var previewUrl = document?.PreviewUrl ?? documentType switch
        {
            "Photo" => employee.PhotoUrl,
            "IdentityDocument" => employee.IdentityDocumentUrl,
            "Diploma" => employee.DiplomaDocumentUrl,
            _ => null
        };

        return new EmployeeDocumentSlot(
            documentType,
            shortCode,
            label,
            document?.Id,
            document?.OriginalFileName ?? (string.IsNullOrWhiteSpace(previewUrl) ? (isRequired ? "Manquant" : "Optionnel") : "Piece deposee"),
            previewUrl,
            document?.ContentType,
            IsImageDocument(documentType, document?.ContentType, document?.OriginalFileName),
            string.IsNullOrWhiteSpace(previewUrl) ? (isRequired ? "missing" : "optional") : "ready");
    }

    private string ToPreviewUrl(string previewUrl)
    {
        return previewUrl == "#" ? previewUrl : ApiClient.ToApiUrl(previewUrl);
    }

    private static bool IsImageDocument(string documentType, string? contentType, string? fileName)
    {
        if (documentType == "Photo")
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(contentType) && contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return fileName?.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) == true
            || fileName?.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) == true
            || fileName?.EndsWith(".png", StringComparison.OrdinalIgnoreCase) == true
            || fileName?.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) == true;
    }


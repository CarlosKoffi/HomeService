@page "/employees"
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Employes</PageTitle>

<section class="workspace-header">
    <div>
        <p class="eyebrow">Portail entreprise</p>
        <h1>Employes</h1>
        <p class="lead">Ajoutez, controlez et suivez les prestataires que votre entreprise autorise sur la plateforme.</p>
    </div>
    <a class="secondary-action" href="@PortalLink("dashboard")">Retour portail</a>
</section>

@if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous avec le compte entreprise active pour gerer vos employes.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalNav Active="employees" />

    <section class="portal-session-banner">
        <div>
            <span>Entreprise active</span>
            <strong>@Session.CompanyName</strong>
            <p>@EmployeeRows.Count employe(s) suivi(s)</p>
        </div>
        <button type="button" class="primary-action" @onclick="ToggleForm">
            @(ShowForm ? "Masquer l'ajout" : "Ajouter un employe")
        </button>
    </section>

    @if (ShowForm)
    {
        <EditForm Model="Form" OnSubmit="CreateEmployeeAsync" class="employee-form">
            <div class="form-section-title">
                <h2>@T("company.employees.form.title", "Nouvel employe")</h2>
                <p>@T("company.employees.form.description", "Renseignez les informations essentielles. Les prix des services sont fixes par la plateforme.")</p>
            </div>

            <div class="form-grid">
                <label>
                    Prenom
                    <InputText @bind-Value="Form.FirstName" placeholder="Awa" />
                </label>
                <label>
                    Nom
                    <InputText @bind-Value="Form.LastName" placeholder="Kone" />
                </label>
                <label>
                    Telephone
                    <InputText @bind-Value="Form.PhoneNumber" placeholder="+225 07 00 00 00 00" />
                </label>
                <label>
                    Date de naissance
                    <InputDate @bind-Value="BirthDate" />
                </label>
                <label class="wide-field">
                    Adresse
                    <InputText @bind-Value="Form.Address" placeholder="Cocody, Abidjan" />
                </label>
                <label>
                    Sexe
                    <InputSelect @bind-Value="Form.Gender">
                        <option value="Unspecified">Non renseigne</option>
                        <option value="Female">Femme</option>
                        <option value="Male">Homme</option>
                    </InputSelect>
                </label>
                <label>
                    Type
                    <InputSelect @bind-Value="Form.EmploymentType">
                        <option value="CompanyEmployee">Employe de l'entreprise</option>
                        <option value="TemporaryWorker">Interimaire</option>
                    </InputSelect>
                </label>
                <label>
                    Experience
                    <InputNumber @bind-Value="Form.YearsOfExperience" />
                </label>
                <label>
                    Perimetre km
                    <InputNumber @bind-Value="Form.MissionRadiusKm" />
                </label>
                <label>
                    Niveau
                    <InputSelect @bind-Value="Form.ExperienceLevel">
                        <option value="Junior">Junior</option>
                        <option value="Confirmed">Confirme</option>
                        <option value="Senior">Senior</option>
                        <option value="Expert">Expert</option>
                    </InputSelect>
                </label>
                <label>
                    Latitude mission
                    <InputNumber @bind-Value="Form.MissionLatitude" />
                </label>
                <label>
                    Longitude mission
                    <InputNumber @bind-Value="Form.MissionLongitude" />
                </label>
            </div>

            <div class="service-picker">
                <strong>@T("company.employees.services.title", "Services maitrises")</strong>
                <p>@T("company.employees.services.description", "Selectionnez les services que ce prestataire peut realiser. Les tarifs normal et premium sont fixes dans l'administration.")</p>
                <div>
                    @foreach (var service in Services)
                    {
                        <label class="service-check">
                            <input type="checkbox" checked="@Form.ServiceIds.Contains(service.Id)" @onchange="eventArgs => ToggleService(service.Id, eventArgs)" />
                            <span>@service.Name</span>
                        </label>
                    }
                </div>
            </div>

            <div class="employee-upload-grid">
                <label class="upload-mini">
                    <strong>@T("company.employees.upload.photo", "Photo du prestataire")</strong>
                    <small>@DisplayFileName(PhotoFileName, "JPG, PNG ou WEBP")</small>
                    <em>@T("company.employees.upload.choose", "Selectionner")</em>
                    <InputFile OnChange="OnPhotoSelected" accept=".jpg,.jpeg,.png,.webp" />
                </label>
                <label class="upload-mini required">
                    <strong>@T("company.employees.upload.identity", "Piece d'identite")</strong>
                    <small>@DisplayFileName(IdentityFileName, "PDF, JPG ou PNG")</small>
                    <em>@T("company.employees.upload.choose", "Selectionner")</em>
                    <InputFile OnChange="OnIdentitySelected" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                </label>
                <label class="upload-mini optional">
                    <strong>@T("company.employees.upload.diploma", "Diplome ou certificat")</strong>
                    <small>@DisplayFileName(DiplomaFileName, "Optionnel")</small>
                    <em>@T("company.employees.upload.choose", "Selectionner")</em>
                    <InputFile OnChange="OnDiplomaSelected" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                </label>
            </div>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <p class="field-message">@Message</p>
            }

            <button type="submit" class="primary-action" disabled="@IsSaving">
                @(IsSaving ? "Enregistrement..." : "Enregistrer l'employe")
            </button>
        </EditForm>
    }

    <section class="employee-directory">
        <div class="directory-header">
            <div>
                <h2>Liste des employes</h2>
                <p>Vue de pilotage pour verifier rapidement disponibilite, services, tarifs et pieces.</p>
            </div>
            <span>@EmployeeRows.Count profil(s)</span>
        </div>

        <div class="employee-table-wrap">
            <table class="employee-table">
                <thead>
                    <tr>
                        <th>Employe</th>
                        <th>Type</th>
                        <th>Sexe</th>
                        <th>Services</th>
                        <th>Prix service</th>
                        <th>Experience</th>
                        <th>Zone</th>
                        <th>Statut</th>
                        <th>Pieces</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in EmployeeRows)
                    {
                        <tr class="@GetRowClass(employee)" @onclick="() => SelectEmployee(employee)">
                            <td data-label="Employe">
                                <div class="employee-identity">
                                    <div class="employee-avatar compact">@GetInitials(employee)</div>
                                    <div>
                                        <strong>@employee.FirstName @employee.LastName</strong>
                                        <span>@employee.PhoneNumber</span>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Type">
                                <span class="employment-pill">@GetEmploymentTypeLabel(employee.EmploymentType)</span>
                                <span class="assignment-note">@GetAssignmentLabel(employee.ReceivesDirectRequests)</span>
                            </td>
                            <td data-label="Sexe">@GetGenderLabel(employee.Gender)</td>
                            <td data-label="Services">@GetServicesText(employee)</td>
                            <td data-label="Prix service">@GetServicePriceText(employee)</td>
                            <td data-label="Experience">
                                <strong>@employee.YearsOfExperience an(s)</strong>
                                <span>@GetExperienceLevelText(employee)</span>
                            </td>
                            <td data-label="Zone">
                                <strong>@(employee.ServiceRadiusKm?.ToString("N0") ?? "-") km</strong>
                                <span>@Display(employee.Address)</span>
                            </td>
                            <td data-label="Statut">
                                <span class="status-pill @GetStatusClass(employee.Status)">@GetStatusLabel(employee.Status)</span>
                            </td>
                            <td data-label="Pieces">@GetDocumentsText(employee)</td>
                            <td data-label="Actions">
                                <div class="row-actions" @onclick:stopPropagation>
                                    <button type="button" @onclick="() => SuspendEmployeeAsync(employee.Id)">Suspendre</button>
                                    <button type="button" class="danger-action" @onclick="() => DeleteEmployeeAsync(employee.Id)">Supprimer</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </section>

    @if (SelectedEmployee is not null)
    {
        <div class="modal-backdrop" @onclick="ClearSelectedEmployee">
            <section class="employee-modal" @onclick:stopPropagation>
                <div class="employee-detail-heading">
                    <div class="employee-identity">
                        <div class="employee-avatar compact">@GetInitials(SelectedEmployee)</div>
                        <div>
                            <h2>@SelectedEmployee.FirstName @SelectedEmployee.LastName</h2>
                            <span>@SelectedEmployee.PhoneNumber</span>
                        </div>
                    </div>
                    <button type="button" @onclick="ClearSelectedEmployee">Fermer</button>
                </div>

                <div class="form-grid compact-form">
                    <label>Prenom<InputText @bind-Value="EditModel.FirstName" /></label>
                    <label>Nom<InputText @bind-Value="EditModel.LastName" /></label>
                    <label>Telephone<InputText @bind-Value="EditModel.PhoneNumber" /></label>
                    <label>Date de naissance<InputDate @bind-Value="EditBirthDate" /></label>
                    <label>Sexe
                        <InputSelect @bind-Value="EditModel.Gender">
                            <option value="Unspecified">Non renseigne</option>
                            <option value="Female">Femme</option>
                            <option value="Male">Homme</option>
                        </InputSelect>
                    </label>
                    <label>Type
                        <InputSelect @bind-Value="EditModel.EmploymentType">
                            <option value="CompanyEmployee">Employe de l'entreprise</option>
                            <option value="TemporaryWorker">Interimaire</option>
                        </InputSelect>
                    </label>
                    <label>Experience<InputNumber @bind-Value="EditModel.YearsOfExperience" /></label>
                    <label>Perimetre km<InputNumber @bind-Value="EditModel.MissionRadiusKm" /></label>
                    <label class="wide-field">Adresse<InputText @bind-Value="EditModel.Address" /></label>
                </div>

                <div class="employee-detail-grid">
                    <article>
                        <span>Affectation</span>
                        <strong>@GetAssignmentLabel(EditModel.EmploymentType == "TemporaryWorker")</strong>
                        <p>@(EditModel.EmploymentType == "TemporaryWorker" ? "Eligible aux demandes directes." : "Affectation depuis le portail entreprise.")</p>
                    </article>
                    <article>
                        <span>Statut</span>
                        <strong>@GetStatusLabel(SelectedEmployee.Status)</strong>
                        <p>@(SelectedEmployee.IsAvailable ? "Disponible" : "Non disponible")</p>
                    </article>
                </div>

                <div class="employee-detail-section">
                    <h3>Services et prix plateforme</h3>
                    <div class="service-editor-toolbar">
                        <select @bind="ServiceToAddId">
                            <option value="">Ajouter un service</option>
                            @foreach (var service in Services.Where(service => EditableServices.All(item => item.ServiceId != service.Id)))
                            {
                                <option value="@service.Id">@service.Name</option>
                            }
                        </select>
                        <button type="button" @onclick="AddEditableService">Ajouter</button>
                    </div>
                    @if (EditableServices.Count == 0)
                    {
                        <p>Aucun service rattache. Ajoutez au moins un service avant de rendre le profil exploitable.</p>
                    }
                    else
                    {
                        <div class="service-edit-list">
                            @foreach (var service in EditableServices)
                            {
                                <div class="service-edit-row">
                                    <strong>@service.ServiceName</strong>
                                    <label>Niveau
                                        <select @bind="service.ExperienceLevel">
                                            <option value="Junior">Junior</option>
                                            <option value="Confirmed">Confirme</option>
                                            <option value="Senior">Senior</option>
                                            <option value="Expert">Expert</option>
                                        </select>
                                    </label>
                                    <label>Experience
                                        <InputNumber @bind-Value="service.YearsOfExperience" />
                                    </label>
                                    <label>Mode tarif
                                        <select @bind="service.PriceTier">
                                            <option value="Normal">Normal</option>
                                            <option value="Premium">Premium</option>
                                        </select>
                                    </label>
                                    <div class="service-price-readonly">
                                        <span>Prix normal</span>
                                        <strong>@service.NormalPriceAmount.ToString("N0") @service.Currency</strong>
                                    </div>
                                    <div class="service-price-readonly premium">
                                        <span>Prix premium</span>
                                        <strong>@service.PremiumPriceAmount.ToString("N0") @service.Currency</strong>
                                    </div>
                                    <button type="button" class="danger-action" @onclick="() => RemoveEditableService(service.ServiceId)">Retirer</button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="employee-detail-section">
                    <h3>Pieces du dossier</h3>
                    <div class="document-manager">
                        @foreach (var slot in GetDocumentSlots(SelectedEmployee))
                        {
                            <article class="@($"document-slot {slot.StatusClass}")">
                                <div>
                                    <span>@slot.ShortCode</span>
                                    <strong>@slot.Label</strong>
                                    <small>@slot.FileName</small>
                                </div>
                                <div class="document-actions">
                                    @if (!string.IsNullOrWhiteSpace(slot.PreviewUrl))
                                    {
                                        <a href="@ApiClient.ToApiUrl(slot.PreviewUrl)" target="_blank">Ouvrir</a>
                                        <button type="button" class="danger-action" @onclick="() => DeleteEmployeeDocumentAsync(slot.DocumentId!.Value)">Supprimer</button>
                                    }
                                    <label class="replace-document">
                                        @(slot.DocumentId is null ? "Ajouter" : "Remplacer")
                                        <InputFile OnChange="eventArgs => UploadEmployeeDocumentAsync(slot.DocumentType, eventArgs)" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                                    </label>
                                </div>
                            </article>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <p class="field-message">@Message</p>
                }

                <div class="modal-actions">
                    <button type="button" class="secondary-action" @onclick="ClearSelectedEmployee">Annuler</button>
                    <button type="button" class="primary-action" @onclick="SaveEmployeeEditAsync">Enregistrer</button>
                </div>
            </section>
        </div>
    }
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyEmployeeResponse> EmployeeRows { get; set; } = [];
    private IReadOnlyList<ServiceSummaryResponse> Services { get; set; } = [];
    private CompanyEmployeeFormModel Form { get; set; } = new();
    private DateTime? BirthDate { get; set; }
    private bool ShowForm { get; set; }
    private bool IsSaving { get; set; }
    private string? Message { get; set; }
    private string? PhotoFileName { get; set; }
    private string? IdentityFileName { get; set; }
    private string? DiplomaFileName { get; set; }
    private CompanyEmployeeResponse? SelectedEmployee { get; set; }
    private CompanyEmployeeEditModel EditModel { get; set; } = new();
    private DateTime? EditBirthDate { get; set; }
    private List<CompanyEmployeeServiceEditModel> EditableServices { get; set; } = [];
    private string? ServiceToAddId { get; set; }
    private IReadOnlyDictionary<string, string> Texts { get; set; } = new Dictionary<string, string>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            LoadPreviewData();
            ShowForm = Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("form=1", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadAsync();
        }

        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        if (IsPreviewMode())
        {
            LoadPreviewData();
            SelectedEmployee = EmployeeRows.FirstOrDefault();
            return;
        }

        await LoadTextsAsync();
        Services = await ApiClient.GetServicesAsync();
        if (Session is not null)
        {
            EmployeeRows = await ApiClient.GetCompanyEmployeesAsync(Session.CompanyId);
            SelectedEmployee ??= EmployeeRows.FirstOrDefault();
        }
    }

    private void ToggleForm()
    {
        ShowForm = !ShowForm;
        Message = null;
    }

    private void SelectEmployee(CompanyEmployeeResponse employee)
    {
        SelectedEmployee = employee;
        EditModel = new CompanyEmployeeEditModel
        {
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            PhoneNumber = employee.PhoneNumber,
            Address = employee.Address ?? string.Empty,
            Gender = employee.Gender,
            EmploymentType = employee.EmploymentType,
            YearsOfExperience = employee.YearsOfExperience,
            MissionRadiusKm = (int)(employee.ServiceRadiusKm ?? 5)
        };
        EditableServices = employee.Services
            .Where(service => service.IsActive)
            .Select(service => new CompanyEmployeeServiceEditModel
            {
                ServiceId = service.ServiceId,
                ServiceName = service.ServiceName,
                ExperienceLevel = service.ExperienceLevel,
                YearsOfExperience = service.YearsOfExperience,
                PriceTier = service.PriceTier,
                NormalPriceAmount = service.NormalPriceAmount,
                PremiumPriceAmount = service.PremiumPriceAmount,
                Currency = service.Currency
            })
            .ToList();
        ServiceToAddId = null;
        EditBirthDate = employee.BirthDate?.ToDateTime(TimeOnly.MinValue);
    }

    private void ClearSelectedEmployee()
    {
        SelectedEmployee = null;
        EditableServices = [];
        ServiceToAddId = null;
    }

    private async Task SaveEmployeeEditAsync()
    {
        if (SelectedEmployee is null || Session is null || EditBirthDate is null)
        {
            return;
        }

        var updated = SelectedEmployee with
        {
            FirstName = EditModel.FirstName,
            LastName = EditModel.LastName,
            PhoneNumber = EditModel.PhoneNumber,
            Address = EditModel.Address,
            Gender = EditModel.Gender,
            EmploymentType = EditModel.EmploymentType,
            ReceivesDirectRequests = EditModel.EmploymentType == "TemporaryWorker",
            YearsOfExperience = EditModel.YearsOfExperience,
            ServiceRadiusKm = EditModel.MissionRadiusKm,
            BirthDate = DateOnly.FromDateTime(EditBirthDate.Value),
            Services = EditableServices
                .Select(service => new CompanyEmployeeServiceResponse(
                    service.ServiceId,
                    service.ServiceName,
                    service.ExperienceLevel,
                    service.YearsOfExperience,
                    service.PriceTier,
                    service.NormalPriceAmount,
                    service.PremiumPriceAmount,
                    service.Currency,
                    true))
                .ToList()
        };

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(employee => employee.Id == updated.Id ? updated : employee).ToList();
            SelectedEmployee = updated;
            return;
        }

        var profileResult = await ApiClient.UpdateCompanyEmployeeAsync(
            Session.CompanyId,
            SelectedEmployee.Id,
            new UpdateCompanyEmployeeRequest(
                EditModel.FirstName,
                EditModel.LastName,
                EditModel.PhoneNumber,
                DateOnly.FromDateTime(EditBirthDate.Value),
                EditModel.Address,
                EditModel.Gender,
                EditModel.EmploymentType,
                EditModel.YearsOfExperience,
                EditModel.MissionRadiusKm));

        if (!profileResult.IsSuccess)
        {
            Message = profileResult.ErrorMessage;
            return;
        }

        var servicesResult = await ApiClient.UpdateCompanyEmployeeServicesAsync(
            Session.CompanyId,
            SelectedEmployee.Id,
            new UpdateCompanyEmployeeServicesRequest(EditableServices
                .Select(service => new UpsertCompanyEmployeeServiceRequest(
                    service.ServiceId,
                    service.ExperienceLevel,
                    service.YearsOfExperience,
                    service.PriceTier))
                .ToList()));

        if (!servicesResult.IsSuccess)
        {
            Message = servicesResult.ErrorMessage;
            return;
        }

        await LoadAsync();
        SelectedEmployee = EmployeeRows.FirstOrDefault(employee => employee.Id == updated.Id);
    }

    private void AddEditableService()
    {
        if (!Guid.TryParse(ServiceToAddId, out var serviceId) || EditableServices.Any(service => service.ServiceId == serviceId))
        {
            return;
        }

        var service = Services.FirstOrDefault(service => service.Id == serviceId);
        if (service is null)
        {
            return;
        }

        EditableServices.Add(new CompanyEmployeeServiceEditModel
        {
            ServiceId = service.Id,
            ServiceName = service.Name,
            ExperienceLevel = "Confirmed",
            YearsOfExperience = EditModel.YearsOfExperience,
            PriceTier = "Normal",
            NormalPriceAmount = service.NormalPriceAmount,
            PremiumPriceAmount = service.PremiumPriceAmount,
            Currency = service.Currency
        });
        ServiceToAddId = null;
    }

    private void RemoveEditableService(Guid serviceId)
    {
        EditableServices.RemoveAll(service => service.ServiceId == serviceId);
    }

    private async Task UploadEmployeeDocumentAsync(string documentType, InputFileChangeEventArgs eventArgs)
    {
        if (SelectedEmployee is null || Session is null || eventArgs.File is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            var document = new CompanyEmployeeDocumentResponse(
                Guid.NewGuid(),
                documentType,
                eventArgs.File.Name,
                string.IsNullOrWhiteSpace(eventArgs.File.ContentType) ? "application/octet-stream" : eventArgs.File.ContentType,
                "#",
                DateTimeOffset.UtcNow);
            var documents = SelectedEmployee.Documents
                .Where(item => item.DocumentType != documentType)
                .Append(document)
                .ToList();
            ApplySelectedEmployeeUpdate(SelectedEmployee with
            {
                Documents = documents,
                PhotoUrl = documentType == "Photo" ? "#" : SelectedEmployee.PhotoUrl,
                IdentityDocumentUrl = documentType == "IdentityDocument" ? "#" : SelectedEmployee.IdentityDocumentUrl,
                DiplomaDocumentUrl = documentType == "Diploma" ? "#" : SelectedEmployee.DiplomaDocumentUrl,
                HasDiploma = documentType == "Diploma" || SelectedEmployee.HasDiploma
            });
            return;
        }

        var result = await ApiClient.UploadCompanyEmployeeDocumentAsync(Session.CompanyId, SelectedEmployee.Id, documentType, eventArgs.File);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await RefreshSelectedEmployeeAsync();
    }

    private async Task DeleteEmployeeDocumentAsync(Guid documentId)
    {
        if (SelectedEmployee is null || Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            var removed = SelectedEmployee.Documents.FirstOrDefault(document => document.Id == documentId);
            var documents = SelectedEmployee.Documents.Where(document => document.Id != documentId).ToList();
            ApplySelectedEmployeeUpdate(SelectedEmployee with
            {
                Documents = documents,
                PhotoUrl = removed?.DocumentType == "Photo" ? null : SelectedEmployee.PhotoUrl,
                IdentityDocumentUrl = removed?.DocumentType == "IdentityDocument" ? null : SelectedEmployee.IdentityDocumentUrl,
                DiplomaDocumentUrl = removed?.DocumentType == "Diploma" ? null : SelectedEmployee.DiplomaDocumentUrl,
                HasDiploma = removed?.DocumentType == "Diploma" ? false : SelectedEmployee.HasDiploma
            });
            return;
        }

        var result = await ApiClient.DeleteCompanyEmployeeDocumentAsync(Session.CompanyId, SelectedEmployee.Id, documentId);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await RefreshSelectedEmployeeAsync();
    }

    private async Task RefreshSelectedEmployeeAsync()
    {
        if (SelectedEmployee is null)
        {
            return;
        }

        var selectedId = SelectedEmployee.Id;
        await LoadAsync();
        var refreshed = EmployeeRows.FirstOrDefault(employee => employee.Id == selectedId);
        if (refreshed is not null)
        {
            SelectEmployee(refreshed);
        }
    }

    private void ApplySelectedEmployeeUpdate(CompanyEmployeeResponse updated)
    {
        EmployeeRows = EmployeeRows.Select(employee => employee.Id == updated.Id ? updated : employee).ToList();
        SelectEmployee(updated);
    }

    private void ToggleService(Guid serviceId, ChangeEventArgs eventArgs)
    {
        var isChecked = eventArgs.Value is bool value && value;
        if (isChecked && !Form.ServiceIds.Contains(serviceId))
        {
            Form.ServiceIds.Add(serviceId);
        }
        else if (!isChecked)
        {
            Form.ServiceIds.Remove(serviceId);
        }
    }

    private void OnPhotoSelected(InputFileChangeEventArgs eventArgs)
    {
        Form.Photo = eventArgs.File;
        PhotoFileName = eventArgs.File.Name;
    }

    private void OnIdentitySelected(InputFileChangeEventArgs eventArgs)
    {
        Form.IdentityDocument = eventArgs.File;
        IdentityFileName = eventArgs.File.Name;
    }

    private void OnDiplomaSelected(InputFileChangeEventArgs eventArgs)
    {
        Form.DiplomaDocument = eventArgs.File;
        DiplomaFileName = eventArgs.File.Name;
    }

    private async Task CreateEmployeeAsync()
    {
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Message = "Mode demo local: la fiche serait enregistree en base en production.";
            ShowForm = false;
            return;
        }

        Message = null;
        Form.DateOfBirth = BirthDate is null ? null : DateOnly.FromDateTime(BirthDate.Value);
        IsSaving = true;

        var result = await ApiClient.CreateCompanyEmployeeAsync(Session.CompanyId, Form);
        IsSaving = false;

        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        Form = new();
        BirthDate = null;
        PhotoFileName = null;
        IdentityFileName = null;
        DiplomaFileName = null;
        ShowForm = false;
        await LoadAsync();
    }

    private async Task SuspendEmployeeAsync(Guid employeeId)
    {
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(employee => employee.Id == employeeId
                ? employee with { Status = "SuspendedByCompany", IsAvailable = false }
                : employee).ToList();
            return;
        }

        await ApiClient.SuspendCompanyEmployeeAsync(Session.CompanyId, employeeId);
        await LoadAsync();
    }

    private async Task DeleteEmployeeAsync(Guid employeeId)
    {
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Where(employee => employee.Id != employeeId).ToList();
            if (SelectedEmployee?.Id == employeeId)
            {
                SelectedEmployee = EmployeeRows.FirstOrDefault();
            }
            return;
        }

        await ApiClient.DeleteCompanyEmployeeAsync(Session.CompanyId, employeeId);
        await LoadAsync();
    }


    private async Task CreateEmployeeAsync()
    {
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Message = "Mode demo local: la fiche serait enregistree en base en production.";
            ShowForm = false;
            return;
        }

        Message = null;
        Form.DateOfBirth = BirthDate is null ? null : DateOnly.FromDateTime(BirthDate.Value);
        IsSaving = true;

        var result = await ApiClient.CreateCompanyEmployeeAsync(Session.CompanyId, Form);
        IsSaving = false;

        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        Form = new();
        BirthDate = null;
        PhotoFileName = null;
        IdentityFileName = null;
        DiplomaFileName = null;
        ShowForm = false;
        await LoadAsync();
    }

    private async Task SuspendEmployeeAsync(Guid employeeId)
    {
        OpenEmployeeActionMenuId = null;
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(employee => employee.Id == employeeId
                ? employee with { Status = "SuspendedByCompany", IsAvailable = false }
                : employee).ToList();
            var updatedPreview = EmployeeRows.FirstOrDefault(employee => employee.Id == employeeId);
            if (updatedPreview is not null)
            {
                SelectEmployee(updatedPreview);
            }

            return;
        }

        await ApiClient.SuspendCompanyEmployeeAsync(Session.CompanyId, employeeId);
        await LoadAsync();
        var updated = EmployeeRows.FirstOrDefault(employee => employee.Id == employeeId);
        if (updated is not null)
        {
            SelectEmployee(updated);
        }
    }

    private async Task ApproveEmployeeAsync(Guid employeeId)
    {
        OpenEmployeeActionMenuId = null;
        if (Session is null)
        {
            return;
        }

        Message = null;
        IsSaving = true;
        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(employee => employee.Id == employeeId
                ? employee with { Status = "Approved", IsAvailable = false }
                : employee).ToList();
            var updatedPreview = EmployeeRows.FirstOrDefault(employee => employee.Id == employeeId);
            if (updatedPreview is not null)
            {
                SelectEmployee(updatedPreview);
            }
            IsSaving = false;
            return;
        }

        var result = await ApiClient.ApproveCompanyEmployeeAsync(Session.CompanyId, employeeId);
        IsSaving = false;
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await LoadAsync();
        var updated = EmployeeRows.FirstOrDefault(employee => employee.Id == employeeId);
        if (updated is not null)
        {
            SelectEmployee(updated);
        }
    }

    private async Task ToggleEmployeeAvailabilityAsync(CompanyEmployeeResponse employee)
    {
        OpenEmployeeActionMenuId = null;
        if (Session is null || !CanChangeAvailability(employee))
        {
            return;
        }

        var nextAvailability = !employee.IsAvailable;
        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Select(row => row.Id == employee.Id
                ? row with { IsAvailable = nextAvailability }
                : row).ToList();
            return;
        }

        var result = await ApiClient.UpdateCompanyEmployeeAvailabilityAsync(
            Session.CompanyId,
            employee.Id,
            new UpdateCompanyEmployeeAvailabilityRequest(nextAvailability));
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage;
            return;
        }

        await LoadAsync();
    }

    private async Task DeleteEmployeeAsync(Guid employeeId)
    {
        OpenEmployeeActionMenuId = null;
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            EmployeeRows = EmployeeRows.Where(employee => employee.Id != employeeId).ToList();
            if (SelectedEmployee?.Id == employeeId)
            {
                SelectedEmployee = EmployeeRows.FirstOrDefault();
            }
            return;
        }

        await ApiClient.DeleteCompanyEmployeeAsync(Session.CompanyId, employeeId);
        await LoadAsync();
    }


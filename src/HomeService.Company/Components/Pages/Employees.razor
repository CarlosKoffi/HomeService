            .Where(prestation => ids.Contains(prestation.Id))
            .ToList();
    }

    private ServicePrestationSummaryResponse? FindPrestation(Guid serviceId, string? searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return null;
        }

        var normalizedSearch = NormalizeSearch(searchTerm);
        var prestations = GetActivePrestations(serviceId);
        return prestations.FirstOrDefault(prestation => NormalizeSearch(prestation.Name) == normalizedSearch)
            ?? prestations.FirstOrDefault(prestation => NormalizeSearch(prestation.Name).Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase));
    }

    private static string GetPrestationDatalistId(string scope, Guid serviceId)
    {
        return $"prestations-{scope}-{serviceId:N}";
    }

    private static string NormalizeSearch(string value)
    {
        var normalized = value.Trim().Normalize(NormalizationForm.FormD);
        var builder = new StringBuilder(normalized.Length);
        foreach (var character in normalized)
        {
            if (CharUnicodeInfo.GetUnicodeCategory(character) != UnicodeCategory.NonSpacingMark)
            {
                builder.Append(character);
            }
        }

        return builder.ToString().Normalize(NormalizationForm.FormC).ToUpperInvariant();
    }


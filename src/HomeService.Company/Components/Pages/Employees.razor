    private async Task LoadTextsAsync()
    {
        try
        {
            Texts = (await ApiClient.GetTranslationsAsync("Company"))
                .ToDictionary(item => item.Key, item => item.Value);
        }
        catch
        {
            Texts = PreviewTexts();
        }
    }

    private string T(string key, string fallback)
    {
        return Texts.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;
    }

    private static string DisplayFileName(string? fileName, string fallback)
    {
        return string.IsNullOrWhiteSpace(fileName) ? fallback : fileName;
    }

    private static string GetAgeText(DateTime? birthDate)
    {
        if (birthDate is null)
        {
            return "-- ans";
        }

        var today = DateTime.Today;
        var age = today.Year - birthDate.Value.Year;
        if (birthDate.Value.Date > today.AddYears(-age))
        {
            age--;
        }

        return age < 0 ? "-- ans" : $"{age} ans";
    }

    private static string GetAgeBadgeClass(DateTime? birthDate)
    {
        return birthDate is null ? "employee-age-box" : "employee-age-box ready";
    }

    private static bool HasEmployeePhoto(CompanyEmployeeResponse employee)
    {
        return !string.IsNullOrWhiteSpace(employee.PhotoUrl)
            || employee.Documents.Any(document => document.DocumentType == "Photo");
    }


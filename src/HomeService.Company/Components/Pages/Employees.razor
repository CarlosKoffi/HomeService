    private static string GetServicesText(CompanyEmployeeResponse employee)
    {
        return employee.Services.Count == 0
            ? "Aucun service"
            : string.Join(", ", employee.Services.Select(service => service.ServiceName));
    }

    private static string GetServicePriceText(CompanyEmployeeResponse employee)
    {
        if (employee.Services.Count == 0)
        {
            return "Non defini";
        }

        var minRate = employee.Services.Min(service => service.NormalPriceAmount);
        var maxRate = employee.Services.Max(service => service.PremiumPriceAmount);
        var currency = employee.Services.First().Currency;
        return minRate == maxRate
            ? $"{minRate:N0} {currency}"
            : $"{minRate:N0} - {maxRate:N0} {currency}";
    }

    private static string GetDocumentsText(CompanyEmployeeResponse employee)
    {
        var documents = new List<string>();
        if (employee.Documents.Any(document => document.DocumentType == "IdentityDocument") || !string.IsNullOrWhiteSpace(employee.IdentityDocumentUrl))
        {
            documents.Add("Piece ID");
        }

        if (employee.HasDiploma || employee.Documents.Any(document => document.DocumentType == "Diploma"))
        {
            documents.Add("Diplome");
        }

        return documents.Count == 0 ? "A verifier" : string.Join(", ", documents);
    }

    private IReadOnlyList<EmployeeDocumentSlot> GetDocumentSlots(CompanyEmployeeResponse employee)
    {
        return
        [
            ToDocumentSlot(employee, "Photo", "Photo", "Photo", false),
            ToDocumentSlot(employee, "IdentityDocument", "ID", "Piece d'identite", true),
            ToDocumentSlot(employee, "Diploma", "DIP", "Diplome ou certificat", false)
        ];
    }

    private EmployeeDocumentSlot ToDocumentSlot(CompanyEmployeeResponse employee, string documentType, string shortCode, string label, bool isRequired)
    {
        var document = employee.Documents
            .Where(document => document.DocumentType == documentType)
            .OrderByDescending(document => document.CreatedAt)
            .FirstOrDefault();

        var previewUrl = document?.PreviewUrl ?? documentType switch
        {
            "Photo" => employee.PhotoUrl,
            "IdentityDocument" => employee.IdentityDocumentUrl,
            "Diploma" => employee.DiplomaDocumentUrl,
            _ => null
        };

        return new EmployeeDocumentSlot(
            documentType,
            shortCode,
            label,
            document?.Id,
            document?.OriginalFileName ?? (string.IsNullOrWhiteSpace(previewUrl) ? (isRequired ? "Manquant" : "Optionnel") : "Piece deposee"),
            previewUrl,
            string.IsNullOrWhiteSpace(previewUrl) ? (isRequired ? "missing" : "optional") : "ready");
    }


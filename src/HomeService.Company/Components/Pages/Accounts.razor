@page "/accounts"
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Encaissements</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture des encaissements.</p>
    </section>
}
else if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous pour voir les encaissements.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalNav Active="accounts" />

    <section class="workspace-header">
        <div>
            <p class="eyebrow">Portail entreprise</p>
            <h1>Encaissements</h1>
            <p class="lead">Controlez Mobile Money, cash terrain, commissions et rapprochements par periode.</p>
        </div>
        <a class="secondary-action" href="@PortalLink("dashboard")">Retour portail</a>
    </section>

    <section class="portal-tabs" aria-label="Periode encaissements">
        <button class="@GetTabClass("week")" type="button" @onclick='() => LoadPaymentsAsync("week")'>Semaine</button>
        <button class="@GetTabClass("month")" type="button" @onclick='() => LoadPaymentsAsync("month")'>Mois</button>
        <button class="@GetTabClass("year")" type="button" @onclick='() => LoadPaymentsAsync("year")'>Annee</button>
    </section>

    @if (Summary is not null)
    {
        <section class="metric-strip">
            <article><span>Total</span><strong>@Summary.TotalAmount.ToString("N0") @Summary.Currency</strong></article>
            <article><span>Mobile Money</span><strong>@Summary.MobileMoneyAmount.ToString("N0")</strong></article>
            <article><span>Cash a recuperer</span><strong>@Summary.CashToCollectAmount.ToString("N0")</strong></article>
        </section>

        @if (Summary.Missions.Count == 0)
        {
            <section class="empty-state">
                <h2>Aucun encaissement</h2>
                <p>Les paiements apparaitront ici quand des missions seront terminees.</p>
            </section>
        }
        else
        {
            <section class="mission-list">
                @foreach (var mission in Summary.Missions)
                {
                    <article class="mission-row">
                        <div>
                            <span class="status-pill @GetPaymentStatusClass(mission.PaymentStatus)">@GetPaymentStatusLabel(mission.PaymentStatus)</span>
                            <h2>@mission.ServiceName</h2>
                            <p>@mission.CustomerName - @(mission.ProviderName ?? "Prestataire")</p>
                        </div>
                        <div>
                            <strong>@GetPaymentLabel(mission.PaymentMethod)</strong>
                            <span>@(mission.ScheduledFor?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                        </div>
                        <div>
                            <strong>@(mission.FinalTotalAmount?.ToString("N0") ?? "0") @mission.Currency</strong>
                            <span>@mission.CustomerPhoneNumber</span>
                        </div>
                    </article>
                }
            </section>
        }
    }
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private CompanyPortalPaymentSummaryResponse? Summary { get; set; }
    private string ActivePeriod { get; set; } = "month";
    private bool IsSessionLoading { get; set; } = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            await LoadPaymentsAsync("month");
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadPaymentsAsync("month");
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadPaymentsAsync(string period)
    {
        if (Session is null)
        {
            return;
        }

        ActivePeriod = period;
        if (IsPreviewMode())
        {
            Summary = GetPreviewSummary(period);
            StateHasChanged();
            return;
        }

        Summary = await ApiClient.GetCompanyPaymentsAsync(Session.CompanyId, period);
        StateHasChanged();
    }

    private string GetTabClass(string period) => ActivePeriod == period ? "active" : string.Empty;

    private static string GetPaymentLabel(string method) => method == "MobileMoney" ? "Mobile Money" : "Cash";

    private static string GetPaymentStatusClass(string status) => status == "Paid" ? "status-ok" : "status-pending";

    private static string GetPaymentStatusLabel(string status) => status switch
    {
        "Paid" => "Paye",
        "Authorized" => "Autorise",
        "Failed" => "Echec",
        _ => "A suivre"
    };

    private bool IsPreviewMode()
    {
        return Environment.IsDevelopment()
            && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    }

    private string PortalLink(string path) => IsPreviewMode() ? $"{path}?preview=1" : path;

    private static CompanyPortalSessionResponse DemoSession()
    {
        return new CompanyPortalSessionResponse(
            Guid.Parse("11111111-1111-1111-1111-111111111111"),
            "Entreprise Demo CI",
            "Direction Demo",
            "direction@entreprise.ci",
            DateTimeOffset.UtcNow,
            "demo-preview-token",
            "PendingReview",
            false);
    }

    private static CompanyPortalPaymentSummaryResponse GetPreviewSummary(string period)
    {
        var missions = GetPreviewPaidMissions(period);
        return new CompanyPortalPaymentSummaryResponse(
            period,
            missions.Sum(mission => mission.FinalTotalAmount ?? 0),
            missions.Where(mission => mission.PaymentMethod == "MobileMoney").Sum(mission => mission.FinalTotalAmount ?? 0),
            missions.Where(mission => mission.PaymentMethod == "Cash").Sum(mission => mission.FinalTotalAmount ?? 0),
            missions.Where(mission => mission.PaymentMethod == "Cash").Sum(mission => mission.FinalTotalAmount ?? 0),
            missions.Count,
            "XOF",
            missions);
    }

    private static IReadOnlyList<CompanyPortalMissionResponse> GetPreviewPaidMissions(string period)
    {
        var now = DateTimeOffset.Now;
        var extra = period == "week" ? 0 : 2;
        var missions = new List<CompanyPortalMissionResponse>
        {
            new(Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddd01"), "Menage a domicile", "Mme Bamba", "+225 01 11 22 33 44", "Scheduled", "Completed", "MobileMoney", "Paid", now.AddDays(-2), 240, 22000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1"), "Awa Kone"),
            new(Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddd02"), "Jardinage", "M. Kouassi", "+225 07 45 45 45 45", "Direct", "Completed", "Cash", "Paid", now.AddDays(-5), 180, 16000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb2"), "Yao N'Dri"),
            new(Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddd03"), "Nounou", "Mme Traore", "+225 07 77 10 20 30", "Scheduled", "Completed", "MobileMoney", "Paid", now.AddDays(-9), 300, 30000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1"), "Awa Kone")
        };

        if (extra > 0)
        {
            missions.Add(new(Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddd04"), "Menage a domicile", "Residence Riviera", "+225 05 20 20 20 20", "Scheduled", "Completed", "Cash", "Paid", now.AddDays(-18), 360, 36000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb3"), "Mariam Coulibaly"));
        }

        if (period == "year")
        {
            missions.Add(new(Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddd05"), "Jardinage", "Villa Angre", "+225 01 88 77 66 55", "Scheduled", "Completed", "MobileMoney", "Paid", now.AddMonths(-2), 420, 52000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb2"), "Yao N'Dri"));
        }

        return missions;
    }
}

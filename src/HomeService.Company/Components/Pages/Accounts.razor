    private sealed record PaymentTransactionViewModel(
        Guid Id,
        string CustomerName,
        string ProviderName,
        string ServiceName,
        DateTimeOffset? Date,
        int Amount,
        string PaymentMethod,
        string PaymentStatus,
        string Reference,
        int PlatformCommissionAmount)
    {
        public static PaymentTransactionViewModel FromMission(CompanyPortalMissionResponse mission, int index)
        {
            return new PaymentTransactionViewModel(
                mission.Id,
                mission.CustomerName,
                mission.ProviderName ?? "Prestataire",
                mission.ServiceName,
                mission.ScheduledFor,
                mission.FinalTotalAmount ?? 0,
                mission.PaymentMethod,
                mission.PaymentStatus,
                mission.MissionNumber,
                GetPlatformRevenue(mission));
        }
    }

    private static int GetPlatformRevenue(CompanyPortalMissionResponse mission)
    {
        if (mission.PlatformCommissionAmount > 0)
        {
            return mission.PlatformCommissionAmount;
        }

        return (int)Math.Round((mission.FinalTotalAmount ?? 0) * 0.15m);
    }

    private sealed record PaymentChartPoint(string Label, int Total, int MobileMoney, int Card, int Cash)
    {
        public static PaymentChartPoint FromRows(string label, IReadOnlyList<PaymentTransactionViewModel> rows)
        {
            var mobileMoney = rows.Where(row => row.PaymentMethod == "MobileMoney").Sum(row => row.Amount);
            var card = rows.Where(row => row.PaymentMethod == "Card").Sum(row => row.Amount);
            var cash = rows.Where(row => row.PaymentMethod == "Cash").Sum(row => row.Amount);
            return new PaymentChartPoint(label, mobileMoney + card + cash, mobileMoney, card, cash);
        }
    }

    private sealed record PaymentServiceBreakdown(string ServiceName, int Amount);

@page "/"
@page "/bleu"
@page "/vert"
@page "/noir"
@using HomeService.Company.Services
@using HomeService.Contracts.Branding
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Kaza Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et revenir vers vous.</p>
    </section>
}

<div class="@LandingThemeClass">
<section id="home" class="hero hero-company country-branded @MotifClass" style="@BrandStyle">
    <div class="hero-copy">
        <p class="eyebrow">Partenariat entreprises</p>
        <h1>Recevez plus de missions avec <span>Kaza</span></h1>
        <p class="lead">
            Kaza apporte des demandes clients qualifiees. Vous choisissez les missions, affectez vos prestataires
            et suivez chaque intervention depuis un portail simple.
        </p>
        <div class="actions">
            <a class="primary-action" href="register">Devenir partenaire</a>
            <a class="secondary-action" href="#how-it-works">Voir le fonctionnement</a>
        </div>
        <div class="hero-service-strip" aria-label="Services de depart">
            <span>Menage a domicile</span>
            <span>Nounou</span>
            <span>Jardinage</span>
            <span>Services proposes par vos equipes</span>
        </div>
    </div>
</section>

<section id="concept" class="landing-section split-section section-soft">
    <div class="landing-section-head">
        <p class="eyebrow">Concept</p>
        <h2>Des clients cherchent un service. Votre entreprise peut repondre.</h2>
        <p>
            Kaza met en relation les clients avec des entreprises identifiees et suivies. Vous gardez la main :
            les demandes acceptees, les prestataires affectes et le suivi terrain restent sous votre controle.
        </p>
    </div>
    <div class="control-list">
        <article><strong>Prestataires</strong><span>Ajout, suspension, documents et services maitrises.</span></article>
        <article><strong>Demandes</strong><span>Acceptation selon vos disponibilites et votre zone.</span></article>
        <article><strong>Affectations</strong><span>Choix du prestataire ou delegation a Kaza selon votre mode.</span></article>
        <article><strong>Operations</strong><span>Suivi des missions, paiements, retours clients et historique.</span></article>
    </div>
</section>

<section id="benefits" class="landing-section section-muted">
    <div class="landing-section-head">
        <p class="eyebrow">Avantages</p>
        <h2>Un nouveau canal de missions, sans perdre le controle.</h2>
        <p>Kaza vous aide a trouver des clients, pendant que vous gardez votre facon de travailler.</p>
    </div>

    <div class="benefit-list">
        <article><h3>Plus de demandes utiles</h3><p>Recevez des missions qui correspondent a vos services et a votre zone.</p></article>
        <article><h3>Revenus mieux suivis</h3><p>Chaque mission, paiement et commission reste visible dans votre espace.</p></article>
        <article><h3>Votre equipe reste a vous</h3><p>Vous decidez qui intervient, quand et sur quel type de service.</p></article>
        <article><h3>Un seul portail</h3><p>Demandes, prestataires, documents et paiements sont reunis au meme endroit.</p></article>
        <article><h3>Vous choisissez</h3><p>Vous acceptez uniquement les missions adaptees a votre organisation.</p></article>
        <article><h3>Presence locale</h3><p>Votre entreprise devient plus visible aupres des clients proches de vous.</p></article>
        <article><h3>Encaissements clairs</h3><p>Mobile Money, cash terrain et commissions sont traces proprement.</p></article>
        <article><h3>Accompagnement</h3><p>L'equipe Kaza vous aide a demarrer et a traiter les cas terrain.</p></article>
    </div>
</section>

<section id="how-it-works" class="landing-section section-warm">
    <div class="landing-section-head">
        <p class="eyebrow">Fonctionnement</p>
        <h2>Simple a lancer, clair a suivre.</h2>
    </div>

    <div class="timeline-six">
        <article><strong>1</strong><h3>Inscription</h3><p>Vous indiquez votre entreprise, vos services et le contact responsable.</p></article>
        <article><strong>2</strong><h3>Dossier</h3><p>Vous ajoutez les pieces en ligne ou vous les deposez dans nos bureaux.</p></article>
        <article><strong>3</strong><h3>Verification</h3><p>Kaza controle les informations avant d'ouvrir les fonctions sensibles.</p></article>
        <article><strong>4</strong><h3>Equipe</h3><p>Vous ajoutez vos prestataires, leurs pieces et leurs services.</p></article>
        <article><strong>5</strong><h3>Demandes</h3><p>Les clients vous sollicitent selon vos services et votre zone.</p></article>
        <article><strong>6</strong><h3>Mission</h3><p>Vous affectez, suivez l'intervention et gardez la trace du paiement.</p></article>
    </div>
</section>

<section id="services" class="landing-section section-green">
    <div class="landing-section-head">
        <p class="eyebrow">Services</p>
        <h2>Qui peut rejoindre Kaza ?</h2>
        <p>Toute entreprise serieuse proposant des services a domicile ou de proximite.</p>
    </div>


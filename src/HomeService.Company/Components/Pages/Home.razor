@page "/"
@inject NavigationManager Navigation

<PageTitle>HomeService Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et les pieces fournies.</p>
    </section>
}

<section class="hero hero-company">
    <div class="hero-copy">
        <div class="soft-shape shape-one"></div>
        <div class="soft-shape shape-two"></div>
        <p class="eyebrow">Entreprises partenaires - Cote d'Ivoire</p>
        <h1>Faites intervenir vos equipes a domicile en toute <span>CONFIANCE</span></h1>
        <p class="lead">
            ProxiPro connecte les clients a des prestataires recommandes par des entreprises verifiees.
            Votre structure garde le controle: validation des employes, services proposes, tarifs horaires,
            missions realisees, satisfaction client et encaissements.
        </p>
        <div class="actions">
            <a class="primary-action" href="register">Inscrire mon entreprise</a>
            <a class="secondary-action" href="concept">Comprendre le concept</a>
        </div>
    </div>

    <aside class="hero-panel" aria-label="Parcours entreprise">
        <strong>Parcours entreprise</strong>
        <ol>
            <li>Dossier et pieces</li>
            <li>Validation plateforme</li>
            <li>Lien d'activation email</li>
            <li>Ajout des prestataires</li>
        </ol>
    </aside>
</section>

@code {
    private bool IsSubmittedConfirmationVisible { get; set; }

    protected override void OnInitialized()
    {
        IsSubmittedConfirmationVisible = new Uri(Navigation.Uri)
            .Query
            .Contains("submitted=1", StringComparison.OrdinalIgnoreCase);
    }
}

<section class="service-strip" aria-label="Services de depart">
    <span>Menage a domicile</span>
    <span>Nounou</span>
    <span>Jardinage</span>
    <span>Services proposes par vos equipes</span>
</section>

<section class="dashboard-grid feature-grid">
    <article>
        <h2>Votre entreprise est verifiee</h2>
        <p>Vous deposez vos informations et pieces justificatives. Apres validation, nous vous envoyons un lien pour creer votre acces.</p>
    </article>
    <article>
        <h2>Vos prestataires sont encadres</h2>
        <p>Vous ajoutez vos employes, ils completent leur dossier, puis la plateforme valide leur profil avant toute mission.</p>
    </article>
    <article>
        <h2>Vous gardez la tracabilite</h2>
        <p>Suivez les demandes, refus, retards, notes clients, paiements Mobile Money et cash collecte sur le terrain.</p>
    </article>
</section>

@page "/"
@using HomeService.Company.Services
@using HomeService.Contracts.Branding
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>HomeService Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et les pieces fournies.</p>
    </section>
}

<section class="hero hero-company country-branded @MotifClass" style="@BrandStyle">
    <div class="hero-copy">
        <h1>@Branding.BrandName <span>@Branding.HeroTitle</span></h1>
        <p class="lead">
            @Branding.HeroSubtitle
        </p>
        <div class="actions">
            <a class="primary-action" href="register">Inscrire mon entreprise</a>
            <a class="secondary-action" href="concept">Comprendre le concept</a>
        </div>
    </div>

    <aside class="hero-panel" aria-label="Parcours entreprise">
        <strong>Parcours entreprise</strong>
        <ol>
            <li>
                <PlatformIcon Name="company" Tone="green" />
                <div>
                    <strong>Creer</strong>
                    <small>Compte entreprise</small>
                </div>
            </li>
            <li>
                <PlatformIcon Name="documents" Tone="orange" />
                <div>
                    <strong>Completer</strong>
                    <small>Pieces et services</small>
                </div>
            </li>
            <li>
                <PlatformIcon Name="validate" Tone="green" />
                <div>
                    <strong>Valider</strong>
                    <small>Conformite admin</small>
                </div>
            </li>
            <li>
                <PlatformIcon Name="pilot" Tone="orange" />
                <div>
                    <strong>Piloter</strong>
                    <small>Employes, missions, XOF</small>
                </div>
            </li>
        </ol>
    </aside>
</section>

@code {
    private CountryBrandingResponse Branding { get; set; } = DefaultBranding;
    private bool IsSubmittedConfirmationVisible { get; set; }

    private string BrandStyle =>
        $"--country-primary:{Branding.PrimaryColor}; --country-secondary:{Branding.SecondaryColor}; --country-accent:{Branding.AccentColor};";

    private string MotifClass => Branding.MotifStyle == "minimal" ? "motif-minimal" : "motif-flag-ribbon";

    protected override async Task OnInitializedAsync()
    {
        IsSubmittedConfirmationVisible = new Uri(Navigation.Uri)
            .Query
            .Contains("submitted=1", StringComparison.OrdinalIgnoreCase);

        try
        {
            Branding = await ApiClient.GetCountryBrandingAsync("CI") ?? DefaultBranding;
        }
        catch
        {
            Branding = DefaultBranding;
        }
    }

    private static readonly CountryBrandingResponse DefaultBranding = new(
        "CI",
        "Cote d'Ivoire",
        "Kaza",
        "#0f9f7a",
        "#ffffff",
        "#f97316",
        "Le service a domicile en toute confiance",
        "Une plateforme pensee pour la Cote d'Ivoire: entreprises verifiees, prestataires suivis et services a domicile plus fiables.",
        null,
        "flag-ribbon");
}

<section class="service-strip" aria-label="Services de depart">
    <span>Menage a domicile</span>
    <span>Nounou</span>
    <span>Jardinage</span>
    <span>Services proposes par vos equipes</span>
</section>

<section class="dashboard-grid feature-grid">
    <article>
        <PlatformIcon Name="company" Tone="green" />
        <h2>Votre entreprise est verifiee</h2>
        <p>Vous creez votre compte, puis vous ajoutez les pieces de conformite depuis le portail ou via nos bureaux.</p>
    </article>
    <article>
        <PlatformIcon Name="providers" Tone="orange" />
        <h2>Vos prestataires sont encadres</h2>
        <p>Vous ajoutez salaries et interimaires, avec leurs documents, services maitrises et niveau normal ou premium.</p>
    </article>
    <article>
        <PlatformIcon Name="payments" Tone="green" />
        <h2>Vous gardez la tracabilite</h2>
        <p>Suivez les demandes, refus, retards, notes clients, paiements Mobile Money et cash collecte sur le terrain.</p>
    </article>
</section>

        <symbol id="service-paint" viewBox="0 0 24 24"><path d="M4 6h12v5H4z"/><path d="M16 8h2a3 3 0 0 1 3 3v1a3 3 0 0 1-3 3h-6"/><path d="M10 11v9"/><path d="M8 20h4"/><path d="M6 8h8"/></symbol>

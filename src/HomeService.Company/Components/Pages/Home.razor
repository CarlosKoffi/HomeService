@page "/"
@using HomeService.Company.Services
@using HomeService.Contracts.Branding
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Kaza Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et revenir vers vous.</p>
    </section>
}

<section id="home" class="hero hero-company country-branded @MotifClass" style="@BrandStyle">
    <div class="hero-copy">
        <p class="eyebrow">Partenariat entreprises</p>
        <h1>Developpez votre activite avec <span>Kaza</span></h1>
        <p class="lead">
            Recevez de nouvelles demandes de services a domicile, pilotez vos prestataires depuis un portail clair
            et gardez le controle de vos missions, paiements et equipes.
        </p>
        <div class="actions">
            <a class="primary-action" href="register">Devenir partenaire</a>
            <a class="secondary-action" href="#how-it-works">Voir le fonctionnement</a>
        </div>
        <div class="hero-service-strip" aria-label="Services de depart">
            <span>Menage a domicile</span>
            <span>Nounou</span>
            <span>Jardinage</span>
            <span>Services proposes par vos equipes</span>
        </div>
    </div>
</section>

<section id="concept" class="landing-section split-section">
    <div class="landing-section-head">
        <p class="eyebrow">Concept</p>
        <h2>Kaza connecte les clients avec des entreprises de services verifiees</h2>
        <p>
            Les entreprises recoivent des demandes adaptees a leurs services et a leur zone d'intervention.
            Elles restent maitres de leurs equipes, des missions acceptees et des prestataires affectes.
        </p>
    </div>
    <div class="control-list">
        <article><strong>Prestataires</strong><span>Ajout, suspension, documents et services maitrises.</span></article>
        <article><strong>Demandes</strong><span>Acceptation selon vos disponibilites et votre zone.</span></article>
        <article><strong>Affectations</strong><span>Choix du prestataire ou delegation a Kaza selon votre mode.</span></article>
        <article><strong>Operations</strong><span>Suivi des missions, paiements, retours clients et historique.</span></article>
    </div>
</section>

<section id="benefits" class="landing-section">
    <div class="landing-section-head">
        <p class="eyebrow">Avantages</p>
        <h2>Pourquoi devenir partenaire ?</h2>
        <p>Un canal de demandes supplementaire, sans perdre le controle de votre activite.</p>
    </div>

    <div class="benefit-list">
        <article><h3>Nouveaux clients</h3><p>Recevez des demandes qualifiees dans vos services.</p></article>
        <article><h3>Chiffre d'affaires</h3><p>Developpez vos revenus avec des missions suivies.</p></article>
        <article><h3>Controle equipe</h3><p>Vous decidez qui intervient et sur quel service.</p></article>
        <article><h3>Portail unique</h3><p>Employes, missions et paiements au meme endroit.</p></article>
        <article><h3>Demandes choisies</h3><p>Vous acceptez uniquement les missions pertinentes.</p></article>
        <article><h3>Visibilite</h3><p>Votre entreprise gagne en presence locale.</p></article>
        <article><h3>Paiements suivis</h3><p>Mobile Money, cash terrain et commissions traces.</p></article>
        <article><h3>Support partenaire</h3><p>Une equipe Kaza vous accompagne dans le demarrage.</p></article>
    </div>
</section>

<section id="how-it-works" class="landing-section">
    <div class="landing-section-head">
        <p class="eyebrow">Fonctionnement</p>
        <h2>Le parcours partenaire en 6 etapes</h2>
    </div>

    <div class="timeline-six">
        <article><strong>1</strong><h3>Creer le compte</h3><p>Renseignez votre entreprise, vos services et le responsable.</p></article>
        <article><strong>2</strong><h3>Completer le dossier</h3><p>Ajoutez les documents en ligne ou deposez-les dans nos bureaux.</p></article>
        <article><strong>3</strong><h3>Validation Kaza</h3><p>Notre equipe verifie les informations et la conformite.</p></article>
        <article><strong>4</strong><h3>Ajouter l'equipe</h3><p>Ajoutez salaries, interimaires, documents et services maitrises.</p></article>
        <article><strong>5</strong><h3>Recevoir les demandes</h3><p>Les demandes clients arrivent selon vos services et zones.</p></article>
        <article><strong>6</strong><h3>Affecter et suivre</h3><p>Assignez un prestataire, suivez la mission et les encaissements.</p></article>
    </div>
</section>

<section id="services" class="landing-section">
    <div class="landing-section-head">
        <p class="eyebrow">Services</p>
        <h2>Qui peut rejoindre Kaza ?</h2>
        <p>Toute entreprise serieuse proposant des services a domicile ou de proximite.</p>
    </div>

    <svg aria-hidden="true" class="service-icon-defs">
        <symbol id="service-plumbing" viewBox="0 0 24 24"><path d="M5 7h8a3 3 0 0 1 3 3v7"/><path d="M5 4v6"/><path d="M3 4h4"/><path d="M14 17h4"/><path d="M18 15v4"/></symbol>
        <symbol id="service-electricity" viewBox="0 0 24 24"><path d="M13 2 6 13h6l-1 9 7-12h-6z"/></symbol>
        <symbol id="service-cooling" viewBox="0 0 24 24"><path d="M4 6h16v8H4z"/><path d="M7 10h10"/><path d="M8 18h8"/><path d="M10 14v4"/><path d="M14 14v4"/></symbol>
        <symbol id="service-cleaning" viewBox="0 0 24 24"><path d="m6 20 3-11 6-2 3 13"/><path d="M8 14h8"/><path d="M10 4h4"/><path d="M12 4v4"/></symbol>
        <symbol id="service-garden" viewBox="0 0 24 24"><path d="M12 20V9"/><path d="M12 12c-4 0-6-2-7-6 4 0 7 2 7 6z"/><path d="M12 14c4 0 6-2 7-6-4 0-7 2-7 6z"/></symbol>
        <symbol id="service-lock" viewBox="0 0 24 24"><path d="M7 11V8a5 5 0 0 1 10 0v3"/><path d="M6 11h12v9H6z"/><path d="M12 15v2"/></symbol>
        <symbol id="service-paint" viewBox="0 0 24 24"><path d="M4 5h11v6H4z"/><path d="M15 8h3a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-5"/><path d="M10 11v9"/><path d="M8 20h4"/></symbol>
        <symbol id="service-pest" viewBox="0 0 24 24"><path d="M8 10a4 4 0 0 1 8 0v6a4 4 0 0 1-8 0z"/><path d="M12 6V3"/><path d="M7 8 5 6"/><path d="m17 8 2-2"/><path d="M8 13H4"/><path d="M20 13h-4"/><path d="m7 18-2 2"/><path d="m17 18 2 2"/></symbol>
        <symbol id="service-appliance" viewBox="0 0 24 24"><path d="M7 3h10v18H7z"/><path d="M10 6h4"/><path d="M10 10h4"/><circle cx="12" cy="16" r="2.5"/></symbol>
        <symbol id="service-moving" viewBox="0 0 24 24"><path d="M3 8h12v8H3z"/><path d="M15 11h4l2 3v2h-6z"/><circle cx="7" cy="18" r="1.8"/><circle cx="17" cy="18" r="1.8"/></symbol>
        <symbol id="service-home" viewBox="0 0 24 24"><path d="m4 11 8-7 8 7"/><path d="M6 10v10h12V10"/><path d="M10 20v-5h4v5"/></symbol>
        <symbol id="service-more" viewBox="0 0 24 24"><path d="M12 5v14"/><path d="M5 12h14"/></symbol>
    </svg>

    <div class="service-category-grid">
        <article><span><svg><use href="#service-plumbing" /></svg></span><strong>Plomberie</strong></article>
        <article><span><svg><use href="#service-electricity" /></svg></span><strong>Electricite</strong></article>
        <article><span><svg><use href="#service-cooling" /></svg></span><strong>Climatisation</strong></article>
        <article><span><svg><use href="#service-cleaning" /></svg></span><strong>Menage</strong></article>
        <article><span><svg><use href="#service-garden" /></svg></span><strong>Jardinage</strong></article>
        <article><span><svg><use href="#service-lock" /></svg></span><strong>Serrurerie</strong></article>
        <article><span><svg><use href="#service-paint" /></svg></span><strong>Peinture</strong></article>
        <article><span><svg><use href="#service-pest" /></svg></span><strong>Anti-nuisibles</strong></article>
        <article><span><svg><use href="#service-appliance" /></svg></span><strong>Electromenager</strong></article>
        <article><span><svg><use href="#service-moving" /></svg></span><strong>Demenagement</strong></article>
        <article><span><svg><use href="#service-home" /></svg></span><strong>Maintenance maison</strong></article>
        <article><span><svg><use href="#service-more" /></svg></span><strong>Autres services bientot</strong></article>
    </div>
</section>

<section id="requirements" class="landing-section requirements-section">
    <div class="landing-section-head">
        <p class="eyebrow">Conditions</p>
        <h2>Documents et criteres attendus</h2>
        <p>Ces elements permettent de proteger les clients, les entreprises et les prestataires.</p>
    </div>

    <div class="requirements-layout">
        <div class="verified-badge-card">
            <span>Verifie</span>
            <strong>Partenaire Kaza</strong>
            <p>Une entreprise identifiee, joignable, responsable et capable de suivre ses interventions.</p>
        </div>
        <ul class="requirement-list">
            <li>Registre de commerce RCCM</li>
            <li>Declaration fiscale d'existence DFE</li>
            <li>Piece du representant legal</li>
            <li>Adresse de l'entreprise</li>
            <li>Telephone professionnel</li>
            <li>Equipe de prestataires ou techniciens</li>
            <li>Pieces des prestataires</li>
            <li>Diplomes ou certificats si disponibles</li>
            <li>Compte de paiement accepte</li>
            <li>Acceptation des conditions partenaires Kaza</li>
        </ul>
    </div>
</section>

<section id="partner-dashboard" class="landing-section dashboard-preview-section">
    <div class="landing-section-head">
        <p class="eyebrow">Portail partenaire</p>
        <h2>Un tableau de bord pour piloter votre activite</h2>
        <p>Une vision claire des demandes, affectations, prestataires et encaissements.</p>
    </div>

    <div class="dashboard-mockup">
        <aside>
            <strong>Kaza Partner</strong>
            <span>Dashboard</span>
            <span>Demandes</span>
            <span>Equipe</span>
            <span>Services</span>
            <span>Zones</span>
            <span>Paiements</span>
            <span>Notes</span>
            <span>Documents</span>
            <span>Support</span>
        </aside>
        <div class="mockup-main">
            <div class="mockup-stats">
                <article><span>Demandes jour</span><strong>12</strong></article>
                <article><span>Assignees</span><strong>8</strong></article>
                <article><span>Terminees</span><strong>5</strong></article>
                <article><span>Paiements</span><strong>185k</strong></article>
            </div>
            <div class="mockup-grid">
                <section>
                    <h3>Demandes en attente</h3>
                    <p>Menage - Cocody Riviera</p>
                    <p>Jardinage - Marcory</p>
                    <p>Nounou - Deux Plateaux</p>
                </section>
                <section>
                    <h3>Prestataires disponibles</h3>
                    <p>Awa K. - Menage</p>
                    <p>Jean M. - Jardinage</p>
                    <p>Fatou C. - Nounou</p>
                </section>
                <section class="wide">
                    <h3>Activite recente</h3>
                    <p>Mission confirmee, paiement Mobile Money recu, client satisfait.</p>
                </section>
            </div>
        </div>
    </div>
</section>

<section class="landing-section">
    <div class="landing-section-head">
        <p class="eyebrow">Gestion</p>
        <h2>Tout ce que vous pouvez piloter</h2>
    </div>
    <div class="management-grid">
        <span>Demandes clients</span>
        <span>Affectations</span>
        <span>Employes</span>
        <span>Interventions</span>
        <span>Notes clients</span>
        <span>Documents</span>
        <span>Paiements</span>
        <span>Parametres entreprise</span>
        <span>Support</span>
    </div>
</section>

<section class="landing-section commitment-section">
    <div class="commitment-card">
        <h2>Kaza s'engage a</h2>
        <ul>
            <li>Apporter de nouvelles demandes clients</li>
            <li>Fournir une plateforme professionnelle</li>
            <li>Accompagner le support client</li>
            <li>Suivre les paiements de maniere claire</li>
            <li>Ameliorer la plateforme en continu</li>
        </ul>
    </div>
    <div class="commitment-card">
        <h2>Le partenaire s'engage a</h2>
        <ul>
            <li>Assurer un service professionnel</li>
            <li>Encadrer des prestataires qualifies</li>
            <li>Respecter les horaires de rendez-vous</li>
            <li>Respecter les clients</li>
            <li>Maintenir la qualite des interventions</li>
        </ul>
    </div>
</section>

<section class="landing-section pricing-section">
    <div>
        <p class="eyebrow">Tarifs</p>
        <h2>Inscription gratuite</h2>
        <p>Aucun abonnement mensuel. Kaza applique une commission uniquement sur les missions realisees avec succes.</p>
        <p>Le detail complet des commissions est presente avant validation finale du partenariat.</p>
    </div>
    <strong>0 XOF / mois</strong>
</section>

<section id="faq" class="landing-section faq-section">
    <div class="landing-section-head">
        <p class="eyebrow">FAQ</p>
        <h2>Questions frequentes</h2>
    </div>

    <div class="faq-grid">
        <details open><summary>L'inscription est-elle gratuite ?</summary><p>Oui, la demande de partenariat est gratuite.</p></details>
        <details><summary>Puis-je refuser une demande ?</summary><p>Oui, l'entreprise reste libre d'accepter ou non une demande.</p></details>
        <details><summary>Qui choisit le prestataire ?</summary><p>L'entreprise peut affecter elle-meme ou demander a Kaza de le faire selon le mode choisi.</p></details>
        <details><summary>Puis-je ajouter plus d'employes ?</summary><p>Oui, vous pouvez ajouter salaries et interimaires depuis votre portail.</p></details>
        <details><summary>Comment fonctionnent les paiements ?</summary><p>Mobile Money, cash et commissions sont suivis depuis le portail.</p></details>
        <details><summary>Qui gere les reclamations clients ?</summary><p>Kaza centralise le support client et travaille avec l'entreprise pour regler les cas terrain.</p></details>
        <details><summary>Puis-je mettre mon compte en pause ?</summary><p>Oui, les disponibilites et services pourront etre ajustes.</p></details>
        <details><summary>Combien de temps prend la validation ?</summary><p>Elle depend de la qualite du dossier et des documents transmis.</p></details>
    </div>
</section>

<section id="contact" class="landing-section contact-form-section">
    <div class="contact-copy">
        <p class="eyebrow">Contact</p>
        <h2>Parlons de votre entreprise</h2>
        <p>Vous avez une equipe, des services a proposer ou une question avant inscription ? Laissez vos coordonnees, l'equipe Kaza vous recontacte.</p>
        <div class="contact-shortcuts">
            <span>Abidjan et communes proches</span>
            <span>Entreprises de services</span>
            <span>Partenariat Kaza</span>
        </div>
    </div>

    <form class="contact-form" @onsubmit="SubmitContactAsync" @onsubmit:preventDefault>
        <div class="contact-form-grid">
            <label>Nom complet<input placeholder="Ex: Jean Kouadio" @bind="ContactName" /></label>
            <label>Entreprise<input placeholder="Ex: CI Home Service" @bind="ContactCompany" /></label>
            <label>Telephone<input type="tel" placeholder="+225 07 00 00 00 00" @bind="ContactPhone" /></label>
            <label>Email<input type="email" placeholder="direction@entreprise.ci" @bind="ContactEmail" /></label>
        </div>
        <label>
            Sujet
            <select @bind="ContactSubject">
                <option>Devenir partenaire</option>
                <option>Comprendre le fonctionnement</option>
                <option>Suivi d'une demande</option>
                <option>Autre demande</option>
            </select>
        </label>
        <label>
            Message
            <textarea rows="5" placeholder="Expliquez rapidement votre besoin..." @bind="ContactBody"></textarea>
        </label>

        @if (!string.IsNullOrWhiteSpace(ContactMessage))
        {
            <p class="field-message">@ContactMessage</p>
        }

        <div class="contact-form-actions">
            <button type="submit" class="primary-action">Envoyer le message</button>
            <a class="secondary-action" href="register">Devenir partenaire</a>
        </div>
    </form>
</section>

<footer class="site-footer">
    <strong>Kaza</strong>
    <nav aria-label="Liens footer">
        <a href="#concept">A propos</a>
        <a href="register">Devenir partenaire</a>
        <a href="#contact">Support</a>
        <a href="#contact">WhatsApp</a>
        <a href="#contact">Email</a>
        <a href="#faq">Conditions partenaires</a>
    </nav>
</footer>

@code {
    private CountryBrandingResponse Branding { get; set; } = DefaultBranding;
    private bool IsSubmittedConfirmationVisible { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string ContactCompany { get; set; } = string.Empty;
    private string ContactPhone { get; set; } = string.Empty;
    private string ContactEmail { get; set; } = string.Empty;
    private string ContactSubject { get; set; } = "Devenir partenaire";
    private string ContactBody { get; set; } = string.Empty;
    private string? ContactMessage { get; set; }

    private string BrandStyle =>
        $"--country-primary:{Branding.PrimaryColor}; --country-secondary:{Branding.SecondaryColor}; --country-accent:{Branding.AccentColor};";

    private string MotifClass => Branding.MotifStyle == "minimal" ? "motif-minimal" : "motif-flag-ribbon";

    protected override async Task OnInitializedAsync()
    {
        IsSubmittedConfirmationVisible = new Uri(Navigation.Uri)
            .Query
            .Contains("submitted=1", StringComparison.OrdinalIgnoreCase);

        try
        {
            Branding = await ApiClient.GetCountryBrandingAsync("CI") ?? DefaultBranding;
        }
        catch
        {
            Branding = DefaultBranding;
        }
    }

    private Task SubmitContactAsync()
    {
        if (string.IsNullOrWhiteSpace(ContactName)
            || string.IsNullOrWhiteSpace(ContactCompany)
            || string.IsNullOrWhiteSpace(ContactPhone)
            || string.IsNullOrWhiteSpace(ContactBody))
        {
            ContactMessage = "Renseignez au moins le nom, l'entreprise, le telephone et le message.";
            return Task.CompletedTask;
        }

        ContactMessage = "Message pret a etre transmis. Le branchement email/API sera ajoute a la prochaine etape.";
        return Task.CompletedTask;
    }

    private static readonly CountryBrandingResponse DefaultBranding = new(
        "CI",
        "Cote d'Ivoire",
        "Kaza",
        "#0f9f7a",
        "#ffffff",
        "#f97316",
        "Le service a domicile en toute confiance",
        "Une plateforme pensee pour la Cote d'Ivoire: entreprises verifiees, prestataires suivis et services a domicile plus fiables.",
        null,
        "flag-ribbon");
}

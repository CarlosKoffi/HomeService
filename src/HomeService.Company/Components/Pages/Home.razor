@page "/"
@page "/bleu"
@page "/vert"
@page "/noir"
@page "/apple"
@inject NavigationManager Navigation

<PageTitle>Kaza Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et revenir vers vous.</p>
    </section>
}

<div class="@LandingThemeClass">
    <section id="home" class="premium-hero">
        <img class="premium-hero-image" src="images/kaza-premium-hero.png" alt="" aria-hidden="true" />
        <div class="premium-hero-overlay"></div>
        <div class="premium-hero-content">
            <p class="premium-label">Plateforme partenaire</p>
            <h1>
                Recevez plus de missions.
                <span>Developpez votre entreprise.</span>
            </h1>
            <p>
                Kaza connecte les clients aux entreprises de services a domicile verifiees. Vous gardez le controle de vos equipes, de vos demandes et de vos interventions.
            </p>
            <div class="premium-actions">
                <a class="premium-primary" href="register">Commencer</a>
                <a class="premium-secondary" href="#how">Voir le fonctionnement</a>
            </div>
            <div class="premium-proof" aria-label="Indicateurs Kaza">
                <span>Inscription gratuite</span>
                <span>Validation dossier</span>
                <span>Portail entreprise</span>
            </div>
        </div>
    </section>

    <section id="how" class="premium-section">
        <div class="premium-section-head">
            <p class="premium-label">Comment ca marche</p>
            <h2>Trois etapes, puis votre portail est pret.</h2>
            <p>Un parcours court pour verifier l'entreprise et demarrer avec une base claire.</p>
        </div>

        <div class="premium-how-grid">
            <article>
                <figure><img src="images/kaza-how-step-1.png" alt="Creation du compte entreprise Kaza" loading="lazy" /></figure>
                <div class="premium-step-meta"><span>01</span><strong>Compte</strong></div>
                <h3>Creez votre compte</h3>
                <p>Renseignez votre entreprise, vos services et le contact responsable.</p>
            </article>
            <article>
                <figure><img src="images/kaza-how-step-2.png" alt="Verification du dossier partenaire Kaza" loading="lazy" /></figure>
                <div class="premium-step-meta"><span>02</span><strong>Verification</strong></div>
                <h3>Nous verifions votre dossier</h3>
                <p>Kaza controle les informations pour securiser les clients et les missions.</p>
            </article>
            <article>
                <figure><img src="images/kaza-how-step-3.png" alt="Portail entreprise Kaza pour suivre les interventions" loading="lazy" /></figure>
                <div class="premium-step-meta"><span>03</span><strong>Portail</strong></div>
                <h3>Travaillez depuis votre portail</h3>
                <p>Ajoutez vos prestataires, recevez des demandes et suivez vos interventions.</p>
            </article>
        </div>
    </section>

    <section id="trusted" class="premium-trusted" aria-label="Entreprises partenaires">
        <p>Ils font confiance a Kaza</p>
        <div>
            <span>Services verifies</span>
            <span>Entreprises locales</span>
            <span>Prestataires suivis</span>
            <span>Paiements traces</span>
            <span>Support partenaire</span>
        </div>
    </section>

    <section id="dashboard" class="premium-section premium-dashboard-section">
        <div class="premium-section-head">
            <p class="premium-label">Dashboard</p>
            <h2>Tout ce qui compte, lisible en un coup d'oeil.</h2>
            <p>Demandes, equipe, missions, documents et paiements restent au meme endroit.</p>
        </div>

        <div class="premium-dashboard">
            <div class="premium-dashboard-top">
                <div><span></span><strong>Kaza Partner</strong></div>
                <small>Aujourd'hui</small>
            </div>
            <div class="premium-dashboard-stats">
                <article><span>Demandes</span><strong>12</strong><small>+4 cette semaine</small></article>
                <article><span>Assignees</span><strong>8</strong><small>Equipe mobilisee</small></article>
                <article><span>Paiements</span><strong>185k</strong><small>XOF suivis</small></article>
            </div>
            <div class="premium-dashboard-body">
                <section>
                    <h3>Demandes en cours</h3>
                    <p>Menage a Cocody Riviera</p>
                    <p>Jardinage a Marcory</p>
                    <p>Nounou aux Deux Plateaux</p>
                </section>
                <section>
                    <h3>Prestataires disponibles</h3>
                    <p>Awa K. - Menage</p>
                    <p>Jean M. - Jardinage</p>
                    <p>Fatou C. - Nounou</p>
                </section>
            </div>
            <div class="premium-floating-card mission-card">
                <strong>Mission validee</strong>
                <span>Client confirme</span>
            </div>
            <div class="premium-floating-card growth-card">
                <strong>+34%</strong>
                <span>Ce mois</span>
            </div>
        </div>
    </section>

    <section id="faq" class="premium-section premium-faq-section">
        <div class="premium-section-head centered">
            <p class="premium-label">FAQ</p>
            <h2>Foire aux questions</h2>
        </div>

        <div class="premium-faq">
            <details open>
                <summary>Comment sont verifiees les entreprises sur Kaza ?</summary>
                <p>Nous verifions les informations de l'entreprise, les documents essentiels et le contact responsable avant l'activation complete.</p>
            </details>
            <details>
                <summary>L'inscription est-elle gratuite ?</summary>
                <p>Oui. L'inscription est gratuite. Kaza applique ensuite une commission uniquement sur les missions realisees.</p>
            </details>
            <details>
                <summary>Puis-je refuser une demande client ?</summary>
                <p>Oui. Votre entreprise reste libre d'accepter les demandes qui correspondent a son equipe, sa zone et ses disponibilites.</p>
            </details>
            <details>
                <summary>Qui choisit le prestataire ?</summary>
                <p>Vous pouvez affecter vous-meme un prestataire depuis le portail ou laisser Kaza vous accompagner selon le mode choisi.</p>
            </details>
            <details>
                <summary>Comment sont suivis les paiements ?</summary>
                <p>Le portail permet de suivre les paiements Mobile Money, les encaissements terrain et les commissions.</p>
            </details>
            <details>
                <summary>Combien de temps prend la validation ?</summary>
                <p>Elle depend de la qualite du dossier. Plus les informations sont claires, plus la validation est rapide.</p>
            </details>
        </div>
    </section>

    <section id="contact" class="premium-section premium-contact-section">
        <div class="premium-contact-copy">
            <p class="premium-label">Contact</p>
            <h2>Vous voulez en parler avant de vous inscrire ?</h2>
            <p>Laissez vos coordonnees. Nous vous rappelons pour voir comment Kaza peut aider votre entreprise.</p>
            <div class="premium-contact-tags">
                <span>Abidjan</span>
                <span>Services a domicile</span>
                <span>Partenariat entreprise</span>
            </div>
        </div>

        <form class="premium-contact-form" @onsubmit="SubmitContactAsync" @onsubmit:preventDefault>
            <div class="premium-form-grid">
                <label>Nom complet<input placeholder="Ex: Jean Kouadio" @bind="ContactName" /></label>
                <label>Entreprise<input placeholder="Ex: CI Home Service" @bind="ContactCompany" /></label>
                <label>Telephone<input type="tel" placeholder="+225 07 00 00 00 00" @bind="ContactPhone" /></label>
                <label>Email<input type="email" placeholder="direction@entreprise.ci" @bind="ContactEmail" /></label>
            </div>
            <label>
                Sujet
                <select @bind="ContactSubject">
                    <option>Devenir partenaire</option>
                    <option>Comprendre le fonctionnement</option>
                    <option>Suivi d'une demande</option>
                    <option>Autre demande</option>
                </select>
            </label>
            <label>
                Message
                <textarea rows="5" placeholder="Expliquez rapidement votre besoin..." @bind="ContactBody"></textarea>
            </label>

            @if (!string.IsNullOrWhiteSpace(ContactMessage))
            {
                <p class="field-message">@ContactMessage</p>
            }

            <button type="submit" class="premium-primary">Envoyer le message</button>
        </form>
    </section>

    <footer class="premium-footer">
        <div>
            <strong>Kaza</strong>
            <p>La plateforme qui connecte les clients aux entreprises de services a domicile verifiees.</p>
        </div>
        <nav aria-label="Produit">
            <h2>Produit</h2>
            <a href="#how">Comment ca marche</a>
            <a href="#dashboard">Dashboard</a>
            <a href="#faq">FAQ</a>
        </nav>
        <nav aria-label="Entreprise">
            <h2>Entreprise</h2>
            <a href="register">Devenir partenaire</a>
            <a href="dashboard">Se connecter</a>
            <a href="#contact">Contact</a>
        </nav>
        <nav aria-label="Legal">
            <h2>Legal</h2>
            <a href="#contact">Support</a>
            <a href="#contact">Conditions partenaires</a>
            <a href="#contact">Confidentialite</a>
        </nav>
    </footer>
</div>

@code {
    private bool IsSubmittedConfirmationVisible { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string ContactCompany { get; set; } = string.Empty;
    private string ContactPhone { get; set; } = string.Empty;
    private string ContactEmail { get; set; } = string.Empty;
    private string ContactSubject { get; set; } = "Devenir partenaire";
    private string ContactBody { get; set; } = string.Empty;
    private string? ContactMessage { get; set; }

    private string LandingVariant
    {
        get
        {
            var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return path is "bleu" or "vert" or "noir" or "apple" ? path : string.Empty;
        }
    }

    private string LandingThemeClass => LandingVariant switch
    {
        "bleu" => "company-landing premium-b2b premium-theme-blue",
        "vert" => "company-landing premium-b2b premium-theme-green",
        "noir" => "company-landing premium-b2b premium-theme-black",
        "apple" => "company-landing premium-b2b premium-theme-apple",
        _ => "company-landing premium-b2b premium-theme-blue"
    };

    protected override void OnInitialized()
    {
        IsSubmittedConfirmationVisible = new Uri(Navigation.Uri)
            .Query
            .Contains("submitted=1", StringComparison.OrdinalIgnoreCase);
    }

    private Task SubmitContactAsync()
    {
        if (string.IsNullOrWhiteSpace(ContactName)
            || string.IsNullOrWhiteSpace(ContactCompany)
            || string.IsNullOrWhiteSpace(ContactPhone)
            || string.IsNullOrWhiteSpace(ContactBody))
        {
            ContactMessage = "Renseignez au moins le nom, l'entreprise, le telephone et le message.";
            return Task.CompletedTask;
        }

        ContactMessage = "Message pret a etre transmis. Le branchement email/API sera ajoute a la prochaine etape.";
        return Task.CompletedTask;
    }
}

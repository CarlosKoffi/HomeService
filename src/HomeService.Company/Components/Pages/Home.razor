@page "/"
@inject NavigationManager Navigation
@inject PlatformApiClient ApiClient

<PageTitle>wélé Entreprises</PageTitle>

@if (IsSubmittedConfirmationVisible)
{
    <section class="submission-confirmation">
        <strong>Demande envoyee</strong>
        <p>Votre dossier a bien ete transmis. Notre equipe va verifier les informations et revenir vers vous.</p>
    </section>
}

<div class="company-landing premium-b2b">
    <section id="home" class="premium-hero">
        <img class="premium-hero-image" src="@ResolveContentUrl(HomeContent.Hero.ImageUrl)" alt="@HomeContent.Hero.ImageAlt" />
        <div class="premium-hero-overlay"></div>
        <div class="premium-hero-content">
            <p class="premium-label">@HomeContent.Hero.Label</p>
            <h1>
                @HeroHeadline.Main
                @if (!string.IsNullOrWhiteSpace(HeroHeadline.Highlight))
                {
                    <span>@HeroHeadline.Highlight</span>
                }
            </h1>
            <p>@HomeContent.Hero.Subtitle</p>
            <div class="premium-actions">
                <a class="premium-primary" href="@HomeContent.Hero.PrimaryCta.Url">@HomeContent.Hero.PrimaryCta.Label</a>
                <a class="premium-secondary" href="@HomeContent.Hero.SecondaryCta.Url">@HomeContent.Hero.SecondaryCta.Label</a>
            </div>
            <div class="premium-proof" aria-label="Indicateurs wélé">
                @foreach (var proof in HomeContent.Hero.ProofItems)
                {
                    <span>@proof</span>
                }
            </div>
        </div>
    </section>

    <section id="how" class="premium-section">
        <div class="premium-section-head">
            <p class="premium-label">@HomeContent.Steps.Label</p>
            <h2>@HomeContent.Steps.Headline</h2>
            <p>@HomeContent.Steps.Subtitle</p>
        </div>

        <div class="premium-how-grid">
            @foreach (var step in HomeContent.Steps.Items)
            {
                <article>
                    <figure><img src="@ResolveContentUrl(step.Image)" alt="@step.Title" loading="lazy" /></figure>
                    <div class="premium-step-meta"><span>@step.Number</span><strong>@step.Label</strong></div>
                    <h3>@step.Title</h3>
                    <p>@step.Text</p>
                </article>
            }
        </div>
    </section>

    <section id="trusted" class="premium-trusted" aria-label="Entreprises partenaires">
        <p>@HomeContent.Trusted.Headline</p>
        <div>
            @foreach (var item in HomeContent.Trusted.Items)
            {
                <span>@item</span>
            }
        </div>
    </section>

    <section id="dashboard" class="premium-section premium-dashboard-section">
        <div class="premium-section-head">
            <p class="premium-label">@HomeContent.Dashboard.Label</p>
            <h2>@HomeContent.Dashboard.Headline</h2>
            <p>@HomeContent.Dashboard.Subtitle</p>
        </div>

        <div class="premium-dashboard">
            <div class="premium-dashboard-top">
                <div><span></span><strong>wélé Partner</strong></div>
                <small>Aujourd'hui</small>
            </div>
            <div class="premium-dashboard-stats">
                @foreach (var stat in HomeContent.Dashboard.Stats)
                {
                    <article><span>@stat.Label</span><strong>@stat.Value</strong><small>@stat.Help</small></article>
                }
            </div>
            <div class="premium-dashboard-body">
                <section>
                    <h3>Demandes en cours</h3>
                    @foreach (var request in HomeContent.Dashboard.Requests)
                    {
                        <p>@request</p>
                    }
                </section>
                <section>
                    <h3>Prestataires disponibles</h3>
                    @foreach (var provider in HomeContent.Dashboard.Providers)
                    {
                        <p>@provider</p>
                    }
                </section>
            </div>
            <div class="premium-floating-card mission-card">
                <strong>Mission validee</strong>
                <span>Client confirme</span>
            </div>
            <div class="premium-floating-card growth-card">
                <strong>+34%</strong>
                <span>Ce mois</span>
            </div>
        </div>
    </section>

    <section id="faq" class="premium-section premium-faq-section">
        <div class="premium-section-head centered">
            <p class="premium-label">@HomeContent.Faq.Label</p>
            <h2>@HomeContent.Faq.Headline</h2>
        </div>

        <div class="premium-faq">
            @foreach (var item in HomeContent.Faq.Questions.Select((question, index) => new { question, index }))
            {
                <details open="@(item.index == 0)">
                    <summary>@item.question.Question</summary>
                    <p>@item.question.Answer</p>
                </details>
            }
        </div>
    </section>

    <section id="contact" class="premium-section premium-contact-section">
        <div class="premium-contact-copy">
            <p class="premium-label">@HomeContent.Contact.Label</p>
            <h2>@HomeContent.Contact.Headline</h2>
            <p>@HomeContent.Contact.Subtitle</p>
            <div class="premium-contact-tags">
                @foreach (var tag in HomeContent.Contact.Tags)
                {
                    <span>@tag</span>
                }
            </div>
        </div>

        <form class="premium-contact-form" @onsubmit="SubmitContactAsync" @onsubmit:preventDefault>
            <div class="premium-form-grid">
                <label>Nom complet<input placeholder="Ex: Jean Kouadio" @bind="ContactName" /></label>
                <label>Entreprise<input placeholder="Ex: CI Home Service" @bind="ContactCompany" /></label>
                <label>Telephone<input type="tel" placeholder="+225 07 00 00 00 00" @bind="ContactPhone" /></label>
                <label>Email<input type="email" placeholder="direction@entreprise.ci" @bind="ContactEmail" /></label>
            </div>
            <label>
                Sujet
                <select @bind="ContactSubject">
                    <option>Devenir partenaire</option>
                    <option>Comprendre le fonctionnement</option>
                    <option>Suivi d'une demande</option>
                    <option>Autre demande</option>
                </select>
            </label>
            <label>
                Message
                <textarea rows="5" placeholder="Expliquez rapidement votre besoin..." @bind="ContactBody"></textarea>
            </label>

            @if (!string.IsNullOrWhiteSpace(ContactMessage))
            {
                <p class="field-message">@ContactMessage</p>
            }

            <button type="submit" class="premium-primary">Envoyer le message</button>
        </form>
    </section>

    <footer class="premium-footer">
        <div class="premium-footer-brand">
            <a class="premium-footer-logo" href="#home" aria-label="Retour accueil wélé">
                <img src="images/wele-logo.png" alt="wélé" />
            </a>
            <p>@HomeContent.Footer.BrandText</p>
        </div>
        @foreach (var column in HomeContent.Footer.Columns)
        {
            <nav aria-label="@column.Title">
                <h2>@column.Title</h2>
                @foreach (var link in column.Links)
                {
                    <a href="#contact">@link</a>
                }
            </nav>
        }
        <div class="premium-footer-bottom">
            <span>@HomeContent.Footer.Copyright</span>
            <span>@HomeContent.Footer.Baseline</span>
        </div>
    </footer>
</div>

@code {
    private CompanyHomeCmsResponse HomeContent { get; set; } = CreateDefaultHomeContent();
    private HeroHeadlineParts HeroHeadline => SplitHeroHeadline(HomeContent.Hero.Headline);
    private bool IsSubmittedConfirmationVisible { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string ContactCompany { get; set; } = string.Empty;
    private string ContactPhone { get; set; } = string.Empty;
    private string ContactEmail { get; set; } = string.Empty;
    private string ContactSubject { get; set; } = "Devenir partenaire";
    private string ContactBody { get; set; } = string.Empty;
    private string? ContactMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        IsSubmittedConfirmationVisible = new Uri(Navigation.Uri)
            .Query
            .Contains("submitted=1", StringComparison.OrdinalIgnoreCase);

        HomeContent = await ApiClient.GetCompanyHomeContentAsync() ?? CreateDefaultHomeContent();
    }

    private Task SubmitContactAsync()
    {
        if (string.IsNullOrWhiteSpace(ContactName)
            || string.IsNullOrWhiteSpace(ContactCompany)
            || string.IsNullOrWhiteSpace(ContactPhone)
            || string.IsNullOrWhiteSpace(ContactBody))
        {
            ContactMessage = "Renseignez au moins le nom, l'entreprise, le telephone et le message.";
            return Task.CompletedTask;
        }

        ContactMessage = "Message pret a etre transmis. Le branchement email/API sera ajoute a la prochaine etape.";
        return Task.CompletedTask;
    }

    private string ResolveContentUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(url, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return url.StartsWith("/api/", StringComparison.OrdinalIgnoreCase)
            ? ApiClient.ToApiUrl(url)
            : NormalizeLegacyMediaUrl(url.TrimStart('/'));
    }

    private static string NormalizeLegacyMediaUrl(string url)
    {
        return url.Replace("images/kaza-", "images/wele-", StringComparison.OrdinalIgnoreCase);
    }

    private static HeroHeadlineParts SplitHeroHeadline(string headline)
    {
        const string marker = ". ";
        var index = headline.IndexOf(marker, StringComparison.Ordinal);
        return index < 0
            ? new HeroHeadlineParts(headline, string.Empty)
            : new HeroHeadlineParts(headline[..(index + 1)], headline[(index + marker.Length)..]);
    }

    private static CompanyHomeCmsResponse CreateDefaultHomeContent()
    {
        return new CompanyHomeCmsResponse(
            new CompanyHomeHeroCmsResponse(
                "Plateforme partenaire",
                "Recevez plus de missions. Developpez votre entreprise.",
                "wélé connecte les clients aux entreprises de services a domicile verifiees. Vous gardez le controle de vos equipes, de vos demandes et de vos interventions.",
                new CmsLinkResponse("Commencer", "register"),
                new CmsLinkResponse("Voir le fonctionnement", "#how"),
                "images/wele-premium-hero.png",
                "Equipe wélé en intervention chez un client",
                ["Inscription gratuite", "Validation dossier", "Portail entreprise"]),
            new CompanyHomeStepsCmsResponse(
                "Comment ca marche",
                "Trois etapes, puis votre portail est pret.",
                "Un parcours court pour verifier l'entreprise et demarrer avec une base claire.",
                [
                    new CmsStepResponse("01", "Compte", "Creez votre compte", "Renseignez votre entreprise, vos services et le contact responsable.", "images/wele-how-step-1.png"),
                    new CmsStepResponse("02", "Verification", "Nous verifions votre dossier", "wélé controle les informations pour securiser les clients et les missions.", "images/wele-how-step-2.png"),
                    new CmsStepResponse("03", "Portail", "Travaillez depuis votre portail", "Ajoutez vos prestataires, recevez des demandes et suivez vos interventions.", "images/wele-how-step-3.png")
                ]),
            new CompanyHomeTrustedCmsResponse(
                "Ils font confiance a wélé",
                ["Services verifies", "Entreprises locales", "Prestataires suivis", "Paiements traces", "Support partenaire"]),
            new CompanyHomeDashboardCmsResponse(
                "Dashboard",
                "Tout ce qui compte, lisible en un coup d'oeil.",
                "Demandes, equipe, missions, documents et paiements restent au meme endroit.",
                [
                    new CmsDashboardStatResponse("Demandes", "12", "+4 cette semaine"),
                    new CmsDashboardStatResponse("Assignees", "8", "Equipe mobilisee"),
                    new CmsDashboardStatResponse("Paiements", "185k", "XOF suivis")
                ],
                ["Menage a Cocody Riviera", "Jardinage a Marcory", "Nounou aux Deux Plateaux"],
                ["Awa K. - Menage", "Jean M. - Jardinage", "Fatou C. - Nounou"]),
            new CompanyHomeFaqCmsResponse(
                "FAQ",
                "Foire aux questions",
                [
                    new CmsFaqItemResponse("Comment sont verifiees les entreprises sur wélé ?", "Nous verifions les informations de l'entreprise, les documents essentiels et le contact responsable avant l'activation complete."),
                    new CmsFaqItemResponse("L'inscription est-elle gratuite ?", "Oui. L'inscription est gratuite. wélé applique ensuite une commission uniquement sur les missions realisees."),
                    new CmsFaqItemResponse("Puis-je refuser une demande client ?", "Oui. Votre entreprise reste libre d'accepter les demandes qui correspondent a son equipe, sa zone et ses disponibilites."),
                    new CmsFaqItemResponse("Qui choisit le prestataire ?", "Vous pouvez affecter vous-meme un prestataire depuis le portail ou laisser wélé vous accompagner selon le mode choisi."),
                    new CmsFaqItemResponse("Comment sont suivis les paiements ?", "Le portail permet de suivre les paiements Mobile Money, les encaissements terrain et les commissions."),
                    new CmsFaqItemResponse("Combien de temps prend la validation ?", "Elle depend de la qualite du dossier. Plus les informations sont claires, plus la validation est rapide.")
                ]),
            new CompanyHomeContactCmsResponse(
                "Contact",
                "Vous voulez en parler avant de vous inscrire ?",
                "Laissez vos coordonnees. Nous vous rappelons pour voir comment wélé peut aider votre entreprise.",
                ["Abidjan", "Services a domicile", "Partenariat entreprise"]),
            new CompanyHomeFooterCmsResponse(
                "La plateforme B2B pour connecter clients, entreprises et professionnels de confiance.",
                "(c) 2026 wélé Technologies. Tous droits reserves.",
                "Concu pour l'Afrique de l'Ouest",
                [
                    new CmsFooterColumnResponse("Produit", ["Plateforme", "Fonctionnement", "Tarifs", "Securite", "Integrations", "Changelog"]),
                    new CmsFooterColumnResponse("Entreprise", ["A propos", "Blog", "Carrieres", "Presse", "Partenaires"]),
                    new CmsFooterColumnResponse("Ressources", ["Documentation", "Centre d'aide", "Communaute", "Dashboard", "Etudes de cas"]),
                    new CmsFooterColumnResponse("Legal", ["CGU", "Confidentialite", "Cookies", "Mentions legales", "Conditions partenaires"])
                ]));
    }

    private sealed record HeroHeadlineParts(string Main, string Highlight);
}

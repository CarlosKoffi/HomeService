@page "/register"
@using HomeService.Company.Services
@using HomeService.Contracts.Companies
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using System.Text.RegularExpressions
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Inscription entreprise</PageTitle>

<header class="registration-header">
    <p class="eyebrow">Inscription entreprise</p>
    <h1>Creer votre compte entreprise</h1>
    <p>
        Commencez en quelques minutes. Les documents de conformite seront ajoutes ensuite depuis votre espace entreprise
        ou deposes directement dans nos bureaux.
    </p>
</header>

<form class="registration-form">
    <div class="registration-steps" aria-label="Progression inscription">
        <span class="@(Step == 1 ? "active" : "done")">1. Entreprise</span>
        <span class="@(Step == 2 ? "active" : null)">2. Responsable</span>
    </div>

    @if (Step == 1)
    {
        <section>
            <div class="section-intro">
                <h2>Entreprise et services envisages</h2>
                <p>Aucun document n'est requis a cette etape. Vous pourrez les ajouter apres creation du compte.</p>
            </div>
            <label>
                Nom de l'entreprise
                <input name="companyName" type="text" autocomplete="organization" placeholder="Ex: CI Home Services SARL" @bind="CompanyName" />
            </label>
            <label>
                Ville
                <input name="city" type="text" autocomplete="address-level2" placeholder="Ex: Abidjan" @bind="City" />
            </label>
            <label>
                Adresse ou zone principale
                <input name="address" type="text" autocomplete="street-address" placeholder="Ex: Cocody Angre, 7e tranche" @bind="Address" />
            </label>

            <div class="service-picker">
                <div class="service-picker-heading">
                    <strong>Services proposes</strong>
                    <span>Choisissez les services que votre entreprise peut assurer.</span>
                </div>

                <div class="suggested-tags" aria-label="Services existants">
                    @foreach (var service in ExistingServices)
                    {
                        <button type="button"
                                class="service-tag @(IsSelected(service) ? "selected" : null)"
                                @onclick="() => ToggleExistingService(service)">
                            @service
                        </button>
                    }
                </div>
            </div>

        <label class="tag-entry">
            Ajouter un service
            <input name="serviceEntry"
                   type="text"
                   placeholder="Ex: nettoyage de bureaux"
                   @bind="ServiceEntry"
                   @bind:event="oninput"
                   @onkeyup="HandleServiceEntryKeyUp" />
            <small>Appuyez sur Entree ou ajoutez une virgule pour creer un tag.</small>
        </label>

        @if (!string.IsNullOrWhiteSpace(ServiceMessage))
        {
            <p class="field-message">@ServiceMessage</p>
        }

        <div class="selected-service-tags" aria-label="Services selectionnes">
            @foreach (var service in SelectedServices)
            {
                <span class="@(service.IsProposed ? "proposed" : null)">
                    @service.Name
                    @if (service.IsProposed)
                    {
                        <em>propose</em>
                    }
                    <button type="button" aria-label="Retirer @service.Name" @onclick="() => RemoveService(service.Name)">x</button>
                </span>
            }
        </div>

        <p class="field-hint">Les nouveaux services seront verifies avant publication. Les services proches seront regroupes par notre equipe.</p>

        <label>
            Nombre approximatif de prestataires
            <input name="providerCount" type="number" min="1" placeholder="Ex: 25" @bind="EstimatedProviderCount" />
        </label>
        </section>
    }
    else
    {
        <section>
            <div class="section-intro">
                <h2>Contact responsable et acces</h2>
                <p>Cette personne gerera le compte entreprise et suivra la validation des documents.</p>
            </div>
            <label>
                Nom complet
                <input name="ownerName" type="text" autocomplete="name" placeholder="Ex: David Gnahoua" @bind="ContactName" />
            </label>
            <label>
                Email professionnel
                <input name="email" type="email" autocomplete="email" placeholder="Ex: dg@cibank.ci" @bind="Email" />
            </label>
            <label>
                Telephone
                <input name="phone" type="tel" autocomplete="tel" placeholder="Ex: +2250700000000" @bind="PhoneNumber" />
            </label>
            <label>
                Mot de passe
                <input name="password" type="password" autocomplete="new-password" placeholder="Au moins 10 caracteres" @bind="Password" />
            </label>
            <label>
                Confirmer le mot de passe
                <input name="confirmPassword" type="password" autocomplete="new-password" placeholder="Retapez le meme mot de passe" @bind="ConfirmPassword" />
            </label>
            <div class="compliance-note">
                <strong>Apres creation</strong>
                <span>Votre compte sera accessible en mode limite. Les affectations et fonctions sensibles seront activees apres validation des pieces.</span>
            </div>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(FormMessage))
    {
        <p class="field-message">@FormMessage</p>
    }

    @if (ValidationErrors.Count > 0)
    {
        <div class="validation-summary">
            <strong>Avant d'envoyer, corrigez ces points :</strong>
            @foreach (var error in ValidationErrors)
            {
                <span>@error</span>
            }
        </div>
    }

    <div class="form-actions">
        @if (Step == 2)
        {
            <button type="button" class="secondary-action" disabled="@IsSubmitting" @onclick="Back">
                Retour
            </button>
        }
        <button type="button" class="primary-action" disabled="@IsSubmitting" @onclick="PrimaryActionAsync">
            @(Step == 1 ? "Continuer" : IsSubmitting ? "Creation en cours..." : "Creer le compte entreprise")
        </button>
    </div>
</form>

@code {
    private IReadOnlyList<string> ExistingServices { get; set; } = [];
    private readonly List<ServiceTag> SelectedServices = [];
    private string ServiceEntry { get; set; } = string.Empty;
    private string? ServiceMessage { get; set; }
    private string? FormMessage { get; set; }
    private bool IsSubmitting { get; set; }
    private int Step { get; set; } = 1;
    private string CompanyName { get; set; } = string.Empty;
    private string City { get; set; } = string.Empty;
    private string? Address { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string ConfirmPassword { get; set; } = string.Empty;
    private int? EstimatedProviderCount { get; set; }
    private List<string> ValidationErrors { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var services = await ApiClient.GetServicesAsync();
            ExistingServices = services.Where(service => service.IsActive).Select(service => service.Name).ToList();
            foreach (var service in ExistingServices.Take(2))
            {
                SelectedServices.Add(new ServiceTag(service, false));
            }
        }
        catch
        {
            ExistingServices = ["Menage a domicile", "Nounou", "Jardinage"];
            SelectedServices.AddRange(ExistingServices.Take(2).Select(service => new ServiceTag(service, false)));
            FormMessage = "Connexion API indisponible: liste locale chargee temporairement.";
        }
    }

    private bool IsSelected(string service)
    {
        return SelectedServices.Any(item => IsSameService(item.Name, service));
    }

    private void ToggleExistingService(string service)
    {
        ServiceMessage = null;

        if (IsSelected(service))
        {
            RemoveService(service);
            return;
        }

        SelectedServices.Add(new ServiceTag(service, false));
    }

    private void RemoveService(string service)
    {
        var item = SelectedServices.FirstOrDefault(candidate => IsSameService(candidate.Name, service));
        if (item is not null)
        {
            SelectedServices.Remove(item);
        }
    }

    private void HandleServiceEntryKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || ServiceEntry.EndsWith(",", StringComparison.Ordinal))
        {
            AddTypedService();
        }
    }

    private void AddTypedService()
    {
        var service = ServiceEntry.Trim().Trim(',');
        ServiceMessage = null;

        if (service.Length < 3)
        {
            ServiceMessage = "Entrez au moins 3 caracteres.";
            return;
        }

        if (SelectedServices.Count >= 10)
        {
            ServiceMessage = "Vous pouvez ajouter jusqu'a 10 services.";
            return;
        }

        var existingMatch = ExistingServices.FirstOrDefault(existing => IsSameService(existing, service));
        var serviceName = existingMatch ?? service;

        if (SelectedServices.Any(item => IsSameService(item.Name, serviceName)))
        {
            ServiceMessage = "Service deja ajoute.";
            ServiceEntry = string.Empty;
            return;
        }

        SelectedServices.Add(new ServiceTag(serviceName, existingMatch is null));
        ServiceEntry = string.Empty;
    }

    private async Task PrimaryActionAsync()
    {
        FormMessage = null;
        ValidationErrors = Step == 1 ? ValidateCompanyStep() : ValidateContactStep();

        if (ValidationErrors.Count > 0)
        {
            return;
        }

        if (Step == 1)
        {
            Step = 2;
            return;
        }

        await SubmitAsync();
    }

    private void Back()
    {
        FormMessage = null;
        ValidationErrors = [];
        Step = 1;
    }

    private async Task SubmitAsync()
    {
        FormMessage = null;
        ValidationErrors = ValidateCompanyStep().Concat(ValidateContactStep()).ToList();

        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSubmitting = true;
        try
        {
            var request = new RegisterCompanyRequest(
                CompanyName,
                null,
                City,
                Address,
                ContactName,
                Email,
                PhoneNumber,
                Password,
                ConfirmPassword,
                SelectedServices.Select(service => service.Name).ToList(),
                EstimatedProviderCount);

            var result = await ApiClient.RegisterCompanyAsync(request);
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/dashboard?registered=1&email={Uri.EscapeDataString(Email.Trim())}");
                return;
            }

            FormMessage = $"Impossible d'envoyer la demande: {result.ErrorMessage}";
        }
        catch (Exception exception)
        {
            FormMessage = $"Impossible d'envoyer la demande: {exception.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private List<string> ValidateCompanyStep()
    {
        var errors = new List<string>();

        if (CompanyName.Trim().Length < 3)
        {
            errors.Add("Le nom legal de l'entreprise doit contenir au moins 3 caracteres.");
        }

        if (City.Trim().Length < 2)
        {
            errors.Add("La ville est obligatoire.");
        }

        if (EstimatedProviderCount is not null and (< 1 or > 10000))
        {
            errors.Add("Le nombre de prestataires doit etre compris entre 1 et 10000.");
        }

        if (SelectedServices.Count == 0)
        {
            errors.Add("Selectionnez au moins un service envisage.");
        }

        return errors;
    }

    private List<string> ValidateContactStep()
    {
        var errors = new List<string>();

        if (ContactName.Trim().Length < 3)
        {
            errors.Add("Le nom complet du responsable est obligatoire.");
        }

        if (!IsValidEmail(Email))
        {
            errors.Add("L'email professionnel n'est pas valide.");
        }

        if (!IsValidPhoneNumber(PhoneNumber))
        {
            errors.Add("Le telephone doit contenir entre 8 et 15 chiffres. Exemple: +2250700000000.");
        }

        if (Password.Length < 10)
        {
            errors.Add("Le mot de passe doit contenir au moins 10 caracteres.");
        }

        if (Password != ConfirmPassword)
        {
            errors.Add("Les deux mots de passe ne correspondent pas.");
        }

        return errors;
    }

    private static bool IsValidEmail(string value)
    {
        return Regex.IsMatch(value.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.IgnoreCase);
    }

    private static bool IsValidPhoneNumber(string value)
    {
        var digits = Regex.Replace(value, @"\D", string.Empty);
        return digits.Length is >= 8 and <= 15;
    }

    private static bool IsSameService(string left, string right)
    {
        return Normalize(left) == Normalize(right);
    }

    private static string Normalize(string value)
    {
        return value.Trim().ToLowerInvariant();
    }

    private sealed record ServiceTag(string Name, bool IsProposed);
}

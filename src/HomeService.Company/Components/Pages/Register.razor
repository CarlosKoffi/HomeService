@page "/register"
@using HomeService.Company.Services
@using HomeService.Contracts.Companies
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject PlatformApiClient ApiClient

<PageTitle>Inscription entreprise</PageTitle>

<h1>Demande d'inscription</h1>
<p class="lead">
    Ce formulaire permet a votre entreprise de demander son acces ProxiPro. Notre equipe verifiera les informations
    et les pieces fournies. Si le dossier est valide, vous recevrez un lien par email pour creer votre mot de passe.
</p>

<form class="registration-form">
    <section>
        <h2>Entreprise</h2>
        <label>
            Nom legal de l'entreprise
            <input name="companyName" type="text" autocomplete="organization" @bind="CompanyName" />
        </label>
        <label>
            Numero RCCM ou identifiant legal
            <input name="registrationNumber" type="text" @bind="RegistrationNumber" />
        </label>
        <label>
            Ville
            <input name="city" type="text" autocomplete="address-level2" @bind="City" />
        </label>
        <label>
            Adresse
            <input name="address" type="text" autocomplete="street-address" @bind="Address" />
        </label>
    </section>

    <section>
        <h2>Contact responsable</h2>
        <label>
            Nom complet
            <input name="ownerName" type="text" autocomplete="name" @bind="ContactName" />
        </label>
        <label>
            Email professionnel
            <input name="email" type="email" autocomplete="email" @bind="Email" />
        </label>
        <label>
            Telephone
            <input name="phone" type="tel" autocomplete="tel" @bind="PhoneNumber" />
        </label>
    </section>

    <section class="documents-section">
        <div class="section-intro">
            <h2>Pieces justificatives</h2>
            <p>Formats acceptes: PDF, JPG ou PNG. Privilegiez des fichiers lisibles et legers pour faciliter la verification.</p>
        </div>

        <div class="upload-grid">
            <label class="upload-card required">
                <span class="upload-icon">DFE</span>
                <span class="upload-content">
                    <strong>DFE</strong>
                    <small>Declaration Fiscale d'Existence</small>
                    <em>@GetDocumentLabel("fiscalExistenceDeclaration", "Document obligatoire")</em>
                </span>
                <span class="upload-action">Choisir</span>
                <InputFile OnChange="SetFiscalExistenceDeclaration" accept=".pdf,.jpg,.jpeg,.png" />
            </label>

            <label class="upload-card required">
                <span class="upload-icon">RC</span>
                <span class="upload-content">
                    <strong>Registre de commerce</strong>
                    <small>RCCM ou document legal equivalent</small>
                    <em>@GetDocumentLabel("companyDocument", "Document obligatoire")</em>
                </span>
                <span class="upload-action">Choisir</span>
                <InputFile OnChange="SetCompanyDocument" accept=".pdf,.jpg,.jpeg,.png" />
            </label>

            <label class="upload-card required">
                <span class="upload-icon">ID</span>
                <span class="upload-content">
                    <strong>Identite du responsable</strong>
                    <small>CNI, passeport ou document officiel</small>
                    <em>@GetDocumentLabel("ownerIdentityDocument", "Document obligatoire")</em>
                </span>
                <span class="upload-action">Choisir</span>
                <InputFile OnChange="SetOwnerIdentityDocument" accept=".pdf,.jpg,.jpeg,.png" />
            </label>

            <label class="upload-card">
                <span class="upload-icon">ADR</span>
                <span class="upload-content">
                    <strong>Justificatif d'adresse</strong>
                    <small>Facture, bail ou attestation</small>
                    <em>@GetDocumentLabel("addressProof", "Recommande")</em>
                </span>
                <span class="upload-action">Choisir</span>
                <InputFile OnChange="SetAddressProof" accept=".pdf,.jpg,.jpeg,.png" />
            </label>
        </div>
    </section>

    <section class="services-section">
        <div class="section-intro">
            <h2>Services envisages</h2>
            <p>Selectionnez les services que votre entreprise souhaite proposer. Vous pouvez aussi en ajouter un nouveau.</p>
        </div>

        <div class="suggested-tags" aria-label="Services existants">
            @foreach (var service in ExistingServices)
            {
                <button type="button"
                        class="service-tag @(IsSelected(service) ? "selected" : null)"
                        @onclick="() => ToggleExistingService(service)">
                    @service
                </button>
            }
        </div>

        <label class="tag-entry">
            Ajouter un service
            <input name="serviceEntry"
                   type="text"
                   placeholder="Ex: nettoyage de bureaux"
                   @bind="ServiceEntry"
                   @bind:event="oninput"
                   @onkeyup="HandleServiceEntryKeyUp" />
            <small>Appuyez sur Entree ou ajoutez une virgule pour creer un tag.</small>
        </label>

        @if (!string.IsNullOrWhiteSpace(ServiceMessage))
        {
            <p class="field-message">@ServiceMessage</p>
        }

        <div class="selected-service-tags" aria-label="Services selectionnes">
            @foreach (var service in SelectedServices)
            {
                <span class="@(service.IsProposed ? "proposed" : null)">
                    @service.Name
                    @if (service.IsProposed)
                    {
                        <em>propose</em>
                    }
                    <button type="button" aria-label="Retirer @service.Name" @onclick="() => RemoveService(service.Name)">x</button>
                </span>
            }
        </div>

        <p class="field-hint">Les nouveaux services seront verifies avant publication. Les services proches seront regroupes par notre equipe.</p>

        <label>
            Nombre approximatif de prestataires
            <input name="providerCount" type="number" min="1" @bind="EstimatedProviderCount" />
        </label>
    </section>

    @if (!string.IsNullOrWhiteSpace(FormMessage))
    {
        <p class="field-message">@FormMessage</p>
    }

    <button type="button" class="primary-action" disabled="@IsSubmitting" @onclick="SubmitAsync">
        @(IsSubmitting ? "Envoi en cours..." : "Envoyer la demande")
    </button>
</form>

@code {
    private IReadOnlyList<string> ExistingServices { get; set; } = [];
    private readonly List<ServiceTag> SelectedServices = [];
    private string ServiceEntry { get; set; } = string.Empty;
    private string? ServiceMessage { get; set; }
    private string? FormMessage { get; set; }
    private bool IsSubmitting { get; set; }
    private string CompanyName { get; set; } = string.Empty;
    private string? RegistrationNumber { get; set; }
    private string City { get; set; } = string.Empty;
    private string? Address { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private int? EstimatedProviderCount { get; set; }
    private readonly Dictionary<string, IBrowserFile?> Documents = new(StringComparer.OrdinalIgnoreCase)
    {
        ["fiscalExistenceDeclaration"] = null,
        ["companyDocument"] = null,
        ["ownerIdentityDocument"] = null,
        ["addressProof"] = null
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var services = await ApiClient.GetServicesAsync();
            ExistingServices = services.Where(service => service.IsActive).Select(service => service.Name).ToList();
            foreach (var service in ExistingServices.Take(2))
            {
                SelectedServices.Add(new ServiceTag(service, false));
            }
        }
        catch
        {
            ExistingServices = ["Menage a domicile", "Nounou", "Jardinage"];
            SelectedServices.AddRange(ExistingServices.Take(2).Select(service => new ServiceTag(service, false)));
            FormMessage = "Connexion API indisponible: liste locale chargee temporairement.";
        }
    }

    private bool IsSelected(string service)
    {
        return SelectedServices.Any(item => IsSameService(item.Name, service));
    }

    private void ToggleExistingService(string service)
    {
        ServiceMessage = null;

        if (IsSelected(service))
        {
            RemoveService(service);
            return;
        }

        SelectedServices.Add(new ServiceTag(service, false));
    }

    private void RemoveService(string service)
    {
        var item = SelectedServices.FirstOrDefault(candidate => IsSameService(candidate.Name, service));
        if (item is not null)
        {
            SelectedServices.Remove(item);
        }
    }

    private void HandleServiceEntryKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || ServiceEntry.EndsWith(",", StringComparison.Ordinal))
        {
            AddTypedService();
        }
    }

    private void AddTypedService()
    {
        var service = ServiceEntry.Trim().Trim(',');
        ServiceMessage = null;

        if (service.Length < 3)
        {
            ServiceMessage = "Entrez au moins 3 caracteres.";
            return;
        }

        if (SelectedServices.Count >= 10)
        {
            ServiceMessage = "Vous pouvez ajouter jusqu'a 10 services.";
            return;
        }

        var existingMatch = ExistingServices.FirstOrDefault(existing => IsSameService(existing, service));
        var serviceName = existingMatch ?? service;

        if (SelectedServices.Any(item => IsSameService(item.Name, serviceName)))
        {
            ServiceMessage = "Service deja ajoute.";
            ServiceEntry = string.Empty;
            return;
        }

        SelectedServices.Add(new ServiceTag(serviceName, existingMatch is null));
        ServiceEntry = string.Empty;
    }

    private async Task SubmitAsync()
    {
        FormMessage = null;

        if (string.IsNullOrWhiteSpace(CompanyName)
            || string.IsNullOrWhiteSpace(City)
            || string.IsNullOrWhiteSpace(ContactName)
            || string.IsNullOrWhiteSpace(Email)
            || string.IsNullOrWhiteSpace(PhoneNumber))
        {
            FormMessage = "Merci de remplir les informations obligatoires avant d'envoyer la demande.";
            return;
        }

        if (Documents["fiscalExistenceDeclaration"] is null
            || Documents["companyDocument"] is null
            || Documents["ownerIdentityDocument"] is null)
        {
            FormMessage = "Merci d'ajouter le DFE, le registre de commerce et l'identite du responsable.";
            return;
        }

        IsSubmitting = true;
        var request = new RegisterCompanyRequest(
            CompanyName,
            RegistrationNumber,
            City,
            Address,
            ContactName,
            Email,
            PhoneNumber,
            SelectedServices.Select(service => service.Name).ToList(),
            EstimatedProviderCount);

        var success = await ApiClient.RegisterCompanyAsync(request, Documents);
        FormMessage = success
            ? "Demande envoyee. Notre equipe va verifier votre dossier."
            : "Impossible d'envoyer la demande pour le moment. Reessayez dans quelques instants.";
        IsSubmitting = false;
    }

    private void SetFiscalExistenceDeclaration(InputFileChangeEventArgs args)
    {
        SetDocument("fiscalExistenceDeclaration", args);
    }

    private void SetCompanyDocument(InputFileChangeEventArgs args)
    {
        SetDocument("companyDocument", args);
    }

    private void SetOwnerIdentityDocument(InputFileChangeEventArgs args)
    {
        SetDocument("ownerIdentityDocument", args);
    }

    private void SetAddressProof(InputFileChangeEventArgs args)
    {
        SetDocument("addressProof", args);
    }

    private void SetDocument(string key, InputFileChangeEventArgs args)
    {
        Documents[key] = args.File;
        FormMessage = null;
    }

    private string GetDocumentLabel(string key, string fallback)
    {
        return Documents.TryGetValue(key, out var file) && file is not null
            ? file.Name
            : fallback;
    }

    private static bool IsSameService(string left, string right)
    {
        return Normalize(left) == Normalize(right);
    }

    private static string Normalize(string value)
    {
        return value.Trim().ToLowerInvariant();
    }

    private sealed record ServiceTag(string Name, bool IsProposed);
}

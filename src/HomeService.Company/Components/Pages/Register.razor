@page "/register"
@using HomeService.Company.Services
@using HomeService.Contracts.Companies
@using HomeService.Contracts.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using System.Globalization
@using System.Text
@using System.Text.RegularExpressions
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Inscription entreprise</PageTitle>

<header class="registration-header">
    <p class="eyebrow">Inscription entreprise</p>
    <h1>Creer votre compte entreprise</h1>
    <p>
        Commencez en quelques minutes. Les documents de conformite seront ajoutes ensuite depuis votre espace entreprise
        ou deposes directement dans nos bureaux.
    </p>
</header>

<form class="registration-form">
    <div class="registration-steps" aria-label="Progression inscription">
        <span class="@(Step == 1 ? "active" : "done")">1. Entreprise</span>
        <span class="@(Step == 2 ? "active" : null)">2. Responsable</span>
    </div>

    @if (Step == 1)
    {
        <section>
            <div class="section-intro">
                <h2>Entreprise et services envisages</h2>
                <p>Aucun document n'est requis a cette etape. Vous pourrez les ajouter apres creation du compte.</p>
            </div>
            <label>
                Nom de l'entreprise
                <input name="companyName" type="text" autocomplete="organization" placeholder="Ex: CI Home Services SARL" @bind="CompanyName" />
            </label>
            <label>
                Ville
                <input name="city" type="text" autocomplete="address-level2" placeholder="Ex: Abidjan" @bind="City" />
            </label>
            <label>
                Adresse ou zone principale
                <input name="address" type="text" autocomplete="street-address" placeholder="Ex: Cocody Angre, 7e tranche" @bind="Address" />
            </label>

            <div class="service-autocomplete">
                <label class="tag-entry">
                    Service ou prestation proposee
                    <input name="serviceEntry"
                           type="text"
                           list="company-service-options"
                           placeholder="Ex: Jardinage, tondre le gazon, ou Jardinage: taille de palmiers"
                           @bind="ServiceEntry"
                           @bind:event="oninput"
                           @onkeyup="HandleServiceEntryKeyUp" />
                    <small>Choisissez une suggestion ou appuyez sur Entree pour ajouter votre saisie.</small>
                </label>
                <datalist id="company-service-options">
                    @foreach (var option in CatalogOptions)
                    {
                        <option value="@option.InputValue">@option.Helper</option>
                    }
                </datalist>
            </div>

        @if (!string.IsNullOrWhiteSpace(ServiceMessage))
        {
            <p class="field-message">@ServiceMessage</p>
        }

        <div class="selected-service-tags" aria-label="Services selectionnes">
            @foreach (var service in SelectedServices)
            {
                <span class="@(service.IsProposed ? "proposed" : null)">
                    @service.Label
                    @if (service.IsProposed)
                    {
                        <em>propose</em>
                    }
                    <button type="button" aria-label="Retirer @service.Label" @onclick="() => RemoveService(service.Key)">x</button>
                </span>
            }
        </div>

        <p class="field-hint">Les nouveaux services seront verifies avant publication. Les services proches seront regroupes par notre equipe.</p>

        <label>
            Nombre approximatif de prestataires
            <input name="providerCount" type="number" min="1" placeholder="Ex: 25" @bind="EstimatedProviderCount" />
        </label>
        </section>
    }
    else
    {
        <section>
            <div class="section-intro">
                <h2>Contact responsable et acces</h2>
                <p>Cette personne gerera le compte entreprise et suivra la validation des documents.</p>
            </div>
            <label>
                Nom complet
                <input name="ownerName" type="text" autocomplete="name" placeholder="Ex: David Gnahoua" @bind="ContactName" />
            </label>
            <label>
                Email professionnel
                <input name="email" type="email" autocomplete="email" placeholder="Ex: dg@cibank.ci" @bind="Email" />
            </label>
            <label>
                Telephone
                <input name="phone" type="tel" autocomplete="tel" placeholder="Ex: +2250700000000" @bind="PhoneNumber" />
            </label>
            <label>
                Mot de passe
                <input name="password" type="password" autocomplete="new-password" placeholder="Au moins 10 caracteres" @bind="Password" />
            </label>
            <label>
                Confirmer le mot de passe
                <input name="confirmPassword" type="password" autocomplete="new-password" placeholder="Retapez le meme mot de passe" @bind="ConfirmPassword" />
            </label>
            <div class="compliance-note">
                <strong>Apres creation</strong>
                <span>Votre compte sera accessible en mode limite. Les affectations et fonctions sensibles seront activees apres validation des pieces.</span>
            </div>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(FormMessage))
    {
        <p class="field-message">@FormMessage</p>
    }

    @if (ValidationErrors.Count > 0)
    {
        <div class="validation-summary">
            <strong>Avant d'envoyer, corrigez ces points :</strong>
            @foreach (var error in ValidationErrors)
            {
                <span>@error</span>
            }
        </div>
    }

    <div class="form-actions">
        @if (Step == 2)
        {
            <button type="button" class="secondary-action" disabled="@IsSubmitting" @onclick="Back">
                Retour
            </button>
        }
        <button type="button" class="primary-action" disabled="@IsSubmitting" @onclick="PrimaryActionAsync">
            @(Step == 1 ? "Continuer" : IsSubmitting ? "Creation en cours..." : "Creer le compte entreprise")
        </button>
    </div>
</form>

@code {
    private IReadOnlyList<ServiceSummaryResponse> CatalogServices { get; set; } = [];
    private IReadOnlyList<ServiceCatalogOption> CatalogOptions { get; set; } = [];
    private readonly List<ServiceSelection> SelectedServices = [];
    private string ServiceEntry { get; set; } = string.Empty;
    private string? ServiceMessage { get; set; }
    private string? FormMessage { get; set; }
    private bool IsSubmitting { get; set; }
    private int Step { get; set; } = 1;
    private string CompanyName { get; set; } = string.Empty;
    private string City { get; set; } = string.Empty;
    private string? Address { get; set; }
    private string ContactName { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string ConfirmPassword { get; set; } = string.Empty;
    private int? EstimatedProviderCount { get; set; }
    private List<string> ValidationErrors { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var services = await ApiClient.GetServicesAsync();
            CatalogServices = services.Where(service => service.IsActive).ToList();
            CatalogOptions = BuildCatalogOptions(CatalogServices);
            foreach (var service in CatalogServices.Take(2))
            {
                SelectedServices.Add(ServiceSelection.ForService(service.Name, false));
            }
        }
        catch
        {
            CatalogServices =
            [
                new ServiceSummaryResponse(Guid.Empty, "Menage a domicile", null, "sparkles", "Active", true, 3500, 5000, "XOF", []),
                new ServiceSummaryResponse(Guid.Empty, "Nounou", null, "baby", "Active", true, 4000, 6500, "XOF", []),
                new ServiceSummaryResponse(Guid.Empty, "Jardinage", null, "sprout", "Active", true, 4500, 6500, "XOF", [])
            ];
            CatalogOptions = BuildCatalogOptions(CatalogServices);
            SelectedServices.AddRange(CatalogServices.Take(2).Select(service => ServiceSelection.ForService(service.Name, false)));
            FormMessage = "Connexion API indisponible: liste locale chargee temporairement.";
        }
    }

    private void RemoveService(string service)
    {
        var item = SelectedServices.FirstOrDefault(candidate => candidate.Key == service);
        if (item is not null)
        {
            SelectedServices.Remove(item);
        }
    }

    private void HandleServiceEntryKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || ServiceEntry.EndsWith(",", StringComparison.Ordinal))
        {
            AddTypedService();
        }
    }

    private void AddTypedService()
    {
        var input = ServiceEntry.Trim().Trim(',');
        ServiceMessage = null;

        if (input.Length < 3)
        {
            ServiceMessage = "Entrez au moins 3 caracteres.";
            return;
        }

        if (SelectedServices.Count >= 10)
        {
            ServiceMessage = "Vous pouvez ajouter jusqu'a 10 services.";
            return;
        }

        var selection = ResolveServiceSelection(input);

        if (SelectedServices.Any(item => item.Key == selection.Key))
        {
            ServiceMessage = "Element deja ajoute.";
            ServiceEntry = string.Empty;
            return;
        }

        SelectedServices.Add(selection);
        ServiceEntry = string.Empty;
    }

    private async Task PrimaryActionAsync()
    {
        FormMessage = null;
        ValidationErrors = Step == 1 ? ValidateCompanyStep() : ValidateContactStep();

        if (ValidationErrors.Count > 0)
        {
            return;
        }

        if (Step == 1)
        {
            Step = 2;
            return;
        }

        await SubmitAsync();
    }

    private void Back()
    {
        FormMessage = null;
        ValidationErrors = [];
        Step = 1;
    }

    private async Task SubmitAsync()
    {
        FormMessage = null;
        ValidationErrors = ValidateCompanyStep().Concat(ValidateContactStep()).ToList();

        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSubmitting = true;
        try
        {
            var request = new RegisterCompanyRequest(
                CompanyName,
                null,
                City,
                Address,
                ContactName,
                Email,
                PhoneNumber,
                Password,
                ConfirmPassword,
                SelectedServices.Select(service => service.SubmittedName).Distinct(StringComparer.OrdinalIgnoreCase).ToList(),
                EstimatedProviderCount);

            var result = await ApiClient.RegisterCompanyAsync(request);
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/dashboard?registered=1&email={Uri.EscapeDataString(Email.Trim())}");
                return;
            }

            FormMessage = $"Impossible d'envoyer la demande: {result.ErrorMessage}";
        }
        catch (Exception exception)
        {
            FormMessage = $"Impossible d'envoyer la demande: {exception.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private List<string> ValidateCompanyStep()
    {
        var errors = new List<string>();

        if (CompanyName.Trim().Length < 3)
        {
            errors.Add("Le nom legal de l'entreprise doit contenir au moins 3 caracteres.");
        }

        if (City.Trim().Length < 2)
        {
            errors.Add("La ville est obligatoire.");
        }

        if (EstimatedProviderCount is not null and (< 1 or > 10000))
        {
            errors.Add("Le nombre de prestataires doit etre compris entre 1 et 10000.");
        }

        if (SelectedServices.Count == 0)
        {
            errors.Add("Selectionnez au moins un service ou une prestation envisagee.");
        }

        return errors;
    }

    private List<string> ValidateContactStep()
    {
        var errors = new List<string>();

        if (ContactName.Trim().Length < 3)
        {
            errors.Add("Le nom complet du responsable est obligatoire.");
        }

        if (!IsValidEmail(Email))
        {
            errors.Add("L'email professionnel n'est pas valide.");
        }

        if (!IsValidPhoneNumber(PhoneNumber))
        {
            errors.Add("Le telephone doit contenir entre 8 et 15 chiffres. Exemple: +2250700000000.");
        }

        if (Password.Length < 10)
        {
            errors.Add("Le mot de passe doit contenir au moins 10 caracteres.");
        }

        if (Password != ConfirmPassword)
        {
            errors.Add("Les deux mots de passe ne correspondent pas.");
        }

        return errors;
    }

    private static bool IsValidEmail(string value)
    {
        return Regex.IsMatch(value.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.IgnoreCase);
    }

    private static bool IsValidPhoneNumber(string value)
    {
        var digits = Regex.Replace(value, @"\D", string.Empty);
        return digits.Length is >= 8 and <= 15;
    }

    private ServiceSelection ResolveServiceSelection(string input)
    {
        var exactOption = CatalogOptions.FirstOrDefault(option => option.Matches(input));
        if (exactOption is not null)
        {
            return exactOption.ToSelection();
        }

        var fuzzyOption = CatalogOptions
            .Where(option => option.SearchValue.Contains(Normalize(input), StringComparison.Ordinal)
                || Normalize(input).Contains(option.SearchValue, StringComparison.Ordinal))
            .OrderBy(option => option.IsPrestation ? 0 : 1)
            .FirstOrDefault();

        if (fuzzyOption is not null)
        {
            return fuzzyOption.ToSelection();
        }

        var split = SplitServiceAndPrestation(input);
        if (split is not null)
        {
            var parent = CatalogServices.FirstOrDefault(service => Normalize(service.Name) == Normalize(split.Value.Service));
            if (parent is not null)
            {
                return ServiceSelection.ForPrestation(parent.Name, split.Value.Prestation, true);
            }
        }

        return ServiceSelection.ForService(input, true);
    }

    private static (string Service, string Prestation)? SplitServiceAndPrestation(string value)
    {
        var separators = new[] { ':', '/', '-' };
        foreach (var separator in separators)
        {
            var parts = value.Split(separator, 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2 && parts[0].Length >= 3 && parts[1].Length >= 3)
            {
                return (parts[0], parts[1]);
            }
        }

        return null;
    }

    private static IReadOnlyList<ServiceCatalogOption> BuildCatalogOptions(IReadOnlyList<ServiceSummaryResponse> services)
    {
        var options = new List<ServiceCatalogOption>();
        foreach (var service in services.OrderBy(item => item.Name))
        {
            options.Add(ServiceCatalogOption.ForService(service.Name));
            options.AddRange(service.Prestations
                .Where(prestation => prestation.IsActive)
                .OrderBy(prestation => prestation.SortOrder)
                .ThenBy(prestation => prestation.Name)
                .Select(prestation => ServiceCatalogOption.ForPrestation(service.Name, prestation.Name)));
        }

        return options;
    }

    private static string Normalize(string value)
    {
        var normalized = value.Trim().ToLowerInvariant().Normalize(NormalizationForm.FormD);
        return string.Concat(normalized.Where(character => CharUnicodeInfo.GetUnicodeCategory(character) != UnicodeCategory.NonSpacingMark))
            .Normalize(NormalizationForm.FormC);
    }

    private sealed record ServiceSelection(string Key, string Label, string SubmittedName, bool IsProposed)
    {
        public static ServiceSelection ForService(string serviceName, bool isProposed)
        {
            var cleanService = serviceName.Trim();
            return new ServiceSelection($"service:{Normalize(cleanService)}", cleanService, cleanService, isProposed);
        }

        public static ServiceSelection ForPrestation(string serviceName, string prestationName, bool isProposed)
        {
            var cleanService = serviceName.Trim();
            var cleanPrestation = prestationName.Trim();
            return new ServiceSelection(
                $"prestation:{Normalize(cleanService)}:{Normalize(cleanPrestation)}",
                $"{cleanService} - {cleanPrestation}",
                cleanService,
                isProposed);
        }
    }

    private sealed record ServiceCatalogOption(string InputValue, string ServiceName, string? PrestationName, string Helper, bool IsPrestation)
    {
        public string SearchValue { get; } = Normalize($"{InputValue} {ServiceName} {PrestationName}");

        public static ServiceCatalogOption ForService(string serviceName)
        {
            return new ServiceCatalogOption(serviceName, serviceName, null, "Service", false);
        }

        public static ServiceCatalogOption ForPrestation(string serviceName, string prestationName)
        {
            return new ServiceCatalogOption(prestationName, serviceName, prestationName, $"Prestation - {serviceName}", true);
        }

        public bool Matches(string value)
        {
            var normalizedValue = Normalize(value);
            return normalizedValue == Normalize(InputValue)
                || normalizedValue == Normalize($"{ServiceName} - {PrestationName}")
                || normalizedValue == Normalize($"{ServiceName}: {PrestationName}");
        }

        public ServiceSelection ToSelection()
        {
            return PrestationName is null
                ? ServiceSelection.ForService(ServiceName, false)
                : ServiceSelection.ForPrestation(ServiceName, PrestationName, false);
        }
    }
}

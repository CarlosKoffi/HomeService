@page "/operations"
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Missions</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de vos missions.</p>
    </section>
}
else if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous pour voir les missions de votre entreprise.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="operations"
                        Title="Missions"
                        Subtitle="Live, rendez-vous et affectations"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(Session.IsCompanyApproved ? 75 : 35)">

    @if (!Session.IsCompanyApproved)
    {
        <section class="compliance-banner">
            <div>
                <strong>Compte en attente de conformite</strong>
                <span>Vous pouvez consulter les missions et preparer votre equipe. L'affectation et l'envoi en mission seront disponibles apres validation.</span>
            </div>
            <a href="@PortalLink("company-profile")">Finaliser la conformite</a>
        </section>
    }

    <section class="portal-tabs" aria-label="Vues missions">
        <button class="@GetTabClass("live")" type="button" @onclick='() => LoadMissionsAsync("live")'>Live</button>
        <button class="@GetTabClass("upcoming")" type="button" @onclick='() => LoadMissionsAsync("upcoming")'>A venir</button>
        <button class="@GetTabClass("past")" type="button" @onclick='() => LoadMissionsAsync("past")'>Passees</button>
    </section>

    <section class="metric-strip">
        <article><span>Live</span><strong>@LiveCount</strong></article>
        <article><span>A venir</span><strong>@UpcomingCount</strong></article>
        <article><span>Passees</span><strong>@PastCount</strong></article>
    </section>

    @if (IsLoading)
    {
        <section class="empty-state"><h2>Chargement...</h2><p>Recuperation des missions.</p></section>
    }
    else if (Missions.Count == 0)
    {
        <section class="empty-state">
            <h2>Aucune mission pour cette vue</h2>
            <p>Les demandes apparaitront ici quand la partie client commencera a creer des missions.</p>
        </section>
    }
    else
    {
        <section class="mission-list">
            @foreach (var mission in Missions)
            {
                <article class="mission-row @GetMissionRowClass(mission)" @onclick="() => SelectMissionAsync(mission)">
                    <div>
                        <span class="status-pill @GetStatusClass(mission.Status)">@GetStatusLabel(mission.Status)</span>
                        <h2>@mission.ServiceName</h2>
                        <p>@mission.CustomerName - @mission.CustomerPhoneNumber</p>
                    </div>
                    <div>
                        <strong>@(mission.ProviderName ?? "A assigner")</strong>
                        <span>@(mission.ScheduledFor?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Demande directe")</span>
                    </div>
                    <div>
                        <strong>@(mission.FinalTotalAmount?.ToString("N0") ?? "-") @mission.Currency</strong>
                        <span>@GetPaymentLabel(mission.PaymentMethod)</span>
                    </div>
                </article>
            }
        </section>

        @if (SelectedMission is not null)
        {
            <section class="mission-detail-panel">
                <div class="mission-detail-main">
                    <div class="mission-detail-heading">
                        <div>
                            <span class="status-pill @GetStatusClass(SelectedMission.Status)">@GetStatusLabel(SelectedMission.Status)</span>
                            <h2>@SelectedMission.ServiceName</h2>
                            <p>@SelectedMission.CustomerName - @SelectedMission.CustomerPhoneNumber</p>
                        </div>
                        <button type="button" @onclick="ClearSelectedMission">Fermer</button>
                    </div>

                    <div class="employee-detail-grid">
                        <article>
                            <span>Mode</span>
                            <strong>@GetMissionModeLabel(SelectedMission.Mode)</strong>
                            <p>@(SelectedMission.ScheduledFor?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Demande immediate")</p>
                        </article>
                        <article>
                            <span>Prestataire</span>
                            <strong>@(SelectedMission.ProviderName ?? "A assigner")</strong>
                            <p>@GetAssignmentHelp(SelectedMission)</p>
                        </article>
                        <article>
                            <span>Duree</span>
                            <strong>@SelectedMission.EstimatedDurationMinutes min</strong>
                            <p>Estimation client</p>
                        </article>
                        <article>
                            <span>Paiement</span>
                            <strong>@(SelectedMission.FinalTotalAmount?.ToString("N0") ?? "-") @SelectedMission.Currency</strong>
                            <p>@GetPaymentLabel(SelectedMission.PaymentMethod) - @GetPaymentStatusLabel(SelectedMission.PaymentStatus)</p>
                        </article>
                    </div>
                </div>

                <aside class="assignment-panel">
                    <div>
                        <h3>Affecter un prestataire</h3>
                        <p>@(Session.IsCompanyApproved ? "Liste filtree sur le service demande." : "Disponible apres validation de votre entreprise.")</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(AssignmentMessage))
                    {
                        <p class="field-message">@AssignmentMessage</p>
                    }

                    @foreach (var candidate in AssignableProviders)
                    {
                        <article class="candidate-row">
                            <div>
                                <strong>@candidate.FullName</strong>
                                <span>@GetEmploymentTypeLabel(candidate.EmploymentType) - @GetExperienceLabel(candidate.ExperienceLevel) - @(candidate.IsAvailable ? "Disponible" : "Occupe")</span>
                            </div>
                            <div>
                                <strong>@candidate.NormalPriceAmount.ToString("N0") / @candidate.PremiumPriceAmount.ToString("N0") @candidate.Currency</strong>
                                <span>Normal / premium</span>
                                <button type="button" disabled="@(!Session.IsCompanyApproved || !candidate.IsAvailable)" @onclick="() => AssignMissionAsync(candidate)">Affecter</button>
                            </div>
                        </article>
                    }
                </aside>
            </section>
        }
    }
    </CompanyPortalShell>
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyPortalMissionResponse> Missions { get; set; } = [];
    private string ActiveView { get; set; } = "live";
    private bool IsLoading { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private int LiveCount { get; set; }
    private int UpcomingCount { get; set; }
    private int PastCount { get; set; }
    private CompanyPortalMissionResponse? SelectedMission { get; set; }
    private IReadOnlyList<CompanyPortalAssignableProviderResponse> AssignableProviders { get; set; } = [];
    private string? AssignmentMessage { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            await RefreshCountsAsync();
            await LoadMissionsAsync("live");
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await RefreshCountsAsync();
            await LoadMissionsAsync("live");
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task RefreshCountsAsync()
    {
        if (Session is null)
        {
            return;
        }

        if (IsPreviewMode())
        {
            LiveCount = GetPreviewMissions("live").Count;
            UpcomingCount = GetPreviewMissions("upcoming").Count;
            PastCount = GetPreviewMissions("past").Count;
            return;
        }

        LiveCount = (await ApiClient.GetCompanyMissionsAsync(Session.CompanyId, "live")).Count;
        UpcomingCount = (await ApiClient.GetCompanyMissionsAsync(Session.CompanyId, "upcoming")).Count;
        PastCount = (await ApiClient.GetCompanyMissionsAsync(Session.CompanyId, "past")).Count;
    }

    private async Task LoadMissionsAsync(string view)
    {
        if (Session is null)
        {
            return;
        }

        ActiveView = view;
        IsLoading = true;
        if (IsPreviewMode())
        {
            Missions = GetPreviewMissions(view);
            SelectedMission = Missions.FirstOrDefault();
            LoadPreviewAssignableProviders();
            IsLoading = false;
            StateHasChanged();
            return;
        }

        Missions = await ApiClient.GetCompanyMissionsAsync(Session.CompanyId, view);
        SelectedMission = Missions.FirstOrDefault();
        await LoadAssignableProvidersAsync();
        IsLoading = false;
        StateHasChanged();
    }

    private async Task SelectMissionAsync(CompanyPortalMissionResponse mission)
    {
        SelectedMission = mission;
        AssignmentMessage = null;
        if (IsPreviewMode())
        {
            LoadPreviewAssignableProviders();
            return;
        }

        await LoadAssignableProvidersAsync();
    }

    private void ClearSelectedMission()
    {
        SelectedMission = null;
        AssignableProviders = [];
        AssignmentMessage = null;
    }

    private async Task AssignMissionAsync(CompanyPortalAssignableProviderResponse candidate)
    {
        if (SelectedMission is null || Session?.IsCompanyApproved != true)
        {
            return;
        }

        if (!IsPreviewMode())
        {
            var result = await ApiClient.AssignCompanyMissionAsync(Session.CompanyId, SelectedMission.Id, candidate.Id);
            if (!result.IsSuccess)
            {
                AssignmentMessage = result.ErrorMessage ?? "Affectation impossible.";
                return;
            }
        }

        var updatedMission = SelectedMission with
        {
            ProviderId = candidate.Id,
            ProviderName = candidate.FullName,
            Status = SelectedMission.Status == "SearchingProvider" ? "Assigned" : SelectedMission.Status
        };

        Missions = Missions.Select(mission => mission.Id == updatedMission.Id ? updatedMission : mission).ToList();
        SelectedMission = updatedMission;
        AssignmentMessage = "Mission affectee.";
        await RefreshCountsAsync();
    }

    private async Task LoadAssignableProvidersAsync()
    {
        if (Session is null || SelectedMission is null)
        {
            AssignableProviders = [];
            return;
        }

        AssignableProviders = await ApiClient.GetAssignableProvidersAsync(Session.CompanyId, SelectedMission.Id);
    }

    private void LoadPreviewAssignableProviders()
    {
        if (SelectedMission is null)
        {
            AssignableProviders = [];
            return;
        }

        AssignableProviders = GetCandidateProviders(SelectedMission)
            .Select(candidate => new CompanyPortalAssignableProviderResponse(
                candidate.Id,
                candidate.Name,
                "+225 07 00 00 00 00",
                "Approved",
                true,
                candidate.TypeLabel,
                4,
                candidate.ExperienceLabel,
                "Normal",
                candidate.NormalPriceAmount,
                candidate.PremiumPriceAmount,
                "XOF",
                candidate.ReceivesDirectRequests,
                null))
            .ToList();
    }

    private string GetTabClass(string view) => ActiveView == view ? "active" : string.Empty;

    private static string GetStatusClass(string status) => status switch
    {
        "Completed" => "status-ok",
        "Cancelled" or "Disputed" => "status-rejected",
        _ => "status-pending"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "SearchingProvider" => "Recherche",
        "Assigned" => "Assignee",
        "Scheduled" => "Planifiee",
        "OnTheWay" => "En route",
        "Started" => "Demarree",
        "Completed" => "Terminee",
        "Cancelled" => "Annulee",
        _ => status
    };

    private static string GetPaymentLabel(string method) => method == "MobileMoney" ? "Mobile Money" : "Cash";

    private static string GetPaymentStatusLabel(string status) => status switch
    {
        "Paid" => "Paye",
        "Authorized" => "Autorise",
        "Pending" => "En attente",
        "Failed" => "Echec",
        _ => "A suivre"
    };

    private static string GetMissionModeLabel(string mode) => mode switch
    {
        "Scheduled" => "Rendez-vous",
        "Direct" => "Demande directe",
        _ => mode
    };

    private static string GetEmploymentTypeLabel(string employmentType) => employmentType switch
    {
        "CompanyEmployee" or "Employe" => "Employe",
        "TemporaryWorker" or "Interimaire" => "Interimaire",
        _ => employmentType
    };

    private static string GetExperienceLabel(string experienceLevel) => experienceLevel switch
    {
        "Junior" => "Junior",
        "Confirmed" or "Confirme" => "Confirme",
        "Senior" => "Senior",
        "Expert" => "Expert",
        _ => experienceLevel
    };

    private static string GetAssignmentHelp(CompanyPortalMissionResponse mission)
    {
        return mission.ProviderName is null
            ? "Selectionnez un prestataire compatible."
            : "Prestataire deja affecte.";
    }

    private string GetMissionRowClass(CompanyPortalMissionResponse mission)
    {
        return SelectedMission?.Id == mission.Id ? "is-selected" : string.Empty;
    }

    private bool IsPreviewMode()
    {
        return Environment.IsDevelopment()
            && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    }

    private string PortalLink(string path) => IsPreviewMode() ? $"{path}?preview=1" : path;

    private static CompanyPortalSessionResponse DemoSession()
    {
        return new CompanyPortalSessionResponse(
            Guid.Parse("11111111-1111-1111-1111-111111111111"),
            "Entreprise Demo CI",
            "Direction Demo",
            "direction@entreprise.ci",
            DateTimeOffset.UtcNow,
            "demo-preview-token",
            "Activated",
            true);
    }


@page "/missions"
@page "/operations"
@using System.Globalization
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Missions</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de vos missions.</p>
    </section>
}
else if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous pour voir les missions de votre entreprise.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="missions"
                        Title="Missions"
                        Subtitle="@($"{CurrentMonthLabel} - {AllMissions.Count} missions au total")"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(Session.IsCompanyApproved ? 75 : 35)">

        @if (!Session.IsCompanyApproved)
        {
            <section class="compliance-banner">
                <div>
                    <strong>Compte en attente de conformite</strong>
                    <span>Vous pouvez consulter les missions et preparer votre equipe. L'affectation sera disponible apres validation.</span>
                </div>
                <a href="@PortalLink("company-profile")">Finaliser la conformite</a>
            </section>
        }

        <section class="missions-workspace">
            <header class="missions-topbar">
                <div>
                    <span class="missions-eyebrow">Planning entreprise</span>
                    <h2>Missions</h2>
                    <p>@CurrentMonthLabel - @AllMissions.Count missions au total</p>
                </div>
                <button type="button" class="missions-primary-action" disabled>
                    <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                    Nouvelle mission
                </button>
            </header>

            @if (IsLoading)
            {
                <section class="empty-state">
                    <h2>Chargement...</h2>
                    <p>Recuperation des missions.</p>
                </section>
            }
            else
            {
                <section class="missions-kpi-grid" aria-label="Indicateurs missions">
                    <article class="missions-kpi-card">
                        <div>
                            <span>En cours</span>
                            <strong>@CurrentMissions.Count</strong>
                            <small>missions actives maintenant</small>
                        </div>
                        <em class="blue"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></em>
                    </article>
                    <article class="missions-kpi-card">
                        <div>
                            <span>A venir</span>
                            <strong>@UpcomingMissions.Count</strong>
                            <small>dont @UpcomingNextSevenDaysCount dans les 7 prochains jours</small>
                        </div>
                        <em class="amber"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></em>
                    </article>
                    <article class="missions-kpi-card">
                        <div>
                            <span>Taux de completion</span>
                            <strong>@CompletionRate%</strong>
                            <small>@CompletedMissions.Count terminees / @ClosedMissionCount cloturees</small>
                        </div>
                        <em class="green"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></em>
                    </article>
                    <article class="missions-kpi-card">
                        <div>
                            <span>CA encaisse</span>
                            <strong class="compact">@FormatCurrency(CompletedRevenue)</strong>
                            <small>CA potentiel : @FormatCurrency(PotentialRevenue)</small>
                        </div>
                        <em class="violet"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></em>
                    </article>
                </section>

                @if (TodayMissions.Count > 0)
                {
                    <section class="missions-today-banner">
                        <div>
                            <span>Aujourd'hui - @Today.ToString("dd MMMM", FrenchCulture)</span>
                            <strong>@TodayMissions.Count mission(s) en cours ou a assurer</strong>
                            <div>
                                @foreach (var mission in TodayMissions.Take(4))
                                {
                                    <button type="button" @onclick="() => SelectMissionAsync(mission)">
                                        @GetServiceEmoji(mission)
                                        <b>@GetProviderShortName(mission)</b>
                                        <small>@GetStartTime(mission)</small>
                                    </button>
                                }
                            </div>
                        </div>
                        <em><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></em>
                    </section>
                }

                <section class="missions-main-grid">
                    <aside class="missions-calendar-card">
                        <div class="missions-calendar-head">
                            <strong>@CalendarMonth.ToString("MMMM yyyy", FrenchCulture)</strong>
                            <span>
                                <button type="button" @onclick="PreviousMonth" aria-label="Mois precedent">&lt;</button>
                                <button type="button" @onclick="NextMonth" aria-label="Mois suivant">&gt;</button>
                            </span>
                        </div>
                        <div class="missions-calendar-days">
                            @foreach (var day in DayNames)
                            {
                                <span>@day</span>
                            }
                        </div>
                        <div class="missions-calendar-grid">
                            @foreach (var cell in CalendarCells)
                            {
                                if (cell is null)
                                {
                                    <span></span>
                                }
                                else
                                {
                                    var date = cell.Value;
                                    var dayMissions = MissionsForDate(date);
                                    <button type="button" class="@GetCalendarCellClass(date)" @onclick="() => SelectDay(date)">
                                        <span>@date.Day</span>
                                        @if (dayMissions.Count > 0)
                                        {
                                            <em>
                                                @foreach (var mission in dayMissions.Take(3))
                                                {
                                                    <i class="@GetCalendarDotClass(mission)"></i>
                                                }
                                            </em>
                                        }
                                    </button>
                                }
                            }
                        </div>
                        <footer class="missions-calendar-legend">
                            <span><i class="blue"></i>En cours</span>
                            <span><i class="amber"></i>A venir</span>
                            <span><i class="green"></i>Terminee</span>
                            <span><i class="gray"></i>Annulee</span>
                        </footer>
                    </aside>

                    <section class="missions-list-column">
                        <div class="missions-search-panel">
                            <label class="missions-search">
                                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                                <input @bind="SearchTerm" @bind:event="oninput" placeholder="Rechercher client, service, employe, zone..." />
                            </label>
                            <div class="missions-tabs">
                                @foreach (var tab in Tabs)
                                {
                                    <button type="button" class="@GetFilterClass(tab.Key)" @onclick="() => SetFilter(tab.Key)">
                                        @tab.Label <span>@GetTabCount(tab.Key)</span>
                                    </button>
                                }
                            </div>
                        </div>

                        @if (FilteredMissions.Count == 0)
                        {
                            <section class="empty-state">
                                <h2>Aucune mission</h2>
                                <p>Ajustez le filtre, le calendrier ou la recherche.</p>
                            </section>
                        }
                        else
                        {
                            <div class="missions-card-list">
                                @foreach (var mission in FilteredMissions)
                                {
                                    <article class="@($"missions-card {(SelectedMission?.Id == mission.Id ? "selected" : string.Empty)}")" @onclick="() => SelectMissionAsync(mission)">
                                        <span class="@GetAvatarClass(mission.CustomerName)">@GetInitials(mission.CustomerName)</span>
                                        <div class="missions-card-main">
                                            <div>
                                                <strong>@mission.CustomerName</strong>
                                                <span class="@GetMissionStatusBadgeClass(mission)">@GetMissionStatusLabel(mission)</span>
                                            </div>
                                            <p>@GetServiceEmoji(mission) @mission.ServiceName</p>
                                            <footer>
                                                <small>@GetProviderMeta(mission)</small>
                                                <small>@GetLocation(mission)</small>
                                                <small>@GetTimeRange(mission)</small>
                                                @if (IsUpcomingStatus(mission.Status) || IsCancelledStatus(mission.Status))
                                                {
                                                    <small class="date">@GetMissionDateLabel(mission)</small>
                                                }
                                                @if (IsCancelledStatus(mission.Status) && !string.IsNullOrWhiteSpace(mission.CancellationReason))
                                                {
                                                    <small class="cancel">@mission.CancellationReason</small>
                                                }
                                            </footer>
                                        </div>
                                        <aside>
                                            <strong>@FormatCurrency(mission.FinalTotalAmount ?? 0)</strong>
                                            @if (IsCompletedStatus(mission.Status) && mission.CustomerRating is not null)
                                            {
                                                <span class="missions-stars">@BuildStars(mission.CustomerRating.Value)</span>
                                            }
                                        </aside>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                </section>

                @if (SelectedMission is not null)
                {
                    <section class="missions-detail-panel">
                        <div>
                            <span class="@GetMissionStatusBadgeClass(SelectedMission)">@GetMissionStatusLabel(SelectedMission)</span>
                            <h3>@SelectedMission.ServiceName</h3>
                            <p>@SelectedMission.CustomerName - @SelectedMission.CustomerPhoneNumber</p>
                            <div class="missions-detail-grid">
                                <article><span>Adresse</span><strong>@GetLocation(SelectedMission)</strong></article>
                                <article><span>Horaire</span><strong>@GetTimeRange(SelectedMission)</strong></article>
                                <article><span>Duree</span><strong>@SelectedMission.EstimatedDurationMinutes min</strong></article>
                                <article><span>Paiement</span><strong>@GetPaymentLabel(SelectedMission.PaymentMethod)</strong></article>
                                <article><span>Montant</span><strong>@FormatCurrency(SelectedMission.FinalTotalAmount ?? 0)</strong></article>
                                <article><span>Prestataire</span><strong>@(SelectedMission.ProviderName ?? "A assigner")</strong></article>
                            </div>
                        </div>

                        <aside class="missions-assignment-panel">
                            <div>
                                <h3>Affecter un prestataire</h3>
                                <p>@(Session.IsCompanyApproved ? "Liste filtree par service et disponibilite." : "Disponible apres validation de votre entreprise.")</p>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(AssignmentMessage))
                            {
                                <p class="field-message">@AssignmentMessage</p>
                            }

                            @if (AssignableProviders.Count == 0)
                            {
                                <p class="missions-muted">Aucun prestataire compatible pour le moment.</p>
                            }
                            else
                            {
                                @foreach (var candidate in AssignableProviders)
                                {
                                    <article>
                                        <span class="@GetAvatarClass(candidate.FullName)">@GetInitials(candidate.FullName)</span>
                                        <div>
                                            <strong>@candidate.FullName</strong>
                                            <small>@GetEmploymentTypeLabel(candidate.EmploymentType) - @GetExperienceLabel(candidate.ExperienceLevel) - @(candidate.IsAvailable ? "Disponible" : "Occupe")</small>
                                            <em>@GetPriceMin(candidate).ToString("N0") - @GetPriceMax(candidate).ToString("N0") @candidate.Currency</em>
                                        </div>
                                        <button type="button" disabled="@(!Session.IsCompanyApproved || !candidate.IsAvailable)" @onclick="() => AssignMissionAsync(candidate)">Affecter</button>
                                    </article>
                                }
                            }
                        </aside>
                    </section>
                }
            }
        </section>
    </CompanyPortalShell>
}

@code {
    private static readonly CultureInfo FrenchCulture = CultureInfo.GetCultureInfo("fr-FR");
    private static readonly IReadOnlyList<(string Key, string Label)> Tabs =
    [
        ("all", "Toutes"),
        ("current", "En cours"),
        ("upcoming", "A venir"),
        ("completed", "Terminees"),
        ("cancelled", "Annulees")
    ];

    private static readonly IReadOnlyList<string> DayNames = ["Lun", "Mar", "Mer", "Jeu", "Ven", "Sam", "Dim"];

    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyPortalMissionResponse> AllMissions { get; set; } = [];
    private IReadOnlyList<CompanyPortalAssignableProviderResponse> AssignableProviders { get; set; } = [];
    private CompanyPortalMissionResponse? SelectedMission { get; set; }
    private bool IsLoading { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private string ActiveFilter { get; set; } = "all";
    private string? SearchTerm { get; set; }
    private DateOnly? SelectedDay { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly CalendarMonth { get; set; } = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private string? AssignmentMessage { get; set; }

    private DateOnly Today => DateOnly.FromDateTime(DateTime.Today);
    private string CurrentMonthLabel => CalendarMonth.ToString("MMMM yyyy", FrenchCulture);
    private IReadOnlyList<CompanyPortalMissionResponse> CurrentMissions => AllMissions.Where(IsCurrentStatus).ToList();
    private IReadOnlyList<CompanyPortalMissionResponse> UpcomingMissions => AllMissions.Where(mission => IsUpcomingStatus(mission.Status)).ToList();
    private IReadOnlyList<CompanyPortalMissionResponse> CompletedMissions => AllMissions.Where(mission => IsCompletedStatus(mission.Status)).ToList();
    private IReadOnlyList<CompanyPortalMissionResponse> CancelledMissions => AllMissions.Where(mission => IsCancelledStatus(mission.Status)).ToList();
    private IReadOnlyList<CompanyPortalMissionResponse> TodayMissions => AllMissions.Where(mission => GetMissionDate(mission) == Today && !IsCompletedStatus(mission.Status) && !IsCancelledStatus(mission.Status)).ToList();
    private int UpcomingNextSevenDaysCount => UpcomingMissions.Count(mission => GetMissionDate(mission) <= Today.AddDays(7));
    private int ClosedMissionCount => CompletedMissions.Count + CancelledMissions.Count;
    private int CompletionRate => ClosedMissionCount == 0 ? 0 : (int)Math.Round(CompletedMissions.Count * 100m / ClosedMissionCount);
    private int CompletedRevenue => CompletedMissions.Sum(mission => mission.FinalTotalAmount ?? 0);
    private int PotentialRevenue => AllMissions.Where(mission => !IsCancelledStatus(mission.Status)).Sum(mission => mission.FinalTotalAmount ?? 0);

    private IReadOnlyList<DateOnly?> CalendarCells
    {
        get
        {
            var daysInMonth = DateTime.DaysInMonth(CalendarMonth.Year, CalendarMonth.Month);
            var firstDay = CalendarMonth.ToDateTime(TimeOnly.MinValue);
            var startOffset = ((int)firstDay.DayOfWeek - 1 + 7) % 7;
            var cells = new List<DateOnly?>();
            cells.AddRange(Enumerable.Repeat<DateOnly?>(null, startOffset));
            cells.AddRange(Enumerable.Range(1, daysInMonth).Select(day => (DateOnly?)new DateOnly(CalendarMonth.Year, CalendarMonth.Month, day)));
            while (cells.Count % 7 != 0)
            {
                cells.Add(null);
            }

            return cells;
        }
    }

    private IReadOnlyList<CompanyPortalMissionResponse> FilteredMissions
    {
        get
        {
            IEnumerable<CompanyPortalMissionResponse> query = AllMissions;
            if (SelectedDay is not null)
            {
                query = query.Where(mission => GetMissionDate(mission) == SelectedDay.Value);
            }

            query = ActiveFilter switch
            {
                "current" => query.Where(IsCurrentStatus),
                "upcoming" => query.Where(mission => IsUpcomingStatus(mission.Status)),
                "completed" => query.Where(mission => IsCompletedStatus(mission.Status)),
                "cancelled" => query.Where(mission => IsCancelledStatus(mission.Status)),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                var search = SearchTerm.Trim();
                query = query.Where(mission =>
                    mission.CustomerName.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || mission.ServiceName.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || (mission.ProviderName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (mission.LocationLabel?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            return query
                .OrderBy(GetSortWeight)
                .ThenBy(mission => mission.ScheduledFor ?? DateTimeOffset.MaxValue)
                .ThenBy(mission => mission.CustomerName)
                .ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            await LoadMissionsAsync();
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadMissionsAsync();
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadMissionsAsync()
    {
        if (Session is null)
        {
            return;
        }

        IsLoading = true;
        AssignmentMessage = null;
        if (IsPreviewMode())
        {
            AllMissions = GetPreviewMissions();
        }
        else
        {
            AllMissions = await ApiClient.GetCompanyMissionsAsync(Session.CompanyId, "all");
        }

        SelectedMission = AllMissions.OrderBy(GetSortWeight).FirstOrDefault();
        await LoadAssignableProvidersAsync();
        IsLoading = false;
    }

    private async Task SelectMissionAsync(CompanyPortalMissionResponse mission)
    {
        SelectedMission = mission;
        AssignmentMessage = null;
        await LoadAssignableProvidersAsync();
    }

    private async Task AssignMissionAsync(CompanyPortalAssignableProviderResponse candidate)
    {
        if (SelectedMission is null || Session?.IsCompanyApproved != true)
        {
            return;
        }

        if (!IsPreviewMode())
        {
            var result = await ApiClient.AssignCompanyMissionAsync(
                Session.CompanyId,
                SelectedMission.Id,
                candidate.Id,
                GetPriceMin(candidate),
                null);
            if (!result.IsSuccess)
            {
                AssignmentMessage = result.ErrorMessage ?? "Affectation impossible.";
                return;
            }
        }

        var updatedMission = SelectedMission with
        {
            ProviderId = candidate.Id,
            ProviderName = candidate.FullName,
            Status = SelectedMission.Status == "SearchingProvider" ? "Assigned" : SelectedMission.Status
        };

        AllMissions = AllMissions.Select(mission => mission.Id == updatedMission.Id ? updatedMission : mission).ToList();
        SelectedMission = updatedMission;
        AssignmentMessage = "Mission affectee.";
        await LoadAssignableProvidersAsync();
    }

    private async Task LoadAssignableProvidersAsync()
    {
        if (Session is null || SelectedMission is null)
        {
            AssignableProviders = [];
            return;
        }

        AssignableProviders = IsPreviewMode()
            ? GetCandidateProviders(SelectedMission)
                .Select(candidate => new CompanyPortalAssignableProviderResponse(
                    candidate.Id,
                    candidate.Name,
                    "+225 07 00 00 00 00",
                    "Approved",
                    true,
                    candidate.TypeLabel,
                    4,
                    candidate.ExperienceLabel,
                    "Normal",
                    candidate.NormalPriceAmount,
                    candidate.PremiumPriceAmount,
                    "XOF",
                    candidate.ReceivesDirectRequests,
                    null,
                    candidate.NormalPriceAmount,
                    candidate.PremiumPriceAmount))
                .ToList()
            : await ApiClient.GetAssignableProvidersAsync(Session.CompanyId, SelectedMission.Id);
    }

    private void PreviousMonth()
    {
        CalendarMonth = CalendarMonth.AddMonths(-1);
    }

    private void NextMonth()
    {
        CalendarMonth = CalendarMonth.AddMonths(1);
    }

    private void SelectDay(DateOnly day)
    {
        SelectedDay = SelectedDay == day ? null : day;
    }

    private void SetFilter(string filter)
    {
        ActiveFilter = filter;
    }

    private int GetTabCount(string key)
    {
        return key switch
        {
            "current" => CurrentMissions.Count,
            "upcoming" => UpcomingMissions.Count,
            "completed" => CompletedMissions.Count,
            "cancelled" => CancelledMissions.Count,
            _ => AllMissions.Count
        };
    }

    private IReadOnlyList<CompanyPortalMissionResponse> MissionsForDate(DateOnly date)
    {
        return AllMissions.Where(mission => GetMissionDate(mission) == date).ToList();
    }

    private static DateOnly GetMissionDate(CompanyPortalMissionResponse mission)
    {
        return mission.ScheduledFor is null
            ? DateOnly.FromDateTime(DateTime.Today)
            : DateOnly.FromDateTime(mission.ScheduledFor.Value.LocalDateTime.Date);
    }

    private string GetCalendarCellClass(DateOnly date)
    {
        var parts = new List<string> { "missions-calendar-cell" };
        if (date == Today)
        {
            parts.Add("today");
        }

        if (SelectedDay == date)
        {
            parts.Add("selected");
        }

        if (date < Today)
        {
            parts.Add("past");
        }

        return string.Join(' ', parts);
    }

    private static string GetCalendarDotClass(CompanyPortalMissionResponse mission)
    {
        return IsCompletedStatus(mission.Status)
            ? "green"
            : IsCancelledStatus(mission.Status)
                ? "gray"
                : IsUpcomingStatus(mission.Status)
                    ? "amber"
                    : "blue";
    }

    private static int GetSortWeight(CompanyPortalMissionResponse mission)
    {
        if (IsCurrentStatus(mission))
        {
            return 0;
        }

        if (IsUpcomingStatus(mission.Status))
        {
            return 1;
        }

        if (IsCompletedStatus(mission.Status))
        {
            return 2;
        }

        return 3;
    }

    private string GetFilterClass(string filter) => ActiveFilter == filter ? "active" : string.Empty;

    private static bool IsCurrentStatus(CompanyPortalMissionResponse mission) => IsCurrentStatus(mission.Status);

    private static bool IsCurrentStatus(string status)
    {
        return status is "Created" or "SearchingProvider" or "Offered" or "Assigned" or "Accepted" or "OnTheWay" or "Started";
    }

    private static bool IsUpcomingStatus(string status) => status is "Scheduled";
    private static bool IsCompletedStatus(string status) => status is "Completed";
    private static bool IsCancelledStatus(string status) => status is "Cancelled" or "Disputed";

    private static string GetMissionStatusLabel(CompanyPortalMissionResponse mission)
    {
        return mission.Status switch
        {
            "Completed" => "Terminee",
            "Cancelled" => "Annulee",
            "Scheduled" => "A venir",
            _ => "En cours"
        };
    }

    private static string GetMissionStatusBadgeClass(CompanyPortalMissionResponse mission)
    {
        return mission.Status switch
        {
            "Completed" => "mission-badge terminee",
            "Cancelled" or "Disputed" => "mission-badge annulee",
            "Scheduled" => "mission-badge avenir",
            _ => "mission-badge cours"
        };
    }

    private static string GetServiceEmoji(CompanyPortalMissionResponse mission)
    {
        var value = $"{mission.ServiceIconName} {mission.ServiceName}".ToUpperInvariant();
        if (value.Contains("MENAGE") || value.Contains("NETTOYAGE")) return "MN";
        if (value.Contains("JARDIN")) return "JA";
        if (value.Contains("NOUNOU") || value.Contains("ENFANT")) return "NO";
        if (value.Contains("PLOMB")) return "PL";
        if (value.Contains("ELECT")) return "EL";
        if (value.Contains("BLANCH")) return "BL";
        if (value.Contains("AUTO")) return "AU";
        return "OK";
    }

    private static string GetProviderShortName(CompanyPortalMissionResponse mission)
    {
        return string.IsNullOrWhiteSpace(mission.ProviderName)
            ? "A assigner"
            : mission.ProviderName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).FirstOrDefault() ?? mission.ProviderName;
    }

    private static string GetProviderMeta(CompanyPortalMissionResponse mission)
    {
        return string.IsNullOrWhiteSpace(mission.ProviderName)
            ? "Prestataire a assigner"
            : $"Employe - {mission.ProviderName}";
    }

    private static string GetLocation(CompanyPortalMissionResponse mission)
    {
        return string.IsNullOrWhiteSpace(mission.LocationLabel) ? "Zone a confirmer" : mission.LocationLabel;
    }

    private static string GetStartTime(CompanyPortalMissionResponse mission)
    {
        return mission.ScheduledFor?.ToLocalTime().ToString("HH'h'mm", FrenchCulture) ?? "Direct";
    }

    private static string GetTimeRange(CompanyPortalMissionResponse mission)
    {
        if (mission.ScheduledFor is null)
        {
            return "Demande directe";
        }

        var start = mission.ScheduledFor.Value.ToLocalTime();
        var end = start.AddMinutes(mission.EstimatedDurationMinutes);
        return $"{start:HH'h'mm} - {end:HH'h'mm}";
    }

    private static string GetMissionDateLabel(CompanyPortalMissionResponse mission)
    {
        return GetMissionDate(mission).ToString("dd MMM", FrenchCulture);
    }

    private static string FormatCurrency(int amount)
    {
        return string.Format(FrenchCulture, "{0:N0} F", amount);
    }

    private static string BuildStars(int note)
    {
        var rating = Math.Clamp(note, 0, 5);
        return new string('*', rating) + new string('-', 5 - rating);
    }

    private static string GetPaymentLabel(string method) => method == "MobileMoney" ? "Mobile Money" : "Cash";

    private static string GetEmploymentTypeLabel(string employmentType) => employmentType switch
    {
        "CompanyEmployee" or "Employe" => "Employe",
        "TemporaryWorker" or "Interimaire" => "Interimaire",
        _ => employmentType
    };

    private static string GetExperienceLabel(string experienceLevel) => experienceLevel switch
    {
        "Junior" => "Junior",
        "Confirmed" or "Confirme" => "Confirme",
        "Senior" => "Senior",
        "Expert" => "Expert",
        _ => experienceLevel
    };

    private static int GetPriceMin(CompanyPortalAssignableProviderResponse candidate)
    {
        return candidate.PriceMinAmount ?? candidate.NormalPriceAmount;
    }

    private static int GetPriceMax(CompanyPortalAssignableProviderResponse candidate)
    {
        return candidate.PriceMaxAmount ?? candidate.PremiumPriceAmount;
    }

    private static string GetInitials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => part[0])).ToUpperInvariant();
    }

    private static string GetAvatarClass(string value)
    {
        var colors = new[] { "blue", "violet", "green", "amber", "rose" };
        var hash = value.Aggregate(0, (current, character) => ((current * 31) + character) & 0xffff);
        return $"mission-avatar {colors[hash % colors.Length]}";
    }

    private bool IsPreviewMode()
    {
        return Environment.IsDevelopment()
            && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    }

    private string PortalLink(string path) => IsPreviewMode() ? $"{path}?preview=1" : path;


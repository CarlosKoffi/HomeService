    }

    private static IReadOnlyList<PreviewProviderCandidate> GetCandidateProviders(CompanyPortalMissionResponse mission)
    {
        var candidates = new List<PreviewProviderCandidate>
        {
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1"), "Awa Kone", "Employe", "Senior", "Menage a domicile", 3500, 5000, 2.4m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1"), "Awa Kone", "Employe", "Confirme", "Nounou", 4000, 6500, 2.4m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb2"), "Yao N'Dri", "Interimaire", "Expert", "Jardinage", 4500, 6500, 3.1m, true),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb3"), "Mariam Coulibaly", "Employe", "Junior", "Menage a domicile", 3500, 5000, 6.8m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb4"), "Fatou Soro", "Employe", "Confirme", "Menage a domicile", 3500, 5500, 1.2m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb4"), "Fatou Soro", "Employe", "Expert", "Menage apres travaux", 5500, 8000, 1.2m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb5"), "Aminata Bamba", "Interimaire", "Senior", "Nounou", 4500, 7000, 4.6m, true),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb6"), "Jean Kouame", "Employe", "Expert", "Menage apres travaux", 6000, 8500, 5.4m, false),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb7"), "Serge Yapi", "Interimaire", "Confirme", "Jardinage", 4000, 6000, 1.9m, true),
            new(Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb8"), "Nadia Konan", "Employe", "Confirme", "Nounou", 4200, 6800, 7.2m, false)
        };

        return candidates
            .Where(candidate => string.Equals(candidate.ServiceName, mission.ServiceName, StringComparison.OrdinalIgnoreCase))
            .OrderBy(candidate => candidate.DistanceKm)
            .ThenBy(candidate => candidate.Name)
            .ToList();
    }

    private sealed record PreviewProviderCandidate(
        Guid Id,
        string Name,
        string TypeLabel,
        string ExperienceLabel,
        string ServiceName,
        int NormalPriceAmount,
        int PremiumPriceAmount,
        decimal DistanceKm,
        bool ReceivesDirectRequests);
}

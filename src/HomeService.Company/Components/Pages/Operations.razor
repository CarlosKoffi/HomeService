                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc4"), "Jardinage", "Residence Palm Club", "+225 05 12 34 56 78", "Scheduled", "Scheduled", "Cash", "Pending", now.AddDays(1).AddHours(2), 240, 26000, "XOF", null, null),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc7"), "Menage a domicile", "Cabinet N'Da", "+225 27 22 44 88 10", "Scheduled", "Scheduled", "MobileMoney", "Authorized", now.AddDays(1).AddHours(5), 300, 32000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb4"), "Fatou Soro"),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc8"), "Nounou", "Mme Amani", "+225 01 45 60 11 22", "Scheduled", "SearchingProvider", "Cash", "Pending", now.AddDays(2).AddHours(3), 360, 28000, "XOF", null, null),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc9"), "Menage apres travaux", "SCI Lagune", "+225 05 33 44 55 66", "Scheduled", "Scheduled", "MobileMoney", "Authorized", now.AddDays(3), 420, 48000, "XOF", null, null)
            ],
            "past" =>
            [
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc5"), "Menage a domicile", "Mme Bamba", "+225 01 11 22 33 44", "Scheduled", "Completed", "MobileMoney", "Paid", now.AddDays(-2), 240, 22000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1"), "Awa Kone"),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc6"), "Jardinage", "M. Kouassi", "+225 07 45 45 45 45", "Direct", "Completed", "Cash", "Paid", now.AddDays(-5), 180, 16000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb2"), "Yao N'Dri"),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-cccccccccc10"), "Nounou", "Mme Koffi", "+225 07 15 12 09 09", "Scheduled", "Completed", "MobileMoney", "Paid", now.AddDays(-7), 360, 30000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb5"), "Aminata Bamba"),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-cccccccccc11"), "Menage apres travaux", "Atelier Riviera", "+225 05 71 22 10 00", "Scheduled", "Completed", "Cash", "Paid", now.AddDays(-9), 420, 45000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb6"), "Jean Kouame"),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-cccccccccc12"), "Menage a domicile", "Mme Diaby", "+225 01 22 80 90 33", "Direct", "Cancelled", "MobileMoney", "Failed", now.AddDays(-11), 180, 15000, "XOF", null, null)
            ],
            _ =>
            [
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc1"), "Menage a domicile", "Mme Akissi", "+225 07 00 11 22 33", "Direct", "SearchingProvider", "MobileMoney", "Authorized", null, 180, 15000, "XOF", null, null),
                new(Guid.Parse("cccccccc-cccc-cccc-cccc-ccccccccccc2"), "Jardinage", "M. Diarra", "+225 05 90 80 70 60", "Direct", "OnTheWay", "Cash", "Pending", null, 120, 12000, "XOF", Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb2"), "Yao N'Dri"),

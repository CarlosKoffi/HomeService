@page "/concept"

<PageTitle>Concept</PageTitle>

<h1>Le concept</h1>
<p class="lead">
    Entreprises verifiees. Prestataires rattaches. Missions et paiements suivis.
</p>

<section class="concept-snapshot" aria-label="Resume du concept">
    <article>
        <span>ID</span>
        <strong>Entreprise identifiee</strong>
        <small>Compte cree en ligne</small>
    </article>
    <article>
        <span>DOC</span>
        <strong>Pieces controlees</strong>
        <small>Upload ou depot bureau</small>
    </article>
    <article>
        <span>TEAM</span>
        <strong>Prestataires encadres</strong>
        <small>Salaries et interimaires</small>
    </article>
    <article>
        <span>XOF</span>
        <strong>Argent trace</strong>
        <small>Mobile Money et cash</small>
    </article>
</section>

<section class="concept-flow" aria-label="Parcours entreprise">
    <article>
        <span class="flow-step">1</span>
        <strong>Creer</strong>
        <small>Compte + responsable</small>
    </article>
    <article>
        <span class="flow-step">2</span>
        <strong>Completer</strong>
        <small>Documents + services</small>
    </article>
    <article>
        <span class="flow-step">3</span>
        <strong>Valider</strong>
        <small>Controle admin</small>
    </article>
    <article>
        <span class="flow-step">4</span>
        <strong>Piloter</strong>
        <small>Employes, missions, comptes</small>
    </article>
</section>

<section class="concept-rules" aria-label="Regles importantes">
    <article>
        <span>LOCK</span>
        <div>
            <h2>Avant validation</h2>
            <p>Le portail est ouvert. Les affectations sensibles restent bloquees.</p>
        </div>
    </article>
    <article>
        <span>OPS</span>
        <div>
            <h2>Apres validation</h2>
            <p>L'entreprise affecte, suit les missions et controle les encaissements.</p>
        </div>
    </article>
</section>

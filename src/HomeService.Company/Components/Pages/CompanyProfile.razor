@page "/company-profile"
@layout HomeService.Company.Components.Layout.EmptyLayout
@using HomeService.Company.Services
@using HomeService.Contracts.CompanyPortal
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject PlatformApiClient ApiClient
@inject IJSRuntime Js
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Informations entreprise</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de votre fiche entreprise.</p>
    </section>
}
else if (Session is null)
{
    <section class="activation-card">
        <h1>Connexion requise</h1>
        <p class="lead">Connectez-vous au portail entreprise pour consulter vos informations et suivre la conformite.</p>
        <a class="primary-action" href="dashboard">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="company-profile"
                        Title="Informations"
                        Subtitle="Profil, documents et conformite"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(IsCompanyApproved() ? 75 : 35)">

        @if (!IsCompanyApproved())
        {
            <section class="compliance-banner">
                <div>
                    <strong>Compte en attente de conformite</strong>
                    <span>Votre profil est cree. Les affectations et fonctions sensibles seront ouvertes apres validation des pieces.</span>
                </div>
                <a href="#documents">Finaliser</a>
            </section>
        }

        @if (IsLoading)
        {
            <section class="empty-state"><h2>Chargement...</h2><p>Recuperation de votre fiche entreprise.</p></section>
        }
        else
        {
            <section class="info-profile-page">
                <section class="info-hero-card">
                    <div class="info-company-mark">@GetInitials(Profile?.CompanyName ?? Session.CompanyName)</div>
                    <div class="info-company-main">
                        <h1>@Display(Profile?.CompanyName, Session.CompanyName)</h1>
                        <p>@GetLegalSubtitle()</p>
                    </div>
                    <div class="info-hero-stats">
                        <div>
                            <strong class="@GetStatusToneClass()">@GetShortStatusLabel()</strong>
                            <span>Statut</span>
                        </div>
                        <a href="#documents">
                            <strong class="@GetDocumentToneClass()">@GetDocumentCounter()</strong>
                            <span>Documents</span>
                        </a>
                        <div>
                            <strong>@GetZoneCount()</strong>
                            <span>Zones</span>
                        </div>
                    </div>
                </section>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <p class="info-inline-message">@Message</p>
                }

                <section class="info-grid-row">
                    <article class="info-card info-card-large">
                        <header>
                            <div>
                                <span class="info-card-icon info-blue"><svg viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M6 21V7l6-4 6 4v14"/><path d="M9 10h.01M12 10h.01M15 10h.01M9 14h.01M12 14h.01M15 14h.01"/></svg></span>
                                <h2>Entreprise</h2>
                            </div>
                            <button type="button" class="info-edit-button" @onclick="@(() => StartEdit("company"))">Modifier</button>
                        </header>
                        @if (IsEditing("company"))
                        {
                            <div class="info-edit-grid">
                                <label><span>Raison sociale</span><input @bind="CompanyNameDraft" /></label>
                                <label><span>Forme juridique</span><input @bind="LegalFormDraft" placeholder="SARL, SA, entreprise individuelle..." /></label>
                                <label><span>Numero RCCM</span><input @bind="RegistrationNumberDraft" /></label>
                                <label><span>Numero DFE / NIF</span><input @bind="TaxIdentificationNumberDraft" /></label>
                                <label><span>Ville</span><input @bind="CityDraft" /></label>
                                <label class="info-edit-wide"><span>Adresse</span><textarea @bind="AddressDraft"></textarea></label>
                            </div>
                            <div class="info-card-actions">
                                <button type="button" class="info-save-button" disabled="@IsSaving" @onclick="SaveCompanyInfoAsync">Enregistrer</button>
                                <button type="button" class="info-cancel-button" disabled="@IsSaving" @onclick="CancelEdit">Annuler</button>
                            </div>
                        }
                        else
                        {
                            <dl class="info-fields-grid">
                                <div>
                                    <dt>Raison sociale</dt>
                                    <dd>@Display(Profile?.CompanyName, Session.CompanyName)</dd>
                                </div>
                                <div>
                                    <dt>Forme juridique</dt>
                                    <dd>@Display(Profile?.LegalForm, "A completer")</dd>
                                </div>
                                <div>
                                    <dt>Numero RCCM</dt>
                                    <dd>@Display(Profile?.RegistrationNumber, "A completer")</dd>
                                </div>
                                <div>
                                    <dt>Numero DFE / NIF</dt>
                                    <dd>@Display(Profile?.TaxIdentificationNumber, "A completer")</dd>
                                </div>
                                <div>
                                    <dt>Ville</dt>
                                    <dd>@Display(Profile?.City, "A completer")</dd>
                                </div>
                                <div class="info-field-wide">
                                    <dt>Adresse</dt>
                                    <dd>@Display(Profile?.Address, "A completer")</dd>
                                </div>
                            </dl>
                        }
                    </article>

                    <article class="info-card">
                        <header>
                            <div>
                                <span class="info-card-icon info-purple"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg></span>
                                <h2>Administrateur</h2>
                            </div>
                            <button type="button" class="info-edit-button" @onclick="@(() => StartEdit("contact"))">Modifier</button>
                        </header>
                        @if (IsEditing("contact"))
                        {
                            <div class="info-edit-stack">
                                <label><span>Nom</span><input @bind="ContactNameDraft" /></label>
                                <label><span>Email</span><input type="email" @bind="EmailDraft" /></label>
                                <label><span>Telephone</span><input @bind="PhoneNumberDraft" /></label>
                            </div>
                            <div class="info-card-actions">
                                <button type="button" class="info-save-button" disabled="@IsSaving" @onclick="SaveContactAsync">Enregistrer</button>
                                <button type="button" class="info-cancel-button" disabled="@IsSaving" @onclick="CancelEdit">Annuler</button>
                            </div>
                        }
                        else
                        {
                            <dl class="info-fields-stack">
                                <div>
                                    <dt>Nom</dt>
                                    <dd>@Display(Profile?.ContactName, Session.UserName)</dd>
                                </div>
                                <div>
                                    <dt>Email</dt>
                                    <dd>@Display(Profile?.Email, Session.Email)</dd>
                                </div>
                                <div>
                                    <dt>Telephone</dt>
                                    <dd>@Display(Profile?.PhoneNumber, "A completer")</dd>
                                </div>
                            </dl>
                        }
                        <span class="info-status-badge @GetStatusBadgeClass()">@GetStatusLabel()</span>
                    </article>
                </section>

                <section class="info-grid-row">
                    <article class="info-card info-card-large">
                        <div class="info-section-block">
                            <header>
                                <div>
                                    <span class="info-card-icon info-blue"><svg viewBox="0 0 24 24"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
                                    <h2>Zones d'intervention</h2>
                                </div>
                                <button type="button" class="info-add-button" @onclick="@(() => StartEdit("operations"))">Gerer</button>
                            </header>
                            @if (IsEditing("operations"))
                            {
                                <label class="info-edit-field">
                                    <span>Zones separees par des virgules</span>
                                    <textarea @bind="InterventionZonesDraft" placeholder="Cocody, Angre, Marcory, Zone 4"></textarea>
                                </label>
                            }
                            else
                            {
                                <div class="info-tags">
                                    @foreach (var zone in GetInterventionZones())
                                    {
                                        <span>@zone</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="info-section-divider"></div>

                        <div class="info-section-block">
                            <header>
                                <div>
                                    <span class="info-card-icon info-blue"><svg viewBox="0 0 24 24"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></span>
                                    <h2>Services declares</h2>
                                </div>
                                <button type="button" class="info-add-button" @onclick="@(() => StartEdit("operations"))">Gerer</button>
                            </header>
                            @if (IsEditing("operations"))
                            {
                                <label class="info-edit-field">
                                    <span>Services separes par des virgules</span>
                                    <textarea @bind="PlannedServicesDraft" placeholder="Menage a domicile, Jardinage, Depannage auto"></textarea>
                                </label>
                                <div class="info-card-actions">
                                    <button type="button" class="info-save-button" disabled="@IsSaving" @onclick="SaveOperationsAsync">Enregistrer</button>
                                    <button type="button" class="info-cancel-button" disabled="@IsSaving" @onclick="CancelEdit">Annuler</button>
                                </div>
                            }
                            else
                            {
                                <div class="info-tags info-tags-blue">
                                    @foreach (var service in GetPlannedServices())
                                    {
                                        <span>@service</span>
                                    }
                                </div>
                            }
                        </div>
                    </article>

                    <article class="info-card">
                        <header>
                            <div>
                                <span class="info-card-icon info-amber"><svg viewBox="0 0 24 24"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/></svg></span>
                                <h2>Coordonnees de paiement</h2>
                            </div>
                            <button type="button" class="info-edit-button" @onclick="@(() => StartEdit("payment"))">Modifier</button>
                        </header>
                        @if (IsEditing("payment"))
                        {
                            <div class="info-edit-stack">
                                <label><span>Numero Wave</span><input @bind="WavePaymentNumberDraft" placeholder="+225..." /></label>
                                <label><span>Numero Orange Money</span><input @bind="OrangeMoneyPaymentNumberDraft" placeholder="+225..." /></label>
                            </div>
                            <div class="info-card-actions">
                                <button type="button" class="info-save-button" disabled="@IsSaving" @onclick="SavePaymentAsync">Enregistrer</button>
                                <button type="button" class="info-cancel-button" disabled="@IsSaving" @onclick="CancelEdit">Annuler</button>
                            </div>
                        }
                        else
                        {
                            <div class="info-payment-list">
                                <div class="info-payment-row @(string.IsNullOrWhiteSpace(Profile?.WavePaymentNumber) ? "info-payment-empty" : string.Empty)">
                                    <span class="info-payment-icon info-wave">W</span>
                                    <div>
                                        <strong>Wave</strong>
                                        <small>@Display(Profile?.WavePaymentNumber, "A completer")</small>
                                    </div>
                                    <em>@(string.IsNullOrWhiteSpace(Profile?.WavePaymentNumber) ? "Manquant" : "Actif")</em>
                                </div>
                                <div class="info-payment-row @(string.IsNullOrWhiteSpace(Profile?.OrangeMoneyPaymentNumber) ? "info-payment-empty" : string.Empty)">
                                    <span class="info-payment-icon">OM</span>
                                    <div>
                                        <strong>Orange Money</strong>
                                        <small>@Display(Profile?.OrangeMoneyPaymentNumber, "A completer")</small>
                                    </div>
                                    <em>@(string.IsNullOrWhiteSpace(Profile?.OrangeMoneyPaymentNumber) ? "Manquant" : "Actif")</em>
                                </div>
                            </div>
                        }
                    </article>
                </section>

                <section id="documents" class="info-card info-documents-card @GetDocumentsCardClass()">
                    <header>
                        <div>
                            <span class="info-card-icon @GetDocumentsIconClass()"><svg viewBox="0 0 24 24"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h4"/></svg></span>
                            <h2>Pieces du dossier</h2>
                        </div>
                        <span class="info-status-badge @GetDocumentBadgeClass()">@GetDocumentProgress()</span>
                    </header>

                    <div class="info-documents-grid">
                        @foreach (var slot in DocumentSlots)
                        {
                            var document = FindDocument(slot.Key);
                            var selectedFileName = GetSelectedFileName(slot.UploadKey);
                            <article class="info-document-row @GetDocumentRowClass(document?.ReviewStatus)">
                                <span class="info-document-code @GetDocumentStatusClass(document?.ReviewStatus)">@slot.ShortLabel</span>
                                <div>
                                    <strong>@slot.Label</strong>
                                    <small>@(document?.OriginalFileName ?? slot.Description)</small>
                                    @if (!string.IsNullOrWhiteSpace(selectedFileName))
                                    {
                                        <em>@selectedFileName</em>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(document?.ReviewNote))
                                    {
                                        <small>@document.ReviewNote</small>
                                    }
                                </div>
                                <div class="info-document-actions">
                                    @if (document is not null)
                                    {
                                        <a href="@ApiClient.ToApiUrl(document.PreviewUrl)" target="_blank" title="Voir">Voir</a>
                                    }
                                    <label>
                                        @(document is null ? "Ajouter" : "Remplacer")
                                        <InputFile OnChange="@((InputFileChangeEventArgs args) => SetDocument(slot.UploadKey, args))" accept=".pdf,.jpg,.jpeg,.png" />
                                    </label>
                                </div>
                            </article>
                        }
                    </div>

                    <footer class="info-documents-footer">
                        <span>Depot possible dans nos bureaux si vous preferez nous remettre les pieces en main propre.</span>
                        <button type="button" class="info-send-button" disabled="@IsUploading" @onclick="UploadAsync">
                            @(IsUploading ? "Envoi..." : "Envoyer les pieces")
                        </button>
                    </footer>
                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        <p class="field-message">@Message</p>
                    }
                </section>
            </section>
        }
    </CompanyPortalShell>
}

@code {
    private static readonly IReadOnlyList<DocumentSlot> DocumentSlots =
    [
        new("FiscalExistenceDeclaration", "fiscalExistenceDeclaration", "DFE", "DFE", "Declaration Fiscale d'Existence", false),
        new("BusinessRegistration", "companyDocument", "RC", "Registre de commerce", "RCCM ou document legal equivalent", false),
        new("OwnerIdentity", "ownerIdentityDocument", "ID", "Identite du responsable", "CNI, passeport ou document officiel", false),
        new("AddressProof", "addressProof", "ADR", "Justificatif d'adresse", "Facture, bail ou attestation", true)
    ];

    private CompanyPortalSessionResponse? Session { get; set; }
    private CompanyPortalProfileResponse? Profile { get; set; }
    private bool IsLoading { get; set; }
    private bool IsUploading { get; set; }
    private bool IsSaving { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private string? Message { get; set; }
    private string? EditingSection { get; set; }
    private string CompanyNameDraft { get; set; } = string.Empty;
    private string? LegalFormDraft { get; set; }
    private string? RegistrationNumberDraft { get; set; }
    private string? TaxIdentificationNumberDraft { get; set; }
    private string CityDraft { get; set; } = string.Empty;
    private string? AddressDraft { get; set; }
    private string ContactNameDraft { get; set; } = string.Empty;
    private string EmailDraft { get; set; } = string.Empty;
    private string PhoneNumberDraft { get; set; } = string.Empty;
    private string? InterventionZonesDraft { get; set; }
    private string? PlannedServicesDraft { get; set; }
    private string? WavePaymentNumberDraft { get; set; }
    private string? OrangeMoneyPaymentNumberDraft { get; set; }
    private readonly Dictionary<string, IBrowserFile?> Documents = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase))
        {
            Session = DemoSession();
            Profile = DemoProfile(Session);
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadProfileAsync();
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadProfileAsync()
    {
        if (Session is null)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Profile = await ApiClient.GetCompanyProfileAsync(Session.CompanyId);
            if (Profile is not null)
            {
                Session = Session with
                {
                    CompanyName = Profile.CompanyName,
                    CompanyStatus = Profile.CompanyStatus,
                    IsCompanyApproved = Profile.IsCompanyApproved
                };
                await Js.InvokeVoidAsync("localStorage.setItem", "homeservice.company.session", JsonSerializer.Serialize(Session));
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool IsCompanyApproved() => (Profile?.IsCompanyApproved ?? Session?.IsCompanyApproved) == true;

    private bool IsEditing(string section) => string.Equals(EditingSection, section, StringComparison.OrdinalIgnoreCase);

    private void StartEdit(string section)
    {
        HydrateDrafts();
        EditingSection = section;
        Message = null;
    }

    private void CancelEdit()
    {
        EditingSection = null;
        Message = null;
    }

    private void HydrateDrafts()
    {
        if (Session is null)
        {
            return;
        }

        CompanyNameDraft = Display(Profile?.CompanyName, Session.CompanyName);
        LegalFormDraft = Profile?.LegalForm;
        RegistrationNumberDraft = Profile?.RegistrationNumber;
        TaxIdentificationNumberDraft = Profile?.TaxIdentificationNumber;
        CityDraft = Display(Profile?.City, "Abidjan");
        AddressDraft = Profile?.Address;
        ContactNameDraft = Display(Profile?.ContactName, Session.UserName);
        EmailDraft = Display(Profile?.Email, Session.Email);
        PhoneNumberDraft = Display(Profile?.PhoneNumber, string.Empty);
        InterventionZonesDraft = Profile?.InterventionZones ?? string.Join(", ", GetInterventionZones().Where(zone => zone != "A completer"));
        PlannedServicesDraft = Profile?.PlannedServices ?? string.Join(", ", GetPlannedServices().Where(service => service != "A completer"));
        WavePaymentNumberDraft = Profile?.WavePaymentNumber;
        OrangeMoneyPaymentNumberDraft = Profile?.OrangeMoneyPaymentNumber;
    }

    private async Task SaveCompanyInfoAsync()
    {
        if (Session is null)
        {
            return;
        }

        await SaveProfileSectionAsync(ApiClient.UpdateCompanyInformationAsync(
            Session.CompanyId,
            new UpdateCompanyPortalCompanyInfoRequest(
                CompanyNameDraft,
                LegalFormDraft,
                RegistrationNumberDraft,
                TaxIdentificationNumberDraft,
                CityDraft,
                AddressDraft)));
    }

    private async Task SaveContactAsync()
    {
        if (Session is null)
        {
            return;
        }

        await SaveProfileSectionAsync(ApiClient.UpdateCompanyContactAsync(
            Session.CompanyId,
            new UpdateCompanyPortalContactRequest(ContactNameDraft, EmailDraft, PhoneNumberDraft)));
    }

    private async Task SaveOperationsAsync()
    {
        if (Session is null)
        {
            return;
        }

        await SaveProfileSectionAsync(ApiClient.UpdateCompanyOperationsAsync(
            Session.CompanyId,
            new UpdateCompanyPortalOperationsRequest(InterventionZonesDraft, PlannedServicesDraft)));
    }

    private async Task SavePaymentAsync()
    {
        if (Session is null)
        {
            return;
        }

        await SaveProfileSectionAsync(ApiClient.UpdateCompanyPaymentAsync(
            Session.CompanyId,
            new UpdateCompanyPortalPaymentRequest(WavePaymentNumberDraft, OrangeMoneyPaymentNumberDraft)));
    }

    private async Task SaveProfileSectionAsync(Task<EmployeeSaveResult> operation)
    {
        IsSaving = true;
        Message = null;
        try
        {
            var result = await operation;
            if (!result.IsSuccess)
            {
                Message = result.ErrorMessage;
                return;
            }

            EditingSection = null;
            Message = "Informations mises a jour.";
            await LoadProfileAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private string GetStatusLabel() => IsCompanyApproved()
        ? "Compte valide"
        : "Conformite requise";

    private string GetProfileSubtitle()
    {
        return IsCompanyApproved()
            ? "Votre entreprise est validee et peut affecter ses missions."
            : "Votre entreprise peut preparer son espace. Les affectations seront ouvertes apres validation.";
    }

    private string GetLegalSubtitle()
    {
        var city = Display(Profile?.City, "Cote d'Ivoire");
        var legalForm = Display(Profile?.LegalForm, "Societe de services");
        return $"{legalForm} - {city}";
    }

    private string GetShortStatusLabel() => IsCompanyApproved() ? "Valide" : "Incomplet";

    private string GetStatusToneClass() => IsCompanyApproved() ? "info-tone-green" : "info-tone-amber";

    private string GetStatusBadgeClass() => IsCompanyApproved() ? "info-badge-green" : "info-badge-amber";

    private string GetDocumentBadgeClass() => AreRequiredDocumentsApproved() ? "info-badge-green" : "info-badge-amber";

    private string GetDocumentsCardClass() => AreRequiredDocumentsApproved() ? "info-documents-complete" : "info-documents-pending";

    private string GetDocumentsIconClass() => AreRequiredDocumentsApproved() ? "info-green" : "info-amber";

    private string GetDocumentToneClass() => AreRequiredDocumentsApproved() ? "info-tone-green" : "info-tone-amber";

    private string GetDocumentCounter()
    {
        var (approved, total) = GetRequiredDocumentCounts();
        return $"{approved}/{total}";
    }

    private bool AreRequiredDocumentsApproved()
    {
        var (approved, total) = GetRequiredDocumentCounts();
        return total > 0 && approved == total;
    }

    private (int Approved, int Total) GetRequiredDocumentCounts()
    {
        var required = DocumentSlots.Where(slot => !slot.Optional).ToList();
        var approved = required.Count(slot => FindDocument(slot.Key)?.ReviewStatus == "Approved");
        return (approved, required.Count);
    }

    private int GetZoneCount() => GetInterventionZones().Count;

    private IReadOnlyList<string> GetInterventionZones()
    {
        var zones = new List<string>();
        if (!string.IsNullOrWhiteSpace(Profile?.City))
        {
            zones.Add(Profile.City);
        }

        if (!string.IsNullOrWhiteSpace(Profile?.Address))
        {
            zones.AddRange(Profile.Address
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(zone => !string.IsNullOrWhiteSpace(zone)));
        }

        if (!string.IsNullOrWhiteSpace(Profile?.InterventionZones))
        {
            zones.AddRange(Profile.InterventionZones
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(zone => !string.IsNullOrWhiteSpace(zone)));
        }

        return zones.Count == 0 ? ["A completer"] : zones.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
    }

    private string PortalLink(string path)
    {
        return Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase)
            ? $"{path}?preview=1"
            : path;
    }

    private IReadOnlyList<string> GetPlannedServices()
    {
        var services = (Profile?.PlannedServices ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(service => !string.IsNullOrWhiteSpace(service))
            .ToList();

        return services.Count == 0 ? ["A completer"] : services;
    }

    private CompanyPortalProfileDocumentResponse? FindDocument(string documentType)
    {
        return Profile?.Documents
            .Where(document => string.Equals(document.DocumentType, documentType, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(document => document.CreatedAt)
            .FirstOrDefault();
    }

    private string GetDocumentProgress()
    {
        var required = DocumentSlots.Where(slot => !slot.Optional).ToList();
        var approved = required.Count(slot => FindDocument(slot.Key)?.ReviewStatus == "Approved");
        return $"{approved}/{required.Count} obligatoires valides";
    }

    private static string GetDocumentStatusClass(string? status) => status switch
    {
        "Approved" => "status-ok",
        "Rejected" or "NeedsReplacement" => "status-rejected",
        "Pending" => "status-pending",
        _ => "status-muted"
    };

    private static string GetDocumentRowClass(string? status) => status switch
    {
        "Approved" => "info-document-valid",
        "Rejected" or "NeedsReplacement" => "info-document-rejected",
        "Pending" => "info-document-pending",
        _ => "info-document-missing"
    };

    private static string GetDocumentStatusLabel(string? status) => status switch
    {
        "Approved" => "Valide",
        "Rejected" => "Refuse",
        "NeedsReplacement" => "A remplacer",
        "Pending" => "En verification",
        _ => "A fournir"
    };

    private void SetDocument(string key, InputFileChangeEventArgs args)
    {
        Documents[key] = args.File;
        Message = null;
    }

    private string? GetSelectedFileName(string key)
    {
        return Documents.TryGetValue(key, out var file) && file is not null ? file.Name : null;
    }

    private async Task UploadAsync()
    {
        if (Session is null)
        {
            return;
        }

        if (Documents.Values.All(file => file is null))
        {
            Message = "Ajoutez au moins un document avant l'envoi.";
            return;
        }

        IsUploading = true;
        try
        {
            var result = await ApiClient.UploadCompanyComplianceDocumentsAsync(Session.CompanyId, Documents);
            Message = result.IsSuccess
                ? "Documents recus. Notre equipe va les verifier."
                : $"Envoi impossible: {result.ErrorMessage}";
            if (result.IsSuccess)
            {
                Documents.Clear();
                await LoadProfileAsync();
            }
        }
        finally
        {
            IsUploading = false;
        }
    }

    private static string Display(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private static string GetInitials(string value)
    {
        var parts = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]).ToString());

        var initials = string.Concat(parts);
        return string.IsNullOrWhiteSpace(initials) ? "K" : initials;
    }


@page "/company-profile"
@using HomeService.Company.Services
@using HomeService.Contracts.CompanyPortal
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject PlatformApiClient ApiClient
@inject IJSRuntime Js
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Informations entreprise</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de votre fiche entreprise.</p>
    </section>
}
else if (Session is null)
{
    <section class="activation-card">
        <h1>Connexion requise</h1>
        <p class="lead">Connectez-vous au portail entreprise pour consulter vos informations et suivre la conformite.</p>
        <a class="primary-action" href="dashboard">Se connecter</a>
    </section>
}
else
{
    <div class="company-profile-shell">
        <CompanyPortalNav Active="company-profile" />

        @if (!IsCompanyApproved())
        {
            <section class="compliance-banner">
                <div>
                    <strong>Compte en attente de conformite</strong>
                    <span>Votre profil est cree. Les affectations et fonctions sensibles seront ouvertes apres validation des pieces.</span>
                </div>
                <a href="#documents">Finaliser</a>
            </section>
        }

        <section class="company-profile-hero">
            <div>
                <p class="eyebrow">Profil entreprise</p>
                <h1>@(Profile?.CompanyName ?? Session.CompanyName)</h1>
                <p>@GetProfileSubtitle()</p>
            </div>
            <span class="activation-status">@GetStatusLabel()</span>
        </section>

        @if (IsLoading)
        {
            <section class="empty-state"><h2>Chargement...</h2><p>Recuperation de votre fiche entreprise.</p></section>
        }
        else
        {
            <section class="profile-overview-strip">
                <article><span>Statut</span><strong>@GetStatusLabel()</strong><small>@(Profile?.ApplicationStatus ?? Session.CompanyStatus)</small></article>
                <article><span>Documents</span><strong>@GetDocumentProgress()</strong><small>DFE, RCCM, identite</small></article>
                <article><span>Services</span><strong>@GetPlannedServices().Count</strong><small>Activites declarees</small></article>
            </section>

            <section class="company-profile-grid">
                <article class="profile-card">
                    <p class="eyebrow">Entreprise</p>
                    <h2>Informations principales</h2>
                    <dl class="profile-definition-list">
                        <div><dt>Nom</dt><dd>@Display(Profile?.CompanyName, Session.CompanyName)</dd></div>
                        <div><dt>Ville</dt><dd>@Display(Profile?.City, "A completer")</dd></div>
                        <div><dt>Adresse / zone</dt><dd>@Display(Profile?.Address, "A completer")</dd></div>
                        <div><dt>Prestataires prevus</dt><dd>@(Profile?.EstimatedProviderCount?.ToString() ?? "A definir")</dd></div>
                    </dl>
                </article>

                <article class="profile-card">
                    <p class="eyebrow">Responsable</p>
                    <h2>Compte administrateur</h2>
                    <dl class="profile-definition-list">
                        <div><dt>Nom</dt><dd>@Display(Profile?.ContactName, Session.UserName)</dd></div>
                        <div><dt>Email</dt><dd>@Display(Profile?.Email, Session.Email)</dd></div>
                        <div><dt>Telephone</dt><dd>@Display(Profile?.PhoneNumber, "A completer")</dd></div>
                        <div><dt>Statut</dt><dd>@GetStatusLabel()</dd></div>
                    </dl>
                </article>
            </section>

            <section class="profile-card">
                <div class="profile-section-heading">
                    <div>
                        <p class="eyebrow">Services</p>
                        <h2>Services envisages</h2>
                    </div>
                </div>
                <div class="selected-service-tags">
                    @foreach (var service in GetPlannedServices())
                    {
                        <span>@service</span>
                    }
                </div>
            </section>

            <section id="documents" class="compliance-grid">
                <article class="profile-card">
                    <div class="profile-section-heading">
                        <div>
                            <p class="eyebrow">Documents</p>
                            <h2>Pieces du dossier</h2>
                        </div>
                        <span>@GetDocumentProgress()</span>
                    </div>

                    <div class="document-status-list">
                        @foreach (var slot in DocumentSlots)
                        {
                            var document = FindDocument(slot.Key);
                            <article class="document-status-row">
                                <span class="document-status-icon @GetDocumentStatusClass(document?.ReviewStatus)">@slot.ShortLabel</span>
                                <div>
                                    <strong>@slot.Label</strong>
                                    <small>@slot.Description</small>
                                    @if (document is not null)
                                    {
                                        <em>@document.OriginalFileName</em>
                                        @if (!string.IsNullOrWhiteSpace(document.ReviewNote))
                                        {
                                            <small>@document.ReviewNote</small>
                                        }
                                    }
                                </div>
                                <div>
                                    <span class="status-pill @GetDocumentStatusClass(document?.ReviewStatus)">@GetDocumentStatusLabel(document?.ReviewStatus)</span>
                                    @if (document is not null)
                                    {
                                        <a href="@ApiClient.ToApiUrl(document.PreviewUrl)" target="_blank">Voir</a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </article>

                <article class="profile-card upload-panel">
                    <p class="eyebrow">Mise a jour</p>
                    <h2>Ajouter ou remplacer une piece</h2>
                    <p>Ajoutez vos documents en ligne ou deposez-les dans nos bureaux. Si vous venez au bureau, l'admin pourra les scanner et les ajouter a votre dossier.</p>
                    <div class="compliance-upload-grid">
                        @foreach (var slot in DocumentSlots)
                        {
                            <label class="compliance-upload-card">
                                <span class="compliance-upload-icon">@slot.ShortLabel</span>
                                <span class="compliance-upload-content">
                                    <strong>@slot.Label</strong>
                                    <small>@slot.Description</small>
                                    <em>@GetUploadLabel(slot.UploadKey, slot.Optional ? "Optionnel" : "A fournir")</em>
                                </span>
                                <span class="compliance-upload-action">@GetUploadActionLabel(slot.UploadKey)</span>
                                <InputFile OnChange="@((InputFileChangeEventArgs args) => SetDocument(slot.UploadKey, args))" accept=".pdf,.jpg,.jpeg,.png" />
                            </label>
                        }
                    </div>
                    <div class="compliance-options">
                        <button type="button" class="primary-action" disabled="@IsUploading" @onclick="UploadAsync">
                            @(IsUploading ? "Envoi en cours..." : "Envoyer les pieces selectionnees")
                        </button>
                        <button type="button" class="secondary-action">Depot au bureau</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        <p class="field-message">@Message</p>
                    }
                </article>
            </section>
        }
    </div>
}

@code {
    private static readonly IReadOnlyList<DocumentSlot> DocumentSlots =
    [
        new("FiscalExistenceDeclaration", "fiscalExistenceDeclaration", "DFE", "DFE", "Declaration Fiscale d'Existence", false),
        new("BusinessRegistration", "companyDocument", "RC", "Registre de commerce", "RCCM ou document legal equivalent", false),
        new("OwnerIdentity", "ownerIdentityDocument", "ID", "Identite du responsable", "CNI, passeport ou document officiel", false),
        new("AddressProof", "addressProof", "ADR", "Justificatif d'adresse", "Facture, bail ou attestation", true)
    ];

    private CompanyPortalSessionResponse? Session { get; set; }
    private CompanyPortalProfileResponse? Profile { get; set; }
    private bool IsLoading { get; set; }
    private bool IsUploading { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private string? Message { get; set; }
    private readonly Dictionary<string, IBrowserFile?> Documents = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase))
        {
            Session = DemoSession();
            Profile = DemoProfile(Session);
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            await LoadProfileAsync();
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadProfileAsync()
    {
        if (Session is null)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Profile = await ApiClient.GetCompanyProfileAsync(Session.CompanyId);
            if (Profile is not null)
            {
                Session = Session with
                {
                    CompanyName = Profile.CompanyName,
                    CompanyStatus = Profile.CompanyStatus,
                    IsCompanyApproved = Profile.IsCompanyApproved
                };
                await Js.InvokeVoidAsync("localStorage.setItem", "homeservice.company.session", JsonSerializer.Serialize(Session));
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool IsCompanyApproved() => (Profile?.IsCompanyApproved ?? Session?.IsCompanyApproved) == true;

    private string GetStatusLabel() => IsCompanyApproved()
        ? "Compte valide"
        : "Conformite requise";

    private string GetProfileSubtitle()
    {
        return IsCompanyApproved()
            ? "Votre entreprise est validee et peut affecter ses missions."
            : "Votre entreprise peut preparer son espace. Les affectations seront ouvertes apres validation.";
    }

    private string PortalLink(string path)
    {
        return Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase)
            ? $"{path}?preview=1"
            : path;
    }

    private IReadOnlyList<string> GetPlannedServices()
    {
        var services = (Profile?.PlannedServices ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(service => !string.IsNullOrWhiteSpace(service))
            .ToList();

        return services.Count == 0 ? ["A completer"] : services;
    }

    private CompanyPortalProfileDocumentResponse? FindDocument(string documentType)
    {
        return Profile?.Documents
            .Where(document => string.Equals(document.DocumentType, documentType, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(document => document.CreatedAt)
            .FirstOrDefault();
    }

    private string GetDocumentProgress()
    {
        var required = DocumentSlots.Where(slot => !slot.Optional).ToList();
        var approved = required.Count(slot => FindDocument(slot.Key)?.ReviewStatus == "Approved");
        return $"{approved}/{required.Count} obligatoires valides";
    }

    private static string GetDocumentStatusClass(string? status) => status switch
    {
        "Approved" => "status-ok",
        "Rejected" or "NeedsReplacement" => "status-rejected",
        "Pending" => "status-pending",
        _ => "status-muted"
    };

    private static string GetDocumentStatusLabel(string? status) => status switch
    {
        "Approved" => "Valide",
        "Rejected" => "Refuse",
        "NeedsReplacement" => "A remplacer",
        "Pending" => "En verification",
        _ => "A fournir"
    };

    private void SetDocument(string key, InputFileChangeEventArgs args)
    {
        Documents[key] = args.File;
        Message = null;
    }

    private string GetUploadLabel(string key, string fallback)
    {
        return Documents.TryGetValue(key, out var file) && file is not null ? file.Name : fallback;
    }

    private string GetUploadActionLabel(string key)
    {
        return Documents.TryGetValue(key, out var file) && file is not null ? "Remplacer" : "Ajouter";
    }

    private async Task UploadAsync()
    {
        if (Session is null)
        {
            return;
        }

        if (Documents.Values.All(file => file is null))
        {
            Message = "Ajoutez au moins un document avant l'envoi.";
            return;
        }

        IsUploading = true;
        try
        {
            var result = await ApiClient.UploadCompanyComplianceDocumentsAsync(Session.CompanyId, Documents);
            Message = result.IsSuccess
                ? "Documents recus. Notre equipe va les verifier."
                : $"Envoi impossible: {result.ErrorMessage}";
            if (result.IsSuccess)
            {
                Documents.Clear();
                await LoadProfileAsync();
            }
        }
        finally
        {
            IsUploading = false;
        }
    }

    private static string Display(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private static CompanyPortalSessionResponse DemoSession()
    {
        return new CompanyPortalSessionResponse(
            Guid.Parse("11111111-1111-1111-1111-111111111111"),
            "Entreprise Demo CI",
            "Direction Demo",
            "direction@entreprise.ci",
            DateTimeOffset.UtcNow,
            "demo-preview-token",
            "PendingReview",
            false);
    }

    private static CompanyPortalProfileResponse DemoProfile(CompanyPortalSessionResponse session)
    {
        return new CompanyPortalProfileResponse(
            session.CompanyId,
            Guid.Parse("22222222-2222-2222-2222-222222222222"),
            session.CompanyName,
            null,
            "Abidjan",
            "Cocody Angre, 7e tranche",
            session.UserName,
            session.Email,
            "+2250700000000",
            "Menage a domicile, Jardinage, Nounou",
            12,
            session.CompanyStatus,
            "Submitted",
            false,
            null,
            [
                new CompanyPortalProfileDocumentResponse(Guid.NewGuid(), "FiscalExistenceDeclaration", "DFE", "dfe-demo.pdf", "application/pdf", "Pending", null, DateTimeOffset.UtcNow.AddDays(-1), "#"),
                new CompanyPortalProfileDocumentResponse(Guid.NewGuid(), "BusinessRegistration", "Registre de commerce", "rccm-demo.pdf", "application/pdf", "Approved", null, DateTimeOffset.UtcNow.AddDays(-2), "#")
            ]);
    }

    private sealed record DocumentSlot(string Key, string UploadKey, string ShortLabel, string Label, string Description, bool Optional);
}

                "Disponible rapidement. Peut passer au bureau pour un test.",
                "Entreprise Demo CI",
                null,
                DateTimeOffset.UtcNow.AddHours(-5),
                null,
                [
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Menage a domicile", "Confirmed", 5),
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Nounou", "Junior", 2)
                ],
                [
                    new CompanyInterimCandidateAffiliationResponse(Guid.Parse("11111111-1111-1111-1111-111111111101"), Guid.Parse("11111111-1111-1111-1111-111111111111"), "Entreprise Demo CI", "Pending", DateTimeOffset.UtcNow.AddHours(-5), null, true),
                    new CompanyInterimCandidateAffiliationResponse(Guid.NewGuid(), Guid.NewGuid(), "Cocody Services", "Pending", DateTimeOffset.UtcNow.AddHours(-4), null, false)
                ]),
            new CompanyInterimCandidateResponse(
                Guid.Parse("11111111-1111-1111-1111-111111111102"),
                Guid.Parse("22222222-2222-2222-2222-222222222202"),
                "Serge",
                "Kouame",
                "+225 05 22 33 44 55",
                new DateOnly(1991, 11, 16),
                "Yopougon, Abidjan",
                "Male",
                8,
                "Pending",
                "Jardinier avec references disponibles.",
                "Entreprise Demo CI",
                null,
                DateTimeOffset.UtcNow.AddDays(-1),
                null,
                [
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Jardinage", "Senior", 8)
                ],
                [
                    new CompanyInterimCandidateAffiliationResponse(Guid.Parse("11111111-1111-1111-1111-111111111102"), Guid.Parse("11111111-1111-1111-1111-111111111111"), "Entreprise Demo CI", "Pending", DateTimeOffset.UtcNow.AddDays(-1), null, true)
                ]),
            new CompanyInterimCandidateResponse(
                Guid.Parse("11111111-1111-1111-1111-111111111103"),
                Guid.Parse("22222222-2222-2222-2222-222222222203"),
                "Yves",
                "Bamba",
                "+225 01 55 88 20 14",
                new DateOnly(1988, 2, 20),
                "Cocody, Abidjan",
                "Male",
                9,
                "Approved",
                "Profil recu et valide apres entretien.",
                "Entreprise Demo CI",
                "Entretien realise, profil operationnel.",
                DateTimeOffset.UtcNow.AddDays(-3),
                DateTimeOffset.UtcNow.AddDays(-2),
                [
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Electricite", "Expert", 9),
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Depannage auto", "Confirmed", 6)
                ],
                [
                    new CompanyInterimCandidateAffiliationResponse(Guid.Parse("11111111-1111-1111-1111-111111111103"), Guid.Parse("11111111-1111-1111-1111-111111111111"), "Entreprise Demo CI", "Approved", DateTimeOffset.UtcNow.AddDays(-3), DateTimeOffset.UtcNow.AddDays(-2), true),
                    new CompanyInterimCandidateAffiliationResponse(Guid.NewGuid(), Guid.NewGuid(), "Yop Services", "Cancelled", DateTimeOffset.UtcNow.AddDays(-3), DateTimeOffset.UtcNow.AddDays(-2), false)
                ]),
            new CompanyInterimCandidateResponse(
                Guid.Parse("11111111-1111-1111-1111-111111111104"),
                Guid.Parse("22222222-2222-2222-2222-222222222204"),

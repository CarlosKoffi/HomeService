@page "/interim-candidates"
@layout HomeService.Company.Components.Layout.EmptyLayout
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject IWebHostEnvironment Environment

<PageTitle>Interim</PageTitle>

@if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous au portail entreprise pour consulter les demandes d'interim.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="interim-candidates"
                        Title="Interim"
                        Subtitle="@($"{VisibleCandidates.Count} candidature(s) affichee(s)")"
                        CompanyId="@Session.CompanyId"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(Session.IsCompanyApproved ? 75 : 35)">
        <section class="interim-workspace">
            <section class="interim-hero-panel">
                <div>
                    <span>Viviers candidats</span>
                    <strong>@PendingCandidates.Count demande(s) a evaluer</strong>
                    <p>Consultez les profils, filtrez par service ou zone, puis validez uniquement les candidats que votre entreprise accepte.</p>
                </div>
                <div class="interim-toggle-panel @(AcceptsInterimApplications ? "enabled" : "disabled")">
                    <span>Reception des demandes</span>
                    <strong>@(AcceptsInterimApplications ? "Activee" : "Desactivee")</strong>
                    <p>@InterimSettingsMessage</p>
                    <button type="button"
                            class="interim-switch @(AcceptsInterimApplications ? "on" : "off")"
                            disabled="@IsSavingInterimSettings"
                            @onclick="ToggleInterimSettingsAsync"
                            aria-pressed="@AcceptsInterimApplications">
                        <span></span>
                        @(AcceptsInterimApplications ? "ON" : "OFF")
                    </button>
                </div>
                <div class="interim-hero-stats">
                    <button type="button" class="@GetFilterButtonClass("A evaluer")" @onclick="@(() => SetFilter("A evaluer"))">
                        <strong>@PendingCandidates.Count</strong>
                        <span>A evaluer</span>
                    </button>
                    <button type="button" class="@GetFilterButtonClass("Valides")" @onclick="@(() => SetFilter("Valides"))">
                        <strong>@ApprovedCandidates.Count</strong>
                        <span>Valides</span>
                    </button>
                    <button type="button" class="@GetFilterButtonClass("Refuses")" @onclick="@(() => SetFilter("Refuses"))">
                        <strong>@RejectedCandidates.Count</strong>
                        <span>Refuses</span>
                    </button>
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <p class="field-message">@Message</p>
            }

            <section class="interim-toolbar">
                <label class="employee-search">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input @bind="Search" @bind:event="oninput" placeholder="Rechercher candidat, service ou zone..." />
                </label>
                <div class="employee-filter-tabs" role="tablist" aria-label="Filtres interim">
                    @foreach (var filter in Filters)
                    {
                        <button type="button" class="@GetFilterTabClass(filter)" @onclick="@(() => SetFilter(filter))">@filter <span>@GetFilterCount(filter)</span></button>
                    }
                </div>
            </section>

            <section class="interim-modern-table">
                <div class="interim-table-head">
                    <span>Candidat</span>
                    <span>Services</span>
                    <span>Experience</span>
                    <span>Zone</span>
                    <span>Statut</span>
                    <span>Actions</span>
                </div>

                @if (VisibleCandidates.Count == 0)
                {
                    <div class="interim-empty-line">
                        <strong>Aucune candidature trouvee</strong>
                        <span>Changez le filtre ou la recherche pour afficher d'autres profils.</span>
                    </div>
                }
                else
                {
                    @foreach (var candidate in VisibleCandidates)
                    {
                        <article class="@GetCandidateRowClass(candidate)">
                            <div class="interim-person-cell"
                                 title="@GetCandidateActionTitle()"
                                 @onclick="() => OpenCandidate(candidate)">
                                <span class="@GetAvatarClass(candidate)">@GetInitials(candidate)</span>
                                <div>
                                    <strong>@candidate.FirstName @candidate.LastName</strong>
                                    <a href="tel:@candidate.PhoneNumber">@candidate.PhoneNumber</a>
                                    <small>@GetGenderLabel(candidate.Gender) - demande a @candidate.TargetCompanyName</small>
                                </div>
                            </div>

                            <div class="employee-service-tags">
                                @foreach (var service in candidate.Services.Take(3))
                                {
                                    <span>@service.ServiceName</span>
                                }
                                @if (candidate.Services.Count > 3)
                                {
                                    <span>+@(candidate.Services.Count - 3)</span>
                                }
                            </div>

                            <div class="employee-experience-cell">
                                <strong>@candidate.YearsOfExperience an(s)</strong>
                                <span>@GetMainExperience(candidate)</span>
                                <small>@GetServiceSummary(candidate)</small>
                            </div>

                            <div class="employee-zone-cell">
                                <svg viewBox="0 0 24 24"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                                <span>@Display(candidate.Address)</span>
                            </div>

                            <div class="employee-status-cell">
                                <span class="@GetStatusBadgeClass(candidate.Status)">@GetStatusLabel(candidate.Status)</span>
                                <small>@GetCandidateMessage(candidate)</small>
                            </div>

                            <div class="interim-actions">
                                <button type="button"
                                        class="interim-action-secondary"
                                        disabled="@(!CanManageInterimCandidates)"
                                        title="@GetCandidateActionTitle()"
                                        @onclick="() => OpenCandidate(candidate)">
                                    Voir la fiche
                                </button>
                                <button type="button"
                                        class="interim-action-primary"
                                        disabled="@(!CanManageInterimCandidates || IsClosed(candidate.Status))"
                                        title="Ouvrir la fiche pour confirmer l'evaluation"
                                        @onclick="() => OpenCandidate(candidate)">
                                    Evaluer
                                </button>
                            </div>
                        </article>
                    }
                }
            </section>
        </section>

        @if (SelectedCandidate is not null)
        {
            <div class="modal-backdrop interim-profile-backdrop" @onclick="CloseCandidate">
                <section class="interim-profile-modal" @onclick:stopPropagation>
                    <header class="interim-profile-header">
                        <div class="interim-profile-title">
                            <span class="@GetAvatarClass(SelectedCandidate)">@GetInitials(SelectedCandidate)</span>
                            <div>
                                <small>Demande interimaire</small>
                                <strong>@SelectedCandidate.FirstName @SelectedCandidate.LastName</strong>
                                <em>@GetStatusLabel(SelectedCandidate.Status)</em>
                            </div>
                        </div>
                        <button type="button" class="employee-upsert-close" @onclick="CloseCandidate" aria-label="Fermer">
                            <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </header>

                    <div class="interim-profile-body">
                        <article class="interim-profile-card">
                            <div class="interim-card-title">
                                <span>Identite</span>
                                <strong>Informations principales</strong>
                            </div>
                            <dl class="interim-info-grid">
                                <div>
                                    <dt>Prenom nom</dt>
                                    <dd>@SelectedCandidate.FirstName @SelectedCandidate.LastName</dd>
                                </div>
                                <div>
                                    <dt>Sexe</dt>
                                    <dd>@GetGenderLabel(SelectedCandidate.Gender)</dd>
                                </div>
                                <div>
                                    <dt>Date de naissance</dt>
                                    <dd>@FormatDate(SelectedCandidate.BirthDate)</dd>
                                </div>
                                <div>
                                    <dt>Telephone</dt>
                                    <dd><a href="tel:@SelectedCandidate.PhoneNumber">@SelectedCandidate.PhoneNumber</a></dd>
                                </div>
                                <div class="wide">
                                    <dt>Adresse</dt>
                                    <dd>@Display(SelectedCandidate.Address)</dd>
                                </div>
                                <div>
                                    <dt>Candidature recue</dt>
                                    <dd>@SelectedCandidate.RequestedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                                </div>
                                <div>
                                    <dt>Entreprise ciblee</dt>
                                    <dd>@SelectedCandidate.TargetCompanyName</dd>
                                </div>
                            </dl>
                        </article>

                        <article class="interim-profile-card">
                            <div class="interim-card-title">
                                <span>Metier</span>
                                <strong>Services proposes</strong>
                            </div>
                            <div class="interim-profile-services">
                                @foreach (var service in SelectedCandidate.Services)
                                {
                                    <div>
                                        <strong>@service.ServiceName</strong>
                                        <span>@GetExperienceLabel(service.ExperienceLevel) - @service.YearsOfExperience an(s)</span>
                                    </div>
                                }
                            </div>
                        </article>

                        <article class="interim-profile-card">
                            <div class="interim-card-title">
                                <span>Decision</span>
                                <strong>Validation entreprise</strong>
                            </div>
                            <p class="interim-profile-note">@GetCandidateMessage(SelectedCandidate)</p>
                            @if (!string.IsNullOrWhiteSpace(SelectedCandidate.ReviewNote))
                            {
                                <p class="interim-profile-note">@SelectedCandidate.ReviewNote</p>
                            }
                            <label class="interim-review-field">
                                Note interne
                                <textarea @bind="ReviewNotes[SelectedCandidate.RequestId]" placeholder="Ex: Recu au bureau, test pratique OK, piece verifiee."></textarea>
                            </label>
                            <label class="interim-competency-check">
                                <input type="checkbox" @bind="CompetencyChecks[SelectedCandidate.RequestId]" />
                                <span>
                                    <strong>J'ai rencontre ce candidat et je valide ses competences.</strong>
                                    <small>Il sera ajoute dans vos employes comme interimaire, avec un profil a completer avant activation.</small>
                                </span>
                            </label>
                        </article>

                        <article class="interim-profile-card">
                            <div class="interim-card-title">
                                <span>Demandes</span>
                                <strong>Entreprises sollicitees</strong>
                            </div>
                            <div class="interim-affiliation-list">
                                @foreach (var application in SelectedCandidate.Applications)
                                {
                                    <div class="@(application.IsCurrentCompany ? "current" : string.Empty)">
                                        <span>
                                            <strong>@application.CompanyName</strong>
                                            <small>@application.RequestedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                        </span>
                                        <em class="@GetAffiliationStatusClass(application.Status)">@GetAffiliationStatusLabel(application.Status)</em>
                                    </div>
                                }
                            </div>
                        </article>
                    </div>

                    <footer class="interim-profile-footer">
                        <button type="button" class="secondary-action" @onclick="CloseCandidate">Fermer</button>
                        <button type="button" class="secondary-action danger-action" disabled="@(!CanManageInterimCandidates || IsClosed(SelectedCandidate.Status))" @onclick="() => RejectAsync(SelectedCandidate.RequestId)">Refuser</button>
                        <button type="button" class="primary-action" disabled="@(!CanApproveSelectedCandidate(SelectedCandidate))" @onclick="() => ApproveAsync(SelectedCandidate.RequestId)">Valider comme interimaire</button>
                    </footer>
                </section>
            </div>
        }
    </CompanyPortalShell>
}

@code {
    private static readonly IReadOnlyList<string> Filters = ["Tous", "A evaluer", "Valides", "Refuses"];

    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyInterimCandidateResponse> Candidates { get; set; } = [];
    private Dictionary<Guid, string?> ReviewNotes { get; } = [];
    private Dictionary<Guid, bool> CompetencyChecks { get; } = [];
    private string? Message { get; set; }
    private string Search { get; set; } = string.Empty;
    private string ActiveFilter { get; set; } = "Tous";
    private CompanyInterimCandidateResponse? SelectedCandidate { get; set; }
    private bool AcceptsInterimApplications { get; set; }
    private bool IsSavingInterimSettings { get; set; }
    private string InterimSettingsMessage { get; set; } = "Activez cette option si votre entreprise souhaite recevoir des candidatures interimaires.";
    private bool CanManageInterimCandidates => AcceptsInterimApplications;

    private IReadOnlyList<CompanyInterimCandidateResponse> PendingCandidates => Candidates.Where(candidate => !IsClosed(candidate.Status)).ToList();
    private IReadOnlyList<CompanyInterimCandidateResponse> ApprovedCandidates => Candidates.Where(candidate => candidate.Status == "Approved").ToList();
    private IReadOnlyList<CompanyInterimCandidateResponse> RejectedCandidates => Candidates.Where(candidate => candidate.Status == "Rejected").ToList();
    private IReadOnlyList<CompanyInterimCandidateResponse> VisibleCandidates => Candidates
        .Where(MatchesFilter)
        .Where(MatchesSearch)
        .OrderBy(candidate => GetStatusSort(candidate.Status))
        .ThenByDescending(candidate => candidate.RequestedAt)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (IsPreviewMode())
        {
            Session = DemoSession();
            LoadPreviewData();
            return;
        }

        var stored = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(stored))
        {
            Session = System.Text.Json.JsonSerializer.Deserialize<CompanyPortalSessionResponse>(stored);
        }

        if (Session is not null)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (Session is null)
        {
            return;
        }

        var settings = await ApiClient.GetInterimSettingsAsync(Session.CompanyId);
        if (settings is not null)
        {
            ApplyInterimSettings(settings);
        }

        Candidates = await ApiClient.GetInterimCandidatesAsync(Session.CompanyId);
        foreach (var candidate in Candidates)
        {
            ReviewNotes.TryAdd(candidate.RequestId, null);
            CompetencyChecks.TryAdd(candidate.RequestId, false);
        }
    }

    private async Task ToggleInterimSettingsAsync()
    {
        if (Session is null)
        {
            return;
        }

        IsSavingInterimSettings = true;
        var result = await ApiClient.UpdateInterimSettingsAsync(Session.CompanyId, !AcceptsInterimApplications);
        IsSavingInterimSettings = false;
        if (!result.IsSuccess || result.Settings is null)
        {
            Message = result.ErrorMessage ?? "Modification de la reception interim impossible.";
            return;
        }

        ApplyInterimSettings(result.Settings);
        Message = result.Settings.Message;
    }

    private void ApplyInterimSettings(CompanyInterimSettingsResponse settings)
    {
        AcceptsInterimApplications = settings.AcceptsInterimApplications;
        InterimSettingsMessage = settings.Message;
        if (!CanManageInterimCandidates)
        {
            SelectedCandidate = null;
        }
    }

    private async Task ApproveAsync(Guid requestId)
    {
        if (Session is null || !CanManageInterimCandidates)
        {
            Message = !CanManageInterimCandidates
                ? "Activez la reception des demandes interimaires avant de valider une candidature."
                : Message;
            return;
        }

        var note = ReviewNotes.GetValueOrDefault(requestId);
        var competencyValidated = CompetencyChecks.GetValueOrDefault(requestId);
        if (!competencyValidated)
        {
            Message = "Cochez la confirmation de competence dans la fiche avant de valider l'interimaire.";
            return;
        }

        if (IsPreviewMode())
        {
            Candidates = Candidates.Select(candidate => candidate.RequestId == requestId ? candidate with { Status = "Approved" } : candidate).ToList();
            SelectedCandidate = null;
            Message = "Interimaire ajoute. Completez maintenant son profil depuis la liste des employes.";
            Navigation.NavigateTo(PortalLink("employees"));
            return;
        }

        var result = await ApiClient.ApproveInterimCandidateAsync(Session.CompanyId, requestId, note, competencyValidated);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage ?? "Validation impossible.";
            return;
        }

        await LoadAsync();
        SelectedCandidate = null;
        Message = "Interimaire ajoute. Completez maintenant son profil depuis la liste des employes.";
        Navigation.NavigateTo(PortalLink("employees"));
    }

    private async Task RejectAsync(Guid requestId)
    {
        if (Session is null || !CanManageInterimCandidates)
        {
            Message = !CanManageInterimCandidates
                ? "Activez la reception des demandes interimaires avant de refuser une candidature."
                : Message;
            return;
        }

        var note = ReviewNotes.GetValueOrDefault(requestId);
        if (string.IsNullOrWhiteSpace(note))
        {
            Message = "Ajoutez une note avant de refuser une candidature.";
            return;
        }

        if (IsPreviewMode())
        {
            Candidates = Candidates.Select(candidate => candidate.RequestId == requestId ? candidate with { Status = "Rejected" } : candidate).ToList();
            SelectedCandidate = Candidates.FirstOrDefault(candidate => candidate.RequestId == requestId);
            return;
        }

        var result = await ApiClient.RejectInterimCandidateAsync(Session.CompanyId, requestId, note);
        Message = result.ErrorMessage;
        await LoadAsync();
        SelectedCandidate = Candidates.FirstOrDefault(candidate => candidate.RequestId == requestId);
    }

    private void OpenCandidate(CompanyInterimCandidateResponse candidate)
    {
        if (!CanManageInterimCandidates)
        {
            Message = "Activez la reception des demandes interimaires pour consulter et traiter les fiches.";
            return;
        }

        SelectedCandidate = candidate;
        ReviewNotes.TryAdd(candidate.RequestId, null);
        CompetencyChecks.TryAdd(candidate.RequestId, false);
    }

    private void CloseCandidate()
    {
        SelectedCandidate = null;
    }

    private void SetFilter(string filter)
    {
        ActiveFilter = filter;
    }

    private bool MatchesFilter(CompanyInterimCandidateResponse candidate)
    {
        return ActiveFilter switch
        {
            "A evaluer" => !IsClosed(candidate.Status),
            "Valides" => candidate.Status == "Approved",
            "Refuses" => candidate.Status == "Rejected",
            _ => true
        };
    }

    private bool MatchesSearch(CompanyInterimCandidateResponse candidate)
    {
        if (string.IsNullOrWhiteSpace(Search))
        {
            return true;
        }

        var text = $"{candidate.FirstName} {candidate.LastName} {candidate.PhoneNumber} {candidate.Address} {candidate.Message} {string.Join(' ', candidate.Services.Select(service => service.ServiceName))}";
        return text.Contains(Search.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private int GetFilterCount(string filter) => filter switch
    {
        "A evaluer" => PendingCandidates.Count,
        "Valides" => ApprovedCandidates.Count,
        "Refuses" => RejectedCandidates.Count,
        _ => Candidates.Count
    };

    private string GetFilterTabClass(string filter) => ActiveFilter == filter ? "active" : string.Empty;
    private string GetFilterButtonClass(string filter) => ActiveFilter == filter ? "active" : string.Empty;

    private void LoadPreviewData()
    {
        Candidates =
        [
            new CompanyInterimCandidateResponse(
                Guid.Parse("11111111-1111-1111-1111-111111111101"),
                Guid.Parse("22222222-2222-2222-2222-222222222201"),
                "Aminata",
                "Traore",
                "+225 07 40 11 22 33",
                new DateOnly(1997, 4, 8),
                "Abobo, Abidjan",

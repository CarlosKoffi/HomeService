        AcceptsInterimApplications = true;
        InterimSettingsMessage = "Votre entreprise apparait aux candidats interimaires compatibles.";
    }

    private static int GetStatusSort(string status) => status switch
    {
        "Pending" => 0,
        "Approved" => 1,
        "Rejected" => 2,
        _ => 3
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "Approved" => "Valide",
        "Rejected" => "Refuse",
        "Cancelled" => "Cloture",
        _ => "A evaluer"
    };

    private static string GetCandidateRowClass(CompanyInterimCandidateResponse candidate)
    {
        return $"interim-table-row {GetCandidateClass(candidate.Status)}";
    }

    private static string GetCandidateClass(string status) => status switch
    {
        "Approved" => "is-approved",
        "Rejected" => "is-rejected",
        _ => "is-pending"
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Approved" => "employee-status-badge available",
        "Rejected" => "employee-status-badge suspended",
        "Cancelled" => "employee-status-badge unavailable",
        _ => "employee-status-badge mission"
    };

    private static string GetAffiliationStatusLabel(string status) => status switch
    {
        "Approved" => "Validee",
        "Rejected" => "Refusee",
        "Cancelled" => "Cloturee",
        _ => "En attente"
    };

    private static string GetAffiliationStatusClass(string status) => status switch
    {
        "Approved" => "status-ok",
        "Rejected" => "status-rejected",
        "Cancelled" => "status-neutral",
        _ => "status-pending"
    };

    private static string GetExperienceLabel(string value) => value switch
    {
        "Junior" => "Junior",
        "Senior" => "Senior",
        "Expert" => "Expert",
        _ => "Confirme"
    };

    private static string GetMainExperience(CompanyInterimCandidateResponse candidate)
    {
        var service = candidate.Services.OrderByDescending(item => item.YearsOfExperience).FirstOrDefault();
        return service is null ? "Experience a verifier" : GetExperienceLabel(service.ExperienceLevel);
    }

    private static string GetServiceSummary(CompanyInterimCandidateResponse candidate)
    {
        return candidate.Services.Count == 0 ? "Aucun service renseigne" : $"{candidate.Services.Count} service(s)";
    }

    private static string GetCandidateMessage(CompanyInterimCandidateResponse candidate)
    {
        return string.IsNullOrWhiteSpace(candidate.Message) ? "Aucune note candidat" : candidate.Message;
    }

    private static bool IsClosed(string status) => status is "Approved" or "Rejected" or "Cancelled";

    private bool CanApproveSelectedCandidate(CompanyInterimCandidateResponse candidate)
    {
        return CanManageInterimCandidates
            && !IsClosed(candidate.Status)
            && CompetencyChecks.GetValueOrDefault(candidate.RequestId);
    }

    private string GetCandidateActionTitle()
    {
        return CanManageInterimCandidates
            ? "Consulter la candidature"
            : "Activez la reception des demandes pour consulter et traiter cette candidature.";
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "Adresse non renseignee" : value;

    private static string FormatDate(DateOnly? value) => value is null ? "Non renseignee" : value.Value.ToString("dd/MM/yyyy");

    private static string GetGenderLabel(string gender) => gender switch
    {
        "Female" => "Femme",
        "Male" => "Homme",
        _ => "Sexe non renseigne"
    };

    private static string GetInitials(CompanyInterimCandidateResponse candidate)
    {
        var first = string.IsNullOrWhiteSpace(candidate.FirstName) ? string.Empty : candidate.FirstName.Trim()[0].ToString();
        var last = string.IsNullOrWhiteSpace(candidate.LastName) ? string.Empty : candidate.LastName.Trim()[0].ToString();
        return $"{first}{last}".ToUpperInvariant();
    }

    private static string GetAvatarClass(CompanyInterimCandidateResponse candidate)
    {
        return candidate.Gender == "Female" ? "employee-avatar-modern violet" : "employee-avatar-modern blue";
    }

    private bool IsPreviewMode()
    {
        return Environment.IsDevelopment()
            && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    }

    private string PortalLink(string path) => IsPreviewMode() ? $"{path}?preview=1" : path;

    private static CompanyPortalSessionResponse DemoSession()
    {
        return new CompanyPortalSessionResponse(
            Guid.Parse("11111111-1111-1111-1111-111111111111"),
            "Entreprise Demo CI",
            "Direction Demo",
            "direction@entreprise.ci",
            DateTimeOffset.UtcNow,
            "demo-preview-token",
            "Approved",
            true);
    }
}

                "Entreprise Demo CI",
                "Candidature refusee pour la zone actuelle.",
                DateTimeOffset.UtcNow.AddDays(-4),
                DateTimeOffset.UtcNow.AddDays(-3),
                [
                    new CompanyInterimCandidateServiceResponse(Guid.NewGuid(), "Blanchisserie", "Junior", 3)
                ],
                [
                    new CompanyInterimCandidateAffiliationResponse(Guid.Parse("11111111-1111-1111-1111-111111111104"), Guid.Parse("11111111-1111-1111-1111-111111111111"), "Entreprise Demo CI", "Rejected", DateTimeOffset.UtcNow.AddDays(-4), DateTimeOffset.UtcNow.AddDays(-3), true)
                ])

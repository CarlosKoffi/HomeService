@page "/Error"
@layout HomeService.Company.Components.Layout.EmptyLayout
@using System.Diagnostics

<PageTitle>Erreur - Kaza</PageTitle>

<main class="portal-error-page">
    <section class="portal-error-card">
        <span>Erreur temporaire</span>
        <h1>Une action n'a pas pu aboutir.</h1>
        <p>Rechargez la page ou revenez au portail. Si le probleme continue, l'equipe Kaza pourra retrouver l'incident avec la reference ci-dessous.</p>

        @if (ShowRequestId)
        {
            <p class="portal-error-reference">
                Reference: <code>@RequestId</code>
            </p>
        }

        <div class="portal-error-actions">
            <a class="primary-action" href="/dashboard">Retour au portail</a>
            <a class="secondary-action" href="/">Accueil</a>
        </div>
    </section>
</main>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}

@page "/notifications"
@layout HomeService.Company.Components.Layout.EmptyLayout
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Notifications</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture des notifications.</p>
    </section>
}
else if (Session is null)
{
    <section class="empty-state">
        <h2>Connexion requise</h2>
        <p>Connectez-vous au portail entreprise pour consulter vos notifications.</p>
        <a class="primary-action" href="@PortalLink("dashboard")">Se connecter</a>
    </section>
}
else
{
    <CompanyPortalShell Active="notifications"
                        Title="Notifications"
                        Subtitle="Messages destines a votre entreprise"
                        CompanyId="@Session.CompanyId"
                        CompanyName="@Session.CompanyName"
                        Email="@Session.Email"
                        ProfileCompletionPercent="@(Session.IsCompanyApproved ? 75 : 35)"
                        UnreadNotificationCount="@UnreadCount">
        <section class="notifications-page">
            <div class="notifications-hero">
                <div>
                    <span>Centre de notifications</span>
                    <h2>@UnreadCount notification(s) non lue(s)</h2>
                    <p>Retrouvez ici uniquement les messages qui concernent votre entreprise : documents, validation, demandes d'information ou actions a traiter.</p>
                </div>
                <button type="button" @onclick="MarkAllReadAsync" disabled="@IsMarkingRead || UnreadCount == 0">
                    @(IsMarkingRead ? "Mise a jour..." : "Tout marquer comme lu")
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="notifications-message">@Message</div>
            }

            <nav class="notifications-section-menu" aria-label="Navigation notifications">
                <button class="@GetCategoryClass("all")" type="button" @onclick='() => ActiveCategory = "all"'>
                    <span>Toutes</span>
                    <em>@NotificationItems.Count</em>
                </button>
                <button class="@GetCategoryClass("action")" type="button" @onclick='() => ActiveCategory = "action"'>
                    <span>A traiter</span>
                    <em>@CountByCategory("action")</em>
                </button>
                <button class="@GetCategoryClass("documents")" type="button" @onclick='() => ActiveCategory = "documents"'>
                    <span>Dossier</span>
                    <em>@CountByCategory("documents")</em>
                </button>
                <button class="@GetCategoryClass("missions")" type="button" @onclick='() => ActiveCategory = "missions"'>
                    <span>Missions</span>
                    <em>@CountByCategory("missions")</em>
                </button>
                <button class="@GetCategoryClass("account")" type="button" @onclick='() => ActiveCategory = "account"'>
                    <span>Compte</span>
                    <em>@CountByCategory("account")</em>
                </button>
            </nav>

            <div class="notifications-toolbar">
                <label>
                    <span>Recherche</span>
                    <input @bind="Search" @bind:event="oninput" placeholder="Titre, message, type..." />
                </label>
                <div class="notifications-filter" aria-label="Filtre notifications">
                    <button class="@GetFilterClass("all")" type="button" @onclick='() => ActiveFilter = "all"'>Toutes <em>@NotificationItems.Count</em></button>
                    <button class="@GetFilterClass("unread")" type="button" @onclick='() => ActiveFilter = "unread"'>Non lues <em>@UnreadCount</em></button>
                    <button class="@GetFilterClass("read")" type="button" @onclick='() => ActiveFilter = "read"'>Lues <em>@ReadCount</em></button>
                </div>
            </div>

            @if (FilteredNotifications.Count == 0)
            {
                <section class="notifications-empty">
                    <strong>Aucune notification</strong>
                    <span>Aucun message ne correspond au filtre actuel.</span>
                </section>
            }
            else
            {
                <section class="notifications-list" aria-label="Notifications entreprise">
                    @foreach (var notification in FilteredNotifications)
                    {
                        <article class="@GetNotificationClass(notification)"
                                 role="button"
                                 tabindex="0"
                                 @onclick="() => OpenNotificationAsync(notification)"
                                 @onkeydown="eventArgs => OpenNotificationFromKeyboardAsync(eventArgs, notification)">
                            <div class="notifications-icon">
                                <span></span>
                            </div>
                            <div class="notifications-copy">
                                <div>
                                    <strong>@notification.Title</strong>
                                    @if (!notification.IsRead)
                                    {
                                        <em>Non lue</em>
                                    }
                                </div>
                                <p>@notification.Message</p>
                                <small>@GetTypeLabel(notification.Type) - @FormatDate(notification.OccurredAt)</small>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(notification.ActionUrl))
                            {
                                <button type="button" @onclick:stopPropagation @onclick="() => OpenNotificationAsync(notification)">Ouvrir</button>
                            }
                        </article>
                    }
                </section>
            }
        </section>
    </CompanyPortalShell>
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private IReadOnlyList<CompanyPortalNotificationResponse> NotificationItems { get; set; } = [];
    private bool IsSessionLoading { get; set; } = true;
    private bool IsMarkingRead { get; set; }
    private string Search { get; set; } = string.Empty;
    private string ActiveCategory { get; set; } = "all";
    private string ActiveFilter { get; set; } = "all";
    private string? Message { get; set; }

    private int UnreadCount => NotificationItems.Count(notification => !notification.IsRead);
    private int ReadCount => NotificationItems.Count(notification => notification.IsRead);

    private IReadOnlyList<CompanyPortalNotificationResponse> FilteredNotifications
    {
        get
        {
            var query = NotificationItems.AsEnumerable();
            if (ActiveCategory != "all")
            {
                query = query.Where(notification => GetNotificationCategory(notification) == ActiveCategory);
            }

            query = ActiveFilter switch
            {
                "unread" => query.Where(notification => !notification.IsRead),
                "read" => query.Where(notification => notification.IsRead),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(Search))
            {
                var search = Search.Trim();
                query = query.Where(notification =>
                    notification.Title.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || notification.Message.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || notification.Type.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            return query
                .OrderBy(notification => notification.IsRead)
                .ThenByDescending(notification => notification.OccurredAt)
                .ToList();
        }
    }

    private int CountByCategory(string category)
    {
        return NotificationItems.Count(notification => GetNotificationCategory(notification) == category);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (IsPreviewMode())
        {
            Session = DemoSession();
            NotificationItems = DemoNotifications();
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
        }

        if (Session is not null)
        {
            await LoadNotificationsAsync();
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task LoadNotificationsAsync()
    {
        if (Session is null)
        {
            return;
        }

        var response = await ApiClient.GetCompanyNotificationsAsync(Session.CompanyId);
        NotificationItems = response?.Notifications ?? [];
    }

    private async Task MarkAllReadAsync()
    {
        if (Session is null || UnreadCount == 0)
        {
            return;
        }

        IsMarkingRead = true;
        Message = null;
        try
        {
            if (IsPreviewMode())
            {
                NotificationItems = NotificationItems
                    .Select(notification => notification with { IsRead = true })
                    .ToList();
                Message = "Notifications marquees comme lues.";
                return;
            }

            var result = await ApiClient.MarkCompanyNotificationsReadAsync(Session.CompanyId);
            if (!result.IsSuccess)
            {
                Message = result.ErrorMessage ?? "Action impossible.";
                return;
            }

            await LoadNotificationsAsync();
            Message = "Notifications marquees comme lues.";
        }
        finally
        {
            IsMarkingRead = false;
        }
    }

    private async Task OpenNotificationFromKeyboardAsync(KeyboardEventArgs eventArgs, CompanyPortalNotificationResponse notification)
    {
        if (eventArgs.Key is "Enter" or " ")
        {
            await OpenNotificationAsync(notification);
        }
    }

    private async Task OpenNotificationAsync(CompanyPortalNotificationResponse notification)
    {
        await MarkNotificationReadLocallyAsync(notification);
        Navigation.NavigateTo(PortalLink(notification.ActionUrl ?? "notifications"));
    }

    private async Task MarkNotificationReadLocallyAsync(CompanyPortalNotificationResponse notification)
    {
        if (notification.IsRead || Session is null)
        {
            return;
        }

        NotificationItems = NotificationItems
            .Select(item => item.Id == notification.Id ? item with { IsRead = true } : item)
            .ToList();
        StateHasChanged();

        if (IsPreviewMode())
        {
            return;
        }

        var result = await ApiClient.MarkCompanyNotificationReadAsync(Session.CompanyId, notification.Id);
        if (!result.IsSuccess)
        {
            Message = result.ErrorMessage ?? "Notification non marquee comme lue cote serveur.";
        }
    }

    private string GetFilterClass(string filter)
    {
        return string.Equals(ActiveFilter, filter, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    private string GetCategoryClass(string category)
    {
        return string.Equals(ActiveCategory, category, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    private string PortalLink(string? path)
    {
        var cleanPath = string.IsNullOrWhiteSpace(path) ? "dashboard" : path.TrimStart('/');
        if (!IsPreviewMode())
        {
            return cleanPath;
        }

        var hashIndex = cleanPath.IndexOf('#', StringComparison.Ordinal);
        if (hashIndex < 0)
        {
            return $"{cleanPath}?preview=1";
        }

        return $"{cleanPath[..hashIndex]}?preview=1{cleanPath[hashIndex..]}";
    }

    private bool IsPreviewMode()
    {
        return Environment.IsDevelopment()
            && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetNotificationClass(CompanyPortalNotificationResponse notification)
    {
        var tone = notification.Tone switch
        {
            "success" => "success",
            "warning" => "warning",
            "danger" => "danger",
            _ => "info"
        };

        return $"notifications-item {tone} {(notification.IsRead ? "read" : "unread")}";
    }

    private static string GetTypeLabel(string type)
    {
        return type switch
        {
            "CompanyDocumentRejected" => "Piece refusee",
            "CompanyDocumentApproved" => "Piece validee",
            "CompanyApplicationApproved" => "Dossier valide",
            "CompanyApplicationRejected" => "Dossier refuse",
            "CompanyApplicationMoreInformationRequested" => "Complement demande",
            _ => "Notification"
        };
    }

    private static string GetNotificationCategory(CompanyPortalNotificationResponse notification)
    {
        if (notification.CompanyApplicationDocumentId is not null
            || notification.Type.Contains("Document", StringComparison.OrdinalIgnoreCase)
            || (notification.ActionUrl?.Contains("documents", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            return "documents";
        }

        if (notification.Type.Contains("Mission", StringComparison.OrdinalIgnoreCase)
            || (notification.ActionUrl?.Contains("mission", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            return "missions";
        }

        if (!notification.IsRead
            || notification.Tone is "warning" or "danger"
            || notification.Type.Contains("MoreInformation", StringComparison.OrdinalIgnoreCase)
            || notification.Type.Contains("Rejected", StringComparison.OrdinalIgnoreCase))
        {
            return "action";
        }

        return "account";
    }

    private static string FormatDate(DateTimeOffset date)
    {
        return date.ToLocalTime().ToString("dd MMMM yyyy - HH:mm", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"));
    }

    private static CompanyPortalSessionResponse DemoSession()
    {
        return new CompanyPortalSessionResponse(
            Guid.Parse("11111111-1111-1111-1111-111111111111"),
            "CI Home Service",
            "Direction Demo",
            "direction@entreprise.ci",
            DateTimeOffset.UtcNow,
            "demo-preview-token",
            "Approved",
            true);
    }

    private static IReadOnlyList<CompanyPortalNotificationResponse> DemoNotifications()
    {
        var now = DateTimeOffset.Now;
        return
        [
            new(Guid.NewGuid(), "CompanyDocumentRejected", "Piece d'identite a reprendre", "Le document envoye est trop flou. Ajoutez une photo plus nette ou passez au bureau pour le scan.", "danger", "company-profile#documents", now.AddMinutes(-30), false, Guid.NewGuid()),
            new(Guid.NewGuid(), "CompanyApplicationMoreInformationRequested", "Complement demande", "Precisez votre zone principale d'intervention pour finaliser le dossier entreprise.", "warning", "company-profile", now.AddHours(-3), false, null),
            new(Guid.NewGuid(), "CompanyDocumentApproved", "DFE valide", "Votre Declaration Fiscale d'Existence a ete controlee et validee.", "success", "company-profile#documents", now.AddDays(-1), true, Guid.NewGuid()),
            new(Guid.NewGuid(), "CompanyApplicationApproved", "Compte entreprise valide", "Votre entreprise peut maintenant affecter des missions et suivre ses prestataires.", "success", "dashboard", now.AddDays(-2), true, null)
        ];
    }
}

@page "/dashboard"
@layout HomeService.Company.Components.Layout.EmptyLayout
@using System.Text.Json
@inject IJSRuntime Js
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Espace entreprise</PageTitle>

@if (IsSessionLoading)
{
    <section class="empty-state">
        <h2>Chargement...</h2>
        <p>Ouverture de votre espace entreprise.</p>
    </section>
}
else if (Session is null)
{
    <section class="portal-entry country-branded">
        <div class="portal-copy">
            <p class="eyebrow">Portail entreprise</p>
            <h1>Espace entreprise</h1>
            <p class="lead">
                Connectez-vous avec l'email utilise lors de l'inscription une fois votre dossier valide.
                Vous pourrez ensuite ajouter vos prestataires, suivre les missions et garder une vision claire
                des encaissements.
            </p>

            <div class="portal-highlights" aria-label="Points forts du portail">
                <span><strong>Validation</strong>Dossier controle</span>
                <span><strong>Suivi</strong>Missions et cash</span>
                <span><strong>Equipe</strong>Prestataires encadres</span>
            </div>

            <div class="portal-actions">
                <a class="secondary-action" href="register">Creer un compte entreprise</a>
                <span>Dossier deja valide ? utilisez votre acces recu par email.</span>
            </div>
        </div>

        <form class="portal-login" @onsubmit="SubmitLoginAsync" @onsubmit:preventDefault>
            <div class="login-accent" aria-hidden="true"></div>
            <div class="section-intro">
                <h2>Connexion</h2>
                <p>Acces reserve aux entreprises validees par l'equipe wélé.</p>
            </div>

            <label>
                Email professionnel
                <input type="email" autocomplete="username" placeholder="direction@entreprise.ci" @bind="Email" />
            </label>
            <label>
                Mot de passe
                <input type="password" autocomplete="current-password" placeholder="Votre mot de passe" @bind="Password" />
            </label>

            <div class="login-options">
                <label class="remember-option">
                    <input type="checkbox" @bind="RememberMe" />
                    <span>
                        <strong>Se souvenir de moi</strong>
                        <small>Garder mon email et rester connecte sur cet appareil.</small>
                    </span>
                </label>
                <a href="forgot-password">Mot de passe oublie ?</a>
            </div>

            @if (!string.IsNullOrWhiteSpace(LoginMessage))
            {
                <p class="field-message">@LoginMessage</p>
            }

            <button type="submit" class="primary-action" disabled="@IsSubmitting">
                @(IsSubmitting ? "Connexion..." : "Se connecter")
            </button>
            <a class="create-account-link" href="register">Nouvelle entreprise ? Creer un compte</a>
        </form>
    </section>
}
else
{
    <CompanyPortalShell Active="dashboard"
                        Title="Tableau de bord"
                        Subtitle="@DashboardSubtitle"
                        CompanyName="@PortalCompanyName"
                        Email="@PortalEmail"
                        ProfileCompletionPercent="@PortalCompletion"
                        UnreadNotificationCount="@(DashboardData?.UnreadNotificationCount ?? 0)"
                        ProgressSteps="@PortalProgressSteps">
        @if (!Session.IsCompanyApproved)
        {
            <section class="portal-alert portal-alert-warning">
                <div>
                    <strong>Compte en attente de conformite</strong>
                    <span>Vous pouvez preparer votre equipe. Les affectations seront ouvertes apres validation.</span>
                </div>
                <a href="@PortalLink("company-profile")">Finaliser</a>
            </section>
        }

        <section class="portal-mission-banner">
            <div>
                <span class="portal-mission-eyebrow">Prochaine action</span>
                <h2>@NextMissionTitle</h2>
                <div class="portal-mission-meta">
                    <span><FigmaDashboardIcon Name="calendar" Tone="light" /> @NextMissionScheduleText</span>
                    <span><FigmaDashboardIcon Name="customer" Tone="light" /> @NextMissionCustomerText</span>
                </div>
            </div>
            <a href="@PortalLink("missions")">Voir les missions</a>
        </section>

        @if (PortalNotifications.Any())
        {
            <section class="portal-notification-strip">
                <div class="portal-panel-heading">
                    <div>
                        <span>Notifications</span>
                        <h2>Messages de l'equipe wélé</h2>
                    </div>
                    @if ((DashboardData?.UnreadNotificationCount ?? 0) > 0)
                    {
                        <strong>@DashboardData!.UnreadNotificationCount non lue(s)</strong>
                    }
                </div>
                <div class="portal-notification-list">
                    @foreach (var notification in PortalNotifications)
                    {
                        <button class="@GetNotificationClass(notification)" type="button" @onclick="() => OpenDashboardNotificationAsync(notification)">
                            <span></span>
                            <div>
                                <strong>@notification.Title</strong>
                                <small>@notification.Message</small>
                            </div>
                            <time>@notification.OccurredAt.ToLocalTime().ToString("dd/MM HH:mm")</time>
                        </button>
                    }
                </div>
            </section>
        }

        <section class="portal-stats-grid" aria-label="Indicateurs du portail">
            <article>
                <div class="portal-stat-head">
                    <span>Employes</span>
                    <FigmaDashboardIcon Name="employees" />
                </div>
                <strong>@(DashboardData?.EmployeeCount ?? 0)</strong>
                <small>@(DashboardData?.AvailableEmployeeCount ?? 0) disponibles</small>
            </article>
            <article>
                <div class="portal-stat-head">
                    <span>Missions live</span>
                    <FigmaDashboardIcon Name="live-missions" />
                </div>
                <strong>@(DashboardData?.LiveMissionCount ?? 0)</strong>
                <small>@(DashboardData?.UpcomingMissionCount ?? 0) rendez-vous a venir</small>
            </article>
            <article>
                <div class="portal-stat-head">
                    <span>Terminees</span>
                    <FigmaDashboardIcon Name="completed" />
                </div>
                <strong>@(DashboardData?.CompletedMissionCount ?? 0)</strong>
                <small>Historique suivi</small>
            </article>
            <article>
                <div class="portal-stat-head">
                    <span>Encaissements</span>
                    <FigmaDashboardIcon Name="payments" />
                </div>
                <strong>@FormatMoney(DashboardData?.MonthlyRevenueAmount ?? 0)</strong>
                <small>@FormatMoney(DashboardData?.CashToCollectAmount ?? 0) cash a suivre</small>
            </article>
        </section>

        <section class="portal-dashboard-grid">
            <article class="portal-panel portal-panel-wide">
                <div class="portal-panel-heading">
                    <div>
                        <span>Activite recente</span>
                        <h2>Ce qui bouge dans votre entreprise</h2>
                    </div>
                    <a href="@PortalLink("missions")">Ouvrir</a>
                </div>

                <div class="portal-activity-list">
                    @foreach (var activity in PortalActivities)
                    {
                        <div class="portal-activity-row">
                            <span class="@GetActivityToneClass(activity.Tone)"></span>
                            <div>
                                <strong>@activity.Title</strong>
                                <small>@activity.Description</small>
                            </div>
                            <time>@activity.OccurredAt.ToLocalTime().ToString("HH:mm")</time>
                        </div>
                    }
                </div>
            </article>

            <article class="portal-panel">
                <div class="portal-panel-heading">
                    <div>
                        <span>Equipe</span>
                        <h2>Prestataires suivis</h2>
                    </div>
                    <a href="@PortalLink("employees")">Gerer</a>
                </div>

                <div class="portal-employee-digest">
                    @foreach (var employee in PortalEmployees)
                    {
                        <div>
                            <span>@employee.Initials</span>
                            <div>
                                <strong>@employee.FullName</strong>
                                <small>@employee.Role - @(employee.IsAvailable ? "Disponible" : "Indisponible")</small>
                            </div>
                        </div>
                    }
                </div>
            </article>
        </section>

        <section class="portal-quick-actions">
            <a href="@PortalLink("company-profile")">
                <strong>Informations</strong>
                <span>Documents, statut et profil entreprise.</span>
            </a>
            <a href="@PortalLink("employees")">
                <strong>Employes</strong>
                <span>Ajouter, verifier et suivre les prestataires.</span>
            </a>
            <a href="@PortalLink("interim-candidates")">
                <strong>Interim</strong>
                <span>Voir les candidatures proches de vos services.</span>
            </a>
            <a href="@PortalLink("accounts")">
                <strong>Encaissements</strong>
                <span>Paiements carte bancaire, Mobile Money et suivi des commissions.</span>
            </a>
        </section>
    </CompanyPortalShell>
}

@code {
    private string Email { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private bool RememberMe { get; set; }
    private string? LoginMessage { get; set; }
    private bool IsSubmitting { get; set; }
    private bool IsSessionLoading { get; set; } = true;
    private CompanyPortalSessionResponse? Session { get; set; }
    private CompanyPortalDashboardResponse? DashboardData { get; set; }

    private string DashboardSubtitle => $"Portail connecte - {PortalCompanyName}";
    private string PortalCompanyName => DashboardData?.CompanyName ?? Session?.CompanyName ?? "Entreprise";
    private string PortalEmail => DashboardData?.UserEmail ?? Session?.Email ?? "mode.demo@wele.ci";
    private int PortalCompletion => DashboardData?.ProfileCompletionPercent ?? (Session?.IsCompanyApproved == true ? 75 : 25);
    private IReadOnlyList<CompanyPortalProgressStepResponse> PortalProgressSteps => DashboardData?.ProgressSteps ?? DefaultProgressSteps;
    private IEnumerable<CompanyPortalActivityResponse> PortalActivities => DashboardData?.RecentActivities is { Count: > 0 } activities ? activities : DemoActivities();
    private IEnumerable<CompanyPortalNotificationResponse> PortalNotifications => DashboardData?.Notifications is { Count: > 0 } notifications ? notifications : [];
    private IEnumerable<CompanyPortalEmployeeDigestResponse> PortalEmployees => DashboardData?.EmployeeDigest is { Count: > 0 } employees ? employees : DemoEmployees();
    private string NextMissionTitle => DashboardData?.NextMission is null ? "Aucune mission urgente" : DashboardData.NextMission.ServiceName;
    private string NextMissionScheduleText => DashboardData?.NextMission?.ScheduledFor?.ToLocalTime().ToString("dd/MM HH:mm") ?? "Demande directe";
    private string NextMissionCustomerText => DashboardData?.NextMission?.CustomerName ?? "Aucune demande urgente";

    private static readonly IReadOnlyList<CompanyPortalProgressStepResponse> DefaultProgressSteps =
    [
        new("Profil entreprise", true, null, null),
        new("Documents de conformite", false, "Completer", "company-profile"),
        new("Premier employe ajoute", false, "Ajouter", "employees"),
        new("Premiere mission creee", false, "Voir", "missions")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase))
        {
            Session = new CompanyPortalSessionResponse(
                Guid.Parse("11111111-1111-1111-1111-111111111111"),
                "Entreprise Demo CI",
                "Direction Demo",
                "direction@entreprise.ci",
                DateTimeOffset.UtcNow,
                "demo-preview-token",
                "PendingReview",
                false);
            RememberMe = true;
            Email = Session.Email;
            DashboardData = DemoDashboard(Session);
            IsSessionLoading = false;
            StateHasChanged();
            return;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("email", out var registeredEmail))
        {
            Email = registeredEmail.ToString();
            LoginMessage = "Compte cree. Connectez-vous pour ajouter vos documents de conformite.";
        }

        RememberMe = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.rememberMe") == "true";
        if (RememberMe)
        {
            Email = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.email") ?? string.Empty;
        }

        var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
        if (!string.IsNullOrWhiteSpace(sessionJson))
        {
            Session = JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
        }

        if (Session is not null)
        {
            DashboardData = await ApiClient.GetCompanyDashboardAsync(Session.CompanyId);
        }

        IsSessionLoading = false;
        StateHasChanged();
    }

    private async Task SubmitLoginAsync()
    {
        LoginMessage = null;
        IsSubmitting = true;

        if (RememberMe)
        {
            await Js.InvokeVoidAsync("localStorage.setItem", "homeservice.company.rememberMe", "true");
            await Js.InvokeVoidAsync("localStorage.setItem", "homeservice.company.email", Email.Trim());
        }
        else
        {
            await Js.InvokeVoidAsync("localStorage.removeItem", "homeservice.company.rememberMe");
            await Js.InvokeVoidAsync("localStorage.removeItem", "homeservice.company.email");
        }

        try
        {
            var result = await ApiClient.LoginCompanyPortalAsync(new(Email, Password, RememberMe));
            if (!result.IsSuccess || result.Session is null)
            {
                LoginMessage = result.ErrorMessage ?? "Connexion impossible.";
                return;
            }

            Session = result.Session;
            await Js.InvokeVoidAsync("localStorage.setItem", "homeservice.company.session", JsonSerializer.Serialize(Session));
            DashboardData = await ApiClient.GetCompanyDashboardAsync(Session.CompanyId);
            Password = string.Empty;
            Navigation.NavigateTo("dashboard");
        }
        catch (Exception exception)
        {
            LoginMessage = $"Connexion impossible pour le moment. Detail: {exception.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task LogoutAsync()
    {
        Session = null;
        DashboardData = null;
        await Js.InvokeVoidAsync("localStorage.removeItem", "homeservice.company.session");
    }

    private string PortalLink(string path)
    {
        return Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase)
            ? $"{path}?preview=1"
            : path;
    }

    private async Task OpenDashboardNotificationAsync(CompanyPortalNotificationResponse notification)
    {
        if (!notification.IsRead && Session is not null)
        {
            if (Environment.IsDevelopment() && Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase))
            {
                MarkDashboardNotificationRead(notification.Id);
            }
            else
            {
                MarkDashboardNotificationRead(notification.Id);
                var result = await ApiClient.MarkCompanyNotificationReadAsync(Session.CompanyId, notification.Id);
                if (!result.IsSuccess)
                {
                    LoginMessage = result.ErrorMessage ?? "Notification non marquee comme lue cote serveur.";
                }
            }
        }

        Navigation.NavigateTo(PortalLink(notification.ActionUrl ?? "company-profile"));
    }

    private void MarkDashboardNotificationRead(Guid notificationId)
    {
        if (DashboardData is null)
        {
            return;
        }

        var notifications = DashboardData.Notifications
            .Select(notification => notification.Id == notificationId ? notification with { IsRead = true } : notification)
            .ToList();
        DashboardData = DashboardData with
        {
            Notifications = notifications,
            UnreadNotificationCount = notifications.Count(notification => !notification.IsRead)
        };
    }

    private string FormatMoney(int amount)
    {
        return $"{amount:N0} {DashboardData?.Currency ?? "XOF"}";
    }

    private static string GetActivityToneClass(string tone) => tone switch
    {
        "success" => "tone-success",
        "warning" => "tone-warning",
        "danger" => "tone-danger",
        _ => "tone-info"
    };

    private static string GetNotificationClass(CompanyPortalNotificationResponse notification)
    {
        var tone = notification.Tone switch
        {
            "success" => "success",
            "warning" => "warning",
            "danger" => "danger",
            _ => "info"
        };

        return $"portal-notification-row {tone} {(notification.IsRead ? "read" : "unread")}";
    }

    private static CompanyPortalDashboardResponse DemoDashboard(CompanyPortalSessionResponse session)
    {
        return new CompanyPortalDashboardResponse(
            session.CompanyId,
            session.CompanyName,
            session.Email,
            session.CompanyStatus,
            true,
            session.UserName,
            session.Email,
            78,
            [
                new("Profil entreprise", true, null, null),
                new("Documents de conformite", true, null, null),
                new("Equipe initiale", true, null, null),
                new("Premiere mission", false, "Voir", "missions")
            ],
            8,
            5,
            12,
            4,
            38,
            185000,
            42000,
            "XOF",
            new(Guid.NewGuid(), "Menage a domicile", "Mme Akissi", "+225 07 00 11 22 33", "Direct", "SearchingProvider", "MobileMoney", "Authorized", null, 180, 15000, "XOF", null, null),
            2,
            [
                new(Guid.NewGuid(), "CompanyDocumentRejected", "Piece a reprendre", "Le DFE envoye est illisible. Merci de deposer une version plus nette.", "danger", "company-profile#documents", DateTimeOffset.Now.AddMinutes(-25), false, Guid.NewGuid()),
                new(Guid.NewGuid(), "CompanyApplicationMoreInformationRequested", "Complement demande", "Ajoutez votre zone d'intervention principale avant validation finale.", "warning", "company-profile", DateTimeOffset.Now.AddHours(-3), false, null)
            ],
            DemoActivities().ToList(),
            DemoEmployees().ToList());
    }

    private static IReadOnlyList<CompanyPortalActivityResponse> DemoActivities()
    {
        var now = DateTimeOffset.Now;
        return
        [
            new(Guid.NewGuid(), "Mission", "Nouvelle demande recue", "Menage a domicile - Cocody Angre", "info", now.AddMinutes(-12), false),
            new(Guid.NewGuid(), "Affectation", "Prestataire affecte", "Yao N'Dri sur Jardinage - Riviera", "success", now.AddMinutes(-42), true),
            new(Guid.NewGuid(), "Paiement", "Paiement confirme", "12 000 XOF encaisses par Mobile Money", "success", now.AddHours(-2), false)
        ];
    }

    private static IReadOnlyList<CompanyPortalEmployeeDigestResponse> DemoEmployees()
    {
        return
        [
            new(Guid.NewGuid(), "AK", "Awa Kone", "Menage", "Approved", true, false, null),
            new(Guid.NewGuid(), "YN", "Yao N'Dri", "Jardinage", "Approved", true, true, null),
            new(Guid.NewGuid(), "FS", "Fatou Soro", "Menage", "Approved", false, false, null)
        ];
    }
}

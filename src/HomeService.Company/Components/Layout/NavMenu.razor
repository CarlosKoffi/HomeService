@using System.Text.Json
@implements IDisposable
@inject IJSRuntime Js
@inject NavigationManager Navigation

@if (!HideGlobalHeader)
{
    <header class="site-header @HeaderThemeClass public-mode">
        <a class="brand brand-logo" href="@BrandHref" aria-label="Accueil Wele">
            <img src="images/wele-logo.png" alt="Wele" />
        </a>

        <input type="checkbox" id="menu-toggle" class="menu-toggle" />
        <label for="menu-toggle" class="menu-button" title="Menu">
            <span></span>
            <span></span>
            <span></span>
        </label>

        <nav class="site-nav public-nav">
            <a href="@($"{PublicLandingBase}#home")" data-section-nav="home">Accueil</a>
            <a href="@($"{PublicLandingBase}#how")" data-section-nav="how">Fonctionnement</a>
            <a href="@($"{PublicLandingBase}#trusted")" data-section-nav="trusted">References</a>
            <a href="@($"{PublicLandingBase}#dashboard")" data-section-nav="dashboard">Dashboard</a>
            <a href="@($"{PublicLandingBase}#faq")" data-section-nav="faq">FAQ</a>
            <a href="@($"{PublicLandingBase}#contact")" data-section-nav="contact">Contact</a>
            <div class="header-actions">
                <a class="header-secondary" href="@PortalLink("dashboard")">@PortalAccessLabel</a>
                <a class="header-primary" href="register">Devenir partenaire</a>
            </div>
        </nav>
    </header>
}

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private const string PublicLandingBase = "/";

    private const string HeaderThemeClass = "theme-premium";
    private static readonly HashSet<string> PortalSegments = new(StringComparer.OrdinalIgnoreCase)
    {
        "dashboard",
        "company-profile",
        "employees",
        "interim-candidates",
        "missions",
        "operations",
        "notifications",
        "accounts"
    };

    private bool IsPortalExperience => IsPreviewMode || Session is not null;
    private bool HideGlobalHeader => PortalSegments.Contains(CurrentSegment) && IsPortalExperience;
    private bool IsPreviewMode => Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("preview=1", StringComparison.OrdinalIgnoreCase);
    private string CurrentSegment => Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? string.Empty;
    private string BrandHref => IsPortalExperience ? PortalLink("dashboard") : PublicLandingBase;
    private string PortalAccessLabel => IsPortalExperience ? "Mon portail" : "Se connecter";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshSessionAsync();
            await Js.InvokeVoidAsync("weleCompanyNavigation.init");
        }
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await RefreshSessionAsync();
    }

    private async Task RefreshSessionAsync()
    {
        try
        {
            var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
            Session = string.IsNullOrWhiteSpace(sessionJson)
                ? null
                : JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            StateHasChanged();
            await Js.InvokeVoidAsync("weleCompanyNavigation.init");
        }
        catch
        {
            Session = null;
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private string PortalLink(string path)
    {
        return IsPreviewMode ? $"{path}?preview=1" : path;
    }
}

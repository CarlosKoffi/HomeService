@using System.Text.Json
@implements IDisposable
@inject IJSRuntime Js
@inject NavigationManager Navigation

<header class="site-header @HeaderThemeClass">
    <a class="brand" href="">Kaza</a>

    <input type="checkbox" id="menu-toggle" class="menu-toggle" />
    <label for="menu-toggle" class="menu-button" title="Menu">
        <span></span>
        <span></span>
        <span></span>
    </label>

    <nav class="site-nav @(Session is null ? "public-nav" : "portal-header-nav")">
        @if (Session is null)
        {
            <a href="@($"{PublicLandingBase}#home")" data-section-nav="home">Accueil</a>
            <a href="@($"{PublicLandingBase}#concept")" data-section-nav="concept">Concept</a>
            <a href="@($"{PublicLandingBase}#benefits")" data-section-nav="benefits">Avantages</a>
            <a href="@($"{PublicLandingBase}#how-it-works")" data-section-nav="how-it-works">Fonctionnement</a>
            <a href="@($"{PublicLandingBase}#requirements")" data-section-nav="requirements">Conditions</a>
            <a href="@($"{PublicLandingBase}#partner-dashboard")" data-section-nav="partner-dashboard">Portail</a>
            <a href="@($"{PublicLandingBase}#faq")" data-section-nav="faq">FAQ</a>
            <a href="@($"{PublicLandingBase}#contact")" data-section-nav="contact">Contact</a>
            <div class="header-actions">
                <a class="header-secondary" href="dashboard">Se connecter</a>
                <a class="header-primary" href="register">Devenir partenaire</a>
            </div>
        }
        else
        {
            <NavLink href="dashboard" Match="NavLinkMatch.All">Tableau de bord</NavLink>
            <NavLink href="company-profile">Informations</NavLink>
            <NavLink href="employees">Employes</NavLink>
            <NavLink href="interim-candidates">Interim</NavLink>
            <NavLink href="operations">Missions</NavLink>
            <NavLink href="accounts">Encaissements</NavLink>
            <div class="session-chip" title="@Session.Email">
                <strong>@Session.CompanyName</strong>
                <span>@Session.Email</span>
            </div>
            <button type="button" class="logout-button" @onclick="LogoutAsync">Sortir</button>
        }
    </nav>
</header>

@code {
    private CompanyPortalSessionResponse? Session { get; set; }
    private string PublicLandingBase
    {
        get
        {
            var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return path is "bleu" or "vert" or "noir" or "apple" ? $"/{path}" : "/";
        }
    }

    private string HeaderThemeClass
    {
        get
        {
            var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return path switch
            {
                "bleu" => "theme-blue",
                "vert" => "theme-green",
                "noir" => "theme-black",
                "apple" => "theme-apple",
                _ => string.Empty
            };
        }
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshSessionAsync();
            await Js.InvokeVoidAsync("kazaCompanyNavigation.init");
        }
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await RefreshSessionAsync();
    }

    private async Task RefreshSessionAsync()
    {
        try
        {
            var sessionJson = await Js.InvokeAsync<string?>("localStorage.getItem", "homeservice.company.session");
            Session = string.IsNullOrWhiteSpace(sessionJson)
                ? null
                : JsonSerializer.Deserialize<CompanyPortalSessionResponse>(sessionJson);
            StateHasChanged();
            await Js.InvokeVoidAsync("kazaCompanyNavigation.init");
        }
        catch
        {
            Session = null;
        }
    }

    private async Task LogoutAsync()
    {
        await Js.InvokeVoidAsync("localStorage.removeItem", "homeservice.company.session");
        Session = null;
        Navigation.NavigateTo("");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}

@page "/companies/{CompanyId:guid}"
@using HomeService.Admin.Services
@using HomeService.Contracts.Admin
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Entreprise</PageTitle>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p class="admin-message error-message">@ErrorMessage</p>
}

@if (IsLoading)
{
    <section class="info-panel">
        <div>
            <h1>Chargement...</h1>
            <p>Ouverture du dossier entreprise.</p>
        </div>
    </section>
}
else if (Company is null)
{
    <section class="info-panel">
        <div>
            <h1>Entreprise introuvable</h1>
            <p>Le dossier entreprise n'existe plus ou n'est pas accessible.</p>
        </div>
        <button type="button" class="secondary-action" @onclick="BackToList">Retour entreprises</button>
    </section>
}
else
{
    <div class="admin-page-heading company-admin-hero">
        <div>
            <button type="button" class="link-action" @onclick="BackToList">Retour aux entreprises</button>
            <h1>@Company.Name</h1>
            <p class="lead">@Company.PhoneNumber - @(Company.Email ?? "Email non renseigne")</p>
        </div>
        <div class="company-admin-status">
            <span class="@GetStatusClass(Company.Status)">@TranslateStatus(Company.Status)</span>
            <small>Creation @FormatDate(Company.CreatedAt)</small>
        </div>
    </div>

    <section class="admin-action-panel company-admin-actions">
        <div>
            <span>Action plateforme</span>
            <strong>@GetCompanyActionTitle()</strong>
            <p>@GetCompanyActionHelp()</p>
        </div>
        <div class="admin-action-form">
            <input @bind="CompanyActionNote"
                   placeholder="Note interne visible dans le journal"
                   disabled="@IsCompanyActionBusy" />
            @if (Company.Status == "Suspended")
            {
                <button type="button" class="primary-action" disabled="@IsCompanyActionBusy" @onclick="ReactivateCompanyAsync">Reactiver</button>
            }
            else
            {
                <button type="button" class="danger-action" disabled="@IsCompanyActionBusy" @onclick="SuspendCompanyAsync">Suspendre</button>
            }
        </div>
    </section>

    <section class="company-admin-kpis">
        <article>
            <span>Equipe</span>
            <strong>@Company.Summary.ActiveProviderCount / @Company.Summary.ProviderCount</strong>
            <small>prestataires valides</small>
        </article>
        <article>
            <span>Interim</span>
            <strong>@Company.Summary.PendingInterimRequestCount</strong>
            <small>demande(s) a traiter</small>
        </article>
        <article>
            <span>Missions ouvertes</span>
            <strong>@Company.Summary.OpenMissionCount</strong>
            <small>@Company.Summary.DisputedMissionCount litige(s)</small>
        </article>
        <article>
            <span>Pieces entreprise</span>
            <strong>@Company.Summary.ValidCompanyDocumentCount / @Company.Summary.CompanyDocumentCount</strong>
            <small>documents valides</small>
        </article>
        <article>
            <span>Notifications</span>
            <strong>@Company.Summary.UnreadNotificationCount</strong>
            <small>non lue(s)</small>
        </article>
    </section>

    <section class="company-control-strip">
        <button type="button" class='@GetTabClass("summary")' @onclick='() => SelectTab("summary")'>Resume</button>
        <button type="button" class='@GetTabClass("providers")' @onclick='() => SelectTab("providers")'>Employes</button>
        <button type="button" class='@GetTabClass("interim")' @onclick='() => SelectTab("interim")'>Interim</button>
        <button type="button" class='@GetTabClass("missions")' @onclick='() => SelectTab("missions")'>Missions</button>
        <button type="button" class='@GetTabClass("documents")' @onclick='() => SelectTab("documents")'>Documents</button>
        <button type="button" class='@GetTabClass("notifications")' @onclick='() => SelectTab("notifications")'>Notifications</button>
        <button type="button" class='@GetTabClass("timeline")' @onclick='() => SelectTab("timeline")'>Historique</button>
        <button type="button" class='@GetTabClass("logs")' @onclick='() => SelectTab("logs")'>Journal</button>
    </section>

    @if (SelectedTab == "summary")
    {
        <section class="company-detail-grid">
            <article>
                <h2>Informations entreprise</h2>
                <dl class="detail-list">
                    <div><dt>Statut</dt><dd>@TranslateStatus(Company.Status)</dd></div>
                    <div><dt>Mode affectation</dt><dd>@TranslateAssignmentMode(Company.AssignmentMode)</dd></div>
                    <div><dt>Ville</dt><dd>@(Company.City ?? "Non renseignee")</dd></div>
                    <div><dt>Adresse</dt><dd>@(Company.Address ?? "Non renseignee")</dd></div>
                    <div><dt>RCCM</dt><dd>@(Company.RegistrationNumber ?? "Non renseigne")</dd></div>
                    <div><dt>DFE</dt><dd>@(Company.TaxIdentificationNumber ?? "Non renseigne")</dd></div>
                </dl>
            </article>
            <article>
                <h2>Operations</h2>
                <dl class="detail-list">
                    <div><dt>Zones</dt><dd>@(Company.InterventionZones ?? "Non renseigne")</dd></div>
                    <div><dt>Services</dt><dd>@(Company.PlannedServices ?? "Non renseigne")</dd></div>
                    <div><dt>Wave</dt><dd>@(Company.WavePaymentNumber ?? "Non renseigne")</dd></div>
                    <div><dt>Orange Money</dt><dd>@(Company.OrangeMoneyPaymentNumber ?? "Non renseigne")</dd></div>
                    <div><dt>Montant a suivre</dt><dd>@FormatMoney(Company.Summary.PendingPaymentAmount, Company.Summary.Currency)</dd></div>
                </dl>
            </article>
        </section>
    }
    else if (SelectedTab == "providers")
    {
        <section class="operator-list">
            <header>
                <div>
                    <h2>Employes et interimaires</h2>
                    <p>@Company.Providers.Count profil(s) rattache(s)</p>
                </div>
            </header>
            @foreach (var provider in Company.Providers)
            {
                <article class="operator-row provider-row">
                    <div class="company-identity">
                        <span class="avatar-token">@GetInitials(provider.FullName)</span>
                        <div>
                            <strong>@provider.FullName</strong>
                            <p>@provider.PhoneNumber - @TranslateEmploymentType(provider.EmploymentType)</p>
                        </div>
                    </div>
                    <div class="operator-meta">
                        <span class="@GetProviderStatusClass(provider.Status)">@TranslateProviderStatus(provider.Status)</span>
                        <small>@(provider.IsAvailable ? "Disponible" : "Non disponible")</small>
                    </div>
                    <div class="operator-kpis">
                        <span>@provider.YearsOfExperience an(s)</span>
                        <span>@FormatSkills(provider.Services, provider.Prestations)</span>
                        <span>@provider.DocumentCount document(s)</span>
                    </div>
                    <div class="operator-actions">
                        <button type="button" @onclick="() => OpenProvider(provider.Id)">Ouvrir</button>
                    </div>
                </article>
            }
        </section>
    }
    else if (SelectedTab == "interim")
    {
        <section class="operator-list">
            <header>
                <div>
                    <h2>Demandes interim</h2>
                    <p>@Company.InterimRequests.Count candidature(s) rattachee(s)</p>
                </div>
            </header>
            @foreach (var request in Company.InterimRequests)
            {
                <article class="operator-row interim-row">
                    <div class="company-identity">
                        <span class="avatar-token">@GetInitials(request.ProviderName)</span>
                        <div>
                            <strong>@request.ProviderName</strong>
                            <p>@request.PhoneNumber - @request.Gender</p>
                        </div>
                    </div>
                    <div class="operator-meta">
                        <span class="@GetInterimStatusClass(request.Status)">@TranslateInterimStatus(request.Status)</span>
                        <small>@FormatDate(request.RequestedAt)</small>
                    </div>
                    <div class="operator-kpis">
                        <span>@FormatSkills(request.Services, request.Prestations)</span>
                        <span>@(request.Message ?? "Aucun message")</span>
                        <span>@(request.ReviewNote ?? "Pas de note")</span>
                    </div>
                    <div class="operator-actions">
                        <button type="button" @onclick="() => OpenProvider(request.ProviderId)">Voir le profil</button>
                    </div>
                </article>
            }
        </section>
    }
    else if (SelectedTab == "missions")
    {
        <section class="operator-list">
            <header>
                <div>
                    <h2>Missions</h2>
                    <p>@Company.Missions.Count derniere(s) mission(s)</p>
                </div>
            </header>
            @foreach (var mission in Company.Missions)
            {
                <article class="operator-row mission-row">
                    <div>
                        <strong>@FormatMissionTitle(mission)</strong>
                        <p>@mission.CustomerName - @(mission.ServiceAddress ?? "Adresse non renseignee")</p>
                    </div>
                    <div class="operator-meta">
                        <span class="@GetMissionStatusClass(mission.Status)">@TranslateMissionStatus(mission.Status)</span>
                        <small>@mission.PaymentMethod / @mission.PaymentStatus</small>
                    </div>
                    <div class="operator-kpis">
                        <span>@(mission.ProviderName ?? "Prestataire non affecte")</span>
                        <span>@FormatMoney(mission.CompanyQuotedAmount ?? mission.EstimatedTotalAmount, mission.Currency)</span>
                        <span>@FormatDate(mission.ScheduledFor)</span>
                    </div>
                    <div class="operator-actions">
                        <button type="button" @onclick="() => OpenMission(mission.Id)">Ouvrir</button>
                    </div>
                </article>
            }
        </section>
    }
    else if (SelectedTab == "documents")
    {
        <section class="company-documents-grid">
            <article class="operator-list">
                <header>
                    <div>
                        <h2>Pieces entreprise</h2>
                        <p>@Company.ApplicationDocuments.Count document(s) du dossier legal</p>
                    </div>
                </header>
                @foreach (var document in Company.ApplicationDocuments)
                {
                    <article class="operator-row document-row">
                        <div>
                            <strong>@TranslateCompanyDocumentType(document.DocumentType)</strong>
                            <p>@document.OriginalFileName</p>
                            @if (!string.IsNullOrWhiteSpace(document.ReviewNote))
                            {
                                <small>@document.ReviewNote</small>
                            }
                        </div>
                        <div class="operator-meta">
                            <span class="@GetDocumentStatusClass(document.ReviewStatus)">@TranslateDocumentStatus(document.ReviewStatus)</span>
                        </div>
                        <div class="operator-actions">
                            <a href="@ApiClient.GetCompanyApplicationDocumentPreviewUrl(document.Id)" target="_blank" rel="noopener">Voir la piece</a>
                        </div>
                    </article>
                }
            </article>
            <article class="operator-list">
                <header>
                    <div>
                        <h2>Pieces prestataires</h2>
                        <p>@Company.Documents.Count piece(s) rattachee(s) aux employes</p>
                    </div>
                </header>
                @foreach (var document in Company.Documents)
                {
                    <article class="operator-row document-row">
                        <div>
                            <strong>@document.ProviderName</strong>
                            <p>@TranslateDocumentType(document.DocumentType) - @document.OriginalFileName</p>
                        </div>
                        <div class="operator-actions">
                            <a href="@ApiClient.GetProviderDocumentPreviewUrl(document.Id)" target="_blank" rel="noopener">Voir la piece</a>
                            <button type="button" @onclick="() => OpenProvider(document.ProviderId)">Voir prestataire</button>
                        </div>
                    </article>
                }
            </article>
        </section>
    }
    else if (SelectedTab == "notifications")
    {
        <section class="timeline-panel company-notification-list">
            @foreach (var notification in Company.Notifications)
            {
                <article class="@GetNotificationClass(notification)">
                    <div>
                        <strong>@notification.Title</strong>
                        <p>@notification.Message</p>
                        <small>@TranslateNotificationTone(notification.Tone) - @FormatDate(notification.OccurredAt)</small>
                    </div>
                    <div class="operator-actions">
                        @if (notification.IsRead)
                        {
                            <button type="button" disabled="@(BusyNotificationId == notification.Id)" @onclick="() => MarkCompanyNotificationUnreadAsync(notification.Id)">Remettre non lue</button>
                        }
                        else
                        {
                            <button type="button" disabled="@(BusyNotificationId == notification.Id)" @onclick="() => MarkCompanyNotificationReadAsync(notification.Id)">Marquer lue</button>
                        }
                        <button type="button" disabled="@(BusyNotificationId == notification.Id)" @onclick="() => ResendCompanyNotificationAsync(notification.Id)">Renvoyer</button>
                    </div>
                </article>
            }
        </section>
    }
    else if (SelectedTab == "timeline")
    {
        <section class="timeline-panel">
            @foreach (var item in Company.Timeline)
            {
                <article>
                    <strong>@TranslateApplicationStatus(item.NewStatus)</strong>
                    <p>@(item.Note ?? "Aucune note")</p>
                    <small>@FormatDate(item.ChangedAt) - @(item.ChangedBy ?? "Systeme")</small>
                </article>
            }
        </section>
    }
    else if (SelectedTab == "logs")
    {
        <AdminAuditLogPanel
            ContextType="Company"
            ContextId="Company.Id"
            Eyebrow="Journal entreprise"
            Title="Activite du dossier"
            Subtitle="Actions admin, portail entreprise, employes et missions rattachees." />
    }
}

@code {
    [Parameter] public Guid CompanyId { get; set; }

    private AdminCompanyDetailResponse? Company { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private string SelectedTab { get; set; } = "summary";
    private string? CompanyActionNote { get; set; }
    private bool IsCompanyActionBusy { get; set; }
    private Guid? BusyNotificationId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            Company = await ApiClient.GetCompanyAsync(CompanyId);
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger l'entreprise. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/companies");
    }

    private void SelectTab(string tab)
    {
        SelectedTab = tab;
    }

    private void OpenProvider(Guid providerId)
    {
        Navigation.NavigateTo($"/providers/{providerId:D}");
    }

    private void OpenMission(Guid missionId)
    {
        Navigation.NavigateTo($"/missions/{missionId:D}");
    }

    private async Task SuspendCompanyAsync()
    {
        if (Company is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(CompanyActionNote))
        {
            ErrorMessage = "Ajoutez une note avant de suspendre l'entreprise.";
            return;
        }

        await RunCompanyActionAsync(() => ApiClient.SuspendAdminCompanyAsync(Company.Id, CompanyActionNote));
    }

    private async Task ReactivateCompanyAsync()
    {
        if (Company is null)
        {
            return;
        }

        await RunCompanyActionAsync(() => ApiClient.ReactivateAdminCompanyAsync(Company.Id, CompanyActionNote));
    }

    private async Task RunCompanyActionAsync(Func<Task<ApiActionResult>> action)
    {
        IsCompanyActionBusy = true;
        ErrorMessage = null;

        try
        {
            var result = await action();
            if (!result.IsSuccess)
            {
                ErrorMessage = result.ErrorMessage;
                return;
            }

            CompanyActionNote = null;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsCompanyActionBusy = false;
        }
    }

    private async Task MarkCompanyNotificationReadAsync(Guid notificationId)
    {
        if (Company is null)
        {
            return;
        }

        await RunNotificationActionAsync(
            notificationId,
            () => ApiClient.MarkCompanyNotificationReadAsync(Company.Id, notificationId));
    }

    private async Task MarkCompanyNotificationUnreadAsync(Guid notificationId)
    {
        if (Company is null)
        {
            return;
        }

        await RunNotificationActionAsync(
            notificationId,
            () => ApiClient.MarkCompanyNotificationUnreadAsync(Company.Id, notificationId));
    }

    private async Task ResendCompanyNotificationAsync(Guid notificationId)
    {
        if (Company is null)
        {
            return;
        }

        await RunNotificationActionAsync(
            notificationId,
            () => ApiClient.ResendCompanyNotificationAsync(Company.Id, notificationId));
    }

    private async Task RunNotificationActionAsync(Guid notificationId, Func<Task<ApiActionResult>> action)
    {
        BusyNotificationId = notificationId;
        ErrorMessage = null;

        try
        {
            var result = await action();
            if (!result.IsSuccess)
            {
                ErrorMessage = result.ErrorMessage;
                return;
            }

            await LoadAsync();
            SelectedTab = "notifications";
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Action notification impossible. Detail: {exception.Message}";
        }
        finally
        {
            BusyNotificationId = null;
        }
    }

    private string GetTabClass(string tab) => SelectedTab == tab ? "active" : string.Empty;

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string FormatMoney(int? amount, string currency) => amount is null or 0 ? $"0 {currency}" : $"{amount:N0} {currency}";
    private static string FormatDate(DateTimeOffset? value) => value?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Non planifie";
    private static string FormatDate(DateTimeOffset value) => value.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    private static string FormatMissionTitle(AdminCompanyMissionResponse mission) => string.IsNullOrWhiteSpace(mission.PrestationName) ? mission.ServiceName : $"{mission.ServiceName} - {mission.PrestationName}";
    private static string FormatSkills(IReadOnlyList<string> services, IReadOnlyList<string> prestations)
    {
        var values = prestations.Count > 0 ? prestations : services;
        return values.Count == 0 ? "Aucun service" : string.Join(", ", values.Take(3));
    }

    private static string TranslateAssignmentMode(string status) => status == "PlatformManaged" ? "Affectation wélé" : "Affectation entreprise";
    private static string TranslateStatus(string status) => status switch { "Approved" => "Active", "Suspended" => "Suspendue", "Rejected" => "Refusee", "PendingReview" => "A verifier", _ => status };
    private static string TranslateEmploymentType(string value) => value switch { "TemporaryWorker" => "Interimaire", "CompanyEmployee" => "Employe", _ => value };
    private static string TranslateProviderStatus(string status) => status switch { "Approved" => "Valide", "Invited" => "Invite", "SuspendedByCompany" => "Suspendu entreprise", "SuspendedByPlatform" => "Suspendu plateforme", "InterimCandidate" => "Candidat interim", _ => status };
    private static string TranslateInterimStatus(string status) => status switch { "Pending" => "A evaluer", "Approved" => "Validee", "Rejected" => "Refusee", "Cancelled" => "Annulee", _ => status };
    private static string TranslateMissionStatus(string status) => status switch { "Created" => "Creee", "Assigned" => "Affectee", "Accepted" => "Acceptee", "Started" => "En cours", "Completed" => "Terminee", "Cancelled" => "Annulee", "Disputed" => "Litige", _ => status };
    private static string TranslateApplicationStatus(string status) => status switch { "Approved" => "Validee", "ActivationSent" => "Lien envoye", "Activated" => "Compte active", "Rejected" => "Refusee", "MoreInformationRequested" => "Complement demande", "UnderReview" => "Analyse", _ => status };
    private static string TranslateDocumentType(string type) => type switch { "Photo" => "Photo", "IdentityDocument" => "Piece d'identite", "Diploma" => "Diplome", _ => type };
    private static string TranslateCompanyDocumentType(string type) => type switch
    {
        "FiscalExistenceDeclaration" => "DFE - Declaration Fiscale d'Existence",
        "BusinessRegistration" => "Registre de commerce",
        "OwnerIdentity" => "Identite responsable",
        "AddressProof" => "Justificatif d'adresse",
        "SupportingDocument" => "Document complementaire",
        "TaxDeclaration" => "DFE - Declaration Fiscale d'Existence",
        "RepresentativeId" => "Identite responsable",
        _ => type
    };
    private static string TranslateDocumentStatus(string status) => status switch { "Approved" => "Valide", "Rejected" => "Refuse", "NeedsReplacement" => "A remplacer", "Pending" => "A verifier", _ => status };
    private static string TranslateNotificationTone(string tone) => tone switch { "success" => "Information validee", "danger" or "error" => "Attention", "warning" => "A traiter", _ => "Information" };

    private string GetCompanyActionTitle()
        => Company?.Status == "Suspended" ? "Entreprise suspendue" : "Entreprise active";

    private string GetCompanyActionHelp()
        => Company?.Status == "Suspended"
            ? "Reactivez l'acces portail quand le dossier peut reprendre."
            : "Suspendez l'acces portail en cas de risque, litige ou controle.";

    private static string GetStatusClass(string status) => status switch { "Approved" => "status-pill ok", "Suspended" or "Rejected" => "status-pill danger", _ => "status-pill pending" };
    private static string GetProviderStatusClass(string status) => status switch { "Approved" => "status-pill ok", "SuspendedByCompany" or "SuspendedByPlatform" or "Inactive" => "status-pill danger", _ => "status-pill pending" };
    private static string GetInterimStatusClass(string status) => status switch { "Approved" => "status-pill ok", "Rejected" or "Cancelled" => "status-pill danger", _ => "status-pill pending" };
    private static string GetMissionStatusClass(string status) => status switch { "Completed" => "status-pill ok", "Cancelled" or "Disputed" => "status-pill danger", _ => "status-pill pending" };
    private static string GetDocumentStatusClass(string status) => status switch { "Approved" => "status-pill ok", "Rejected" => "status-pill danger", _ => "status-pill pending" };
    private static string GetNotificationClass(AdminCompanyNotificationResponse notification)
        => $"company-notification-item {(notification.IsRead ? "read" : "unread")} {notification.Tone.ToLowerInvariant()}";
}

@page "/company-applications/{Id:guid}"
@using HomeService.Admin.Services
@using HomeService.Contracts.Companies
@inject PlatformApiClient ApiClient

<PageTitle>Detail demande entreprise</PageTitle>

<a href="company-applications">Retour a la liste</a>

@if (IsLoading)
{
    <section class="info-panel">
        <p>Chargement du dossier entreprise...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <section class="info-panel">
        <p>@ErrorMessage</p>
    </section>
}
else if (Application is not null)
{
    <section class="detail-header">
        <div>
            <h1>@Application.CompanyName</h1>
            <p class="lead">@Application.City - @Application.ContactName - @Application.Email</p>
            <p class="section-help">
                Dossier depose @FormatDate(Application.SubmittedAt). Verifiez les informations legales, les pieces,
                les services demandes et la coherence globale avant validation.
            </p>
        </div>
        <span class="detail-status">@Application.Status</span>
    </section>

    @if (!string.IsNullOrWhiteSpace(ActionMessage))
    {
        <section class="info-panel action-feedback">
            <p>@ActionMessage</p>
        </section>
    }

    <section class="info-panel">
        <div>
            <h2>Decision attendue</h2>
            <p>
                Valider seulement si l'entreprise existe officiellement, si le responsable est identifiable
                et si les services annonces correspondent a l'activite declaree.
            </p>
        </div>
        <div class="check-list">
            <span>Nom legal coherent</span>
            <span>DFE lisible</span>
            <span>Contact responsable joignable</span>
            <span>Services sans doublon evident</span>
        </div>
    </section>

    <section class="detail-grid">
        <article>
            <h2>Entreprise</h2>
            <dl>
                <dt>Numero legal</dt>
                <dd>@Display(Application.RegistrationNumber)</dd>
                <dt>Adresse</dt>
                <dd>@Display(Application.Address)</dd>
                <dt>Telephone</dt>
                <dd>@Application.PhoneNumber</dd>
                <dt>Prestataires estimes</dt>
                <dd>@(Application.EstimatedProviderCount?.ToString() ?? "Non renseigne")</dd>
                <dt>Note revue</dt>
                <dd>@Display(Application.ReviewNote)</dd>
            </dl>
        </article>

        <article>
            <h2>Services envisages</h2>
            <p>@Display(Application.PlannedServices)</p>
            <p class="section-help">
                Les services doivent etre associes au catalogue existant quand ils sont proches d'un service actif.
            </p>
        </article>
    </section>

    <section class="document-list">
        <h2>Pieces a verifier</h2>
        @if (Application.Documents.Count == 0)
        {
            <article>
                <p>Aucune piece rattachee a ce dossier.</p>
            </article>
        }
        else
        {
            @foreach (var document in Application.Documents)
            {
                <article>
                    <div>
                        <strong>@GetDocumentLabel(document.DocumentType)</strong>
                        <p>@document.OriginalFileName - @document.ContentType</p>
                        <p class="section-help">@GetDocumentHelp(document.DocumentType)</p>
                        @if (!string.IsNullOrWhiteSpace(document.ReviewNote))
                        {
                            <p class="section-help">Note piece: @document.ReviewNote</p>
                        }
                    </div>
                    <span>@document.ReviewStatus</span>
                    <div class="document-actions">
                        <textarea rows="2"
                                  placeholder="Commentaire obligatoire pour refus ou remplacement"
                                  @bind="DocumentNotes[document.Id]"></textarea>
                        <div class="easy-actions">
                            <a href="@ApiClient.GetCompanyApplicationDocumentUrl(document.Id)" target="_blank" rel="noopener">Ouvrir</a>
                            <button type="button" disabled="@IsBusy" @onclick="() => ApproveDocumentAsync(document.Id)">Valider piece</button>
                            <button type="button" disabled="@IsBusy" @onclick="() => RequestDocumentReplacementAsync(document.Id)">Complement piece</button>
                            <button type="button" disabled="@IsBusy" @onclick="() => RejectDocumentAsync(document.Id)">Refuser piece</button>
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    <section class="review-panel">
        <h2>Actions dossier</h2>
        <p class="section-help">
            La note est obligatoire pour demander un complement ou refuser le dossier.
            La validation envoie ou regenere un lien d'activation pour creation du mot de passe.
        </p>
        <textarea rows="4" placeholder="Note interne ou message de complement" @bind="ReviewNote"></textarea>
        <div class="easy-actions">
            <button type="button" disabled="@IsBusy" @onclick="RequestMoreInformationAsync">Demander complement</button>
            <button type="button" disabled="@IsBusy" @onclick="ApproveAndSendActivationLinkAsync">Valider et envoyer lien</button>
            <button type="button" disabled="@IsBusy" @onclick="SendActivationLinkAsync">Renvoyer lien</button>
            <button type="button" disabled="@IsBusy" @onclick="RejectApplicationAsync">Rejeter</button>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CompanyApplicationDetailResponse? Application { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private string? ActionMessage { get; set; }
    private string ReviewNote { get; set; } = string.Empty;
    private Dictionary<Guid, string> DocumentNotes { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        await LoadApplicationAsync();
    }

    private async Task LoadApplicationAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            Application = await ApiClient.GetCompanyApplicationAsync(Id);
            if (Application is null)
            {
                ErrorMessage = "Dossier introuvable.";
                return;
            }

            DocumentNotes = Application.Documents.ToDictionary(document => document.Id, _ => string.Empty);
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger ce dossier depuis l'API. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RequestMoreInformationAsync()
    {
        if (!TryRequireReviewNote("Ajoutez une note avant de demander un complement."))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RequestCompanyApplicationMoreInformationAsync(Id, ReviewNote),
            "Complement demande a l'entreprise.");
    }

    private async Task RejectApplicationAsync()
    {
        if (!TryRequireReviewNote("Ajoutez une note avant de refuser le dossier."))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RejectCompanyApplicationAsync(Id, ReviewNote),
            "Dossier refuse avec note.");
    }

    private async Task ApproveAndSendActivationLinkAsync()
    {
        await RunActivationLinkActionAsync(async () =>
        {
            await ApiClient.ApproveCompanyApplicationAsync(Id);
            return await ApiClient.SendCompanyApplicationActivationLinkAsync(Id);
        });
    }

    private async Task SendActivationLinkAsync()
    {
        await RunActivationLinkActionAsync(() => ApiClient.SendCompanyApplicationActivationLinkAsync(Id));
    }

    private async Task ApproveDocumentAsync(Guid documentId)
    {
        await RunActionAsync(
            () => ApiClient.ApproveCompanyApplicationDocumentAsync(documentId),
            "Piece validee.");
    }

    private async Task RequestDocumentReplacementAsync(Guid documentId)
    {
        if (!TryGetDocumentNote(documentId, "Ajoutez un commentaire avant de demander un complement de piece.", out var note))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RequestCompanyApplicationDocumentReplacementAsync(documentId, note),
            "Complement de piece demande.");
    }

    private async Task RejectDocumentAsync(Guid documentId)
    {
        if (!TryGetDocumentNote(documentId, "Ajoutez un commentaire avant de refuser la piece.", out var note))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RejectCompanyApplicationDocumentAsync(documentId, note),
            "Piece refusee.");
    }

    private async Task RunActionAsync<T>(Func<Task<T?>> action, string successMessage)
    {
        IsBusy = true;
        ActionMessage = null;

        try
        {
            await action();
            ActionMessage = successMessage;
            await LoadApplicationAsync();
        }
        catch (Exception exception)
        {
            ActionMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBusy = false;
            IsLoading = false;
        }
    }

    private async Task RunActivationLinkActionAsync(Func<Task<CompanyApplicationActivationLinkResponse?>> action)
    {
        IsBusy = true;
        ActionMessage = null;

        try
        {
            var response = await action();
            ActionMessage = response is null
                ? "Lien d'activation genere."
                : $"Lien d'activation valable jusqu'au {response.ExpiresAt.ToLocalTime():dd/MM/yyyy HH:mm}: {response.ActivationLink}";
            await LoadApplicationAsync();
        }
        catch (Exception exception)
        {
            ActionMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBusy = false;
            IsLoading = false;
        }
    }

    private bool TryRequireReviewNote(string message)
    {
        if (!string.IsNullOrWhiteSpace(ReviewNote))
        {
            return true;
        }

        ActionMessage = message;
        return false;
    }

    private bool TryGetDocumentNote(Guid documentId, string message, out string note)
    {
        DocumentNotes.TryGetValue(documentId, out var value);
        note = value?.Trim() ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(note))
        {
            return true;
        }

        ActionMessage = message;
        return false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Non renseigne" : value;
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value is null ? "a une date inconnue" : $"le {value.Value.ToLocalTime():dd/MM/yyyy HH:mm}";
    }

    private static string GetDocumentLabel(string documentType)
    {
        return documentType switch
        {
            "FiscalExistenceDeclaration" => "DFE - Declaration Fiscale d'Existence",
            "BusinessRegistration" => "Registre de commerce",
            "OwnerIdentity" => "Identite responsable",
            "AddressProof" => "Justificatif d'adresse",
            _ => "Document complementaire"
        };
    }

    private static string GetDocumentHelp(string documentType)
    {
        return documentType switch
        {
            "FiscalExistenceDeclaration" => "Verifier le nom legal, le numero fiscal, la lisibilite et la coherence avec le registre.",
            "BusinessRegistration" => "Comparer la raison sociale, l'adresse et l'activite declaree avec le formulaire.",
            "OwnerIdentity" => "Le nom doit correspondre au contact responsable ou a une personne autorisee.",
            "AddressProof" => "Document recommande pour securiser les futures relations et relances.",
            _ => "Verifier la pertinence du document pour le dossier."
        };
    }
}

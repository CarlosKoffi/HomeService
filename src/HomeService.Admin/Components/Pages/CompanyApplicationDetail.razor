    private sealed record ApplicationDetail(
        Guid Id,
        string CompanyName,
        string? RegistrationNumber,
        string City,
        string? Address,
        string ContactName,
        string Email,
        string PhoneNumber,
        string? PlannedServices,
        int? EstimatedProviderCount,
        string Status,
        IReadOnlyList<DocumentRow> Documents);

    private sealed record DocumentRow(
        string DocumentType,
        string OriginalFileName,
        string ContentType,
        string ReviewStatus,
        string ReviewHelp);
}

@page "/company-applications/{Id:guid}"
@using HomeService.Admin.Services
@using HomeService.Contracts.Companies
@inject PlatformApiClient ApiClient
@inject IJSRuntime Js

<PageTitle>Detail demande entreprise</PageTitle>

<a href="company-applications">Retour a la liste</a>

@if (IsLoading)
{
    <section class="info-panel">
        <p>Chargement du dossier entreprise...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <section class="info-panel">
        <p>@ErrorMessage</p>
    </section>
}
else if (Application is not null)
{
    <section class="detail-header">
        <div>
            <h1>@Application.CompanyName</h1>
            <p class="lead">@Application.City - @Application.ContactName - @Application.Email</p>
            <p class="section-help">
                Dossier depose @FormatDate(Application.SubmittedAt). Verifiez les informations legales, les pieces,
                les services demandes et la coherence globale avant validation.
            </p>
        </div>
        <span class="detail-status @GetStatusClass(Application.Status)">@Application.Status</span>
    </section>

    @if (!string.IsNullOrWhiteSpace(ActionMessage))
    {
        <section class="info-panel action-feedback">
            <p>@ActionMessage</p>
        </section>
    }

    <section class="info-panel">
        <div>
            <h2>Decision attendue</h2>
            <p>
                Valider seulement si l'entreprise existe officiellement, si le responsable est identifiable
                et si les services annonces correspondent a l'activite declaree.
            </p>
        </div>
        <div class="check-list">
            <span>Nom legal coherent</span>
            <span>DFE lisible</span>
            <span>Contact responsable joignable</span>
            <span>Services sans doublon evident</span>
        </div>
    </section>

    <section class="activation-link-panel">
        <div>
            <h2>Lien d'activation entreprise</h2>
            @if (!string.IsNullOrWhiteSpace(Application.LastActivationLink))
            {
                <p class="section-help">
                    Dernier lien genere, valable jusqu'au @FormatDate(Application.LastActivationLinkExpiresAt).
                </p>
                <input class="readonly-link" value="@Application.LastActivationLink" readonly />
            }
            else
            {
                <p class="section-help">
                    Aucun lien d'activation n'a encore ete genere pour ce dossier.
                    Validez le dossier puis genere le lien a transmettre au responsable entreprise.
                </p>
                <input class="readonly-link" value="Aucun lien disponible" readonly disabled />
            }
        </div>
        <div class="easy-actions">
            @if (!string.IsNullOrWhiteSpace(Application.LastActivationLink))
            {
                <button type="button" @onclick="CopyActivationLinkAsync">Copier lien</button>
                <a href="@Application.LastActivationLink" target="_blank" rel="noopener">Ouvrir lien</a>
            }
            <button type="button" disabled="@IsBusy" @onclick="SendActivationLinkAsync">Generer / renvoyer lien</button>
        </div>
    </section>

    <section class="info-panel assignment-mode-panel">
        <div>
            <h2>Affectation des missions</h2>
            <p class="section-help">
                Choisissez qui affecte les demandes aux prestataires de cette entreprise. Si ProxiPro gere
                l'affectation, une commission additionnelle pourra etre appliquee plus tard.
            </p>
        </div>
        @if (Application.CompanyId is null)
        {
            <p class="section-help">Disponible apres validation de l'entreprise.</p>
        }
        else
        {
            <div class="assignment-mode-actions">
                <select @bind="SelectedAssignmentMode" disabled="@IsBusy">
                    <option value="SelfManaged">Entreprise affecte elle-meme</option>
                    <option value="PlatformManaged">ProxiPro affecte pour l'entreprise</option>
                </select>
                <button type="button" disabled="@IsBusy" @onclick="SaveAssignmentModeAsync">Enregistrer</button>
            </div>
            <p class="section-help">@GetAssignmentModeHelp(SelectedAssignmentMode)</p>
        }
    </section>

    <section class="detail-grid">
        <article>
            <h2>Entreprise</h2>
            <dl>
                <dt>Numero legal</dt>
                <dd>@Display(Application.RegistrationNumber)</dd>
                <dt>Adresse</dt>
                <dd>@Display(Application.Address)</dd>
                <dt>Telephone</dt>
                <dd>@Application.PhoneNumber</dd>
                <dt>Prestataires estimes</dt>
                <dd>@(Application.EstimatedProviderCount?.ToString() ?? "Non renseigne")</dd>
                <dt>Note revue</dt>
                <dd>@Display(Application.ReviewNote)</dd>
            </dl>
        </article>

        <article>
            <h2>Services envisages</h2>
            <p>@Display(Application.PlannedServices)</p>
            <p class="section-help">
                Les services doivent etre associes au catalogue existant quand ils sont proches d'un service actif.
            </p>
        </article>
    </section>

    <section class="document-list">
        <div class="document-list-heading">
            <div>
                <h2>Pieces a verifier</h2>
                <p class="section-help">
                    Les pieces obligatoires doivent etre validees avant de pouvoir approuver le dossier.
                    Les lignes manquantes restent visibles pour savoir exactement ce qui bloque.
                </p>
            </div>
            <span class="document-readiness @GetRequiredDocumentsReadinessClass()">@GetRequiredDocumentsReadinessLabel()</span>
        </div>

        @foreach (var slot in RequiredDocumentSlots)
        {
            var document = FindLatestDocument(slot.Type);
            <article class="@GetDocumentStatusClass(document?.ReviewStatus)">
                <div>
                    <strong>@slot.Label</strong>
                    @if (document is null)
                    {
                        <p>Aucun fichier depose pour cette piece.</p>
                        <p class="section-help">@slot.Help</p>
                    }
                    else
                    {
                        <p>@document.OriginalFileName - @document.ContentType</p>
                        <p class="section-help">@slot.Help</p>
                        @if (!string.IsNullOrWhiteSpace(document.ReviewNote))
                        {
                            <p class="document-review-note">Note piece: @document.ReviewNote</p>
                        }
                        @if (CanPreviewDocument(document.ContentType))
                        {
                            <details class="document-preview">
                                <summary>Previsualiser</summary>
                                @if (IsImageDocument(document.ContentType))
                                {
                                    <img src="@ApiClient.GetCompanyApplicationDocumentPreviewUrl(document.Id)"
                                         loading="lazy"
                                         alt="Previsualisation de @slot.Label" />
                                }
                                else
                                {
                                    <iframe src="@ApiClient.GetCompanyApplicationDocumentPreviewUrl(document.Id)"
                                            loading="lazy"
                                            title="Previsualisation de @slot.Label"></iframe>
                                }
                            </details>
                        }
                        else
                        {
                            <p class="section-help">Previsualisation non disponible pour ce format. Utilisez Ouvrir.</p>
                        }
                    }
                </div>
                <span class="document-status @GetDocumentStatusClass(document?.ReviewStatus)">@GetDocumentStatusLabel(document?.ReviewStatus)</span>
                @if (document is not null)
                {
                    <div>
                        <textarea rows="2"
                                  placeholder="Commentaire obligatoire pour refus ou remplacement"
                                  @bind="DocumentNotes[document.Id]"></textarea>
                        <div class="easy-actions">
                            <a href="@ApiClient.GetCompanyApplicationDocumentUrl(document.Id)" target="_blank" rel="noopener">Ouvrir</a>
                            <button type="button" disabled="@IsBusy" @onclick="() => ApproveDocumentAsync(document.Id)">Valider piece</button>
                            <button type="button" disabled="@IsBusy" @onclick="() => RequestDocumentReplacementAsync(document.Id)">Complement piece</button>
                            <button type="button" disabled="@IsBusy" @onclick="() => RejectDocumentAsync(document.Id)">Refuser piece</button>
                            @if (document.ReviewStatus == "Rejected")
                            {
                                <button type="button" disabled="@IsBusy" @onclick="() => ReopenDocumentAsync(document.Id)">Reouvrir piece</button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="document-actions document-actions-empty">
                        <p class="section-help">Demandez a l'entreprise d'ajouter cette piece depuis son portail.</p>
                    </div>
                }
            </article>
        }

        @foreach (var document in GetAdditionalDocuments())
        {
            <article class="@GetDocumentStatusClass(document.ReviewStatus)">
                <div>
                    <strong>@GetDocumentLabel(document.DocumentType)</strong>
                    <p>@document.OriginalFileName - @document.ContentType</p>
                    <p class="section-help">@GetDocumentHelp(document.DocumentType)</p>
                    @if (!string.IsNullOrWhiteSpace(document.ReviewNote))
                    {
                        <p class="document-review-note">Note piece: @document.ReviewNote</p>
                    }
                </div>
                <span class="document-status @GetDocumentStatusClass(document.ReviewStatus)">@GetDocumentStatusLabel(document.ReviewStatus)</span>
                <div class="document-actions">
                    <textarea rows="2"
                              placeholder="Commentaire obligatoire pour refus ou remplacement"
                              @bind="DocumentNotes[document.Id]"></textarea>
                    <div class="easy-actions">
                        <a href="@ApiClient.GetCompanyApplicationDocumentUrl(document.Id)" target="_blank" rel="noopener">Ouvrir</a>
                        <button type="button" disabled="@IsBusy" @onclick="() => ApproveDocumentAsync(document.Id)">Valider piece</button>
                        <button type="button" disabled="@IsBusy" @onclick="() => RequestDocumentReplacementAsync(document.Id)">Complement piece</button>
                        <button type="button" disabled="@IsBusy" @onclick="() => RejectDocumentAsync(document.Id)">Refuser piece</button>
                    </div>
                </div>
            </article>
        }
    </section>

    <section class="review-panel">
        <h2>Actions dossier</h2>
        <p class="section-help">
            La note est obligatoire pour demander un complement ou refuser le dossier.
            La validation envoie ou regenere un lien d'activation pour creation du mot de passe.
        </p>
        <textarea rows="4" placeholder="Note interne ou message de complement" @bind="ReviewNote"></textarea>
        <div class="easy-actions">
            <button type="button" disabled="@IsBusy" @onclick="RequestMoreInformationAsync">Demander complement</button>
            <button type="button" disabled="@IsBusy" @onclick="ApproveAndSendActivationLinkAsync">Valider et envoyer lien</button>
            <button type="button" disabled="@IsBusy" @onclick="SendActivationLinkAsync">Renvoyer lien</button>
            <button type="button" disabled="@IsBusy" @onclick="RejectApplicationAsync">Rejeter</button>
            @if (Application.Status == "Rejected")
            {
                <button type="button" disabled="@IsBusy" @onclick="ReopenApplicationAsync">Reouvrir dossier</button>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CompanyApplicationDetailResponse? Application { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private string? ActionMessage { get; set; }
    private string ReviewNote { get; set; } = string.Empty;
    private string SelectedAssignmentMode { get; set; } = "SelfManaged";
    private Dictionary<Guid, string> DocumentNotes { get; set; } = [];
    private static readonly IReadOnlyList<DocumentSlot> RequiredDocumentSlots =
    [
        new("FiscalExistenceDeclaration", "DFE - Declaration Fiscale d'Existence", "Verifier le nom legal, le numero fiscal, la lisibilite et la coherence avec le registre."),
        new("BusinessRegistration", "Registre de commerce", "Comparer la raison sociale, l'adresse et l'activite declaree avec le formulaire."),
        new("OwnerIdentity", "Identite responsable", "Le nom doit correspondre au contact responsable ou a une personne autorisee."),
        new("AddressProof", "Justificatif d'adresse", "Document recommande pour securiser les futures relations et relances.")
    ];

    protected override async Task OnParametersSetAsync()
    {
        await LoadApplicationAsync();
    }

    private async Task LoadApplicationAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            Application = await ApiClient.GetCompanyApplicationAsync(Id);
            if (Application is null)
            {
                ErrorMessage = "Dossier introuvable.";
                return;
            }

            DocumentNotes = Application.Documents.ToDictionary(document => document.Id, _ => string.Empty);
            SelectedAssignmentMode = string.IsNullOrWhiteSpace(Application.CompanyAssignmentMode)
                ? "SelfManaged"
                : Application.CompanyAssignmentMode;
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger ce dossier depuis l'API. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAssignmentModeAsync()
    {
        if (Application?.CompanyId is null)
        {
            ActionMessage = "Validez d'abord l'entreprise avant de choisir le mode d'affectation.";
            return;
        }

        IsBusy = true;
        ActionMessage = null;

        try
        {
            var response = await ApiClient.UpdateCompanyAssignmentModeAsync(Application.CompanyId.Value, SelectedAssignmentMode);
            ActionMessage = response?.Message ?? "Mode d'affectation mis a jour.";
            await LoadApplicationAsync();
        }
        catch (Exception exception)
        {
            ActionMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RequestMoreInformationAsync()
    {
        if (!TryRequireReviewNote("Ajoutez une note avant de demander un complement."))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RequestCompanyApplicationMoreInformationAsync(Id, ReviewNote),
            "Complement demande a l'entreprise.");
    }

    private async Task RejectApplicationAsync()
    {
        if (!TryRequireReviewNote("Ajoutez une note avant de refuser le dossier."))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RejectCompanyApplicationAsync(Id, ReviewNote),
            "Dossier refuse avec note.");
    }

    private async Task ReopenApplicationAsync()
    {
        if (!TryRequireReviewNote("Ajoutez une note avant de reouvrir le dossier."))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.ReopenCompanyApplicationAsync(Id, ReviewNote),
            "Dossier reouvert pour verification.");
    }

    private async Task ApproveAndSendActivationLinkAsync()
    {
        await RunActivationLinkActionAsync(async () =>
        {
            await ApiClient.ApproveCompanyApplicationAsync(Id);
            return await ApiClient.SendCompanyApplicationActivationLinkAsync(Id);
        });
    }

    private async Task SendActivationLinkAsync()
    {
        await RunActivationLinkActionAsync(() => ApiClient.SendCompanyApplicationActivationLinkAsync(Id));
    }

    private async Task CopyActivationLinkAsync()
    {
        if (string.IsNullOrWhiteSpace(Application?.LastActivationLink))
        {
            ActionMessage = "Aucun lien d'activation disponible.";
            return;
        }

        await Js.InvokeVoidAsync("navigator.clipboard.writeText", Application.LastActivationLink);
        ActionMessage = "Lien d'activation copie.";
    }

    private async Task ApproveDocumentAsync(Guid documentId)
    {
        await RunActionAsync(
            () => ApiClient.ApproveCompanyApplicationDocumentAsync(documentId),
            "Piece validee.");
    }

    private async Task RequestDocumentReplacementAsync(Guid documentId)
    {
        if (!TryGetDocumentNote(documentId, "Ajoutez un commentaire avant de demander un complement de piece.", out var note))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RequestCompanyApplicationDocumentReplacementAsync(documentId, note),
            "Complement de piece demande.");
    }

    private async Task RejectDocumentAsync(Guid documentId)
    {
        if (!TryGetDocumentNote(documentId, "Ajoutez un commentaire avant de refuser la piece.", out var note))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.RejectCompanyApplicationDocumentAsync(documentId, note),
            "Piece refusee.");
    }

    private async Task ReopenDocumentAsync(Guid documentId)
    {
        if (!TryGetDocumentNote(documentId, "Ajoutez un commentaire avant de reouvrir la piece.", out var note))
        {
            return;
        }

        await RunActionAsync(
            () => ApiClient.ReopenCompanyApplicationDocumentAsync(documentId, note),
            "Piece reouverte pour verification.");
    }

    private async Task RunActionAsync<T>(Func<Task<T?>> action, string successMessage)
    {
        IsBusy = true;
        ActionMessage = null;

        try
        {
            await action();
            ActionMessage = successMessage;
            await LoadApplicationAsync();
        }
        catch (Exception exception)
        {
            ActionMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBusy = false;
            IsLoading = false;
        }
    }

    private async Task RunActivationLinkActionAsync(Func<Task<CompanyApplicationActivationLinkResponse?>> action)
    {
        IsBusy = true;
        ActionMessage = null;

        try
        {
            var response = await action();
            ActionMessage = response is null
                ? "Lien d'activation genere."
                : $"Lien d'activation valable jusqu'au {response.ExpiresAt.ToLocalTime():dd/MM/yyyy HH:mm}: {response.ActivationLink}";
            await LoadApplicationAsync();
        }
        catch (Exception exception)
        {
            ActionMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBusy = false;
            IsLoading = false;
        }
    }

    private bool TryRequireReviewNote(string message)
    {
        if (!string.IsNullOrWhiteSpace(ReviewNote))
        {
            return true;
        }

        ActionMessage = message;
        return false;
    }

    private bool TryGetDocumentNote(Guid documentId, string message, out string note)
    {
        DocumentNotes.TryGetValue(documentId, out var value);
        note = value?.Trim() ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(note))
        {
            return true;
        }

        ActionMessage = message;
        return false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Non renseigne" : value;
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value is null ? "a une date inconnue" : $"le {value.Value.ToLocalTime():dd/MM/yyyy HH:mm}";
    }

    private static string GetDocumentLabel(string documentType)
    {
        return documentType switch
        {
            "FiscalExistenceDeclaration" => "DFE - Declaration Fiscale d'Existence",
            "BusinessRegistration" => "Registre de commerce",
            "OwnerIdentity" => "Identite responsable",
            "AddressProof" => "Justificatif d'adresse",
            _ => "Document complementaire"
        };
    }

    private static string GetDocumentHelp(string documentType)
    {
        return documentType switch
        {
            "FiscalExistenceDeclaration" => "Verifier le nom legal, le numero fiscal, la lisibilite et la coherence avec le registre.",
            "BusinessRegistration" => "Comparer la raison sociale, l'adresse et l'activite declaree avec le formulaire.",
            "OwnerIdentity" => "Le nom doit correspondre au contact responsable ou a une personne autorisee.",
            "AddressProof" => "Document recommande pour securiser les futures relations et relances.",
            _ => "Verifier la pertinence du document pour le dossier."
        };
    }

    private CompanyApplicationDocumentResponse? FindLatestDocument(string documentType)
    {
        return Application?.Documents
            .Where(document => string.Equals(document.DocumentType, documentType, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(document => document.CreatedAt)
            .FirstOrDefault();
    }

    private IReadOnlyList<CompanyApplicationDocumentResponse> GetAdditionalDocuments()
    {
        if (Application is null)
        {
            return [];
        }

        var required = RequiredDocumentSlots.Select(slot => slot.Type).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return Application.Documents
            .Where(document => !required.Contains(document.DocumentType))
            .OrderBy(document => document.DocumentType)
            .ThenByDescending(document => document.CreatedAt)
            .ToList();
    }

    private string GetRequiredDocumentsReadinessLabel()
    {
        var approved = RequiredDocumentSlots.Count(slot => FindLatestDocument(slot.Type)?.ReviewStatus == "Approved");
        return $"{approved}/{RequiredDocumentSlots.Count} pieces obligatoires validees";
    }

    private string GetRequiredDocumentsReadinessClass()
    {
        var approved = RequiredDocumentSlots.Count(slot => FindLatestDocument(slot.Type)?.ReviewStatus == "Approved");
        return approved == RequiredDocumentSlots.Count ? "status-done" : "status-review";
    }

    private static string GetAssignmentModeHelp(string assignmentMode)
    {
        return assignmentMode == "PlatformManaged"
            ? "ProxiPro choisira le meilleur prestataire disponible. Ce mode servira de base a une commission plus elevee."
            : "L'entreprise recoit les demandes et affecte elle-meme ses employes depuis son portail.";
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Rejected" => "status-rejected",
            "Approved" or "ActivationSent" or "Activated" => "status-done",
            "MoreInformationRequested" => "status-info",
            "UnderReview" => "status-review",
            _ => "status-new"
        };
    }

    private static string GetDocumentStatusClass(string? status)
    {
        return status switch
        {
            "Rejected" => "status-rejected",
            "NeedsReplacement" => "status-info",
            "Approved" => "status-done",
            _ => "status-new"
        };
    }

    private static string GetDocumentStatusLabel(string? status)
    {
        return status switch
        {
            "Approved" => "Validee",
            "Rejected" => "Refusee",
            "NeedsReplacement" => "A remplacer",
            "Pending" => "En verification",
            _ => "A fournir"
        };
    }

    private static bool CanPreviewDocument(string? contentType)
    {
        return IsImageDocument(contentType) || IsPdfDocument(contentType);
    }

    private static bool IsImageDocument(string? contentType)
    {
        return contentType?.StartsWith("image/", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsPdfDocument(string? contentType)
    {
        return string.Equals(contentType, "application/pdf", StringComparison.OrdinalIgnoreCase);
    }

    private sealed record DocumentSlot(string Type, string Label, string Help);
}

@page "/providers"
@using HomeService.Admin.Services
@using HomeService.Contracts.Admin
@inject PlatformApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Prestataires</PageTitle>

<div class="admin-page-heading">
    <div>
        <p class="eyebrow">Terrain</p>
        <h1>Prestataires</h1>
        <p class="lead">Consultez les profils, documents, services et rattachements entreprise.</p>
    </div>
    <button type="button" class="secondary-action" @onclick="LoadAsync" disabled="@IsLoading">Actualiser</button>
</div>

@if (Snapshot is not null)
{
    <section class="admin-metric-grid compact">
        <article>
            <span>Total</span>
            <strong>@Snapshot.Stats.TotalProviders</strong>
        </article>
        <article>
            <span>Valides</span>
            <strong>@Snapshot.Stats.ApprovedProviders</strong>
        </article>
        <article>
            <span>Candidats interim</span>
            <strong>@Snapshot.Stats.InterimCandidates</strong>
        </article>
        <article>
            <span>Disponibles</span>
            <strong>@Snapshot.Stats.AvailableProviders</strong>
        </article>
    </section>
}

<section class="toolbar operator-toolbar">
    <label>
        Statut
        <select @bind="SelectedStatus">
            <option value="">Tous</option>
            <option value="Approved">Valides</option>
            <option value="Invited">Invites</option>
            <option value="InterimCandidate">Candidats interim</option>
            <option value="SuspendedByCompany">Suspendus entreprise</option>
            <option value="SuspendedByPlatform">Suspendus plateforme</option>
            <option value="Inactive">Inactifs</option>
        </select>
    </label>
    <label>
        Type
        <select @bind="SelectedEmploymentType">
            <option value="">Tous</option>
            <option value="CompanyEmployee">Employe</option>
            <option value="TemporaryWorker">Interimaire</option>
        </select>
    </label>
    <label>
        Recherche
        <input type="search" @bind="SearchTerm" @bind:event="oninput" placeholder="Nom, telephone, entreprise, service" />
    </label>
    <button type="button" @onclick="LoadAsync" disabled="@IsLoading">Rechercher</button>
</section>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p class="admin-message error-message">@ErrorMessage</p>
}

<section class="operator-list">
    <header>
        <div>
            <h2>Profils prestataires</h2>
            <p>@(Snapshot?.Items.Count ?? 0) profil(s) affiche(s)</p>
        </div>
    </header>

    @if (IsLoading)
    {
        <article class="operator-row">
            <div>
                <strong>Chargement...</strong>
                <p>Lecture des prestataires depuis l'API.</p>
            </div>
        </article>
    }
    else if (Snapshot is null || Snapshot.Items.Count == 0)
    {
        <article class="admin-empty-row">
            <strong>Aucun prestataire</strong>
            <p>Aucun resultat pour les filtres actuels. Essayez un autre statut, type, nom, telephone, entreprise ou service.</p>
        </article>
    }
    else
    {
        @foreach (var provider in Snapshot.Items)
        {
            <article class="operator-row provider-row">
                <div class="company-identity">
                    <span class="avatar-token">@GetInitials(provider.FullName)</span>
                    <div>
                        <strong>@provider.FullName</strong>
                        <p>@provider.PhoneNumber - @TranslateEmploymentType(provider.EmploymentType)</p>
                        <small>@(provider.CompanyName ?? "Non rattache a une entreprise")</small>
                    </div>
                </div>
                <div class="operator-meta">
                    <span class="@GetProviderStatusClass(provider.Status)">@GetProviderAuthorizationLabel(provider)</span>
                    <small>@GetAvailabilityLabel(provider)</small>
                </div>
                <div class="operator-kpis">
                    <span>@provider.YearsOfExperience an(s)</span>
                    @foreach (var service in provider.Services.Take(3))
                    {
                        <span>@service</span>
                    }
                    @if (provider.Services.Count == 0)
                    {
                        <span>Aucun service</span>
                    }
                </div>
                <div class="provider-doc-actions">
                    <button type="button" @onclick="() => OpenProvider(provider.Id)">Voir fiche</button>
                    @foreach (var document in provider.Documents.Take(3))
                    {
                        <a href="@ApiClient.GetProviderDocumentPreviewUrl(document.Id)" target="_blank" rel="noopener">
                            @TranslateDocumentType(document.DocumentType)
                        </a>
                    }
                    @if (provider.CompanyId is not null)
                    {
                        <button type="button" @onclick="() => OpenCompany(provider.CompanyId.Value)">Entreprise</button>
                    }
                    <button type="button" @onclick="() => ShowProviderLogs(provider)">Journal</button>
                </div>
            </article>
        }
    }
</section>

@if (SelectedProviderForLogs is not null)
{
    <AdminAuditLogPanel
        ContextType="Provider"
        ContextId="SelectedProviderForLogs.Id"
        Eyebrow="Journal prestataire"
        Title="@SelectedProviderForLogs.FullName"
        Subtitle="Connexions, affectations, disponibilite, missions et actions rattachees." />
}

@code {
    private AdminProviderListResponse? Snapshot { get; set; }
    private AdminProviderSummaryResponse? SelectedProviderForLogs { get; set; }
    private string? SelectedStatus { get; set; }
    private string? SelectedEmploymentType { get; set; }
    private string? SearchTerm { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            Snapshot = await ApiClient.GetAdminProvidersAsync(SelectedStatus, SelectedEmploymentType, SearchTerm);
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger les prestataires. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OpenCompany(Guid companyId)
    {
        Navigation.NavigateTo($"/companies/{companyId}");
    }

    private void OpenProvider(Guid providerId)
    {
        Navigation.NavigateTo($"/providers/{providerId}");
    }

    private void ShowProviderLogs(AdminProviderSummaryResponse provider)
    {
        SelectedProviderForLogs = provider;
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string TranslateEmploymentType(string value) => value switch
    {
        "TemporaryWorker" => "Interimaire",
        "CompanyEmployee" => "Employe",
        _ => value
    };

    private static string TranslateProviderStatus(string status) => status switch
    {
        "Approved" => "Valide",
        "Invited" => "Invite",
        "SuspendedByCompany" => "Suspendu entreprise",
        "SuspendedByPlatform" => "Suspendu plateforme",
        "InterimCandidate" => "Candidat interim",
        "Inactive" => "Inactif",
        _ => status
    };

    private static string TranslateDocumentType(string type) => type switch
    {
        "Photo" => "Photo",
        "IdentityDocument" => "Piece ID",
        "Diploma" => "Diplome",
        _ => type
    };

    private static string GetProviderStatusClass(string status) => status switch
    {
        "Approved" => "status-pill ok",
        "SuspendedByCompany" or "SuspendedByPlatform" or "Inactive" => "status-pill danger",
        _ => "status-pill pending"
    };

    private static string GetAvailabilityLabel(AdminProviderSummaryResponse provider)
    {
        if (provider.Status != "Approved")
        {
            return "Non affectable";
        }

        return provider.IsAvailable ? "Disponible terrain" : "Indisponible terrain";
    }

    private static string GetProviderAuthorizationLabel(AdminProviderSummaryResponse provider)
    {
        return provider.Status switch
        {
            "Approved" => "Actif mission",
            "SuspendedByCompany" => "Suspendu entreprise",
            "SuspendedByPlatform" => "Suspendu wélé",
            "Inactive" => "Inactif",
            "InterimCandidate" => "Candidat interim",
            "Invited" => "Invitation envoyee",
            _ => TranslateProviderStatus(provider.Status)
        };
    }
}

@page "/service-proposals"
@using HomeService.Admin.Services
@using HomeService.Contracts.Services
@inject PlatformApiClient ApiClient

<PageTitle>Catalogue services</PageTitle>

<section class="admin-page-heading">
    <div>
        <p class="eyebrow">Catalogue operationnel</p>
        <h1>Services et prestations</h1>
        <p class="lead">
            Un service reste le metier principal. Les prestations servent a detailler ce que le client peut demander,
            par exemple tondre le gazon dans Jardinage.
        </p>
    </div>
    <button type="button" class="secondary-action" @onclick="LoadServicesAsync" disabled="@IsLoading">
        Actualiser
    </button>
</section>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p class="admin-message">@Message</p>
}

<section class="toolbar">
    <label>
        Recherche
        <input type="search" placeholder="Service ou prestation" @bind="Search" @bind:event="oninput" />
    </label>
    <label>
        Affichage
        <select @bind="StatusFilter">
            <option value="all">Tous</option>
            <option value="active">Services actifs</option>
            <option value="inactive">Services inactifs</option>
        </select>
    </label>
</section>

<section class="service-admin-create orphan-proposals">
    <div>
        <p class="eyebrow">A rattacher</p>
        <h2>Services saisis par les entreprises</h2>
        <p>
            Tout libelle non reconnu arrive ici. Rattachez-le a un service existant, a une prestation,
            ou creez une prestation sous le bon service parent.
        </p>
    </div>

    @if (CompanyServiceProposals.Count == 0)
    {
        <div class="info-panel compact">
            <h3>Aucun libelle orphelin</h3>
            <p>Les services proposes sont tous rattaches au catalogue.</p>
        </div>
    }
    else
    {
        <div class="proposal-review-list">
            @foreach (var proposal in CompanyServiceProposals)
            {
                var draft = GetProposalDraft(proposal);

                <article class="proposal-review-card" @key="proposal.Id">
                    <div>
                        <span class="status-pill pending">@proposal.MatchStatus</span>
                        <h3>@proposal.RawName</h3>
                        <p>@proposal.CompanyName - dossier @proposal.CompanyApplicationId.ToString()[..8]</p>
                        @if (proposal.Suggestions.Count > 0)
                        {
                            <div class="proposal-suggestions">
                                @foreach (var suggestion in proposal.Suggestions.Take(3))
                                {
                                    <button type="button" class="light-action" @onclick="() => ApplySuggestion(proposal.Id, suggestion)">
                                        @FormatSuggestion(suggestion) (@suggestion.Score)
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    <div class="service-admin-form proposal-actions">
                        <label>
                            Rattachement
                            <select @bind="draft.Selection">
                                <option value="">Choisir un service ou une prestation</option>
                                @foreach (var service in Services.Where(item => item.IsActive).OrderBy(item => item.Name))
                                {
                                    <option value="@BuildServiceSelection(service.Id)">@service.Name</option>
                                    @foreach (var prestation in service.Prestations.Where(item => item.IsActive).OrderBy(item => item.Name))
                                    {
                                        <option value="@BuildPrestationSelection(service.Id, prestation.Id)">@service.Name - @prestation.Name</option>
                                    }
                                }
                            </select>
                        </label>
                        <label>
                            Creer prestation sous
                            <select @bind="draft.CreateUnderServiceId">
                                <option value="">Ne pas creer</option>
                                @foreach (var service in Services.Where(item => item.IsActive).OrderBy(item => item.Name))
                                {
                                    <option value="@service.Id">@service.Name</option>
                                }
                            </select>
                        </label>
                        <div class="easy-actions">
                            <button type="button" @onclick="() => AttachProposalAsync(proposal.Id)" disabled="@IsSaving">
                                Rattacher
                            </button>
                            <button type="button" class="light-action" @onclick="() => CreatePrestationFromProposalAsync(proposal)" disabled="@IsSaving">
                                Creer prestation
                            </button>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

<section class="service-admin-create">
    <div>
        <p class="eyebrow">Nouveau service</p>
        <h2>Ajouter un service au catalogue</h2>
        <p>Ajoutez le service principal. Les prestations detaillees pourront ensuite etre rattachees dans sa fiche.</p>
    </div>
    <div class="service-admin-form compact">
        <label>
            Nom
            <input type="text" placeholder="Ex: Depannage auto" @bind="NewServiceDraft.Name" />
        </label>
        <label>
            Icone
            <input type="text" placeholder="Ex: car, zap, shirt" @bind="NewServiceDraft.IconName" />
        </label>
        <label>
            Prix minimum
            <input type="number" min="0" step="100" @bind="NewServiceDraft.NormalPriceAmount" />
        </label>
        <label>
            Prix maximum
            <input type="number" min="0" step="100" @bind="NewServiceDraft.PremiumPriceAmount" />
        </label>
        <label>
            Devise
            <input type="text" maxlength="8" @bind="NewServiceDraft.Currency" />
        </label>
        <label class="wide">
            Description
            <textarea rows="2" placeholder="Description courte du service." @bind="NewServiceDraft.Description"></textarea>
        </label>
        <button type="button" @onclick="CreateServiceAsync" disabled="@IsSaving">Ajouter le service</button>
    </div>
</section>

@if (IsLoading)
{
    <section class="info-panel">
        <div>
            <h2>Chargement du catalogue</h2>
            <p>Recuperation des services et prestations depuis l'API.</p>
        </div>
    </section>
}
else if (FilteredServices.Count == 0)
{
    <section class="info-panel">
        <div>
            <h2>Aucun service trouve</h2>
            <p>Modifiez la recherche ou rechargez le catalogue.</p>
        </div>
    </section>
}
else
{
    <section class="service-catalog">
        @foreach (var service in FilteredServices)
        {
            var draft = GetDraft(service.Id);
            var activePrestations = service.Prestations.Count(item => item.IsActive);

            <article class="service-catalog-card" @key="service.Id">
                <header>
                    <div>
                        <span class="catalog-icon">@service.IconName</span>
                        <div>
                            <h2>@service.Name</h2>
                            <p>@(string.IsNullOrWhiteSpace(service.Description) ? "Service officiel du catalogue Kaza." : service.Description)</p>
                        </div>
                    </div>
                    <div class="catalog-meta">
                        <span class="@(service.IsActive ? "status-pill accepted" : "status-pill rejected")">
                            @(service.IsActive ? "Actif" : "Inactif")
                        </span>
                        <strong>@activePrestations/@service.Prestations.Count prestations actives</strong>
                        <small>@FormatPriceRange(service.PriceMinAmount ?? service.NormalPriceAmount, service.PriceMaxAmount ?? service.PremiumPriceAmount, service.Currency)</small>
                    </div>
                </header>

                <div class="prestation-admin-grid">
                    <div class="prestation-list">
                        @if (EditingServiceId == service.Id)
                        {
                            var serviceEditDraft = GetServiceEditDraft(service);
                            <div class="service-edit-panel">
                                <label>
                                    Nom
                                    <input type="text" @bind="serviceEditDraft.Name" />
                                </label>
                                <label>
                                    Icone
                                    <input type="text" @bind="serviceEditDraft.IconName" />
                                </label>
                                <label>
                                    Prix minimum
                                    <input type="number" min="0" step="100" @bind="serviceEditDraft.NormalPriceAmount" />
                                </label>
                                <label>
                                    Prix maximum
                                    <input type="number" min="0" step="100" @bind="serviceEditDraft.PremiumPriceAmount" />
                                </label>
                                <label>
                                    Devise
                                    <input type="text" maxlength="8" @bind="serviceEditDraft.Currency" />
                                </label>
                                <label class="wide">
                                    Description
                                    <textarea rows="2" @bind="serviceEditDraft.Description"></textarea>
                                </label>
                                <div class="easy-actions wide">
                                    <button type="button" @onclick="() => UpdateServiceAsync(service.Id)" disabled="@IsSaving">Enregistrer service</button>
                                    <button type="button" class="light-action" @onclick="CancelServiceEdit">Annuler</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="easy-actions service-card-actions">
                                <button type="button" @onclick="() => StartServiceEdit(service)">Modifier le service</button>
                                @if (service.IsActive)
                                {
                                    <button type="button" class="light-action" @onclick="() => DeactivateServiceAsync(service.Id)" disabled="@IsSaving">Desactiver</button>
                                }
                                else
                                {
                                    <button type="button" @onclick="() => ActivateServiceAsync(service.Id)" disabled="@IsSaving">Reactiver</button>
                                }
                            </div>
                        }

                        @if (service.Prestations.Count == 0)
                        {
                            <p class="section-help">Aucune prestation specifique pour ce service. Il peut rester simple si cela suffit au produit.</p>
                        }
                        else
                        {
                            @foreach (var prestation in service.Prestations.OrderBy(item => item.SortOrder).ThenBy(item => item.Name))
                            {
                                var isEditing = EditingPrestationId == prestation.Id;
                                var editDraft = GetEditDraft(prestation);

                                <div class="prestation-row" @key="prestation.Id">
                                    @if (isEditing)
                                    {
                                        <div class="prestation-edit">
                                            <label>
                                                Nom
                                                <input type="text" @bind="editDraft.Name" />
                                            </label>
                                            <label>
                                                Ordre
                                                <input type="number" min="0" @bind="editDraft.SortOrder" />
                                            </label>
                                            <label>
                                                Prix minimum
                                                <input type="number" min="0" step="100" @bind="editDraft.NormalPriceAmount" />
                                            </label>
                                            <label>
                                                Prix maximum
                                                <input type="number" min="0" step="100" @bind="editDraft.PremiumPriceAmount" />
                                            </label>
                                            <label>
                                                Devise
                                                <input type="text" maxlength="8" @bind="editDraft.Currency" />
                                            </label>
                                            <label class="wide">
                                                Description courte
                                                <input type="text" @bind="editDraft.Description" />
                                            </label>
                                        </div>
                                        <div class="easy-actions">
                                            <button type="button" @onclick="() => UpdatePrestationAsync(prestation.Id)" disabled="@IsSaving">Enregistrer</button>
                                            <button type="button" class="light-action" @onclick="CancelEdit">Annuler</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>
                                            <strong>@prestation.Name</strong>
                                            <p>@(string.IsNullOrWhiteSpace(prestation.Description) ? "Aucune description." : prestation.Description)</p>
                                        </div>
                                        <div class="prestation-state">
                                            <span class="@(prestation.IsActive ? "status-pill accepted" : "status-pill rejected")">
                                                @(prestation.IsActive ? "Active" : "Inactive")
                                            </span>
                                            <small>Ordre @prestation.SortOrder</small>
                                            <small>@FormatPriceRange(prestation.PriceMinAmount ?? prestation.NormalPriceAmount, prestation.PriceMaxAmount ?? prestation.PremiumPriceAmount, prestation.Currency)</small>
                                        </div>
                                        <div class="easy-actions">
                                            <button type="button" @onclick="() => StartEdit(prestation)">Modifier</button>
                                            @if (prestation.IsActive)
                                            {
                                                <button type="button" class="light-action" @onclick="() => DeactivatePrestationAsync(prestation.Id)" disabled="@IsSaving">Desactiver</button>
                                            }
                                            else
                                            {
                                                <button type="button" @onclick="() => ActivatePrestationAsync(prestation.Id)" disabled="@IsSaving">Reactiver</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="service-admin-form">
                        <h3>Ajouter une prestation</h3>
                        <label>
                            Nom
                            <input type="text" placeholder="Ex: Tondre le gazon" @bind="draft.Name" />
                        </label>
                        <label>
                            Description courte
                            <textarea rows="3" placeholder="Expliquez clairement ce que couvre la prestation." @bind="draft.Description"></textarea>
                        </label>
                        <label>
                            Ordre d'affichage
                            <input type="number" min="0" @bind="draft.SortOrder" />
                        </label>
                        <label>
                            Prix minimum
                            <input type="number" min="0" step="100" @bind="draft.NormalPriceAmount" />
                        </label>
                        <label>
                            Prix maximum
                            <input type="number" min="0" step="100" @bind="draft.PremiumPriceAmount" />
                        </label>
                        <label>
                            Devise
                            <input type="text" maxlength="8" @bind="draft.Currency" />
                        </label>
                        <button type="button" @onclick="() => SaveNewPrestationAsync(service.Id)" disabled="@IsSaving">
                            Ajouter
                        </button>
                    </div>
                </div>
            </article>
        }
    </section>
}

@code {
    private readonly Dictionary<Guid, PrestationDraft> Drafts = [];
    private readonly Dictionary<Guid, PrestationDraft> EditDrafts = [];
    private readonly Dictionary<Guid, ServiceDraft> ServiceEditDrafts = [];
    private readonly Dictionary<Guid, ProposalDraft> ProposalDrafts = [];
    private IReadOnlyList<ServiceSummaryResponse> Services = [];
    private IReadOnlyList<CompanyServiceProposalResponse> CompanyServiceProposals = [];
    private ServiceDraft NewServiceDraft { get; set; } = new();
    private string Search { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = "all";
    private string? Message { get; set; }
    private Guid? EditingPrestationId { get; set; }
    private Guid? EditingServiceId { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }

    private IReadOnlyList<ServiceSummaryResponse> FilteredServices
    {
        get
        {
            var query = Services.AsEnumerable();

            query = StatusFilter switch
            {
                "active" => query.Where(service => service.IsActive),
                "inactive" => query.Where(service => !service.IsActive),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(Search))
            {
                var search = Search.Trim();
                query = query.Where(service =>
                    service.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || service.Prestations.Any(prestation => prestation.Name.Contains(search, StringComparison.OrdinalIgnoreCase)));
            }

            return query.ToList();
        }
    }

    protected override Task OnInitializedAsync()
    {
        return LoadServicesAsync();
    }

    private async Task LoadServicesAsync()
    {
        IsLoading = true;
        Message = null;

        try
        {
            Services = await ApiClient.GetServicesAsync();
            CompanyServiceProposals = (await ApiClient.GetCompanyServiceProposalsAsync())?.Items ?? [];
        }
        catch (PlatformApiException exception)
        {
            Message = $"Impossible de charger le catalogue. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private ProposalDraft GetProposalDraft(CompanyServiceProposalResponse proposal)
    {
        if (!ProposalDrafts.TryGetValue(proposal.Id, out var draft))
        {
            draft = new ProposalDraft
            {
                Selection = proposal.MatchedServicePrestationId.HasValue
                    ? BuildPrestationSelection(proposal.MatchedServiceId!.Value, proposal.MatchedServicePrestationId.Value)
                    : proposal.MatchedServiceId.HasValue
                        ? BuildServiceSelection(proposal.MatchedServiceId.Value)
                        : string.Empty
            };
            ProposalDrafts[proposal.Id] = draft;
        }

        return draft;
    }

    private void ApplySuggestion(Guid proposalId, CompanyServiceProposalSuggestionResponse suggestion)
    {
        var draft = ProposalDrafts.TryGetValue(proposalId, out var existing) ? existing : new ProposalDraft();
        draft.Selection = suggestion.ServicePrestationId.HasValue
            ? BuildPrestationSelection(suggestion.ServiceId, suggestion.ServicePrestationId.Value)
            : BuildServiceSelection(suggestion.ServiceId);
        draft.CreateUnderServiceId = suggestion.ServiceId.ToString();
        ProposalDrafts[proposalId] = draft;
    }

    private async Task AttachProposalAsync(Guid proposalId)
    {
        var draft = GetProposalDraft(CompanyServiceProposals.First(proposal => proposal.Id == proposalId));
        var selection = ParseSelection(draft.Selection);
        if (selection.ServiceId is null && selection.ServicePrestationId is null)
        {
            Message = "Selectionnez un rattachement avant de valider.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.AttachCompanyServiceProposalAsync(
                proposalId,
                new AttachCompanyServiceProposalRequest(selection.ServiceId, selection.ServicePrestationId));
            Message = "Libelle rattache au catalogue.";
        });
    }

    private async Task CreatePrestationFromProposalAsync(CompanyServiceProposalResponse proposal)
    {
        var draft = GetProposalDraft(proposal);
        if (!Guid.TryParse(draft.CreateUnderServiceId, out var serviceId))
        {
            Message = "Selectionnez le service parent avant de creer la prestation.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.CreatePrestationFromCompanyServiceProposalAsync(
                proposal.Id,
                new CreatePrestationFromCompanyServiceProposalRequest(serviceId, proposal.RawName));
            Message = "Prestation creee et libelle rattache.";
        });
    }

    private static string BuildServiceSelection(Guid serviceId)
    {
        return $"service:{serviceId}";
    }

    private static string BuildPrestationSelection(Guid serviceId, Guid prestationId)
    {
        return $"prestation:{serviceId}:{prestationId}";
    }

    private static ProposalSelection ParseSelection(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new ProposalSelection(null, null);
        }

        var parts = value.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2 && parts[0] == "service" && Guid.TryParse(parts[1], out var serviceId))
        {
            return new ProposalSelection(serviceId, null);
        }

        if (parts.Length == 3
            && parts[0] == "prestation"
            && Guid.TryParse(parts[1], out var parentServiceId)
            && Guid.TryParse(parts[2], out var prestationId))
        {
            return new ProposalSelection(parentServiceId, prestationId);
        }

        return new ProposalSelection(null, null);
    }

    private static string FormatSuggestion(CompanyServiceProposalSuggestionResponse suggestion)
    {
        return suggestion.ServicePrestationId.HasValue
            ? $"{suggestion.ServiceName} - {suggestion.ServicePrestationName}"
            : suggestion.ServiceName;
    }

    private PrestationDraft GetDraft(Guid serviceId)
    {
        if (!Drafts.TryGetValue(serviceId, out var draft))
        {
            draft = new PrestationDraft();
            Drafts[serviceId] = draft;
        }

        return draft;
    }

    private ServiceDraft GetServiceEditDraft(ServiceSummaryResponse service)
    {
        if (!ServiceEditDrafts.TryGetValue(service.Id, out var draft))
        {
            draft = ToServiceDraft(service);
            ServiceEditDrafts[service.Id] = draft;
        }

        return draft;
    }

    private static ServiceDraft ToServiceDraft(ServiceSummaryResponse service)
    {
        return new ServiceDraft
        {
            Name = service.Name,
            Description = service.Description ?? string.Empty,
            IconName = service.IconName,
            NormalPriceAmount = service.PriceMinAmount ?? service.NormalPriceAmount,
            PremiumPriceAmount = service.PriceMaxAmount ?? service.PremiumPriceAmount,
            Currency = service.Currency
        };
    }

    private void StartServiceEdit(ServiceSummaryResponse service)
    {
        EditingServiceId = service.Id;
        ServiceEditDrafts[service.Id] = ToServiceDraft(service);
    }

    private void CancelServiceEdit()
    {
        EditingServiceId = null;
    }

    private PrestationDraft GetEditDraft(ServicePrestationSummaryResponse prestation)
    {
        if (!EditDrafts.TryGetValue(prestation.Id, out var draft))
        {
            draft = new PrestationDraft
            {
                Name = prestation.Name,
                Description = prestation.Description ?? string.Empty,
                SortOrder = prestation.SortOrder,
                NormalPriceAmount = prestation.PriceMinAmount ?? prestation.NormalPriceAmount,
                PremiumPriceAmount = prestation.PriceMaxAmount ?? prestation.PremiumPriceAmount,
                Currency = prestation.Currency
            };
            EditDrafts[prestation.Id] = draft;
        }

        return draft;
    }

    private void StartEdit(ServicePrestationSummaryResponse prestation)
    {
        EditingPrestationId = prestation.Id;
        EditDrafts[prestation.Id] = new PrestationDraft
        {
            Name = prestation.Name,
            Description = prestation.Description ?? string.Empty,
            SortOrder = prestation.SortOrder,
            NormalPriceAmount = prestation.PriceMinAmount ?? prestation.NormalPriceAmount,
            PremiumPriceAmount = prestation.PriceMaxAmount ?? prestation.PremiumPriceAmount,
            Currency = prestation.Currency
        };
    }

    private void CancelEdit()
    {
        EditingPrestationId = null;
    }

    private async Task SaveNewPrestationAsync(Guid serviceId)
    {
        var draft = GetDraft(serviceId);
        if (string.IsNullOrWhiteSpace(draft.Name))
        {
            Message = "Renseignez le nom de la prestation avant d'ajouter.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.CreateServicePrestationAsync(
                serviceId,
                new UpsertServicePrestationRequest(
                    draft.Name,
                    draft.Description,
                    draft.SortOrder,
                    draft.NormalPriceAmount,
                    draft.PremiumPriceAmount,
                    draft.Currency));
            Drafts[serviceId] = new PrestationDraft();
            Message = "Prestation ajoutee au catalogue.";
        });
    }

    private async Task CreateServiceAsync()
    {
        if (string.IsNullOrWhiteSpace(NewServiceDraft.Name))
        {
            Message = "Renseignez le nom du service avant d'ajouter.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.CreateServiceAsync(ToUpsertServiceRequest(NewServiceDraft));
            NewServiceDraft = new ServiceDraft();
            Message = "Service ajoute au catalogue.";
        });
    }

    private async Task UpdateServiceAsync(Guid serviceId)
    {
        var draft = ServiceEditDrafts[serviceId];
        if (string.IsNullOrWhiteSpace(draft.Name))
        {
            Message = "Le nom du service est obligatoire.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.UpdateServiceAsync(serviceId, ToUpsertServiceRequest(draft));
            EditingServiceId = null;
            Message = "Service modifie.";
        });
    }

    private Task ActivateServiceAsync(Guid serviceId)
    {
        return RunMutationAsync(async () =>
        {
            await ApiClient.ActivateServiceAsync(serviceId);
            Message = "Service reactive.";
        });
    }

    private Task DeactivateServiceAsync(Guid serviceId)
    {
        return RunMutationAsync(async () =>
        {
            await ApiClient.DeactivateServiceAsync(serviceId);
            Message = "Service desactive.";
        });
    }

    private static UpsertServiceRequest ToUpsertServiceRequest(ServiceDraft draft)
    {
        return new UpsertServiceRequest(
            draft.Name,
            draft.Description,
            draft.IconName,
            draft.NormalPriceAmount,
            draft.PremiumPriceAmount,
            draft.Currency,
            draft.NormalPriceAmount,
            draft.PremiumPriceAmount);
    }

    private async Task UpdatePrestationAsync(Guid prestationId)
    {
        var draft = EditDrafts[prestationId];
        if (string.IsNullOrWhiteSpace(draft.Name))
        {
            Message = "Le nom de la prestation est obligatoire.";
            return;
        }

        await RunMutationAsync(async () =>
        {
            await ApiClient.UpdateServicePrestationAsync(
                prestationId,
                new UpsertServicePrestationRequest(
                    draft.Name,
                    draft.Description,
                    draft.SortOrder,
                    draft.NormalPriceAmount,
                    draft.PremiumPriceAmount,
                    draft.Currency,
                    draft.NormalPriceAmount,
                    draft.PremiumPriceAmount));
            EditingPrestationId = null;
            Message = "Prestation modifiee.";
        });
    }

    private Task ActivatePrestationAsync(Guid prestationId)
    {
        return RunMutationAsync(async () =>
        {
            await ApiClient.ActivateServicePrestationAsync(prestationId);
            Message = "Prestation reactivee.";
        });
    }

    private Task DeactivatePrestationAsync(Guid prestationId)
    {
        return RunMutationAsync(async () =>
        {
            await ApiClient.DeactivateServicePrestationAsync(prestationId);
            Message = "Prestation desactivee.";
        });
    }

    private async Task RunMutationAsync(Func<Task> action)
    {
        IsSaving = true;

        try
        {
            await action();
            await LoadServicesAsync();
        }
        catch (PlatformApiException exception)
        {
            Message = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private static string FormatPriceRange(int priceMinAmount, int priceMaxAmount, string currency)
    {
        var max = Math.Max(priceMinAmount, priceMaxAmount);
        return priceMinAmount == max
            ? $"{priceMinAmount:N0} {currency}"
            : $"{priceMinAmount:N0} - {max:N0} {currency}";
    }


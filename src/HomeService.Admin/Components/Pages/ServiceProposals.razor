    }

    private static ProposalSelection ParseSelection(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new ProposalSelection(null, null);
        }

        var parts = value.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2 && parts[0] == "service" && Guid.TryParse(parts[1], out var serviceId))
        {
            return new ProposalSelection(serviceId, null);
        }

        if (parts.Length == 3
            && parts[0] == "prestation"
            && Guid.TryParse(parts[1], out var parentServiceId)
            && Guid.TryParse(parts[2], out var prestationId))
        {
            return new ProposalSelection(parentServiceId, prestationId);
        }

        return new ProposalSelection(null, null);
    }


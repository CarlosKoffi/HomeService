    private async Task RunMutationAsync(Func<Task> action)
    {
        IsSaving = true;

        try
        {
            await action();
            await LoadServicesAsync();
        }
        catch (PlatformApiException exception)
        {
            Message = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private static string FormatPriceRange(int priceMinAmount, int priceMaxAmount, string currency)
    {
        var max = Math.Max(priceMinAmount, priceMaxAmount);
        return priceMinAmount == max
            ? $"{priceMinAmount:N0} {currency}"
            : $"{priceMinAmount:N0} - {max:N0} {currency}";
    }

    private string GetTabClass(ServiceAdminTab tab)
    {
        return ActiveTab == tab ? "active" : string.Empty;
    }

    private int CountPendingProposalsFor(Guid serviceId)
    {
        var service = Services.FirstOrDefault(item => item.Id == serviceId);
        return service is null ? 0 : CountPendingProposalsFor(service);
    }

    private int CountPendingProposalsFor(ServiceSummaryResponse service)
    {
        var normalizedServiceName = NormalizeCatalogName(service.Name);
        return CompanyServiceProposals.Count(proposal =>
            NormalizeCatalogName(proposal.RawName).Contains(normalizedServiceName, StringComparison.OrdinalIgnoreCase)
            || service.Prestations.Any(prestation => NormalizeCatalogName(proposal.RawName).Contains(NormalizeCatalogName(prestation.Name), StringComparison.OrdinalIgnoreCase)));
    }

    private static string NormalizeCatalogName(string value)
    {
        return CatalogNameNormalizer.Normalize(value);
    }

    private static string FormatAmount(int amount, string currency)
    {
        return $"{amount:N0} {currency}";
    }

    private static string FormatPrestationInsights(IReadOnlyList<ServicePrestationCatalogInsightResponse> prestations)
    {
        var top = prestations
            .OrderByDescending(prestation => prestation.MissionCount)
            .ThenByDescending(prestation => prestation.ActiveProviderCount)
            .Take(3)
            .Select(prestation => $"{prestation.ServicePrestationName}: {prestation.ActiveProviderCount} presta, {prestation.MissionCount} mission(s)");

        return string.Join(" | ", top);
    }


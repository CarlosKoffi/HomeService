@page "/cms"
@using System.Text.Json
@using System.Text.Json.Nodes
@using HomeService.Admin.Services
@using HomeService.Contracts.Cms
@using Microsoft.AspNetCore.Components.Forms
@inject PlatformApiClient ApiClient

<PageTitle>CMS</PageTitle>

<section class="cms-header">
    <div>
        <p class="eyebrow">Contenu & sites</p>
        <h1>CMS wélé</h1>
        <p class="lead">
            Pilotez les surfaces publiques et les contenus administrables sans toucher au code.
        </p>
    </div>
    <div class="cms-health">
        <strong>@Sites.Count</strong>
        <span>sites configures</span>
    </div>
</section>

@if (IsLoading)
{
    <section class="info-panel">
        <div>
            <h2>Chargement du CMS</h2>
            <p>Recuperation des sites, pages, menus et composants disponibles.</p>
        </div>
    </section>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <section class="info-panel status-rejected">
        <div>
            <h2>CMS indisponible</h2>
            <p>@ErrorMessage</p>
        </div>
    </section>
}
else
{
    <section class="cms-overview">
        <article>
            <span>Pages</span>
            <strong>@Sites.Sum(site => site.PageCount)</strong>
            <small>toutes surfaces</small>
        </article>
        <article>
            <span>Menus</span>
            <strong>@Sites.Sum(site => site.MenuCount)</strong>
            <small>navigation par site</small>
        </article>
        <article>
            <span>Composants</span>
            <strong>@Components.Count</strong>
            <small>contrats frontend</small>
        </article>
    </section>

    <section class="cms-workspace">
        <aside class="cms-sites-panel">
            <div class="section-heading">
                <div>
                    <h2>Sites</h2>
                    <p class="section-help">Choisissez une surface pour consulter ses pages et menus.</p>
                </div>
            </div>

            @if (Sites.Count == 0)
            {
                <article class="cms-empty">
                    <strong>Aucun site CMS</strong>
                    <p>Le socle est pret. Il reste a creer les premieres surfaces dans l'administration.</p>
                </article>
            }
            else
            {
                <div class="cms-site-list">
                    @foreach (var site in Sites)
                    {
                        <button type="button"
                                class="@(SelectedSite?.Id == site.Id ? "active" : null)"
                                @onclick="() => SelectSiteAsync(site.Id)">
                            <span>@site.Surface</span>
                            <strong>@site.Name</strong>
                            <small>@site.PageCount page(s) - @site.DefaultLanguageCode</small>
                        </button>
                    }
                </div>
            }
        </aside>

        <section class="cms-detail-panel">
            @if (SelectedSite is null)
            {
                <article class="cms-empty">
                    <strong>Selectionnez un site</strong>
                    <p>Vous verrez ici ses pages, menus et informations de publication.</p>
                </article>
            }
            else
            {
                <div class="cms-detail-heading">
                    <div>
                        <p class="eyebrow">@SelectedSite.Surface</p>
                        <h2>@SelectedSite.Name</h2>
                        <p>@SelectedSite.Code - @SelectedSite.Status - langue @SelectedSite.DefaultLanguageCode</p>
                    </div>
                    <span class="@GetStatusClass(SelectedSite.Status)">@SelectedSite.Status</span>
                </div>

                <div class="cms-detail-grid">
                    <article>
                        <span>Page accueil</span>
                        <strong>@(SelectedSite.HomePageCode ?? "Non definie")</strong>
                    </article>
                    <article>
                        <span>Pages</span>
                        <strong>@SelectedSite.Pages.Count</strong>
                    </article>
                    <article>
                        <span>Menus</span>
                        <strong>@SelectedSite.Menus.Count</strong>
                    </article>
                </div>

                <div class="cms-table-section">
                    <h3>Pages</h3>
                    @if (SelectedSite.Pages.Count == 0)
                    {
                        <p class="section-help">Aucune page n'est encore creee pour ce site.</p>
                    }
                    else
                    {
                        <div class="cms-table">
                            <div class="cms-table-head">
                                <span>Page</span>
                                <span>Route</span>
                                <span>Versions</span>
                                <span>Sections</span>
                                <span>Statut</span>
                                <span>Action</span>
                            </div>
                            @foreach (var cmsPage in SelectedSite.Pages)
                            {
                                <div>
                                    <strong>@cmsPage.InternalName</strong>
                                    <span>@(cmsPage.DefaultSlug ?? cmsPage.Code)</span>
                                    <span>@cmsPage.VersionCount</span>
                                    <span>@cmsPage.SectionCount</span>
                                    <span class="@GetStatusClass(cmsPage.Status)">@cmsPage.Status</span>
                                    <button type="button" class="cms-inline-action" @onclick="() => SelectPageAsync(cmsPage.Id)">Editer</button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="cms-table-section">
                    <h3>Menus</h3>
                    @if (SelectedSite.Menus.Count == 0)
                    {
                        <p class="section-help">Aucun menu configure pour ce site.</p>
                    }
                    else
                    {
                        <div class="cms-table cms-menu-table">
                            <div class="cms-table-head">
                                <span>Menu</span>
                                <span>Emplacement</span>
                                <span>Elements</span>
                                <span>Statut</span>
                            </div>
                            @foreach (var menu in SelectedSite.Menus)
                            {
                                <div>
                                    <strong>@menu.Name</strong>
                                    <span>@menu.Placement</span>
                                    <span>@menu.ItemCount</span>
                                    <span>@(menu.IsActive ? "Actif" : "Masque")</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (SelectedPage is not null)
                {
                    <div class="cms-editor">
                        <div class="cms-editor-heading">
                            <div>
                                <p class="eyebrow">Edition contenu</p>
                                <h3>@SelectedPage.DefaultTitle</h3>
                                <p>@SelectedPage.TemplateKey - version @SelectedPage.VersionNumber - @SelectedPage.VersionStatus</p>
                            </div>
                            <span>@SelectedPage.Sections.Count section(s)</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                        {
                            <p class="admin-message">@SuccessMessage</p>
                        }

                        <div class="cms-section-editor-list">
                            @foreach (var section in SelectedPage.Sections)
                            {
                                <article class="cms-section-editor" @key="section.Id">
                                    <header>
                                        <div>
                                            <span>@(section.ComponentKey)</span>
                                            <strong>@(section.InternalName)</strong>
                                            <small>@(section.Zone) - position @(section.Position)</small>
                                        </div>
                                        <em>@(section.IsActive ? "Actif" : "Masque")</em>
                                    </header>

                                    @if (section.ContentValues.Count == 0)
                                    {
                                        <p class="section-help">Aucun champ editable n'est encore configure pour cette section.</p>
                                    }
                                    else
                                    {
                                        <div class="cms-field-list">
                                            @foreach (var value in section.ContentValues)
                                            {
                                                var draft = GetDraft(value);
                                                <div class="cms-field-row" @key="value.Id">
                                                    <div class="cms-field-editor">
                                                        <div class="cms-field-title">
                                                            <div>
                                                                <span>@ToReadableFieldName(value.FieldKey)</span>
                                                                <small>@GetFieldHelp(value)</small>
                                                            </div>
                                                            @if (value.ValueType == "Json")
                                                            {
                                                                <button type="button" class="cms-ghost-action" @onclick="() => ToggleRawJson(draft)">
                                                                    @(draft.ShowRawJson ? "Edition simple" : "Voir JSON")
                                                                </button>
                                                            }
                                                        </div>

                                                        @if (IsMediaField(value))
                                                        {
                                                            <div class="cms-media-editor">
                                                                <div class="cms-media-preview">
                                                                    @if (!string.IsNullOrWhiteSpace(draft.EditableValue))
                                                                    {
                                                                        <img src="@GetMediaPreviewUrl(draft.EditableValue)" alt="Apercu CMS" />
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>Image</span>
                                                                    }
                                                                </div>
                                                                <label>
                                                                    <small>URL ou chemin image</small>
                                                                    <input type="text" @bind="draft.EditableValue" placeholder="images/nom-image.png" />
                                                                </label>
                                                                <label class="cms-upload-control">
                                                                    <small>Uploader une nouvelle image</small>
                                                                    <InputFile OnChange="file => UploadMediaAsync(value, file)" accept="image/png,image/jpeg,image/webp,image/gif" />
                                                                </label>
                                                            </div>
                                                        }
                                                        else if (value.ValueType == "Json" && !draft.ShowRawJson && draft.JsonItems.Count > 0)
                                                        {
                                                            <div class="cms-json-builder">
                                                                @foreach (var item in draft.JsonItems)
                                                                {
                                                                    <article class="cms-json-card" @key="item.Id">
                                                                        <header>
                                                                            <strong>@GetJsonItemTitle(value.FieldKey, item)</strong>
                                                                            <button type="button" class="cms-danger-action" @onclick="() => RemoveJsonItem(draft, item.Id)">Supprimer</button>
                                                                        </header>

                                                                        @if (draft.JsonShape == CmsJsonShape.StringArray)
                                                                        {
                                                                            <input type="text" @bind="item.Value" placeholder="Texte a afficher" />
                                                                        }
                                                                        else if (value.FieldKey == "questions")
                                                                        {
                                                                            <input type="text" @bind="item.Question" placeholder="Question" />
                                                                            <textarea rows="3" @bind="item.Answer" placeholder="Reponse courte"></textarea>
                                                                        }
                                                                        else if (value.FieldKey == "steps")
                                                                        {
                                                                            <div class="cms-json-grid">
                                                                                <input type="text" @bind="item.Number" placeholder="01" />
                                                                                <input type="text" @bind="item.Label" placeholder="Libelle" />
                                                                            </div>
                                                                            <input type="text" @bind="item.Title" placeholder="Titre" />
                                                                            <textarea rows="3" @bind="item.Text" placeholder="Texte court"></textarea>
                                                                            <input type="text" @bind="item.Image" placeholder="images/..." />
                                                                        }
                                                                        else if (value.FieldKey == "stats")
                                                                        {
                                                                            <div class="cms-json-grid">
                                                                                <input type="text" @bind="item.Label" placeholder="Libelle" />
                                                                                <input type="text" @bind="item.Value" placeholder="Valeur" />
                                                                            </div>
                                                                            <input type="text" @bind="item.Help" placeholder="Aide courte" />
                                                                        }
                                                                        else if (value.FieldKey == "columns")
                                                                        {
                                                                            <input type="text" @bind="item.Title" placeholder="Titre colonne" />
                                                                            <textarea rows="4" @bind="item.LinksText" placeholder="Un lien par ligne"></textarea>
                                                                        }
                                                                        else
                                                                        {
                                                                            <textarea rows="4" @bind="item.RawJson"></textarea>
                                                                        }
                                                                    </article>
                                                                }

                                                                <button type="button" class="cms-add-action" @onclick="() => AddJsonItem(draft, value.FieldKey)">
                                                                    Ajouter une ligne
                                                                </button>
                                                            </div>
                                                        }
                                                        else if (IsLongValue(value))
                                                        {
                                                            <textarea rows="5" @bind="draft.EditableValue"></textarea>
                                                        }
                                                        else
                                                        {
                                                            <input type="text" @bind="draft.EditableValue" />
                                                        }
                                                    </div>
                                                    <button type="button" @onclick="() => SaveContentValueAsync(value)" disabled="@IsSaving">
                                                        Enregistrer
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    </div>
                }
            }
        </section>
    </section>

    <section class="cms-components">
        <div class="section-heading">
            <div>
                <h2>Composants disponibles</h2>
                <p class="section-help">Contrats stables qui permettront de mapper les futurs Figma sans bricoler les pages.</p>
            </div>
        </div>

        <div class="cms-component-grid">
            @foreach (var component in Components)
            {
                <article>
                    <span>v@component.SchemaVersion</span>
                    <strong>@component.Name</strong>
                    <small>@component.Key</small>
                    @if (!string.IsNullOrWhiteSpace(component.Description))
                    {
                        <p>@component.Description</p>
                    }
                </article>
            }
        </div>
    </section>
}

@code {
    private List<CmsSiteSummaryResponse> Sites { get; set; } = [];
    private List<CmsComponentDefinitionResponse> Components { get; set; } = [];
    private CmsSiteDetailResponse? SelectedSite { get; set; }
    private CmsPageDetailResponse? SelectedPage { get; set; }
    private Dictionary<Guid, CmsValueDraft> ContentDrafts { get; set; } = [];
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Sites = (await ApiClient.GetCmsSitesAsync()).ToList();
            Components = (await ApiClient.GetCmsComponentDefinitionsAsync()).ToList();

            var firstSite = Sites.FirstOrDefault();
            if (firstSite is not null)
            {
                SelectedSite = await ApiClient.GetCmsSiteAsync(firstSite.Id);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger le CMS. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SelectSiteAsync(Guid siteId)
    {
        try
        {
            SelectedSite = await ApiClient.GetCmsSiteAsync(siteId);
            SelectedPage = null;
            ContentDrafts = [];
            SuccessMessage = null;
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger le site CMS. Detail: {exception.Message}";
        }
    }

    private async Task SelectPageAsync(Guid pageId)
    {
        try
        {
            SelectedPage = await ApiClient.GetCmsPageAsync(pageId);
            ContentDrafts = [];
            SuccessMessage = null;
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger la page CMS. Detail: {exception.Message}";
        }
    }

    private CmsValueDraft GetDraft(CmsContentValueResponse value)
    {
        if (!ContentDrafts.TryGetValue(value.Id, out var draft))
        {
            draft = new CmsValueDraft
            {
                EditableValue = value.ValueType == "Json" ? value.JsonValue ?? string.Empty : value.TextValue ?? string.Empty
            };

            if (value.ValueType == "Json")
            {
                HydrateJsonDraft(draft, draft.EditableValue);
            }

            ContentDrafts[value.Id] = draft;
        }

        return draft;
    }

    private async Task SaveContentValueAsync(CmsContentValueResponse value)
    {
        var draft = GetDraft(value);
        IsSaving = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var request = value.ValueType == "Json"
                ? new UpdateCmsContentValueRequest(value.TextValue, BuildJsonValue(draft))
                : new UpdateCmsContentValueRequest(draft.EditableValue, value.JsonValue);

            await ApiClient.UpdateCmsContentValueAsync(value.Id, request);
            SuccessMessage = $"Champ '{ToReadableFieldName(value.FieldKey)}' sauvegarde.";

            if (SelectedPage is not null)
            {
                SelectedPage = await ApiClient.GetCmsPageAsync(SelectedPage.Id);
                ContentDrafts = [];
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de sauvegarder le champ CMS. Detail: {exception.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task UploadMediaAsync(CmsContentValueResponse value, InputFileChangeEventArgs fileChange)
    {
        var file = fileChange.File;
        if (file is null)
        {
            return;
        }

        IsSaving = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var response = await ApiClient.UploadCmsMediaAsync(value.Id, file);
            if (response is not null)
            {
                var draft = GetDraft(value);
                draft.EditableValue = response.Url;
                SuccessMessage = $"Image '{response.FileName}' uploadée.";
            }

            if (SelectedPage is not null)
            {
                SelectedPage = await ApiClient.GetCmsPageAsync(SelectedPage.Id);
                ContentDrafts = [];
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible d'uploader l'image CMS. Detail: {exception.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private static bool IsLongValue(CmsContentValueResponse value)
    {
        return value.ValueType is "LongText" or "RichText" or "Json"
            || (value.TextValue?.Length ?? value.JsonValue?.Length ?? 0) > 120;
    }

    private static string ToReadableFieldName(string fieldKey)
    {
        return fieldKey
            .Replace(".", " / ", StringComparison.Ordinal)
            .Replace("_", " ", StringComparison.Ordinal)
            .Replace("-", " ", StringComparison.Ordinal);
    }

    private static string GetFieldHelp(CmsContentValueResponse value)
    {
        if (IsMediaField(value))
        {
            return "Image affichable sur le site";
        }

        return value.ValueType == "Json"
            ? "Liste editable"
            : value.ValueType;
    }

    private static bool IsMediaField(CmsContentValueResponse value)
    {
        return value.ValueType == "Media"
            || value.FieldKey.EndsWith(".url", StringComparison.OrdinalIgnoreCase)
            || value.FieldKey.Contains("image", StringComparison.OrdinalIgnoreCase);
    }

    private string GetMediaPreviewUrl(string value)
    {
        return ApiClient.ToCmsMediaPreviewUrl(value, SelectedSite?.Surface);
    }

    private static void ToggleRawJson(CmsValueDraft draft)
    {
        draft.ShowRawJson = !draft.ShowRawJson;
        if (draft.ShowRawJson)
        {
            draft.EditableValue = BuildJsonValue(draft);
        }
        else
        {
            HydrateJsonDraft(draft, draft.EditableValue);
        }
    }

    private static void AddJsonItem(CmsValueDraft draft, string fieldKey)
    {
        var item = new CmsJsonItemDraft();
        if (draft.JsonShape == CmsJsonShape.StringArray)
        {
            item.Value = "Nouvel element";
        }
        else if (fieldKey == "questions")
        {
            item.Question = "Nouvelle question";
            item.Answer = "Reponse courte.";
        }
        else if (fieldKey == "steps")
        {
            item.Number = (draft.JsonItems.Count + 1).ToString("00");
            item.Label = "Etape";
            item.Title = "Nouveau titre";
            item.Text = "Texte court.";
        }
        else if (fieldKey == "stats")
        {
            item.Label = "Indicateur";
            item.Value = "0";
            item.Help = "Aide courte";
        }
        else if (fieldKey == "columns")
        {
            item.Title = "Colonne";
            item.LinksText = "Lien 1";
        }
        else
        {
            item.RawJson = "{}";
        }

        draft.JsonItems.Add(item);
    }

    private static void RemoveJsonItem(CmsValueDraft draft, Guid itemId)
    {
        var item = draft.JsonItems.FirstOrDefault(candidate => candidate.Id == itemId);
        if (item is not null)
        {
            draft.JsonItems.Remove(item);
        }
    }

    private static string GetJsonItemTitle(string fieldKey, CmsJsonItemDraft item)
    {
        return fieldKey switch
        {
            "questions" => string.IsNullOrWhiteSpace(item.Question) ? "Question" : item.Question,
            "steps" => string.IsNullOrWhiteSpace(item.Title) ? $"Etape {item.Number}" : item.Title,
            "stats" => string.IsNullOrWhiteSpace(item.Label) ? "Indicateur" : item.Label,
            "columns" => string.IsNullOrWhiteSpace(item.Title) ? "Colonne footer" : item.Title,
            _ => string.IsNullOrWhiteSpace(item.Value) ? "Element" : item.Value
        };
    }

    private static string BuildJsonValue(CmsValueDraft draft)
    {
        if (draft.ShowRawJson || draft.JsonItems.Count == 0)
        {
            return draft.EditableValue;
        }

        JsonArray array = [];
        foreach (var item in draft.JsonItems)
        {
            if (draft.JsonShape == CmsJsonShape.StringArray)
            {
                array.Add(item.Value);
                continue;
            }

            if (!string.IsNullOrWhiteSpace(item.RawJson))
            {
                var parsed = JsonNode.Parse(item.RawJson);
                if (parsed is not null)
                {
                    array.Add(parsed);
                    continue;
                }
            }

            var node = new JsonObject();
            AddJsonProperty(node, "number", item.Number);
            AddJsonProperty(node, "label", item.Label);
            AddJsonProperty(node, "title", item.Title);
            AddJsonProperty(node, "text", item.Text);
            AddJsonProperty(node, "image", item.Image);
            AddJsonProperty(node, "question", item.Question);
            AddJsonProperty(node, "answer", item.Answer);
            AddJsonProperty(node, "value", item.Value);
            AddJsonProperty(node, "help", item.Help);

            if (!string.IsNullOrWhiteSpace(item.LinksText))
            {
                node["links"] = new JsonArray(item.LinksText
                    .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Select(link => JsonValue.Create(link))
                    .ToArray<JsonNode?>());
            }

            array.Add(node);
        }

        return array.ToJsonString(new JsonSerializerOptions { WriteIndented = true });
    }

    private static void AddJsonProperty(JsonObject node, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            node[key] = value;
        }
    }

    private static void HydrateJsonDraft(CmsValueDraft draft, string json)
    {
        draft.JsonItems = [];
        draft.JsonShape = CmsJsonShape.Raw;

        try
        {
            var root = JsonNode.Parse(json);
            if (root is not JsonArray array)
            {
                return;
            }

            if (array.All(item => item is JsonValue))
            {
                draft.JsonShape = CmsJsonShape.StringArray;
                draft.JsonItems = array
                    .Select(item => new CmsJsonItemDraft { Value = item?.GetValue<string>() ?? string.Empty })
                    .ToList();
                return;
            }

            draft.JsonShape = CmsJsonShape.ObjectArray;
            foreach (var item in array)
            {
                if (item is not JsonObject obj)
                {
                    continue;
                }

                draft.JsonItems.Add(new CmsJsonItemDraft
                {
                    Number = GetJsonString(obj, "number"),
                    Label = GetJsonString(obj, "label"),
                    Title = GetJsonString(obj, "title"),
                    Text = GetJsonString(obj, "text"),
                    Image = GetJsonString(obj, "image"),
                    Question = GetJsonString(obj, "question"),
                    Answer = GetJsonString(obj, "answer"),
                    Value = GetJsonString(obj, "value"),
                    Help = GetJsonString(obj, "help"),
                    LinksText = obj["links"] is JsonArray links
                        ? string.Join(Environment.NewLine, links.Select(link => link?.GetValue<string>()).Where(link => !string.IsNullOrWhiteSpace(link)))
                        : string.Empty
                });
            }
        }
        catch (JsonException)
        {
            draft.ShowRawJson = true;
        }
    }

    private static string GetJsonString(JsonObject obj, string key)
    {
        return obj.TryGetPropertyValue(key, out var value) && value is not null
            ? value.GetValue<string>()
            : string.Empty;
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Active" or "Published" => "cms-status cms-status-ok",
            "Draft" or "InReview" => "cms-status cms-status-pending",
            "Disabled" or "Archived" => "cms-status cms-status-muted",
            _ => "cms-status"
        };
    }

    private sealed class CmsValueDraft
    {
        public string EditableValue { get; set; } = string.Empty;
        public bool ShowRawJson { get; set; }
        public CmsJsonShape JsonShape { get; set; } = CmsJsonShape.Raw;
        public List<CmsJsonItemDraft> JsonItems { get; set; } = [];
    }

    private sealed class CmsJsonItemDraft
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Number { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public string Image { get; set; } = string.Empty;
        public string Question { get; set; } = string.Empty;
        public string Answer { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public string Help { get; set; } = string.Empty;
        public string LinksText { get; set; } = string.Empty;
        public string RawJson { get; set; } = string.Empty;
    }

    private enum CmsJsonShape
    {
        Raw,
        StringArray,
        ObjectArray
    }
}

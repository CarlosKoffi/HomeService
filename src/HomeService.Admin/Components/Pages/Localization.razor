@page "/localization"
@using HomeService.Admin.Services
@using HomeService.Contracts.Localization
@inject PlatformApiClient ApiClient

<PageTitle>Traductions</PageTitle>

<h1>Traductions</h1>
<p class="lead">
    Centralisez les textes affiches dans les portails et l'admin. On garde une base simple: une cle,
    un scope, une langue et le texte editable.
</p>

<section class="info-panel">
    <div>
        <h2>Objectif</h2>
        <p>
            Aucun texte important ne doit rester bloque dans le code. Les textes du site entreprise,
            du portail connecte et du back-office doivent pouvoir etre ajustes depuis l'admin.
        </p>
    </div>
    <div class="check-list">
        <span>Textes modifiables</span>
        <span>Scopes par portail</span>
        <span>Francais au lancement</span>
        <span>Audit des modifications</span>
    </div>
</section>

<section class="toolbar">
    <label>
        Scope
        <select @bind="SelectedScope">
            <option value="">Tous les scopes</option>
            @foreach (var scope in Scopes)
            {
                <option value="@scope">@scope</option>
            }
        </select>
    </label>
    <label>
        Langue
        <select @bind="SelectedLanguage">
            @foreach (var language in Languages)
            {
                <option value="@language">@language</option>
            }
        </select>
    </label>
    <label>
        Recherche
        <input type="search" @bind="SearchTerm" @bind:event="oninput" placeholder="Cle, scope, texte" />
    </label>
    <button type="button" @onclick="LoadTranslationsAsync" disabled="@IsLoading">Filtrer</button>
</section>

<section class="translation-create-panel">
    <div class="section-heading">
        <div>
            <h2>Ajouter une cle</h2>
            <p class="section-help">Creez une nouvelle entree traduisible, avec son contexte pour eviter les textes hors sujet.</p>
        </div>
    </div>
    <div class="translation-create-grid">
        <label>
            Cle
            <input type="text" @bind="NewKey" placeholder="company.home.hero.title" />
        </label>
        <label>
            Scope
            <input type="text" @bind="NewScope" placeholder="Company" />
        </label>
        <label>
            Description
            <input type="text" @bind="NewDescription" placeholder="Titre principal de la page entreprise" />
        </label>
        <label class="wide-field">
            Texte
            <textarea rows="3" @bind="NewValue"></textarea>
        </label>
        <button type="button" @onclick="CreateTranslationAsync" disabled="@IsSaving">Ajouter</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p class="admin-message">@Message</p>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p class="admin-message error-message">@ErrorMessage</p>
}

<section class="translation-list">
    <div class="section-heading">
        <div>
            <h2>Textes editables</h2>
            <p class="section-help">@Items.Count texte(s) charge(s). Sauvegarde ligne par ligne pour eviter les erreurs de masse.</p>
        </div>
        <button type="button" @onclick="LoadTranslationsAsync" disabled="@IsLoading">Actualiser</button>
    </div>

    @if (IsLoading)
    {
        <article>
            <div>
                <strong>Chargement...</strong>
                <p>Lecture des textes depuis la base.</p>
            </div>
        </article>
    }
    else if (Items.Count == 0)
    {
        <article>
            <div>
                <strong>Aucun texte</strong>
                <p>Aucune traduction ne correspond aux filtres actuels.</p>
            </div>
        </article>
    }
    else
    {
        @foreach (var item in Items)
        {
            <article>
                <div>
                    <strong>@item.Key</strong>
                    <p>@item.Scope - @item.Description</p>
                </div>
                <textarea rows="2" @bind="item.Value"></textarea>
                <button type="button" @onclick="() => SaveTranslationAsync(item)" disabled="@IsSaving">Sauver</button>
            </article>
        }
    }
</section>

@code {
    private List<TranslationDraft> Items { get; set; } = [];
    private List<string> Scopes { get; set; } = [];
    private List<string> Languages { get; set; } = ["fr"];
    private string? SelectedScope { get; set; }
    private string SelectedLanguage { get; set; } = "fr";
    private string? SearchTerm { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private string? Message { get; set; }
    private string? ErrorMessage { get; set; }
    private string? NewKey { get; set; }
    private string? NewScope { get; set; } = "Company";
    private string? NewDescription { get; set; }
    private string? NewValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadTranslationsAsync();
    }

    private async Task LoadTranslationsAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var response = await ApiClient.GetAdminTranslationsAsync(SelectedScope, SearchTerm, SelectedLanguage);
            ApplyResponse(response);
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger les traductions. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CreateTranslationAsync()
    {
        await SaveAsync(new UpsertAdminTranslationRequest(
            NewKey ?? string.Empty,
            NewScope ?? string.Empty,
            NewDescription ?? string.Empty,
            SelectedLanguage,
            NewValue ?? string.Empty));

        NewKey = null;
        NewDescription = null;
        NewValue = null;
    }

    private async Task SaveTranslationAsync(TranslationDraft item)
    {
        await SaveAsync(new UpsertAdminTranslationRequest(
            item.Key,
            item.Scope,
            item.Description,
            item.Language,
            item.Value));
    }

    private async Task SaveAsync(UpsertAdminTranslationRequest request)
    {
        IsSaving = true;
        ErrorMessage = null;
        Message = null;

        try
        {
            var response = await ApiClient.UpsertAdminTranslationAsync(request);
            ApplyResponse(response);
            Message = "Traduction sauvegardee.";
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Sauvegarde impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ApplyResponse(AdminTranslationListResponse? response)
    {
        Items = response?.Items
            .Select(item => new TranslationDraft(
                item.KeyId,
                item.ValueId,
                item.Key,
                item.Scope,
                item.Description,
                item.Language,
                item.Value,
                item.IsActive))
            .ToList() ?? [];

        Scopes = response?.Scopes.ToList() ?? [];
        Languages = response?.Languages.Count > 0 ? response.Languages.ToList() : ["fr"];
        if (!Languages.Contains(SelectedLanguage, StringComparer.OrdinalIgnoreCase))
        {
            SelectedLanguage = Languages[0];
        }
    }

    private sealed class TranslationDraft(
        Guid keyId,
        Guid? valueId,
        string key,
        string scope,
        string description,
        string language,
        string value,
        bool isActive)
    {
        public Guid KeyId { get; } = keyId;
        public Guid? ValueId { get; } = valueId;
        public string Key { get; } = key;
        public string Scope { get; } = scope;
        public string Description { get; } = description;
        public string Language { get; } = language;
        public string Value { get; set; } = value;
        public bool IsActive { get; } = isActive;
    }
}

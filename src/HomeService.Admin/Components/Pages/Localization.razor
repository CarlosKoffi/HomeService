@page "/localization"
@using HomeService.Admin.Services
@using HomeService.Contracts.Branding
@inject PlatformApiClient ApiClient

<PageTitle>Pays et traductions</PageTitle>

<h1>Pays & traductions</h1>
<p class="lead">
    Preparation multi-pays et multilingue. La Cote d'Ivoire est le premier marche, mais les textes,
    devises et variantes pays doivent etre gerables sans redeployer.
</p>

<section class="info-panel">
    <div>
        <h2>Pourquoi cette page est importante</h2>
        <p>
            Pour l'instant, cette page concerne surtout le portail entreprise et l'admin qui le valide:
            textes d'inscription, pieces demandees, emails d'activation, messages de complement et
            libelles de statut. Les futurs portails client et prestataire auront leurs propres blocs
            quand on attaquera ces scopes.
        </p>
    </div>
    <div class="check-list">
        <span>Texte modifiable sans redeploiement</span>
        <span>Base entreprise Cote d'Ivoire</span>
        <span>Preparation multi-pays sans melanger les scopes</span>
        <span>Validation par role contenu admin</span>
    </div>
</section>

<section class="toolbar">
    <label>
        Pays
        <select>
            <option>Cote d'Ivoire - XOF</option>
            <option>Senegal - XOF</option>
            <option>Benin - XOF</option>
        </select>
    </label>
    <label>
        Langue
        <select>
            <option>Francais</option>
            <option>Anglais</option>
            <option>Langue locale a definir</option>
        </select>
    </label>
    <label>
        Recherche
        <input type="search" placeholder="Cle, page, texte" />
    </label>
    <button type="button">Ajouter une cle</button>
</section>

<section class="country-branding-editor">
    <div class="section-heading">
        <div>
            <h2>Identite pays</h2>
            <p class="section-help">
                Ces elements pilotent le rendu public par pays. Pour la Cote d'Ivoire, on garde une base legere:
                orange pour l'action, blanc pour la clarte, vert pour la confiance.
            </p>
        </div>
        <button type="button" @onclick="SaveBrandingAsync">Sauver l'identite CI</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(BrandingMessage))
    {
        <p class="field-message">@BrandingMessage</p>
    }

    <div class="branding-grid">
        <label>
            Marque affichee
            <input type="text" @bind="BrandName" />
        </label>
        <label>
            Couleur confiance
            <input type="text" @bind="PrimaryColor" />
        </label>
        <label>
            Couleur fond
            <input type="text" @bind="SecondaryColor" />
        </label>
        <label>
            Couleur action
            <input type="text" @bind="AccentColor" />
        </label>
        <label>
            Titre accueil entreprise
            <input type="text" @bind="HeroTitle" />
        </label>
        <label>
            Image hero optionnelle
            <input type="url" @bind="HeroImageUrl" placeholder="https://..." />
        </label>
        <label class="wide-field">
            Sous-titre accueil entreprise
            <textarea rows="3" @bind="HeroSubtitle"></textarea>
        </label>
        <label>
            Motif
            <select @bind="MotifStyle">
                <option value="flag-ribbon">Ruban CI</option>
                <option value="minimal">Minimal</option>
            </select>
        </label>
    </div>

    <article class="branding-preview"
             style="@BrandPreviewStyle">
        <span>Cote d'Ivoire - entreprises verifiees</span>
        <h3>@BrandName</h3>
        <p>@HeroTitle</p>
    </article>
</section>

<section class="localization-grid">
    <article>
        <h2>Pays actifs</h2>
        <p class="section-help">
            Un pays actif devient disponible dans les parcours publics. Un pays en preparation permet
            de saisir les textes et parametres avant lancement officiel.
        </p>
        <div class="table-lite">
            <div class="config-row">
                <strong>CI</strong>
                <span>Cote d'Ivoire - marche pilote, Abidjan en priorite</span>
                <em>XOF</em>
                <button>Configurer</button>
            </div>
            <div class="config-row">
                <strong>SN</strong>
                <span>Senegal - preparation future expansion</span>
                <em>XOF</em>
                <button>Preparer</button>
            </div>
            <div class="config-row">
                <strong>BJ</strong>
                <span>Benin - preparation future expansion</span>
                <em>XOF</em>
                <button>Preparer</button>
            </div>
        </div>
    </article>

    <article>
        <h2>Langues</h2>
        <p class="section-help">
            Le francais reste la langue de depart. Les langues locales ou variantes pays seront ajoutees
            quand les textes, supports et operations terrain seront prets.
        </p>
        <div class="table-lite">
            <div class="config-row">
                <strong>fr</strong>
                <span>Francais - langue par defaut pour la Cote d'Ivoire</span>
                <em>Defaut</em>
                <button>Editer</button>
            </div>
            <div class="config-row">
                <strong>en</strong>
                <span>Anglais - option utile pour entreprises internationales</span>
                <em>Prepare</em>
                <button>Editer</button>
            </div>
        </div>
    </article>
</section>

<section class="translation-list">
    <div class="section-heading">
        <div>
            <h2>Textes produit</h2>
            <p class="section-help">
                Chaque cle correspond a un texte affiche dans un portail. Les descriptions expliquent
                le contexte pour eviter les traductions hors sujet. Dans cette phase, on privilegie
                les textes du site entreprise et du back-office de validation.
            </p>
        </div>
        <button type="button">Exporter les textes manquants</button>
    </div>
    @foreach (var item in TranslationRows)
    {
        <article>
            <div>
                <strong>@item.Key</strong>
                <p>@item.Scope - @item.Description</p>
            </div>
            <textarea rows="2">@item.Value</textarea>
            <button type="button">Sauver</button>
        </article>
    }
</section>

@code {
    private string BrandName { get; set; } = "ProxiPro CI";
    private string PrimaryColor { get; set; } = "#0f9f7a";
    private string SecondaryColor { get; set; } = "#ffffff";
    private string AccentColor { get; set; } = "#f97316";
    private string HeroTitle { get; set; } = "Le service a domicile en toute confiance";
    private string HeroSubtitle { get; set; } = "Une plateforme pensee pour la Cote d'Ivoire: entreprises verifiees, prestataires suivis et services a domicile plus fiables.";
    private string? HeroImageUrl { get; set; }
    private string MotifStyle { get; set; } = "flag-ribbon";
    private string? BrandingMessage { get; set; }

    private string BrandPreviewStyle =>
        $"--country-primary:{PrimaryColor}; --country-secondary:{SecondaryColor}; --country-accent:{AccentColor};";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var branding = await ApiClient.GetCountryBrandingAsync("CI");
            if (branding is not null)
            {
                BrandName = branding.BrandName;
                PrimaryColor = branding.PrimaryColor;
                SecondaryColor = branding.SecondaryColor;
                AccentColor = branding.AccentColor;
                HeroTitle = branding.HeroTitle;
                HeroSubtitle = branding.HeroSubtitle;
                HeroImageUrl = branding.HeroImageUrl;
                MotifStyle = branding.MotifStyle;
            }
        }
        catch (Exception exception)
        {
            BrandingMessage = $"Impossible de charger l'identite pays: {exception.Message}";
        }
    }

    private async Task SaveBrandingAsync()
    {
        BrandingMessage = null;

        try
        {
            await ApiClient.UpdateCountryBrandingAsync("CI", new UpdateCountryBrandingRequest(
                BrandName,
                PrimaryColor,
                SecondaryColor,
                AccentColor,
                HeroTitle,
                HeroSubtitle,
                HeroImageUrl,
                MotifStyle));

            BrandingMessage = "Identite Cote d'Ivoire sauvegardee.";
        }
        catch (Exception exception)
        {
            BrandingMessage = $"Sauvegarde impossible: {exception.Message}";
        }
    }

    private static readonly IReadOnlyList<TranslationRow> TranslationRows =
    [
        new("company.home.hero.title", "Company", "Titre principal du portail entreprise", "Faites intervenir vos equipes a domicile en toute confiance"),
        new("company.home.hero.subtitle", "Company", "Texte d'introduction", "ProxiPro connecte les clients a des prestataires recommandes par des entreprises verifiees."),
        new("company.concept.security", "Company", "Explication du modele de confiance", "Chaque prestataire est rattache a une entreprise validee, avec un suivi des missions et des encaissements."),
        new("company.register.documents", "Company", "Introduction de la zone documents", "Ajoutez les pieces necessaires pour permettre a notre equipe de verifier votre entreprise rapidement."),
        new("company.register.submit", "Company", "Bouton de demande inscription", "Envoyer la demande"),
        new("admin.companyApplications.title", "Admin", "Titre de la file de validation", "Demandes entreprises"),
        new("admin.companyApplications.help", "Admin", "Aide affichable aux admins validation", "Controlez les pieces legales, demandez les complements manquants puis envoyez le lien d'activation."),
        new("company.activation.email.subject", "Company", "Sujet email apres validation", "Votre espace entreprise ProxiPro est pret"),
        new("company.activation.email.body", "Company", "Email envoye avec lien de creation de mot de passe", "Votre dossier entreprise a ete valide. Creez votre mot de passe pour acceder au portail et ajouter vos prestataires."),
        new("company.complement.email.body", "Company", "Email quand un document manque", "Nous avons besoin d'un complement pour finaliser votre inscription. Merci d'ajouter le document demande depuis votre espace.")
    ];

    private sealed record TranslationRow(string Key, string Scope, string Description, string Value);
}

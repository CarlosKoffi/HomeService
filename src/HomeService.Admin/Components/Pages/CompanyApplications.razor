        new(Guid.Parse("11111111-1111-1111-1111-111111111111"), "Ivoire Clean Services", "Abidjan", "Awa Kouame", "contact@ivoireclean.ci", "Soumis", "status-new", 2, 3, "aujourd'hui", "Verifier le DFE et demander le justificatif manquant avant validation."),
        new(Guid.Parse("22222222-2222-2222-2222-222222222222"), "Nanny Pro CI", "Cocody", "Mariam Traore", "admin@nannypro.ci", "En verification", "status-review", 3, 3, "hier", "Comparer l'identite du responsable avec le registre puis valider si tout est coherent."),
        new(Guid.Parse("33333333-3333-3333-3333-333333333333"), "Green Yard", "Marcory", "Eric Kone", "hello@greenyard.ci", "Complement demande", "status-info", 1, 3, "il y a 3 jours", "Relancer l'entreprise avec une demande precise: DFE et piece responsable lisible."),
        new(Guid.Parse("44444444-4444-4444-4444-444444444444"), "Maison Plus", "Yopougon", "Serge Bamba", "ops@maisonplus.ci", "Activation envoyee", "status-done", 3, 3, "il y a 6 jours", "Surveiller la premiere connexion. Relancer si le mot de passe n'est pas cree.")

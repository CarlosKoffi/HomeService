@page "/company-applications"
@using HomeService.Admin.Services
@using HomeService.Contracts.Companies
@using System.Net.Http
@inject PlatformApiClient ApiClient

<PageTitle>Demandes entreprises</PageTitle>

<h1>Demandes entreprises</h1>
<p class="lead">Pile de verification des dossiers entreprise, triee pour faire remonter ce qui demande une action.</p>

<section class="info-panel">
    <div>
        <h2>Objectif de validation</h2>
        <p>
            Une entreprise validee pourra creer son mot de passe, entrer dans son portail,
            puis ajouter ses prestataires dans une prochaine etape du portail. Avant validation, il faut confirmer
            que l'entreprise existe, que le responsable est identifiable et que les documents fournis
            sont coherents avec les informations declarees.
        </p>
    </div>
    <div class="check-list">
        <span>DFE present et lisible</span>
        <span>Registre de commerce coherent</span>
        <span>Identite responsable verifiee</span>
        <span>Services envisages controles</span>
    </div>
</section>

<section class="toolbar">
    <label>
        Statut
        <select>
            <option>A traiter</option>
            <option>Soumis</option>
            <option>En verification</option>
            <option>Complement demande</option>
            <option>Valide</option>
            <option>Activation envoyee</option>
        </select>
    </label>
    <label>
        Recherche
        <input type="search" placeholder="Entreprise, ville, email" />
    </label>
    <button type="button">Relancer les validations dormantes</button>
</section>

<section class="work-queue">
    @if (IsLoading)
    {
        <article class="queue-item">
            <p>Chargement des demandes depuis la base...</p>
        </article>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <article class="queue-item status-info">
            <p>@ErrorMessage</p>
        </article>
    }
    else if (Applications.Count == 0)
    {
        <article class="queue-item">
            <p>Aucune demande entreprise pour le moment.</p>
        </article>
    }
    else
    {
        @foreach (var item in Applications)
        {
            <article class="queue-item @(item.StatusClass)">
                <div>
                    <div class="queue-heading">
                        <h2>@item.CompanyName</h2>
                        <span>@item.Status</span>
                    </div>
                    <p>@item.City - @item.ContactName - @item.Email</p>
                    <p>@item.DocumentsReady/@item.DocumentsExpected documents OK - depose @item.SubmittedLabel</p>
                    <p class="queue-note">@item.NextAction</p>
                </div>
                <div class="easy-actions">
                    <a href="company-applications/@item.Id">Voir dossier</a>
                    <button type="button">Demander complement</button>
                    <button type="button">Valider</button>
                    <button type="button">Relancer mail</button>
                </div>
            </article>
        }
    }
</section>

@code {
    private List<ApplicationRow> Applications { get; set; } = [];
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rows = await ApiClient.GetCompanyApplicationsAsync();
            Applications = rows.Select(MapRow).ToList();
        }
        catch (PlatformApiException exception)
        {
            ErrorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            ErrorMessage = $"Impossible de joindre l'API a l'adresse {ApiClient.BaseAddress}. Detail reseau: {exception.Message}";
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger les demandes depuis l'API a l'adresse {ApiClient.BaseAddress}. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static ApplicationRow MapRow(CompanyApplicationSummaryResponse item)
    {
        var statusClass = item.Status switch
        {
            "Submitted" => "status-new",
            "UnderReview" => "status-review",
            "MoreInformationRequested" => "status-info",
            "Approved" or "ActivationSent" or "Activated" => "status-done",
            _ => "status-new"
        };

        var nextAction = item.Status switch
        {
            "Submitted" => "Verifier les documents et les informations legales.",
            "UnderReview" => "Terminer la verification et documenter la decision.",
            "MoreInformationRequested" => "Attendre le complement ou relancer l'entreprise.",
            "Approved" => "Envoyer le lien d'activation entreprise.",
            "ActivationSent" => "Surveiller la creation du mot de passe.",
            _ => "Analyser le dossier."
        };

        return new ApplicationRow(
            item.Id,
            item.CompanyName,
            item.City,
            item.ContactName,
            item.Email,
            item.Status,
            statusClass,
            Math.Max(0, item.DocumentCount - item.PendingDocumentCount),
            item.DocumentCount,
            item.SubmittedAt is null ? "date inconnue" : item.SubmittedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm"),
            nextAction);
    }

    private sealed record ApplicationRow(
        Guid Id,
        string CompanyName,
        string City,
        string ContactName,
        string Email,
        string Status,
        string StatusClass,
        int DocumentsReady,
        int DocumentsExpected,
        string SubmittedLabel,
        string NextAction);
}

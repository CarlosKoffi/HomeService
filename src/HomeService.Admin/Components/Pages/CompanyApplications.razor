@page "/company-applications"
@using HomeService.Admin.Services
@using HomeService.Contracts.Companies
@using System.Net.Http
@inject PlatformApiClient ApiClient
@inject IJSRuntime JsRuntime

<PageTitle>Demandes entreprises</PageTitle>

<h1>Demandes entreprises</h1>
<p class="lead">Pile de verification des dossiers entreprise, triee pour faire remonter ce qui demande une action.</p>

<section class="info-panel">
    <div>
        <h2>Objectif de validation</h2>
        <p>
            Une entreprise validee pourra creer son mot de passe, entrer dans son portail,
            puis ajouter ses prestataires dans une prochaine etape du portail. Avant validation, il faut confirmer
            que l'entreprise existe, que le responsable est identifiable et que les documents fournis
            sont coherents avec les informations declarees.
        </p>
    </div>
    <div class="check-list">
        <span>DFE present et lisible</span>
        <span>Registre de commerce coherent</span>
        <span>Identite responsable verifiee</span>
        <span>Services envisages controles</span>
    </div>
</section>

<section class="toolbar">
    <label>
        Statut
        <select @bind="SelectedStatus">
            <option value="">A traiter</option>
            <option value="Submitted">Soumis</option>
            <option value="UnderReview">En verification</option>
            <option value="MoreInformationRequested">Complement demande</option>
            <option value="Approved">Valide</option>
            <option value="ActivationSent">Activation envoyee</option>
            <option value="Rejected">Rejete</option>
            <option value="Activated">Compte cree</option>
        </select>
    </label>
    <label>
        Recherche
        <input type="search" @bind="SearchTerm" @bind:event="oninput" placeholder="Entreprise, ville, email" />
    </label>
    <button type="button" @onclick="SendDormantActivationLinksAsync" disabled="@IsBulkBusy">Relancer les validations dormantes</button>
</section>

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <p class="admin-message">@SuccessMessage</p>
}

@if (!string.IsNullOrWhiteSpace(ActionErrorMessage))
{
    <p class="admin-message error-message">@ActionErrorMessage</p>
}

<section class="work-queue">
    @if (IsLoading)
    {
        <article class="queue-item">
            <p>Chargement des demandes depuis la base...</p>
        </article>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <article class="queue-item status-info">
            <p>@ErrorMessage</p>
        </article>
    }
    else if (VisibleApplications.Count == 0)
    {
        <article class="queue-item">
            <p>Aucune demande entreprise pour le moment.</p>
        </article>
    }
    else
    {
        @foreach (var item in VisibleApplications)
        {
            <article class="queue-item @(item.StatusClass)">
                <div>
                    <div class="queue-heading">
                        <h2>@item.CompanyName</h2>
                        <span>@item.Status</span>
                    </div>
                    <p>@item.City - @item.ContactName - @item.Email</p>
                    <div class="document-summary" aria-label="Etat des pieces du dossier">
                        @foreach (var document in item.Documents)
                        {
                            <span class="@document.StatusClass" title="@document.Title">@document.Label</span>
                        }
                    </div>
                    <p class="queue-note">Depose @item.SubmittedLabel</p>
                    <p class="queue-note">@item.NextAction</p>
                </div>
                <div class="easy-actions">
                    <a href="company-applications/@item.Id">Voir dossier</a>
                    <button type="button"
                            disabled="@IsActionDisabled(item)"
                            @onclick="() => RequestMoreInformationAsync(item)">
                        Demander complement
                    </button>
                    <button type="button"
                            disabled="@(!CanApprove(item) || IsActionDisabled(item))"
                            @onclick="() => ApproveAndSendActivationLinkAsync(item)">
                        Valider
                    </button>
                    <button type="button"
                            disabled="@(!CanSendActivationLink(item) || IsActionDisabled(item))"
                            @onclick="() => SendActivationLinkAsync(item)">
                        Relancer mail
                    </button>
                </div>
            </article>
        }
    }
</section>

@code {
    private List<ApplicationRow> Applications { get; set; } = [];
    private bool IsLoading { get; set; } = true;
    private bool IsBulkBusy { get; set; }
    private Guid? BusyApplicationId { get; set; }
    private string? ErrorMessage { get; set; }
    private string? ActionErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private string? SearchTerm { get; set; }
    private string? SelectedStatus { get; set; }

    private List<ApplicationRow> VisibleApplications => Applications
        .Where(MatchesStatus)
        .Where(MatchesSearch)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadApplicationsAsync();
    }

    private async Task LoadApplicationsAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var rows = await ApiClient.GetCompanyApplicationsAsync();
            Applications = rows.Select(MapRow).ToList();
        }
        catch (PlatformApiException exception)
        {
            ErrorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            ErrorMessage = $"Impossible de joindre l'API a l'adresse {ApiClient.BaseAddress}. Detail reseau: {exception.Message}";
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger les demandes depuis l'API a l'adresse {ApiClient.BaseAddress}. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RequestMoreInformationAsync(ApplicationRow item)
    {
        var note = await JsRuntime.InvokeAsync<string?>(
            "prompt",
            $"Note obligatoire pour demander un complement a {item.CompanyName} :");

        if (string.IsNullOrWhiteSpace(note))
        {
            ActionErrorMessage = "Action annulee: une note est obligatoire pour demander un complement.";
            return;
        }

        await RunApplicationActionAsync(
            item.Id,
            async () => await ApiClient.RequestCompanyApplicationMoreInformationAsync(item.Id, note),
            $"Complement demande a {item.CompanyName}.");
    }

    private async Task ApproveAndSendActivationLinkAsync(ApplicationRow item)
    {
        await RunApplicationActionAsync(
            item.Id,
            async () =>
            {
                await ApiClient.ApproveCompanyApplicationAsync(item.Id);
                await ApiClient.SendCompanyApplicationActivationLinkAsync(item.Id);
            },
            $"{item.CompanyName} validee. Lien d'activation genere.");
    }

    private async Task SendActivationLinkAsync(ApplicationRow item)
    {
        await RunApplicationActionAsync(
            item.Id,
            async () => await ApiClient.SendCompanyApplicationActivationLinkAsync(item.Id),
            $"Lien d'activation renvoye a {item.CompanyName}.");
    }

    private async Task SendDormantActivationLinksAsync()
    {
        IsBulkBusy = true;
        ActionErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var candidates = Applications
                .Where(item => CanSendActivationLink(item))
                .ToList();

            foreach (var candidate in candidates)
            {
                await ApiClient.SendCompanyApplicationActivationLinkAsync(candidate.Id);
            }

            SuccessMessage = candidates.Count == 0
                ? "Aucune validation dormante a relancer."
                : $"{candidates.Count} lien(s) d'activation relance(s).";

            await LoadApplicationsAsync();
        }
        catch (Exception exception)
        {
            ActionErrorMessage = $"Relance impossible. Detail: {exception.Message}";
        }
        finally
        {
            IsBulkBusy = false;
        }
    }

    private async Task RunApplicationActionAsync(Guid applicationId, Func<Task> action, string successMessage)
    {
        BusyApplicationId = applicationId;
        ActionErrorMessage = null;
        SuccessMessage = null;

        try
        {
            await action();
            SuccessMessage = successMessage;
            await LoadApplicationsAsync();
        }
        catch (Exception exception)
        {
            ActionErrorMessage = $"Action impossible. Detail: {exception.Message}";
        }
        finally
        {
            BusyApplicationId = null;
        }
    }

    private bool MatchesStatus(ApplicationRow item)
    {
        if (string.IsNullOrWhiteSpace(SelectedStatus))
        {
            return item.Status is not "Approved" and not "ActivationSent" and not "Activated";
        }

        return string.Equals(item.Status, SelectedStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSearch(ApplicationRow item)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        var term = SearchTerm.Trim();
        return item.CompanyName.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.City.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.ContactName.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.Email.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActionDisabled(ApplicationRow item)
    {
        return BusyApplicationId == item.Id || IsBulkBusy;
    }

    private static bool CanApprove(ApplicationRow item)
    {
        return item.Status is "Submitted" or "UnderReview" or "MoreInformationRequested" or "Rejected";
    }

    private static bool CanSendActivationLink(ApplicationRow item)
    {
        return item.Status is "Approved" or "ActivationSent";
    }

    private static ApplicationRow MapRow(CompanyApplicationSummaryResponse item)
    {
        var statusClass = item.Status switch
        {
            "Submitted" => "status-new",
            "UnderReview" => "status-review",
            "MoreInformationRequested" => "status-info",
            "Approved" or "ActivationSent" or "Activated" => "status-done",
            "Rejected" => "status-rejected",
            _ => "status-new"
        };

        var nextAction = item.Status switch
        {
            "Submitted" => "Verifier les documents et les informations legales.",
            "UnderReview" => "Terminer la verification et documenter la decision.",
            "MoreInformationRequested" => "Attendre le complement ou relancer l'entreprise.",
            "Approved" => "Envoyer le lien d'activation entreprise.",
            "ActivationSent" => "Surveiller la creation du mot de passe.",
            "Rejected" => "Dossier refuse. Peut etre reouvert si l'entreprise apporte un element solide.",
            _ => "Analyser le dossier."
        };

        return new ApplicationRow(
            item.Id,
            item.CompanyName,
            item.City,
            item.ContactName,
            item.Email,
            item.Status,
            statusClass,
            Math.Max(0, item.DocumentCount - item.PendingDocumentCount),
            item.DocumentCount,
            item.SubmittedAt is null ? "date inconnue" : item.SubmittedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm"),
            nextAction,
            BuildDocumentRows(item.Documents));
    }

    private static IReadOnlyList<DocumentRow> BuildDocumentRows(IReadOnlyList<CompanyApplicationDocumentSummaryResponse> documents)
    {
        var documentsByType = documents
            .GroupBy(document => document.DocumentType)
            .ToDictionary(group => group.Key, group => group.First());

        var expectedDocumentTypes = new[]
        {
            "FiscalExistenceDeclaration",
            "BusinessRegistration",
            "OwnerIdentity",
            "AddressProof"
        };

        return expectedDocumentTypes
            .Select(documentType =>
            {
                documentsByType.TryGetValue(documentType, out var document);
                var reviewStatus = document?.ReviewStatus ?? "Missing";

                return new DocumentRow(
                    GetDocumentLabel(documentType),
                    GetDocumentStatusClass(reviewStatus),
                    $"{GetDocumentLabel(documentType)} - {GetDocumentStatusLabel(reviewStatus)}");
            })
            .ToList();
    }

    private static string GetDocumentLabel(string documentType)
    {
        return documentType switch
        {
            "FiscalExistenceDeclaration" => "DFE",
            "BusinessRegistration" => "Registre",
            "OwnerIdentity" => "Identite",
            "AddressProof" => "Adresse",
            _ => "Piece"
        };
    }

    private static string GetDocumentStatusClass(string status)
    {
        return status switch
        {
            "Approved" => "status-chip status-accepted",
            "Rejected" => "status-chip status-refused",
            _ => "status-chip status-pending"
        };
    }

    private static string GetDocumentStatusLabel(string status)
    {
        return status switch
        {
            "Approved" => "accepte",
            "Rejected" => "refuse",
            "NeedsReplacement" => "complement demande",
            "Missing" => "non depose",
            _ => "en attente"
        };
    }

    private sealed record ApplicationRow(
        Guid Id,
        string CompanyName,
        string City,
        string ContactName,
        string Email,
        string Status,
        string StatusClass,
        int DocumentsReady,
        int DocumentsExpected,
        string SubmittedLabel,
        string NextAction,
        IReadOnlyList<DocumentRow> Documents);

    private sealed record DocumentRow(
        string Label,
        string StatusClass,
        string Title);
}

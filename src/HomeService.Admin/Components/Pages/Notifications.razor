@page "/notifications"
@using HomeService.Admin.Services
@using HomeService.Contracts.Notifications
@inject PlatformApiClient ApiClient

<PageTitle>Notifications</PageTitle>

<div class="admin-page-heading">
    <div>
        <h1>Notifications</h1>
        <p class="lead">Portail entreprise et application sont automatiques. Configurez seulement les envois email et WhatsApp par type de notification.</p>
    </div>
    <button type="button" class="secondary-action" @onclick="LoadAsync">Actualiser</button>
</div>

<nav class="notification-section-nav" aria-label="Navigation notifications">
    <button type="button"
            class="@GetSectionButtonClass("overview")"
            @onclick='() => SetSection("overview")'>
        Vue d'ensemble
        <span>@TotalOpenNotifications</span>
    </button>
    <button type="button"
            class="@GetSectionButtonClass("portal")"
            @onclick='() => SetSection("portal")'>
        Portail entreprise
        <span>@UnreadPortalNotifications</span>
    </button>
    <button type="button"
            class="@GetSectionButtonClass("external")"
            @onclick='() => SetSection("external")'>
        Email / WhatsApp
        <span>@QueuedNotifications.Count</span>
    </button>
    <button type="button"
            class="@GetSectionButtonClass("rules")"
            @onclick='() => SetSection("rules")'>
        Regles
        <span>@DeliveryRules.Count</span>
    </button>
</nav>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p class="admin-message admin-message-error">@ErrorMessage</p>
}

@if (ActiveNotificationSection == "overview")
{
    <section class="notification-command-center">
        <article>
            <span>Portail non lues</span>
            <strong>@UnreadPortalNotifications</strong>
            <small>entreprises</small>
        </article>
        <article>
            <span>A envoyer</span>
            <strong>@CountByStatus("Pending")</strong>
            <small>email / WhatsApp</small>
        </article>
        <article>
            <span>Envoyees</span>
            <strong>@CountByStatus("Sent")</strong>
            <small>email / WhatsApp</small>
        </article>
        <article>
            <span>En erreur</span>
            <strong>@CountByStatus("Failed")</strong>
            <small>email / WhatsApp</small>
        </article>
        <article>
            <span>Annulees</span>
            <strong>@CountByStatus("Cancelled")</strong>
            <small>email / WhatsApp</small>
        </article>
    </section>

    <section class="notification-overview-panel">
        <article>
            <span>Action rapide</span>
            <strong>Messages portail</strong>
            <p>Consultez ce que les entreprises voient dans leur espace et remettez un message en non lu si besoin.</p>
            <button type="button" @onclick='() => SetSection("portal")'>Ouvrir le portail</button>
        </article>
        <article>
            <span>Suivi externe</span>
            <strong>Files email et WhatsApp</strong>
            <p>Renvoyez, annulez ou marquez comme envoyees les notifications externes en attente.</p>
            <button type="button" @onclick='() => SetSection("external")'>Voir les envois</button>
        </article>
        <article>
            <span>Parametrage</span>
            <strong>Regles de diffusion</strong>
            <p>Email et WhatsApp restent configurables. Portail et application sont automatiques selon le destinataire.</p>
            <button type="button" @onclick='() => SetSection("rules")'>Configurer</button>
        </article>
    </section>
}

@if (ActiveNotificationSection == "rules")
{
    <section class="notification-rules-panel">
        <div class="notification-rules-head">
            <div>
                <span>Regles de diffusion</span>
                <strong>Canaux par type de notification</strong>
                <p>Le portail s'applique aux entreprises. L'application s'applique aux clients et prestataires. Email et WhatsApp restent configurables.</p>
            </div>
            <small>@DeliveryRules.Count type(s)</small>
        </div>

        @if (DeliveryRules.Count == 0 && IsLoading)
        {
            <article class="notification-rule-row">
                <p>Chargement des regles...</p>
            </article>
        }
        else
        {
            @foreach (var rule in DeliveryRules)
            {
                <article class="notification-rule-row">
                    <div class="notification-rule-copy">
                        <span>@TranslateAudience(rule.Audience)</span>
                        <strong>@rule.Label</strong>
                        <small>@rule.EventKey</small>
                    </div>
                    <div class="notification-channel-grid">
                        <label class="@GetRuleChannelClass(rule.PortalEnabled, rule.Audience == "Company" || rule.Audience == "Mixed")">
                            <input type="checkbox"
                                   checked="@rule.PortalEnabled"
                                   disabled />
                            <span>Portail</span>
                            <small>@GetInternalChannelHint(rule, "Portal")</small>
                        </label>
                        <label class="@GetRuleChannelClass(rule.MobileAppEnabled, rule.Audience != "Company")">
                            <input type="checkbox"
                                   checked="@rule.MobileAppEnabled"
                                   disabled />
                            <span>Application</span>
                            <small>@GetInternalChannelHint(rule, "MobileApp")</small>
                        </label>
                        <label class="@GetRuleChannelClass(rule.EmailEnabled, true)">
                            <input type="checkbox"
                                   checked="@rule.EmailEnabled"
                                   @onchange='eventArgs => ToggleRuleChannelAsync(rule, "Email", eventArgs)' />
                            <span>Email</span>
                            <small>Configurable</small>
                        </label>
                        <label class="@GetRuleChannelClass(rule.WhatsAppEnabled, true)">
                            <input type="checkbox"
                                   checked="@rule.WhatsAppEnabled"
                                   @onchange='eventArgs => ToggleRuleChannelAsync(rule, "WhatsApp", eventArgs)' />
                            <span>WhatsApp</span>
                            <small>Configurable</small>
                        </label>
                    </div>
                </article>
            }
        }
    </section>
}

@if (ActiveNotificationSection == "portal")
{
    <section class="notification-filters notification-portal-search">
        <label>
            Recherche portail
            <input @bind="SearchTerm" @bind:event="oninput" placeholder="Entreprise, titre, message..." />
        </label>
    </section>

    <section class="notification-rules-panel portal-notification-admin-panel">
        <div class="notification-rules-head">
            <div>
                <span>Portail entreprise</span>
                <strong>Messages envoyes automatiquement au portail entreprise</strong>
                <p>Ces notifications sont visibles par l'entreprise dans son portail. Le renvoi les remet en non lues et les remonte dans son fil.</p>
            </div>
            <small>@CompanyPortalNotifications.Count message(s)</small>
        </div>

        @if (IsLoading)
        {
            <article class="notification-rule-row">
                <p>Chargement des notifications portail...</p>
            </article>
        }
        else if (FilteredCompanyPortalNotifications.Count == 0)
        {
            <article class="notification-rule-row">
                <p>Aucune notification portail ne correspond aux filtres.</p>
            </article>
        }
        else
        {
            @foreach (var notification in FilteredCompanyPortalNotifications)
            {
                <article class="@GetPortalNotificationClass(notification)">
                    <div class="notification-rule-copy">
                        <span>@notification.CompanyName</span>
                        <strong>@notification.Title</strong>
                        <small>@notification.Message</small>
                        <small>@TranslateNotificationTone(notification.Tone) - @notification.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <div class="notification-actions">
                        @if (notification.IsRead)
                        {
                            <button type="button"
                                    disabled="@IsBusy(notification.Id)"
                                    @onclick="() => MarkPortalNotificationUnreadAsync(notification)">
                                Remettre non lue
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    disabled="@IsBusy(notification.Id)"
                                    @onclick="() => MarkPortalNotificationReadAsync(notification)">
                                Marquer lue
                            </button>
                        }
                        <button type="button"
                                disabled="@IsBusy(notification.Id)"
                                @onclick="() => ResendPortalNotificationAsync(notification)">
                            Renvoyer sur le portail
                        </button>
                    </div>
                </article>
            }
        }
    </section>
}

@if (ActiveNotificationSection == "external")
{
    <section class="notification-filters">
        <label>
            Recherche
            <input @bind="SearchTerm" @bind:event="oninput" placeholder="Destinataire, sujet, contenu..." />
        </label>
        <label>
            Statut
            <select @bind="StatusFilter">
                <option value="">Tous</option>
                <option value="Pending">A envoyer</option>
                <option value="Failed">En erreur</option>
                <option value="Sent">Envoyees</option>
                <option value="Cancelled">Annulees</option>
            </select>
        </label>
        <label>
            Canal externe
            <select @bind="ChannelFilter">
                <option value="">Tous</option>
                <option value="Email">Email</option>
                <option value="WhatsApp">WhatsApp</option>
                <option value="MobilePush">Application</option>
            </select>
        </label>
    </section>

    <section class="notification-list">
        @if (IsLoading)
        {
            <article>
                <p>Chargement des notifications...</p>
            </article>
        }
        else if (FilteredNotifications.Count == 0)
        {
            <article>
                <p>Aucune notification ne correspond aux filtres.</p>
            </article>
        }
        else
        {
            @foreach (var notification in FilteredNotifications)
            {
                <article class="@GetNotificationClass(notification.Status)">
                    <div>
                        <strong>@notification.Subject</strong>
                        <p>@notification.Body</p>
                        <small>@notification.Recipient - @notification.ScheduledAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                        @if (!string.IsNullOrWhiteSpace(notification.FailureReason))
                        {
                            <small class="notification-failure">@notification.FailureReason</small>
                        }
                    </div>
                    <span>@TranslateChannel(notification.Channel)</span>
                    <span>@TranslateStatus(notification.Status)</span>
                    <div class="notification-actions">
                        <button type="button"
                                disabled="@(!CanRetry(notification) || IsBusy(notification.Id))"
                                @onclick="() => RetryAsync(notification)">
                            @GetRetryLabel(notification)
                        </button>
                        <button type="button"
                                disabled="@(!CanCancel(notification) || IsBusy(notification.Id))"
                                @onclick="() => ToggleCancel(notification.Id)">
                            Annuler
                        </button>
                        <button type="button"
                                disabled="@(!CanMarkSent(notification) || IsBusy(notification.Id))"
                                @onclick="() => MarkSentAsync(notification)">
                            Marquer envoye
                        </button>
                    </div>
                    @if (CancelNotificationId == notification.Id)
                    {
                        <div class="notification-cancel-row">
                            <input @bind="CancelReason"
                                   @bind:event="oninput"
                                   placeholder="Raison de l'annulation" />
                            <button type="button"
                                    disabled="@IsBusy(notification.Id)"
                                    @onclick="() => CancelAsync(notification)">
                                Confirmer
                            </button>
                        </div>
                    }
                </article>
            }
        }
    </section>
}

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <p class="admin-message">@SuccessMessage</p>
}

@code {
    private List<NotificationOutboxMessageResponse> QueuedNotifications { get; set; } = [];
    private List<AdminCompanyPortalNotificationResponse> CompanyPortalNotifications { get; set; } = [];
    private List<NotificationDeliveryRuleResponse> DeliveryRules { get; set; } = [];
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private Guid? BusyNotificationId { get; set; }
    private Guid? CancelNotificationId { get; set; }
    private string? CancelReason { get; set; }
    private string? SearchTerm { get; set; }
    private string? StatusFilter { get; set; }
    private string? ChannelFilter { get; set; }
    private string ActiveNotificationSection { get; set; } = "overview";

    private IReadOnlyList<NotificationOutboxMessageResponse> FilteredNotifications
        => QueuedNotifications
            .Where(MatchesFilters)
            .OrderBy(notification => notification.Status == "Failed" ? 0 : notification.Status == "Pending" ? 1 : 2)
            .ThenByDescending(notification => notification.ScheduledAt)
            .ToList();

    private IReadOnlyList<AdminCompanyPortalNotificationResponse> FilteredCompanyPortalNotifications
        => CompanyPortalNotifications
            .Where(MatchesPortalFilters)
            .OrderBy(notification => notification.IsRead)
            .ThenByDescending(notification => notification.OccurredAt)
            .ToList();

    private int UnreadPortalNotifications => CompanyPortalNotifications.Count(notification => !notification.IsRead);

    private int TotalOpenNotifications => UnreadPortalNotifications + CountByStatus("Pending") + CountByStatus("Failed");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            QueuedNotifications = (await ApiClient.GetNotificationsAsync()).ToList();
            CompanyPortalNotifications = (await ApiClient.GetCompanyPortalNotificationsAsync()).ToList();
            DeliveryRules = (await ApiClient.GetNotificationDeliveryRulesAsync()).ToList();
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Impossible de charger les notifications. Detail: {exception.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RetryAsync(NotificationOutboxMessageResponse notification)
    {
        await RunNotificationActionAsync(
            notification.Id,
            () => ApiClient.RetryNotificationAsync(notification.Id),
            "Notification relancee.");
    }

    private async Task CancelAsync(NotificationOutboxMessageResponse notification)
    {
        if (string.IsNullOrWhiteSpace(CancelReason))
        {
            ErrorMessage = "Ajoutez une raison avant d'annuler la notification.";
            return;
        }

        await RunNotificationActionAsync(
            notification.Id,
            () => ApiClient.CancelNotificationAsync(notification.Id, CancelReason),
            "Notification annulee.");
    }

    private async Task MarkSentAsync(NotificationOutboxMessageResponse notification)
    {
        await RunNotificationActionAsync(
            notification.Id,
            () => ApiClient.MarkNotificationSentAsync(notification.Id),
            "Notification marquee envoyee.");
    }

    private Task MarkPortalNotificationReadAsync(AdminCompanyPortalNotificationResponse notification)
    {
        return RunPortalNotificationActionAsync(
            notification,
            () => ApiClient.MarkCompanyNotificationReadAsync(notification.CompanyId, notification.Id),
            "Notification portail marquee comme lue.");
    }

    private Task MarkPortalNotificationUnreadAsync(AdminCompanyPortalNotificationResponse notification)
    {
        return RunPortalNotificationActionAsync(
            notification,
            () => ApiClient.MarkCompanyNotificationUnreadAsync(notification.CompanyId, notification.Id),
            "Notification portail remise en non lue.");
    }

    private Task ResendPortalNotificationAsync(AdminCompanyPortalNotificationResponse notification)
    {
        return RunPortalNotificationActionAsync(
            notification,
            () => ApiClient.ResendCompanyNotificationAsync(notification.CompanyId, notification.Id),
            "Notification renvoyee sur le portail entreprise.");
    }

    private async Task ToggleRuleChannelAsync(NotificationDeliveryRuleResponse rule, string channel, ChangeEventArgs eventArgs)
    {
        var isEnabled = eventArgs.Value is true || string.Equals(eventArgs.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        var request = channel switch
        {
            "Portal" => ToRuleRequest(rule, portalEnabled: isEnabled),
            "MobileApp" => ToRuleRequest(rule, mobileAppEnabled: isEnabled),
            "Email" => ToRuleRequest(rule, emailEnabled: isEnabled),
            "WhatsApp" => ToRuleRequest(rule, whatsAppEnabled: isEnabled),
            _ => ToRuleRequest(rule)
        };

        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var updated = await ApiClient.UpdateNotificationDeliveryRuleAsync(rule.Id, request);
            if (updated is not null)
            {
                var index = DeliveryRules.FindIndex(item => item.Id == rule.Id);
                if (index >= 0)
                {
                    DeliveryRules[index] = updated;
                }
            }

            SuccessMessage = "Regle de notification mise a jour.";
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Modification de la regle impossible. Detail: {exception.Message}";
        }
    }

    private async Task RunNotificationActionAsync(
        Guid notificationId,
        Func<Task<NotificationOutboxMessageResponse?>> action,
        string successMessage)
    {
        BusyNotificationId = notificationId;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            await action();
            SuccessMessage = successMessage;
            CancelNotificationId = null;
            CancelReason = null;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Action notification impossible. Detail: {exception.Message}";
        }
        finally
        {
            BusyNotificationId = null;
        }
    }

    private async Task RunPortalNotificationActionAsync(
        AdminCompanyPortalNotificationResponse notification,
        Func<Task<ApiActionResult>> action,
        string successMessage)
    {
        BusyNotificationId = notification.Id;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var result = await action();
            if (!result.IsSuccess)
            {
                ErrorMessage = result.ErrorMessage;
                return;
            }

            SuccessMessage = successMessage;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = $"Action portail impossible. Detail: {exception.Message}";
        }
        finally
        {
            BusyNotificationId = null;
        }
    }

    private bool IsBusy(Guid notificationId)
    {
        return BusyNotificationId == notificationId;
    }

    private void SetSection(string section)
    {
        ActiveNotificationSection = section;
        ErrorMessage = null;
        SuccessMessage = null;
        CancelNotificationId = null;
        CancelReason = null;
    }

    private string GetSectionButtonClass(string section)
    {
        return ActiveNotificationSection == section ? "active" : string.Empty;
    }

    private static bool CanCancel(NotificationOutboxMessageResponse notification)
    {
        return notification.Status is not "Sent" and not "Cancelled";
    }

    private static bool CanRetry(NotificationOutboxMessageResponse notification)
    {
        return notification.Status is not "Sent";
    }

    private static string GetRetryLabel(NotificationOutboxMessageResponse notification)
    {
        return notification.Status switch
        {
            "Pending" => "Renvoyer",
            "Cancelled" => "Remettre a envoyer",
            _ => "Relancer l'envoi"
        };
    }

    private static bool CanMarkSent(NotificationOutboxMessageResponse notification)
    {
        return notification.Status is "Pending" or "Failed";
    }

    private void ToggleCancel(Guid notificationId)
    {
        if (CancelNotificationId == notificationId)
        {
            CancelNotificationId = null;
            CancelReason = null;
            return;
        }

        CancelNotificationId = notificationId;
        CancelReason = null;
        ErrorMessage = null;
        SuccessMessage = null;
    }

    private int CountByStatus(string status)
    {
        return QueuedNotifications.Count(notification => notification.Status == status);
    }

    private bool MatchesFilters(NotificationOutboxMessageResponse notification)
    {
        if (!string.IsNullOrWhiteSpace(StatusFilter)
            && !string.Equals(notification.Status, StatusFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(ChannelFilter)
            && !string.Equals(notification.Channel, ChannelFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        var search = SearchTerm.Trim();
        return notification.Recipient.Contains(search, StringComparison.OrdinalIgnoreCase)
            || notification.Subject.Contains(search, StringComparison.OrdinalIgnoreCase)
            || notification.Body.Contains(search, StringComparison.OrdinalIgnoreCase)
            || (notification.RelatedEntityType?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private bool MatchesPortalFilters(AdminCompanyPortalNotificationResponse notification)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        var search = SearchTerm.Trim();
        return notification.CompanyName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || notification.Title.Contains(search, StringComparison.OrdinalIgnoreCase)
            || notification.Message.Contains(search, StringComparison.OrdinalIgnoreCase)
            || notification.Type.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private static string TranslateChannel(string channel) => channel switch
    {
        "Email" => "Email",
        "WhatsApp" => "WhatsApp",
        "MobilePush" => "Application",
        _ => channel
    };

    private static string TranslateStatus(string status) => status switch
    {
        "Pending" => "A envoyer",
        "Failed" => "En erreur",
        "Sent" => "Envoyee",
        "Cancelled" => "Annulee",
        _ => status
    };

    private static string TranslateAudience(string audience) => audience switch
    {
        "Company" => "Entreprise",
        "Provider" => "Prestataire",
        "Customer" => "Client",
        "Mixed" => "Mixte",
        _ => audience
    };

    private static string TranslateNotificationTone(string tone) => tone switch
    {
        "success" => "Information positive",
        "warning" => "Action attendue",
        "danger" or "error" => "Attention",
        "pending" => "En attente",
        _ => "Information"
    };

    private static string GetNotificationClass(string status)
    {
        return status switch
        {
            "Failed" => "status-rejected",
            "Sent" => "status-done",
            _ => "status-new"
        };
    }

    private static string GetPortalNotificationClass(AdminCompanyPortalNotificationResponse notification)
        => $"notification-rule-row portal-notification-row {notification.Tone} {(notification.IsRead ? "read" : "unread")}";

    private static string GetRuleChannelClass(bool isEnabled, bool isAllowed)
        => $"notification-channel-card {(isEnabled ? "enabled" : "disabled")} {(!isAllowed ? "locked" : string.Empty)}";

    private static string GetInternalChannelHint(NotificationDeliveryRuleResponse rule, string channel)
    {
        var isAutomatic = channel switch
        {
            "Portal" => rule.Audience is "Company" or "Mixed",
            "MobileApp" => rule.Audience is "Provider" or "Customer" or "Mixed",
            _ => false
        };

        return isAutomatic ? "Automatique" : "Non concerne";
    }

    private static UpdateNotificationDeliveryRuleRequest ToRuleRequest(
        NotificationDeliveryRuleResponse rule,
        bool? portalEnabled = null,
        bool? mobileAppEnabled = null,
        bool? emailEnabled = null,
        bool? whatsAppEnabled = null)
    {
        return new UpdateNotificationDeliveryRuleRequest(
            rule.Label,
            rule.Audience,
            portalEnabled ?? rule.PortalEnabled,
            mobileAppEnabled ?? rule.MobileAppEnabled,
            emailEnabled ?? rule.EmailEnabled,
            whatsAppEnabled ?? rule.WhatsAppEnabled);
    }
}
